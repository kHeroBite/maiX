<ui:FluentWindow x:Class="MaiX.Views.ComposeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:MaiX.Views"
        xmlns:vm="clr-namespace:MaiX.ViewModels"
        xmlns:converters="clr-namespace:MaiX.Converters"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Height="700" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Closing="Window_Closing"
        d:DataContext="{d:DesignInstance Type=vm:ComposeViewModel, IsDesignTimeCreatable=False}">

    <ui:FluentWindow.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <converters:Base64ToImageSourceConverter x:Key="Base64ToImageSourceConverter"/>

        <!-- 연락처 제안 아이템 템플릿 -->
        <DataTemplate x:Key="ContactSuggestionTemplate">
            <Border Background="Transparent"
                    Padding="8,6"
                    Cursor="Hand"
                    CornerRadius="4">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 프로필 사진 / 이니셜 컨테이너 -->
                    <Grid Grid.Column="0" Width="32" Height="32" Margin="0,0,10,0">
                        <!-- 프로필 사진 (있을 때만 표시) -->
                        <Border CornerRadius="16"
                                Visibility="{Binding PhotoBase64, Converter={StaticResource NullToVisibilityConverter}}">
                            <Border.Background>
                                <ImageBrush ImageSource="{Binding PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}}"
                                            Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <!-- 이니셜 아바타 (사진 없을 때 표시) -->
                        <Border CornerRadius="16"
                                Background="{DynamicResource SystemAccentColorSecondaryBrush}"
                                Visibility="{Binding PhotoBase64, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                            <TextBlock Text="{Binding Initials}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>

                    <!-- 이름 및 이메일 -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{Binding DisplayName}"
                                   FontWeight="Medium"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding Email, Mode=OneWay}"/>
                            <Run Text="{Binding PositionString, Mode=OneWay, StringFormat=' • {0}'}"
                                 Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- 소스 라벨 -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource ControlFillColorTertiaryBrush}"
                            CornerRadius="4"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            Margin="8,0,0,0">
                        <TextBlock Text="{Binding SourceLabel}"
                                   FontSize="10"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            ShowMaximize="True"
            ShowMinimize="True"
            ShowClose="True"
            CanMaximize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Width="24" Height="24"
                              RenderOptions.BitmapScalingMode="Fant"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                    <ui:ImageIcon.Source>
                        <BitmapImage UriSource="pack://application:,,,/Assets/icon.png"
                                     DecodePixelWidth="256"
                                     DecodePixelHeight="256"
                                     CacheOption="OnLoad"/>
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <TextBlock VerticalAlignment="Center" Text="{Binding WindowTitle}"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 상단 툴바 (아웃룩 스타일) -->
        <Border Grid.Row="1"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽: 보내기 버튼 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:Button x:Name="SendButton"
                              Icon="{ui:SymbolIcon Send24}"
                              Content="보내기"
                              Appearance="Primary"
                              Click="SendButton_Click"
                              MinWidth="100"
                              Padding="16,8"/>
                </StackPanel>

                <!-- 오른쪽: 중요도, 첨부, 삭제 버튼 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <!-- 중요도 드롭다운 -->
                    <ui:DropDownButton x:Name="ImportanceButton"
                                       Content="중요도"
                                       Appearance="Secondary"
                                       Margin="0,0,4,0">
                        <ui:DropDownButton.Flyout>
                            <ContextMenu>
                                <MenuItem Header="높음" Click="ImportanceHigh_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="Important24" Foreground="#FF4444"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="보통" Click="ImportanceNormal_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="Mail24"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="낮음" Click="ImportanceLow_Click">
                                    <MenuItem.Icon>
                                        <ui:SymbolIcon Symbol="ArrowDown24" Foreground="#4488FF"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </ui:DropDownButton.Flyout>
                    </ui:DropDownButton>

                    <!-- 첨부 버튼 -->
                    <ui:Button x:Name="AttachButton"
                              Icon="{ui:SymbolIcon Attach24}"
                              ToolTip="파일 첨부"
                              Appearance="Secondary"
                              Click="AttachButton_Click"
                              Margin="0,0,4,0"/>

                    <!-- 삭제 버튼 -->
                    <ui:Button x:Name="DiscardButton"
                              Icon="{ui:SymbolIcon Delete24}"
                              ToolTip="삭제"
                              Appearance="Secondary"
                              Click="CancelButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 수신자 정보 영역 (아웃룩 스타일) -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 받는 사람 -->
                <Grid Grid.Row="0" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                              Content="받는 사람"
                              Appearance="Secondary"
                              Padding="12,6"
                              MinWidth="80"
                              Margin="0,0,8,0"
                              Click="ToButton_Click"
                              ToolTip="연락처에서 선택"/>

                    <Grid Grid.Column="1">
                        <ui:TextBox x:Name="ToTextBox"
                                   Text="{Binding To, UpdateSourceTrigger=PropertyChanged}"
                                   PlaceholderText=""
                                   PreviewKeyDown="EmailTextBox_PreviewKeyDown"
                                   TextChanged="EmailTextBox_TextChanged"
                                   BorderThickness="0"
                                   Background="Transparent"/>
                        <Popup x:Name="ToSuggestionPopup"
                               PlacementTarget="{Binding ElementName=ToTextBox}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="4"
                                    MinWidth="350" MaxWidth="500">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.15"/>
                                </Border.Effect>
                                <ListBox x:Name="ToSuggestionList"
                                         MaxHeight="250"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionChanged="SuggestionList_SelectionChanged"
                                         MouseDoubleClick="SuggestionList_MouseDoubleClick"
                                         PreviewKeyDown="SuggestionList_PreviewKeyDown"
                                         ItemTemplate="{DynamicResource ContactSuggestionTemplate}"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <TextBlock Grid.Column="2"
                               x:Name="BccToggleLink"
                               Text="숨은 참조"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center"
                               Cursor="Hand"
                               MouseLeftButtonDown="BccToggle_Click"
                               Margin="8,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="TextDecorations" Value="Underline"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- 참조 -->
                <Grid Grid.Row="1" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                              Content="참조"
                              Appearance="Secondary"
                              Padding="12,6"
                              MinWidth="80"
                              Margin="0,0,8,0"
                              Click="CcButton_Click"
                              ToolTip="연락처에서 선택"/>

                    <Grid Grid.Column="1">
                        <ui:TextBox x:Name="CcTextBox"
                                   Text="{Binding Cc, UpdateSourceTrigger=PropertyChanged}"
                                   PlaceholderText=""
                                   PreviewKeyDown="EmailTextBox_PreviewKeyDown"
                                   TextChanged="EmailTextBox_TextChanged"
                                   BorderThickness="0"
                                   Background="Transparent"/>
                        <Popup x:Name="CcSuggestionPopup"
                               PlacementTarget="{Binding ElementName=CcTextBox}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="4"
                                    MinWidth="350" MaxWidth="500">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.15"/>
                                </Border.Effect>
                                <ListBox x:Name="CcSuggestionList"
                                         MaxHeight="250"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionChanged="SuggestionList_SelectionChanged"
                                         MouseDoubleClick="SuggestionList_MouseDoubleClick"
                                         PreviewKeyDown="SuggestionList_PreviewKeyDown"
                                         ItemTemplate="{DynamicResource ContactSuggestionTemplate}"/>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>

                <!-- 숨은 참조 (토글로 표시/숨김) -->
                <Grid Grid.Row="2" x:Name="BccRow" Margin="0,0,0,6" Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <ui:Button Grid.Column="0"
                              Content="숨은 참조"
                              Appearance="Secondary"
                              Padding="12,6"
                              MinWidth="80"
                              Margin="0,0,8,0"
                              Click="BccButton_Click"
                              ToolTip="연락처에서 선택"/>

                    <Grid Grid.Column="1">
                        <ui:TextBox x:Name="BccTextBox"
                                   Text="{Binding Bcc, UpdateSourceTrigger=PropertyChanged}"
                                   PlaceholderText=""
                                   PreviewKeyDown="EmailTextBox_PreviewKeyDown"
                                   TextChanged="EmailTextBox_TextChanged"
                                   BorderThickness="0"
                                   Background="Transparent"/>
                        <Popup x:Name="BccSuggestionPopup"
                               PlacementTarget="{Binding ElementName=BccTextBox}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True">
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6"
                                    Padding="4"
                                    MinWidth="350" MaxWidth="500">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="12" ShadowDepth="3" Opacity="0.15"/>
                                </Border.Effect>
                                <ListBox x:Name="BccSuggestionList"
                                         MaxHeight="250"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         SelectionChanged="SuggestionList_SelectionChanged"
                                         MouseDoubleClick="SuggestionList_MouseDoubleClick"
                                         PreviewKeyDown="SuggestionList_PreviewKeyDown"
                                         ItemTemplate="{DynamicResource ContactSuggestionTemplate}"/>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>

                <!-- 제목 -->
                <ui:TextBox Grid.Row="3"
                           x:Name="SubjectTextBox"
                           Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"
                           PlaceholderText="제목 추가"
                           FontSize="16"
                           FontWeight="SemiBold"
                           BorderThickness="0"
                           Background="Transparent"
                           Padding="0,8"/>
            </Grid>
        </Border>

        <!-- 메일 본문 에디터 및 첨부파일 영역 -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 첨부파일 영역 (첨부파일이 있을 때만 표시) -->
            <Border Grid.Row="0"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="12,8"
                    Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibilityConverter}, FallbackValue=Collapsed}">
                <ItemsControl x:Name="AttachmentsItemsControl"
                              ItemsSource="{Binding Attachments}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                    CornerRadius="4"
                                    Padding="10,6"
                                    Margin="0,0,8,4">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Document24"
                                                   Margin="0,0,6,0"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock Text="{Binding FileName}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{Binding FileSize, StringFormat=' ({0})'}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="4,0,0,0"/>
                                    <ui:Button Icon="{ui:SymbolIcon Dismiss12}"
                                               Appearance="Transparent"
                                               Padding="4"
                                               Margin="8,0,0,0"
                                               Command="{Binding DataContext.RemoveAttachmentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                               CommandParameter="{Binding}"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <!-- 메일 본문 에디터 (WebView2 + TinyMCE) -->
            <Border Grid.Row="1"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <Grid>
                    <!-- 로딩 인디케이터 -->
                    <StackPanel x:Name="LoadingPanel"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Visible">
                        <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                        <TextBlock Text="에디터 로딩 중..."
                                   HorizontalAlignment="Center"
                                   Margin="0,16,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- TinyMCE 에디터 -->
                    <wv2:WebView2 x:Name="EditorWebView"
                                  DefaultBackgroundColor="Transparent"
                                  Visibility="Collapsed"
                                  AllowDrop="True"
                                  PreviewDragOver="EditorWebView_DragOver"
                                  PreviewDrop="EditorWebView_Drop"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</ui:FluentWindow>
