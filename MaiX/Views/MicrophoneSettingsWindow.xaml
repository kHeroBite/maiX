<ui:FluentWindow x:Class="MaiX.Views.MicrophoneSettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="마이크 설정"
                 Height="620" Width="660"
                 WindowStartupLocation="CenterOwner"
                 ResizeMode="NoResize"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar Grid.Row="0"
                     Title="마이크 설정"
                     ShowMaximize="False"
                     ShowMinimize="False"/>

        <!-- 메인 콘텐츠 -->
        <ScrollViewer Grid.Row="1" Padding="24,16">
            <StackPanel>
                <!-- 장치 선택 -->
                <Border Margin="0,0,0,16" Padding="16"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="마이크 장치" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="MicrophoneComboBox"
                                      DisplayMemberPath="FriendlyName"
                                      Margin="0,0,8,0"/>
                            <ui:Button x:Name="RefreshDevicesButton"
                                       Grid.Column="1"
                                       Content="새로고침"
                                       Appearance="Secondary"
                                       Width="80"/>
                        </Grid>
                        <TextBlock x:Name="DeviceStatusText"
                                   Foreground="{DynamicResource SystemFillColorCautionBrush}"
                                   Margin="0,8,0,0"
                                   Visibility="Collapsed"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- 볼륨 조절 -->
                <Border Margin="0,0,0,16" Padding="16"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="입력 볼륨" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="60"/>
                            </Grid.ColumnDefinitions>
                            <Slider x:Name="VolumeSlider"
                                    Minimum="0" Maximum="100"
                                    Value="50"
                                    VerticalAlignment="Center"/>
                            <TextBlock x:Name="VolumeValueText"
                                       Grid.Column="1"
                                       Text="50%"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="13"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 실시간 레벨 -->
                <Border Margin="0,0,0,16" Padding="16"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="실시간 입력 레벨" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                        <!-- 볼륨 레벨 바 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="레벨"
                                       VerticalAlignment="Center"
                                       FontSize="12"/>
                            <ProgressBar x:Name="VolumeLevelBar"
                                         Grid.Column="1"
                                         Minimum="0" Maximum="100"
                                         Value="0"
                                         Height="16"
                                         Foreground="Green"/>
                        </Grid>

                        <!-- dB 미터 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="60"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="70"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="dB"
                                       VerticalAlignment="Center"
                                       FontSize="12"/>
                            <ProgressBar x:Name="DecibelMeter"
                                         Grid.Column="1"
                                         Minimum="0" Maximum="100"
                                         Value="0"
                                         Height="16"/>
                            <TextBlock x:Name="DecibelValueText"
                                       Grid.Column="2"
                                       Text="-60.0 dB"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="12"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 테스트 녹음/재생 -->
                <Border Margin="0,0,0,16" Padding="16"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock Text="테스트 녹음" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:Button x:Name="RecordButton"
                                       Content="녹음 시작"
                                       Appearance="Primary"
                                       Width="100"
                                       Margin="0,0,8,0"/>
                            <ui:Button x:Name="PlayButton"
                                       Grid.Column="1"
                                       Content="재생"
                                       Appearance="Secondary"
                                       Width="70"
                                       IsEnabled="False"
                                       Margin="0,0,8,0"/>
                            <TextBlock x:Name="RecordStatusText"
                                       Grid.Column="2"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <TextBlock x:Name="RecordTimeText"
                                       Grid.Column="3"
                                       Text="00:00"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 하단 버튼 -->
        <Border Grid.Row="2" Padding="24,12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="SaveStatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="12"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button x:Name="SaveButton"
                               Content="저장"
                               Appearance="Primary"
                               Width="100"
                               Margin="0,0,8,0"/>
                    <ui:Button x:Name="CloseButton"
                               Content="닫기"
                               Appearance="Secondary"
                               Width="100"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
