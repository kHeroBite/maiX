<ui:FluentWindow x:Class="MaiX.Views.Dialogs.ComposeCloseDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="메시지 취소"
        Height="110" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStyle="ToolWindow"
        KeyDown="Window_KeyDown">

    <Grid Margin="20,12,20,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 메시지 -->
        <TextBlock Grid.Row="0"
                   Text="이 초안을 삭제하시겠습니까?"
                   FontSize="14"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

        <!-- 버튼 영역 -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">

            <!-- 확인 버튼 (삭제 확인) -->
            <ui:Button x:Name="ConfirmButton"
                       Content="확인"
                       Appearance="Primary"
                       Margin="0,0,8,0"
                       Padding="20,6"
                       Click="ConfirmButton_Click"/>

            <!-- 보관 버튼 (임시보관함에 저장) -->
            <ui:Button x:Name="SaveDraftButton"
                       Content="보관"
                       Appearance="Secondary"
                       Margin="0,0,8,0"
                       Padding="20,6"
                       Click="SaveDraftButton_Click"/>

            <!-- 취소 버튼 -->
            <ui:Button Content="취소"
                       Appearance="Secondary"
                       Padding="20,6"
                       Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
