                            <ui:Button x:Name="NewMailButton"
                                       AutomationProperties.AutomationId="NewMailButton"
                                       Icon="{ui:SymbolIcon MailAdd24}"
                                       ToolTip="새 메일"
                                       Appearance="Primary"
                                       Width="34" Height="34"
                                       Padding="0"
                                       Margin="0,0,8,0"
                                       Click="NewMailButton_Click"/>
                            <ui:Button Icon="{ui:SymbolIcon ArrowClockwise24}"
                                       Command="{Binding RefreshMailsCommand}"
                                       ToolTip="새로고침 (서버 동기화)"
                                       Appearance="Secondary"
                                       Width="34" Height="34"
                                       Padding="0"
                                       Margin="0,0,4,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 정렬/뷰 토글 바 (Row 1) - 아웃룩 스타일 -->
                <Border Grid.Row="1" VerticalAlignment="Top" Padding="12,4,12,4"
                        Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 왼쪽: 전체 선택 체크박스 -->
                        <CheckBox Grid.Column="0"
                                  x:Name="SelectAllCheckBox"
                                  ToolTip="전체 선택"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  Checked="SelectAllCheckBox_Checked"
                                  Unchecked="SelectAllCheckBox_Unchecked"/>

                        <!-- 가운데: 정렬 드롭다운 + 필터 버튼 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 정렬 드롭다운 버튼 -->
                            <ui:Button x:Name="SortDropdownButton"
                                       ToolTip="정렬 기준 선택"
                                       Appearance="Secondary"
                                       Height="28"
                                       Padding="8,0"
                                       Margin="0,0,4,0"
                                       Click="SortDropdownButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowSort24" FontSize="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding SortByDisplayText, FallbackValue='날짜'}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <!-- 정렬 순서 토글 (오름차순/내림차순) -->
