                                            </Border>
                                            <!-- 구분선 (선택 영역 밖) -->
                                            <Border Grid.Row="1"
                                                    Height="1"
                                                    Background="{DynamicResource ControlElevationBorderBrush}"
                                                    Margin="12,2,12,0"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ContentBorder" Property="Background"
                                                        Value="{DynamicResource SelectionBackgroundBrush}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsSelected" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="ContentBorder" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="ItemBorder" Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- 카테고리 색상 바 -->
                                        <ColumnDefinition Width="4"/>
                                        <!-- 아이콘 영역 (중요도, 플래그) -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- 메인 콘텐츠 -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- 삭제 버튼 영역 (우측 끝 고정) -->
                                        <ColumnDefinition Width="18"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 카테고리 색상 바 (왼쪽) -->
                                    <Rectangle Grid.Column="0"
                                               Width="3"
                                               Fill="{Binding Categories, Converter={StaticResource CategoryToColorConverter}}"
                                               Visibility="{Binding Categories, Converter={StaticResource CategoryToVisibilityConverter}}"
                                               RadiusX="1.5" RadiusY="1.5"
                                               Margin="0,2,4,2"/>

                                    <!-- 아이콘 영역 -->
                                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <!-- 고정(Pin) 아이콘 -->
                                        <ui:SymbolIcon Symbol="Pin24"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                       ToolTip="고정됨"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <!-- 중요도 높음 아이콘 -->
                                        <ui:SymbolIcon Symbol="Important24"
                                                       FontSize="14"
                                                       Foreground="#E74856"
                                                       ToolTip="중요"
                                                       Visibility="{Binding Importance, Converter={StaticResource ImportanceToVisibilityConverter}}"/>
                                    </StackPanel>

                                    <!-- 메인 콘텐츠 -->
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 1행: 발신자, 첨부파일, Flag/Pin (우측 고정) -->
                                        <Grid Grid.Row="0" MinHeight="20">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 발신자 + 첨부파일 -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- 일반 메일: 발신자 표시 -->
                                                <TextBlock x:Name="SenderText"
                                                           Text="{Binding From, Converter={StaticResource EmailToDisplayNameConverter}}"
                                                           FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeightConverter}, FallbackValue=Normal}"
                                                           Foreground="{Binding IsRead, Converter={StaticResource IsReadToForegroundConverter}}"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="13"
                                                           MaxWidth="200"/>
                                                <!-- 초안: [초안] + 받는사람 표시 -->
                                                <TextBlock x:Name="DraftText"
                                                           FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeightConverter}, FallbackValue=Normal}"
                                                           Foreground="#0078D4"
                                                           TextTrimming="CharacterEllipsis"
                                                           FontSize="13"
                                                           MaxWidth="200"
                                                           Visibility="Collapsed">
                                                    <Run Text="[초안]" FontWeight="SemiBold"/>
                                                    <Run Text=" "/>
                                                    <Run Text="{Binding To, Converter={StaticResource JsonArrayToStringConverter}, Mode=OneWay}"/>
                                                </TextBlock>
                                                <!-- 첨부파일 아이콘 -->
                                                <ui:SymbolIcon Symbol="Attach24"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               ToolTip="첨부파일 있음"
                                                               Margin="4,0,0,0"
                                                               Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- Flag/Pin 버튼 영역 (Grid로 위치 고정) -->
                                            <Grid x:Name="ActionButtons" Grid.Column="1"
                                                  Margin="4,0,0,0" VerticalAlignment="Center"
                                                  Width="40">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="20"/>
                                                    <ColumnDefinition Width="20"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Flag 버튼 (Column 0 고정) -->
                                                <ui:Button x:Name="FlagButton" Grid.Column="0"
                                                           Appearance="Transparent"
                                                           Padding="0" Width="18" Height="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Focusable="False"
                                                           PreviewMouseLeftButtonDown="EmailFlag_PreviewMouseDown"
                                                           Tag="{Binding}"
                                                           ToolTip="플래그"
                                                           Visibility="Collapsed">
                                                    <ui:SymbolIcon x:Name="FlagIcon" Symbol="Flag24"
                                                                   FontSize="12"
                                                                   Foreground="{Binding FlagStatus, Converter={StaticResource FlagStatusToColorConverter}}"/>
                                                </ui:Button>
                                                <!-- Pin 버튼 (Column 1 고정) -->
                                                <ui:Button x:Name="PinButton" Grid.Column="1"
                                                           Appearance="Transparent"
                                                           Padding="0" Width="18" Height="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Focusable="False"
                                                           PreviewMouseLeftButtonDown="EmailPin_PreviewMouseDown"
                                                           Tag="{Binding}"
                                                           ToolTip="고정"
                                                           Visibility="Collapsed">
                                                    <ui:SymbolIcon x:Name="PinIcon" Symbol="Pin24"
                                                                   FontSize="12"
                                                                   Foreground="{Binding IsPinned, Converter={StaticResource BoolToIconColorConverter}}"/>
                                                </ui:Button>
                                            </Grid>
                                        </Grid>

                                        <!-- 2행: 제목 + 날짜 (우측 고정) -->
                                        <Grid Grid.Row="1" Margin="0,3,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Subject, Converter={StaticResource EmptySubjectConverter}}"
                                                       FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeightConverter}, FallbackValue=Normal}"
                                                       Foreground="{Binding IsRead, Converter={StaticResource IsReadToForegroundConverter}}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="12"/>
                                            <!-- 날짜 (우측) -->
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding ReceivedDateTime, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       FontSize="11"
                                                       Margin="8,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>

                                        <!-- 3행: AI 요약 + AI 아이콘 (항상 높이 보장) -->
                                        <Grid Grid.Row="2" Margin="0,3,0,0" MinHeight="16">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- AI 요약 (있을 경우) -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding SummaryOneline}"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding SummaryOneline, Converter={StaticResource NullToVisibilityConverter}}"/>

                                            <!-- AI 분석 완료 아이콘 (✨ 이모지 모티프) -->
                                            <TextBlock Grid.Column="1"
                                                       Text="✨"
                                                       FontSize="12"
                                                       ToolTip="AI 분석 완료"
                                                       Margin="4,0,0,0"
                                                       Visibility="{Binding AnalysisStatus, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=completed}"/>
                                        </Grid>
                                    </Grid>

                                    <!-- 삭제 버튼 (우측 끝, 세로 중앙 - 아웃룩 스타일) -->
                                    <ui:Button x:Name="DeleteButton" Grid.Column="3"
                                               Appearance="Transparent"
                                               Padding="0" Width="18" Height="18"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Focusable="False"
                                               PreviewMouseLeftButtonDown="EmailDelete_PreviewMouseDown"
                                               Tag="{Binding}"
                                               ToolTip="삭제"
                                               Visibility="Collapsed">
                                        <ui:SymbolIcon x:Name="DeleteIcon" Symbol="Delete24" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </ui:Button>
                                </Grid>
                            </Border>
                            <!-- 아웃룩 스타일 트리거: 호버/설정 시 Flag/Pin 버튼 개별 표시 -->
                            <DataTemplate.Triggers>
                                <!-- 초안 메일: [초안] 텍스트 표시, 발신자 숨김 -->
                                <DataTrigger Binding="{Binding IsDraft}" Value="True">
                                    <Setter TargetName="SenderText" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="DraftText" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- 호버 시: Flag/Pin/Delete 모두 표시 -->
                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                    <Setter TargetName="FlagButton" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="PinButton" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="DeleteButton" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- 플래그 설정됨: Flag 버튼만 표시 -->
                                <DataTrigger Binding="{Binding FlagStatus}" Value="flagged">
                                    <Setter TargetName="FlagButton" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- 플래그 완료: Flag 버튼만 표시 -->
                                <DataTrigger Binding="{Binding FlagStatus}" Value="complete">
                                    <Setter TargetName="FlagButton" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- 핀 설정됨: Pin 버튼만 표시 -->
                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                    <Setter TargetName="PinButton" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <!-- Flag 버튼 호버 시: 선택 상태 색상 (빨강) -->
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=FlagButton}" Value="True">
                                    <Setter TargetName="FlagIcon" Property="Foreground" Value="#E74856"/>
                                </DataTrigger>
                                <!-- Pin 버튼 호버 시: 선택 상태 색상 (파랑) -->
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=PinButton}" Value="True">
                                    <Setter TargetName="PinIcon" Property="Foreground" Value="#0078D4"/>
                                </DataTrigger>
                                <!-- Delete 버튼 호버 시: 빨간색 -->
                                <DataTrigger Binding="{Binding IsMouseOver, ElementName=DeleteButton}" Value="True">
                                    <Setter TargetName="DeleteIcon" Property="Foreground" Value="#E74856"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 삭제 실행취소 팝업 (메일 목록 하단) -->
                <Border x:Name="UndoDeletePopup"
                        Grid.Row="1"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,12"
                        Padding="16,10"
                        CornerRadius="8"
                        Background="{DynamicResource SystemFillColorSolidNeutralBackgroundBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        Visibility="Collapsed">
                    <Border.Effect>
                        <DropShadowEffect Color="Black" Opacity="0.2" BlurRadius="10" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="UndoPopupText"
                                   Text="삭제됨"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   FontSize="13"/>
                        <Border Width="1"
                                Margin="12,0"
                                Background="{DynamicResource ControlElevationBorderBrush}"/>
                        <ui:Button Content="실행 취소"
                                   Appearance="Transparent"
                                   Padding="8,4"
                                   FontSize="13"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   Click="UndoAction_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- GridSplitter 2 -->
        <GridSplitter x:Name="Splitter2" Grid.Column="4"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE"/>

        <!-- ========== 본문 영역 (Column 5) ========== -->
        <Grid x:Name="BodyAreaGrid" Grid.Column="5">

            <!-- ========== 임시보관함 편집 모드 UI (편집 중일 때만 표시) ========== -->
            <Grid Visibility="{Binding IsEditingDraft, Converter={StaticResource BoolToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <!-- 상단 버튼 바 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 받는 사람, 참조, 숨은참조, 제목 입력 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 본문 에디터 -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 상단 버튼 바 -->
                <Border Grid.Row="0"
                        Padding="12,8"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 왼쪽: 제목 -->
                        <TextBlock Grid.Column="0"
                                   Text="임시 보관함"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>

                        <!-- 오른쪽: 액션 버튼들 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 보내기 버튼 -->
                            <ui:Button x:Name="DraftSendButton"
                                       Appearance="Primary"
                                       ToolTip="보내기"
                                       Margin="0,0,8,0"
                                       Click="DraftSendButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Send24" FontSize="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="보내기" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>
                            <!-- 저장 버튼 -->
                            <ui:Button x:Name="DraftSaveButton"
                                       Appearance="Secondary"
                                       ToolTip="임시 저장"
                                       Margin="0,0,8,0"
                                       Click="DraftSaveButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Save24" FontSize="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="저장" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>
                            <!-- 취소 버튼 -->
                            <ui:Button Appearance="Secondary"
                                       ToolTip="취소"
                                       Command="{Binding CloseDraftEditorCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="취소" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 받는 사람, 참조, 제목 입력 영역 -->
                <Border Grid.Row="1"
                        Padding="16,12"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <!-- 받는 사람 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="받는 사람"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding DraftTo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="받는 사람 이메일 주소 (세미콜론으로 구분)"/>
                        </Grid>

                        <!-- 참조 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="참조"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding DraftCc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="참조 이메일 주소"/>
                        </Grid>

                        <!-- 숨은 참조 -->
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="숨은 참조"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding DraftBcc, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="숨은 참조 이메일 주소"/>
                        </Grid>

                        <!-- 제목 -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="제목"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <ui:TextBox Grid.Column="1"
                                        Text="{Binding DraftSubject, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        PlaceholderText="메일 제목"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 본문 에디터 (WebView2) -->
                <Border Grid.Row="2"
                        Padding="0">
                    <wv2:WebView2 x:Name="DraftBodyWebView"
                                  DefaultBackgroundColor="Transparent"
                                  AllowDrop="True"
                                  PreviewDragOver="DraftBodyWebView_DragOver"
                                  PreviewDrop="DraftBodyWebView_Drop"/>
                </Border>
            </Grid>

            <!-- ========== 읽기 모드 UI (편집 중이 아닐 때만 표시) ========== -->
            <Grid Visibility="{Binding IsEditingDraft, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                <Grid.RowDefinitions>
                    <!-- 액션 버튼 바 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 메일 헤더 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 본문 -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 액션 버튼 바 (Row 0) -->
                <Border Grid.Row="0"
                    Padding="12,8"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                    Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 왼쪽: 액션 버튼들 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 회신 버튼 -->
                        <ui:Button x:Name="ReplyButton"
                                   AutomationProperties.AutomationId="ReplyButton"
                                   ToolTip="회신"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="ReplyButton_Click">
                            <ui:SymbolIcon Symbol="ArrowReply24" FontSize="16"/>
                        </ui:Button>
                        <!-- 전체 회신 버튼 -->
                        <ui:Button x:Name="ReplyAllButton"
                                   AutomationProperties.AutomationId="ReplyAllButton"
                                   ToolTip="전체 회신"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="ReplyAllButton_Click">
                            <ui:SymbolIcon Symbol="ArrowReplyAll24" FontSize="16"/>
                        </ui:Button>
                        <!-- 전달 버튼 -->
                        <ui:Button x:Name="ForwardButton"
                                   AutomationProperties.AutomationId="ForwardButton"
                                   ToolTip="전달"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,12,0"
                                   Click="ForwardButton_Click">
                            <ui:SymbolIcon Symbol="ArrowForward24" FontSize="16"/>
                        </ui:Button>
                        <!-- 구분선 -->
                        <Border Width="1" Height="24"
                                Background="{DynamicResource ControlElevationBorderBrush}"
                                Margin="0,0,12,0"/>
                        <!-- 삭제 버튼 -->
                        <ui:Button x:Name="DeleteButton"
                                   ToolTip="삭제"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="DeleteButton_Click">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
                        </ui:Button>
                        <!-- 플래그 버튼 (상태 기반 하이라이팅) -->
                        <ui:Button x:Name="FlagButton"
                                   ToolTip="플래그 설정/해제"
                                   Appearance="{Binding SelectedEmail.FlagStatus, Converter={StaticResource FlagStatusToAppearanceConverter}}"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="FlagButton_Click">
                            <ui:SymbolIcon Symbol="Flag24" FontSize="16"
                                           Foreground="{Binding SelectedEmail.FlagStatus, Converter={StaticResource BoolToForegroundConverter}}"/>
                        </ui:Button>
                        <!-- 읽음/안읽음 토글 버튼 -->
                        <ui:Button x:Name="ReadUnreadButton"
                                   ToolTip="읽음/안읽음 표시"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="ReadUnreadButton_Click">
                            <ui:SymbolIcon Symbol="MailRead24" FontSize="16"/>
                        </ui:Button>
                        <!-- 고정(Pin) 버튼 (상태 기반 하이라이팅) -->
                        <ui:Button x:Name="PinButton"
                                   ToolTip="고정/해제"
                                   Appearance="{Binding SelectedEmail.IsPinned, Converter={StaticResource BoolToAppearanceConverter}}"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Command="{Binding TogglePinnedCommand}">
                            <ui:SymbolIcon Symbol="Pin24" FontSize="16"
                                           Foreground="{Binding SelectedEmail.IsPinned, Converter={StaticResource BoolToForegroundConverter}}"/>
                        </ui:Button>
                    </StackPanel>

                    <!-- 오른쪽: 더보기 버튼만 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- 더보기 버튼 -->
                        <ui:Button x:Name="MoreActionsButton"
                                   ToolTip="더 많은 작업"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Click="MoreActionsButton_Click">
                            <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16"/>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 메일 헤더 정보 (Row 1) -->
            <Border Grid.Row="1"
                    Padding="20,16"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <!-- 제목 -->
                    <TextBlock Text="{Binding SelectedEmail.Subject, Converter={StaticResource EmptySubjectConverter}}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <!-- 발신자 정보 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 아바타 -->
                        <Border Grid.Column="0" Grid.RowSpan="2"
                                Width="40" Height="40"
                                CornerRadius="20"
                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                Margin="0,0,12,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedEmail.From, Converter={StaticResource StringToInitialConverter}}"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- 1행: 발신자 + 날짜 -->
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                   Text="{Binding SelectedEmail.From}"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Grid.Row="0" Grid.Column="2"
                                   Text="{Binding SelectedEmail.ReceivedDateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                   Foreground="#888888"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>

                        <!-- 2행: 받는 사람 (전체 너비) -->
                        <TextBlock Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0,2,0,0">
                            <Run Text="받는 사람:"/>
                            <Run Text="{Binding SelectedEmail.To, Converter={StaticResource JsonArrayToStringConverter}, Mode=OneWay}"/>
                        </TextBlock>
                    </Grid>

                    <!-- 플래그 상태 표시 -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,8,0,0"
                                Visibility="{Binding SelectedEmail.FlagStatus, Converter={StaticResource FlagStatusToVisibilityConverter}}">
                        <ui:SymbolIcon Symbol="Flag24" FontSize="14"
                                       Foreground="{Binding SelectedEmail.FlagStatus, Converter={StaticResource FlagStatusToColorConverter}}"
                                       Margin="0,0,6,0"/>
                        <TextBlock Text="플래그 지정됨"
                                   Foreground="{Binding SelectedEmail.FlagStatus, Converter={StaticResource FlagStatusToColorConverter}}"
                                   FontSize="12"/>
                    </StackPanel>

                    <!-- 첨부파일 표시 -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,12,0,0"
                                Visibility="{Binding SelectedEmail.HasAttachments, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ui:SymbolIcon Symbol="Attach24" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="첨부파일 있음"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                </Border>

                <!-- 메일 본문 (WebView2) -->
                <Border Grid.Row="2">
                    <wv2:WebView2 x:Name="MailBodyWebView"
                                  DefaultBackgroundColor="Transparent"
                                  Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}"/>
                </Border>

                <!-- 메일 미선택 시 안내 -->
                <Border Grid.Row="0" Grid.RowSpan="3"
                        Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <!-- 메일 아이콘 (열린 봉투 스타일) -->
                        <ui:SymbolIcon Symbol="MailInbox24" FontSize="72"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,20"/>
                        <TextBlock Text="읽을 항목 선택"
                                   FontSize="20"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="선택된 항목이 없습니다."
                                   FontSize="14"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
            <!-- 읽기 모드 UI 끝 -->

        </Grid>

        <!-- GridSplitter 3 (본문-AI 패널 사이) -->
        <GridSplitter x:Name="Splitter3" Grid.Column="6"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE"/>

        <!-- ========== 캘린더 뷰 컨테이너 (Column 1-5 전체 사용, 초기에는 숨김) ========== -->
        <Border x:Name="CalendarViewBorder"
                Grid.Column="1" Grid.ColumnSpan="5"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- 좌측 미니캘린더 + 캘린더 목록 -->
                    <ColumnDefinition Width="250" MinWidth="200" MaxWidth="400"/>
                    <!-- GridSplitter -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 메인 캘린더 뷰 -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측 패널: 미니캘린더 + 캘린더 목록 -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 월 네비게이션 -->
                        <Border Grid.Row="0" Padding="12,12,12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        x:Name="CalPrevMonthBtn"
                                        Style="{StaticResource NavIconButtonStyle}"
                                        Width="28" Height="28"
                                        Click="CalPrevMonthBtn_Click">
                                    <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="14"/>
                                </Button>
                                <TextBlock Grid.Column="1"
                                           x:Name="CalMonthYearText"
                                           Text="2026년 1월"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="2"
                                        x:Name="CalNextMonthBtn"
                                        Style="{StaticResource NavIconButtonStyle}"
                                        Width="28" Height="28"
                                        Click="CalNextMonthBtn_Click">
                                    <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 미니 캘린더 그리드 -->
                        <Border Grid.Row="1" Padding="8,0,8,12">
                            <Grid x:Name="MiniCalendarGrid">
                                <!-- 요일 헤더 -->
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 요일 헤더 (일~토) -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="일" HorizontalAlignment="Center" FontSize="11" Foreground="#FF6B6B"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="월" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="화" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="수" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="목" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="5" Text="금" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="토" HorizontalAlignment="Center" FontSize="11" Foreground="#6B9DFF"/>

                                <!-- 날짜들은 코드비하인드에서 동적 생성 -->
                            </Grid>
                        </Border>

                        <!-- 내 캘린더 목록 + 선택된 날짜 일정 -->
                        <Border Grid.Row="2" Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 내 캘린더 섹션 -->
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="내 캘린더" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,8"/>
                                    <CheckBox x:Name="CalCheckDefault" IsChecked="True" Content="일정" Margin="0,4"/>
                                </StackPanel>

                                <!-- 선택된 날짜의 일정 목록 -->
                                <Border Grid.Row="1" Margin="0,16,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="SelectedDateText"
                                                   Grid.Row="0"
                                                   Text="오늘의 일정"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,8"/>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      MaxHeight="200">
                                            <StackPanel x:Name="SelectedDateEventsPanel">
                                                <!-- 일정 아이템들이 동적으로 추가됨 -->
                                                <TextBlock x:Name="NoEventsText"
                                                           Text="일정이 없습니다"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,16"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- 새 일정 버튼 -->
                        <Border Grid.Row="3" Padding="12,8,12,12">
                            <ui:Button x:Name="NewEventButton"
                                       AutomationProperties.AutomationId="NewEventButton"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Click="NewEventButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="새 일정"/>
                                </StackPanel>
                            </ui:Button>
                        </Border>
                    </Grid>
                </Border>

                <!-- GridSplitter (캘린더) -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- 메인 캘린더: 월간 뷰 -->
                <Border Grid.Column="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- 툴바 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 캘린더 그리드 -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 캘린더 툴바 -->
                        <Border Grid.Row="0"
                                Padding="16,8"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 네비게이션 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:Button x:Name="CalTodayBtn" Content="오늘" Margin="0,0,8,0" Click="CalTodayBtn_Click"/>
                                    <Button Style="{StaticResource NavIconButtonStyle}" Width="32" Height="32" Click="CalPrevMonthBtn_Click">
                                        <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="14"/>
                                    </Button>
                                    <Button Style="{StaticResource NavIconButtonStyle}" Width="32" Height="32" Click="CalNextMonthBtn_Click">
                                        <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14"/>
                                    </Button>
                                    <TextBlock x:Name="CalMainMonthYearText"
                                               Text="2026년 1월"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </StackPanel>

                                <!-- 뷰 모드 토글 -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <ui:Button x:Name="CalDayViewBtn" Content="일" Width="40" Margin="0,0,4,0" Click="CalDayViewBtn_Click"/>
                                    <ui:Button x:Name="CalWeekViewBtn" Content="주" Width="40" Margin="0,0,4,0" Click="CalWeekViewBtn_Click"/>
                                    <ui:Button x:Name="CalMonthViewBtn" Content="월" Width="40" Appearance="Primary" Click="CalMonthViewBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 월간 캘린더 그리드 -->
                        <Border Grid.Row="1" Padding="8">
                            <Grid x:Name="MonthCalendarGrid">
                                <Grid.RowDefinitions>
                                    <!-- 요일 헤더 -->
                                    <RowDefinition Height="32"/>
                                    <!-- 6주 (최대) -->
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 요일 헤더 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="일요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="월요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="화요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="수요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="목요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="5" Text="금요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="토요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#6B9DFF"/>

                                <!-- 날짜 셀들은 코드비하인드에서 동적 생성 -->
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ========== 채팅 뷰 컨테이너 (Column 1-5 전체 사용, 초기에는 숨김) - Teams 스타일 ========== -->
        <Border x:Name="ChatViewBorder"
                Grid.Column="1" Grid.ColumnSpan="5"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" MinWidth="320" MaxWidth="400"/>
                    <!-- GridSplitter -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ==================== 좌측 패널: 채팅 목록 (Teams 스타일) ==================== -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더: 채팅 + 액션 버튼들 -->
                        <Border Grid.Row="0" Padding="16,12,12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="채팅" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button Appearance="Transparent" ToolTip="더보기" Padding="6">
                                        <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16"/>
                                    </ui:Button>
                                    <ui:Button Appearance="Transparent" ToolTip="검색" Padding="6"
                                               x:Name="ChatSearchToggleButton" Click="ChatSearchToggleButton_Click">
                                        <ui:SymbolIcon Symbol="Search24" FontSize="16"/>
                                    </ui:Button>
                                    <ui:Button Appearance="Transparent" ToolTip="새 채팅" Padding="6" Margin="0,0,4,0"
                                               x:Name="ChatNewButton">
                                        <ui:SymbolIcon Symbol="Compose24" FontSize="16"/>
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 검색 바 (토글 가능) -->
                        <Border x:Name="ChatSearchPanel" Grid.Row="1" Padding="12,0,12,8" Visibility="Collapsed">
                            <ui:TextBox x:Name="ChatSearchBox" PlaceholderText="검색(Ctrl+E)"
                                        Icon="{ui:SymbolIcon Search24}"
                                        KeyDown="ChatSearchBox_KeyDown"/>
                        </Border>

                        <!-- 필터 탭 (읽지 않음 / 채팅 / 모임 채팅) - 토글 스타일 -->
                        <Border Grid.Row="2" Padding="12,0,12,8">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="ChatFilterUnreadToggle" Content="읽지 않음"
                                              Padding="8,4" Margin="0,0,4,0"
                                              Checked="ChatFilterUnread_Checked" Unchecked="ChatFilterUnread_Unchecked"
                                              Style="{StaticResource {x:Type ToggleButton}}"/>
                                <ToggleButton x:Name="ChatFilterChatToggle" Content="채팅"
                                              Padding="8,4" Margin="0,0,4,0" IsChecked="True"
                                              Checked="ChatFilterChat_Checked" Unchecked="ChatFilterChat_Unchecked"
                                              Style="{StaticResource {x:Type ToggleButton}}"/>
                                <ToggleButton x:Name="ChatFilterMeetingToggle" Content="모임 채팅"
                                              Padding="8,4"
                                              Checked="ChatFilterMeeting_Checked" Unchecked="ChatFilterMeeting_Unchecked"
                                              Style="{StaticResource {x:Type ToggleButton}}"/>
                            </StackPanel>
                        </Border>

                        <!-- 바로가기: Copilot, 멘션 -->
                        <Border Grid.Row="3" Padding="8,0,8,4">
                            <StackPanel>
                                <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Bot24" FontSize="18" Margin="0,0,12,0" Foreground="{StaticResource ChatAccentBrush}"/>
                                        <TextBlock Text="Copilot" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                                <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="@" FontSize="18" FontWeight="Bold" Margin="0,0,12,0" Foreground="{StaticResource ChatAccentBrush}" Width="18" TextAlignment="Center"/>
                                        <TextBlock Text="멘션" FontSize="14" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </ui:Button>
                            </StackPanel>
                        </Border>

                        <!-- 채팅 목록 (즐겨찾기 + 최근) -->
                        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- 즐겨찾기 섹션 -->
                                <Expander x:Name="ChatFavoritesExpander" IsExpanded="True" Padding="0">
                                    <Expander.Header>
                                        <TextBlock Text="즐겨찾기" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="8,0"/>
                                    </Expander.Header>
                                    <ListBox x:Name="ChatFavoritesListBox"
                                             Background="Transparent" BorderThickness="0"
                                             SelectionChanged="ChatListBox_SelectionChanged"
                                             AlternationCount="2"
                                             Padding="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             AllowDrop="True"
                                             PreviewMouseLeftButtonDown="ChatFavorites_PreviewMouseLeftButtonDown"
                                             PreviewMouseMove="ChatFavorites_PreviewMouseMove"
                                             Drop="ChatFavorites_Drop"
                                             DragOver="ChatFavorites_DragOver">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                <Setter Property="Padding" Value="12,8"/>
                                                <Setter Property="Margin" Value="4,1"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <!-- 라이트모드에서 채팅 항목 구분을 위한 배경색 -->
                                                <Style.Triggers>
                                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="즐겨찾기 해제" Click="ChatUnfavorite_Click">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="PinOff20"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 아바타: 1:1 채팅 또는 그룹 채팅 (즐겨찾기 목록) -->
                                                    <Grid Grid.Column="0" Width="36" Height="36">
                                                        <!-- 1:1 채팅: 단일 사진 -->
                                                        <Grid Visibility="{Binding IsGroupChat, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                            <!-- 사진이 있는 경우 (사각형) -->
                                                            <Border CornerRadius="4" ClipToBounds="True" Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <Border.Background>
                                                                    <ImageBrush ImageSource="{Binding PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}}" Stretch="UniformToFill"/>
                                                                </Border.Background>
                                                            </Border>
                                                            <!-- 사진이 없는 경우 이니셜 (아웃룩 스타일 배경색) -->
                                                            <Border CornerRadius="4" Background="{Binding DisplayName, Converter={StaticResource NameToAvatarColorConverter}}"
                                                                    Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                                <TextBlock Text="{Binding DisplayName, Converter={StaticResource StringToInitialConverter}}"
                                                                           FontSize="14" Foreground="White" FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>

                                                        <!-- 그룹 채팅: 2x2 그리드 (사각형) -->
                                                        <Grid Visibility="{Binding IsGroupChat, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Border CornerRadius="4" ClipToBounds="True" Background="{Binding DisplayName, Converter={StaticResource NameToAvatarColorConverter}}">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <!-- 멤버 1 (좌상단) -->
                                                                    <Border Grid.Row="0" Grid.Column="0" Margin="1" CornerRadius="2"
                                                                            Visibility="{Binding MemberPhotos.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=0}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding MemberPhotos[0].PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                        <!-- 사진 없으면 이니셜 -->
                                                                        <TextBlock Text="{Binding MemberPhotos[0].Initial, FallbackValue=''}" FontSize="9" Foreground="White" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding MemberPhotos[0].HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert, FallbackValue=Collapsed}"/>
                                                                    </Border>
                                                                    <!-- 멤버 2 (우상단) -->
                                                                    <Border Grid.Row="0" Grid.Column="1" Margin="1" CornerRadius="2"
                                                                            Visibility="{Binding MemberPhotos.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=1}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding MemberPhotos[1].PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                        <TextBlock Text="{Binding MemberPhotos[1].Initial, FallbackValue=''}" FontSize="9" Foreground="White" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding MemberPhotos[1].HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert, FallbackValue=Collapsed}"/>
                                                                    </Border>
                                                                    <!-- 멤버 3 (좌하단) -->
                                                                    <Border Grid.Row="1" Grid.Column="0" Margin="1" CornerRadius="2"
                                                                            Visibility="{Binding MemberPhotos.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=2}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding MemberPhotos[2].PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                        <TextBlock Text="{Binding MemberPhotos[2].Initial, FallbackValue=''}" FontSize="9" Foreground="White" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding MemberPhotos[2].HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert, FallbackValue=Collapsed}"/>
                                                                    </Border>
                                                                    <!-- 멤버 4 (우하단) -->
                                                                    <Border Grid.Row="1" Grid.Column="1" Margin="1" CornerRadius="2"
                                                                            Visibility="{Binding MemberPhotos.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=3}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding MemberPhotos[3].PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                        <TextBlock Text="{Binding MemberPhotos[3].Initial, FallbackValue=''}" FontSize="9" Foreground="White" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding MemberPhotos[3].HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert, FallbackValue=Collapsed}"/>
                                                                    </Border>
                                                                    <TextBlock Grid.RowSpan="2" Grid.ColumnSpan="2"
                                                                               Text="{Binding DisplayName, Converter={StaticResource StringToInitialConverter}}"
                                                                               FontSize="14" Foreground="White" FontWeight="SemiBold"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               Visibility="{Binding HasGroupPhotos, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>
                                                    </Grid>

                                                    <!-- 2열: 채팅방명 + 메시지 -->
                                                    <StackPanel Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding LastMessage}" FontSize="12"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxHeight="18"/>
                                                    </StackPanel>
                                                    <!-- 3열: 시간 (고정 45px) - 컨버터로 직접 변환 -->
                                                    <TextBlock Grid.Column="2" Text="{Binding LastUpdatedDateTime, Converter={StaticResource DateTimeToRelativeTimeConverter}}" FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                               VerticalAlignment="Top" HorizontalAlignment="Right"
                                                               Margin="0,2,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>

                                <!-- 채팅 섹션 -->
                                <Expander x:Name="ChatRecentExpander" IsExpanded="True" Padding="0" Margin="0,4,0,0">
                                    <Expander.Header>
                                        <TextBlock Text="채팅" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="8,0"/>
                                    </Expander.Header>
                                    <ListBox x:Name="ChatListBox"
                                             Background="Transparent" BorderThickness="0"
                                             SelectionChanged="ChatListBox_SelectionChanged"
                                             VirtualizingPanel.IsVirtualizing="False"
                                             AlternationCount="2"
                                             Padding="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <ListBox.ContextMenu>
                                            <ContextMenu>
                                                <MenuItem Header="즐겨찾기 추가" Click="ChatFavorite_Click">
                                                    <MenuItem.Icon>
                                                        <ui:SymbolIcon Symbol="Pin20"/>
                                                    </MenuItem.Icon>
                                                </MenuItem>
                                            </ContextMenu>
                                        </ListBox.ContextMenu>
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                <Setter Property="Padding" Value="12,8"/>
                                                <Setter Property="Margin" Value="4,1"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <!-- 라이트모드에서 채팅 항목 구분을 위한 배경색 -->
                                                <Style.Triggers>
                                                    <Trigger Property="ItemsControl.AlternationIndex" Value="0">
                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                                                        <Setter Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 아바타: 1:1 채팅 또는 그룹 채팅 -->
                                                    <Grid Grid.Column="0" Width="36" Height="36">
                                                        <!-- 1:1 채팅: 단일 사진 -->
                                                        <Grid Visibility="{Binding IsGroupChat, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                            <!-- 사진이 있는 경우 (사각형) -->
                                                            <Border CornerRadius="4" ClipToBounds="True" Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <Border.Background>
                                                                    <ImageBrush ImageSource="{Binding PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}}" Stretch="UniformToFill"/>
                                                                </Border.Background>
                                                            </Border>
                                                            <!-- 사진이 없는 경우 이니셜 (아웃룩 스타일 배경색) -->
                                                            <Border CornerRadius="4" Background="{Binding DisplayName, Converter={StaticResource NameToAvatarColorConverter}}"
                                                                    Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                                <TextBlock Text="{Binding DisplayName, Converter={StaticResource StringToInitialConverter}}"
                                                                           FontSize="14" Foreground="White" FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </Grid>

                                                        <!-- 그룹 채팅: 2x2 그리드 (최대 4명, 사각형) -->
                                                        <Grid Visibility="{Binding IsGroupChat, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <Border CornerRadius="4" Background="{Binding DisplayName, Converter={StaticResource NameToAvatarColorConverter}}">
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="*"/>
                                                                        <RowDefinition Height="*"/>
                                                                    </Grid.RowDefinitions>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>

                                                                    <!-- 멤버 1 (좌상단) -->
                                                                    <Border Grid.Row="0" Grid.Column="0" Margin="1" CornerRadius="2"
                                                                            Visibility="{Binding MemberPhotos.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=0}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding MemberPhotos[0].PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                        <!-- 사진 없으면 이니셜 -->
                                                                        <TextBlock Text="{Binding MemberPhotos[0].Initial, FallbackValue=''}" FontSize="9" Foreground="White" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding MemberPhotos[0].HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert, FallbackValue=Collapsed}"/>
                                                                    </Border>

                                                                    <!-- 멤버 2 (우상단) -->
                                                                    <Border Grid.Row="0" Grid.Column="1" Margin="1" CornerRadius="2"
                                                                            Visibility="{Binding MemberPhotos.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=1}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding MemberPhotos[1].PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                        <TextBlock Text="{Binding MemberPhotos[1].Initial, FallbackValue=''}" FontSize="9" Foreground="White" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding MemberPhotos[1].HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert, FallbackValue=Collapsed}"/>
                                                                    </Border>

                                                                    <!-- 멤버 3 (좌하단) -->
                                                                    <Border Grid.Row="1" Grid.Column="0" Margin="1" CornerRadius="2"
                                                                            Visibility="{Binding MemberPhotos.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=2}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding MemberPhotos[2].PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                        <TextBlock Text="{Binding MemberPhotos[2].Initial, FallbackValue=''}" FontSize="9" Foreground="White" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding MemberPhotos[2].HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert, FallbackValue=Collapsed}"/>
                                                                    </Border>

                                                                    <!-- 멤버 4 (우하단) -->
                                                                    <Border Grid.Row="1" Grid.Column="1" Margin="1" CornerRadius="2"
                                                                            Visibility="{Binding MemberPhotos.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=3}">
                                                                        <Border.Background>
                                                                            <ImageBrush ImageSource="{Binding MemberPhotos[3].PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}, FallbackValue={x:Null}}" Stretch="UniformToFill"/>
                                                                        </Border.Background>
                                                                        <TextBlock Text="{Binding MemberPhotos[3].Initial, FallbackValue=''}" FontSize="9" Foreground="White" FontWeight="SemiBold"
                                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                   Visibility="{Binding MemberPhotos[3].HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert, FallbackValue=Collapsed}"/>
                                                                    </Border>

                                                                    <!-- 그룹 사진이 없는 경우 기본 이니셜 -->
                                                                    <TextBlock Grid.RowSpan="2" Grid.ColumnSpan="2"
                                                                               Text="{Binding DisplayName, Converter={StaticResource StringToInitialConverter}}"
                                                                               FontSize="14" Foreground="White" FontWeight="SemiBold"
                                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                               Visibility="{Binding HasGroupPhotos, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                                </Grid>
                                                            </Border>
                                                        </Grid>

                                                        <!-- 즐겨찾기 표시 (핀 아이콘) -->
                                                        <Border CornerRadius="6" Background="{Binding DisplayName, Converter={StaticResource NameToAvatarColorConverter}}"
                                                                Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                                Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}">
                                                            <ui:SymbolIcon Symbol="Pin12" FontSize="8" Foreground="White"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- 2열: 채팅방명 + 메시지 -->
                                                    <StackPanel Grid.Column="1" Margin="8,0,4,0" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontSize="14" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding LastMessage}" FontSize="12"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxHeight="18"/>
                                                    </StackPanel>
                                                    <!-- 3열: 시간 (고정 45px) - 컨버터로 직접 변환 -->
                                                    <TextBlock Grid.Column="2" Text="{Binding LastUpdatedDateTime, Converter={StaticResource DateTimeToRelativeTimeConverter}}" FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                               VerticalAlignment="Top" HorizontalAlignment="Right"
                                                               Margin="0,2,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>

                        <!-- 로딩 오버레이 -->
                        <Border x:Name="ChatListLoadingOverlay" Grid.Row="4" Visibility="Collapsed"
                                Background="{DynamicResource ApplicationBackgroundBrush}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:ProgressRing IsIndeterminate="True" Width="32" Height="32"/>
                                <TextBlock Text="채팅 목록 로딩 중..." FontSize="12" Margin="0,8,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- GridSplitter (채팅) -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- ==================== 우측 패널: 채팅 내용 (Teams 스타일) ==================== -->
                <Grid Grid.Column="2">
                    <!-- 채팅방 미선택 시 안내 -->
                    <StackPanel x:Name="ChatEmptyStatePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Chat24" FontSize="64" Foreground="{StaticResource ChatAccentBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="채팅을 선택하세요" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="좌측 목록에서 대화를 선택하면 여기에 표시됩니다" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- 채팅 내용 영역 -->
                    <Grid x:Name="ChatContentPanel" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 채팅방 헤더 (Teams 스타일: 아바타 + 이름 + 탭 + 통화버튼) -->
                        <Border Grid.Row="0" Padding="16,8,16,0"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 상단: 아바타 + 이름 + 통화 버튼 -->
                                <Grid Grid.Row="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal">
                                        <!-- 채팅방 아바타 -->
                                        <Border Width="32" Height="32" CornerRadius="4"
                                                Background="{StaticResource ChatAccentBrush}" Margin="0,0,12,0">
                                            <TextBlock x:Name="ChatHeaderAvatar" Text="장" FontSize="14"
                                                       Foreground="White" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock x:Name="ChatHeaderTitle" Text="채팅방 이름" FontSize="16" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- 통화 버튼들 -->
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ui:Button Appearance="Transparent" ToolTip="음성 통화" Padding="8">
                                            <ui:SymbolIcon Symbol="Call24" FontSize="18"/>
                                        </ui:Button>
                                        <ui:Button Appearance="Transparent" ToolTip="화상 통화" Padding="8">
                                            <ui:SymbolIcon Symbol="Video24" FontSize="18"/>
                                        </ui:Button>
                                        <ui:Button Appearance="Transparent" ToolTip="참가자 추가" Padding="8">
                                            <ui:SymbolIcon Symbol="PersonAdd24" FontSize="18"/>
                                        </ui:Button>
                                        <ui:Button Appearance="Transparent" ToolTip="검색" Padding="8">
                                            <ui:SymbolIcon Symbol="Search24" FontSize="18"/>
                                        </ui:Button>
                                        <ui:Button Appearance="Transparent" ToolTip="더보기" Padding="8">
                                            <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="18"/>
                                        </ui:Button>
                                    </StackPanel>
                                </Grid>

                                <!-- 하단: 탭 (채팅 / 공유 / 스토리라인) -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0">
                                    <ui:Button x:Name="ChatTabChatButton" Content="채팅" Appearance="Transparent"
                                               Padding="12,6" FontWeight="SemiBold"
                                               BorderThickness="0,0,0,2" BorderBrush="{StaticResource ChatAccentBrush}"/>
                                    <ui:Button x:Name="ChatTabShareButton" Content="공유" Appearance="Transparent"
                                               Padding="12,6" Margin="4,0,0,0"/>
                                    <ui:Button x:Name="ChatTabStorylineButton" Content="스토리라인" Appearance="Transparent"
                                               Padding="12,6" Margin="4,0,0,0"/>
                                    <ui:Button Appearance="Transparent" Padding="6" Margin="4,0,0,0" ToolTip="탭 추가">
                                        <ui:SymbolIcon Symbol="Add24" FontSize="14"/>
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 메시지 목록 (Teams 스타일: 내 메시지는 우측 보라색 배경) -->
                        <ScrollViewer x:Name="ChatMessagesScrollViewer" Grid.Row="1" Padding="16,8"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ChatMessagesItemsControl">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <!-- 날짜 분리선 -->
                                            <Grid Visibility="{Binding ShowDateSeparator, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  Margin="0,16,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border Grid.Column="0" Height="1" VerticalAlignment="Center"
                                                        Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding DateSeparatorText}"
                                                           FontSize="12" Margin="16,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <Border Grid.Column="2" Height="1" VerticalAlignment="Center"
                                                        Background="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                                            </Grid>

                                            <Grid Margin="0,8">
                                            <!-- 상대방 메시지 (좌측 정렬) -->
                                            <Grid Visibility="{Binding IsFromMe, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- 발신자 아바타 -->
                                                <Grid Grid.Column="0" Width="32" Height="32" VerticalAlignment="Top">
                                                    <!-- 사진이 있는 경우 -->
                                                    <Border CornerRadius="4" ClipToBounds="True"
                                                            Visibility="{Binding HasFromUserPhoto, Converter={StaticResource BoolToVisibilityConverter}}">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding FromUserPhoto, Converter={StaticResource Base64ToImageSourceConverter}}" Stretch="UniformToFill"/>
                                                        </Border.Background>
                                                    </Border>
                                                    <!-- 사진이 없는 경우 이니셜 -->
                                                    <Border CornerRadius="4" Background="{Binding FromUser, Converter={StaticResource NameToAvatarColorConverter}}"
                                                            Visibility="{Binding HasFromUserPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                        <TextBlock Text="{Binding FromUserInitial}" FontSize="12"
                                                                   Foreground="White" FontWeight="SemiBold"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>

                                                <!-- 메시지 내용 -->
                                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                    <!-- 발신자 이름 + 시간 -->
                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                        <TextBlock Text="{Binding FromUser}" FontSize="13" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   Margin="8,0,0,0" VerticalAlignment="Center"/>
                                                    </StackPanel>

                                                    <!-- 메시지 버블 (좌측) -->
                                                    <Border Padding="12,8" CornerRadius="4"
                                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                            HorizontalAlignment="Left" MaxWidth="500">
                                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>

                                            <!-- 내 메시지 (우측 정렬, 보라색 배경) -->
                                            <Grid Visibility="{Binding IsFromMe, Converter={StaticResource BoolToVisibilityConverter}}"
                                                  HorizontalAlignment="Right" MaxWidth="550">
                                                <StackPanel>
                                                    <!-- 시간 (우측 상단) -->
                                                    <TextBlock Text="{Binding TimeDisplay}" FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                               HorizontalAlignment="Right" Margin="0,0,0,4"/>

                                                    <!-- 메시지 버블 (우측, 보라색 배경) -->
                                                    <Border Padding="12,8" CornerRadius="4"
                                                            Background="{StaticResource ChatAccentBrush}"
                                                            HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14"
                                                                   Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- 메시지 입력 영역 (Teams 스타일: 서식 도구 + 입력창 + 전송) -->
                        <Border Grid.Row="2" Padding="16,8,16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,1,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 입력창 -->
                                <Border Grid.Row="0" BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        BorderThickness="1" CornerRadius="4" Padding="8,4">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 텍스트 입력 -->
                                        <TextBox x:Name="ChatMessageInput" Grid.Row="0"
                                                 AutomationProperties.AutomationId="ChatMessageInput"
                                                 Background="Transparent" BorderThickness="0"
                                                 AcceptsReturn="True" TextWrapping="Wrap"
                                                 MinHeight="24" MaxHeight="120"
                                                 VerticalScrollBarVisibility="Auto"
                                                 KeyDown="ChatMessageInput_KeyDown">
                                            <TextBox.Resources>
                                                <Style TargetType="TextBox">
                                                    <Setter Property="CaretBrush" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>

                                        <!-- 플레이스홀더 -->
                                        <TextBlock x:Name="ChatMessagePlaceholder" Grid.Row="0"
                                                   Text="메시지를 입력하세요."
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   IsHitTestVisible="False" Margin="2,4,0,0"
                                                   Visibility="Visible"/>

                                        <!-- 하단 도구 버튼들 -->
                                        <Grid Grid.Row="1" Margin="0,4,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 왼쪽: 서식 도구 -->
                                            <StackPanel Orientation="Horizontal">
                                                <ui:Button Appearance="Transparent" ToolTip="서식" Padding="4">
                                                    <ui:SymbolIcon Symbol="TextFont24" FontSize="16"/>
                                                </ui:Button>
                                                <ui:Button Appearance="Transparent" ToolTip="이모지" Padding="4">
                                                    <ui:SymbolIcon Symbol="Emoji24" FontSize="16"/>
                                                </ui:Button>
                                                <ui:Button Appearance="Transparent" ToolTip="GIF" Padding="4">
                                                    <ui:SymbolIcon Symbol="Gif24" FontSize="16"/>
                                                </ui:Button>
                                                <ui:Button Appearance="Transparent" ToolTip="스티커" Padding="4">
                                                    <ui:SymbolIcon Symbol="Sticker24" FontSize="16"/>
                                                </ui:Button>
                                                <ui:Button Appearance="Transparent" ToolTip="일정" Padding="4">
                                                    <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="16"/>
                                                </ui:Button>
                                                <ui:Button Appearance="Transparent" ToolTip="첨부" Padding="4">
                                                    <ui:SymbolIcon Symbol="Attach24" FontSize="16"/>
                                                </ui:Button>
                                                <ui:Button Appearance="Transparent" ToolTip="더보기" Padding="4">
                                                    <ui:SymbolIcon Symbol="Add24" FontSize="16"/>
                                                </ui:Button>
                                            </StackPanel>

                                            <!-- 오른쪽: 전송 버튼 -->
                                            <ui:Button x:Name="ChatSendButton" Grid.Column="1"
                                                       AutomationProperties.AutomationId="ChatSendButton"
                                                       Appearance="Primary" Padding="8,4"
                                                       Click="ChatSendButton_Click" ToolTip="전송 (Enter)">
                                                <ui:SymbolIcon Symbol="Send24" FontSize="16"/>
                                            </ui:Button>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- 메시지 로딩 오버레이 -->
                        <Border x:Name="ChatMessagesLoadingOverlay" Grid.Row="1" Visibility="Collapsed"
                                Background="{DynamicResource ApplicationBackgroundBrush}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:ProgressRing IsIndeterminate="True" Width="32" Height="32"/>
                                <TextBlock Text="메시지 로딩 중..." FontSize="12" Margin="0,8,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== 팀 뷰 컨테이너 (Column 1-5 전체 사용, 초기에는 숨김) ========== -->
        <Border x:Name="TeamsViewBorder"
                Grid.Column="1" Grid.ColumnSpan="5"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
                    <!-- GridSplitter -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측 패널: 팀/채널 트리 -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="PeopleTeam24" FontSize="20" Margin="0,0,8,0" Foreground="{StaticResource TeamsAccentBrush}"/>
                                    <TextBlock Text="팀" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ui:Button Grid.Column="1" x:Name="TeamsRefreshButton"
                                           Icon="{ui:SymbolIcon ArrowSync24}"
                                           Appearance="Transparent" Padding="6"
                                           ToolTip="새로고침"
                                           Click="TeamsRefreshButton_Click"/>
                            </Grid>
                        </Border>

                        <!-- 팀 목록 (스크롤) -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- 바로가기 섹션 -->
                                <StackPanel Margin="8,8,8,0">
                                    <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Alert24" FontSize="16" Margin="0,0,8,0" Foreground="{StaticResource TeamsAccentBrush}"/>
                                            <TextBlock Text="읽지 않음" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Search24" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="검색" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Mention24" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="멘션" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:Button>
                                    <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Padding="8,6">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Pin24" FontSize="16" Margin="0,0,8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="팔로우한 스레드" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ui:Button>
                                </StackPanel>

                                <!-- 즐겨찾기 섹션 (Expander) -->
                                <Expander IsExpanded="True" Margin="8,12,8,0">
                                    <Expander.Header>
                                        <TextBlock Text="즐겨찾기" FontWeight="SemiBold" FontSize="13"/>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding FavoriteChannels}" Margin="0,4,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ui:Button Appearance="Transparent"
                                                           HorizontalAlignment="Stretch"
                                                           HorizontalContentAlignment="Left"
                                                           Padding="8,6"
                                                           Click="FavoriteChannelItem_Click"
                                                           Tag="{Binding}">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <TextBlock Text="#" FontSize="14" Margin="0,0,4,0" Foreground="{StaticResource TeamsAccentBrush}"/>
                                                            <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="{Binding LastActivityDisplay}"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   FontSize="11" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </ui:Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>

                                <!-- Teams 및 채널 섹션 (Expander) -->
                                <Expander IsExpanded="True" Margin="8,8,8,0">
                                    <Expander.Header>
                                        <TextBlock Text="Teams 및 채널" FontWeight="SemiBold" FontSize="13"/>
                                    </Expander.Header>
                                    <StackPanel>
                                        <!-- 팀이 없을 때 메시지 표시 -->
                                        <Border Visibility="{Binding HasTeams, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
                                                Margin="4,8" Padding="12" CornerRadius="8"
                                                Background="{DynamicResource SystemFillColorCautionBackgroundBrush}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding NoTeamsMessage}" FontSize="12" TextWrapping="Wrap"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- 팀 목록 -->
                                        <ItemsControl x:Name="TeamsListView" ItemsSource="{Binding Teams}" Margin="0,4,0,0"
                                                      Visibility="{Binding HasTeams, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,2,0,0">
                                                    <!-- 팀 헤더 -->
                                                    <ui:Button Appearance="Transparent"
                                                               HorizontalAlignment="Stretch"
                                                               HorizontalContentAlignment="Left"
                                                               Padding="8,6"
                                                               Click="TeamItem_Click"
                                                               Tag="{Binding}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10" Margin="0,0,6,0"
                                                                           Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                            <ui:SymbolIcon Symbol="ChevronRight24" FontSize="10" Margin="0,0,6,0"
                                                                           Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                            <Border Width="20" Height="20" CornerRadius="4"
                                                                    Background="{StaticResource TeamsAccentBrush}" Margin="0,0,6,0">
                                                                <TextBlock Text="{Binding DisplayName, Converter={StaticResource StringToInitialConverter}}"
                                                                           Foreground="White" FontSize="10" FontWeight="SemiBold"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </ui:Button>
                                                    <!-- 채널 목록 -->
                                                    <ItemsControl ItemsSource="{Binding Channels}"
                                                                  Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                  Margin="32,0,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <ui:Button Appearance="Transparent"
                                                                           HorizontalAlignment="Stretch"
                                                                           HorizontalContentAlignment="Left"
                                                                           Padding="8,5"
                                                                           Click="ChannelItem_Click"
                                                                           Tag="{Binding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="#" FontSize="12" Margin="0,0,4,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                        <TextBlock Text="{Binding DisplayName}" FontSize="13" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </ui:Button>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- GridSplitter (팀) -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- 우측 패널: 채널 콘텐츠 -->
                <Border Grid.Column="2">
                    <Grid>
                        <!-- 채널 미선택 시 플레이스홀더 -->
                        <StackPanel x:Name="TeamsPlaceholder" VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="{Binding HasSelectedChannel, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                            <ui:SymbolIcon Symbol="PeopleTeam24" FontSize="64" Foreground="{StaticResource TeamsAccentBrush}" Margin="0,0,0,16"/>
                            <TextBlock Text="팀 채널을 선택하세요" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                            <TextBlock Text="좌측에서 팀과 채널을 선택하면 대화가 표시됩니다" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- 채널 선택 시 콘텐츠 -->
                        <Grid Visibility="{Binding HasSelectedChannel, Converter={StaticResource BoolToVisibilityConverter}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 채널 헤더 -->
                            <Border Grid.Row="0" Padding="16,12"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="#" FontSize="18" Margin="0,0,6,0" Foreground="{StaticResource TeamsAccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding SelectedChannel.DisplayName}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <ui:Button Icon="{ui:SymbolIcon Call24}" Appearance="Transparent" Padding="6" ToolTip="통화 시작" Margin="0,0,4,0"/>
                                        <ui:Button Icon="{ui:SymbolIcon Video24}" Appearance="Transparent" Padding="6" ToolTip="모임 시작" Margin="0,0,4,0"/>
                                        <ui:Button Icon="{ui:SymbolIcon MoreHorizontal24}" Appearance="Transparent" Padding="6" ToolTip="더 보기"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 탭 바 -->
                            <Border Grid.Row="1" Padding="16,8"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <ui:Button x:Name="TeamsPostsTabButton" Content="게시물" Padding="12,6" Margin="0,0,8,0"
                                               Appearance="{Binding CurrentChannelTab, Converter={StaticResource SortByToAppearanceConverter}, ConverterParameter=posts}"
                                               Click="TeamsPostsTab_Click"/>
                                    <ui:Button x:Name="TeamsFilesTabButton" Content="파일" Padding="12,6"
                                               Appearance="{Binding CurrentChannelTab, Converter={StaticResource SortByToAppearanceConverter}, ConverterParameter=files}"
                                               Click="TeamsFilesTab_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- 게시물 탭 -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding CurrentChannelTab, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=posts}">
                                <ItemsControl ItemsSource="{Binding ChannelMessages}" Margin="16">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,12" Padding="14"
                                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="44"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 아바타 (사용자별 색상) -->
                                                    <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                                            Background="{Binding FromUser, Converter={StaticResource NameToAvatarColorConverter}}" VerticalAlignment="Top">
                                                        <TextBlock Text="{Binding FromUser, Converter={StaticResource StringToInitialConverter}}"
                                                                   Foreground="White" FontWeight="SemiBold" FontSize="15"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <!-- 메시지 내용 -->
                                                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                            <!-- 온라인 상태 표시 -->
                                                            <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding FromUser}" FontWeight="SemiBold" FontSize="14"/>
                                                            <TextBlock Text="{Binding ChannelTimeDisplay}" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                        <!-- 메시지 본문 -->
                                                        <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"/>
                                                        <!-- 스레드에서 회신 버튼 -->
                                                        <ui:Button Appearance="Transparent" Padding="6,4" Margin="0,4,0,0"
                                                                   Click="ReplyToThread_Click" Tag="{Binding}"
                                                                   HorizontalAlignment="Left">
                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon Symbol="ChatMultiple24" FontSize="14" Margin="0,0,6,0" Foreground="{StaticResource TeamsAccentBrush}"/>
                                                                <TextBlock Text="스레드에서 회신" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                            </StackPanel>
                                                        </ui:Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- 파일 탭 -->
                            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                                          Visibility="{Binding CurrentChannelTab, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=files}">
                                <ItemsControl ItemsSource="{Binding ChannelFiles}" Margin="16">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch"
                                                       HorizontalContentAlignment="Left" Padding="12,8" Margin="0,0,0,4"
                                                       Click="ChannelFile_Click" Tag="{Binding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="36"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="100"/>
                                                    </Grid.ColumnDefinitions>
                                                    <ui:SymbolIcon Grid.Column="0" Symbol="{Binding FileIcon}" FontSize="20"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                    <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                                    <TextBlock Grid.Column="3" Text="{Binding LastModified, StringFormat='{}{0:MM/dd HH:mm}'}" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="12"/>
                                                </Grid>
                                            </ui:Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <!-- 메시지 입력 영역 -->
                            <Border Grid.Row="3" Padding="16,12"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Visibility="{Binding CurrentChannelTab, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=posts}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ui:TextBox x:Name="TeamsChannelMessageInput" Grid.Column="0"
                                                PlaceholderText="메시지를 입력하세요..."
                                                Margin="0,0,8,0"
                                                KeyDown="TeamsChannelMessageInput_KeyDown"/>
                                    <ui:Button Grid.Column="1" x:Name="TeamsChannelSendButton"
                                               Icon="{ui:SymbolIcon Send24}"
                                               Appearance="Primary"
                                               Click="TeamsChannelSendButton_Click"
                                               ToolTip="전송"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ========== 활동 뷰 컨테이너 (Column 1-5 전체 사용, 초기에는 숨김) ========== -->
        <Border x:Name="ActivityViewBorder"
                Grid.Column="1" Grid.ColumnSpan="5"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Border Grid.Row="0" Padding="16,12"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Alert24" FontSize="20" Margin="0,0,8,0" Foreground="{StaticResource ActivityAccentBrush}"/>
                            <TextBlock Text="활동" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ui:Button Grid.Column="1" x:Name="ActivityRefreshButton"
                                   Icon="{ui:SymbolIcon ArrowSync24}"
                                   Appearance="Transparent" Padding="6"
                                   ToolTip="새로고침"
                                   Click="ActivityRefreshButton_Click"/>
                    </Grid>
                </Border>

                <!-- 필터 바 -->
                <Border Grid.Row="1" Padding="16,8"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <ui:Button x:Name="ActivityFilterAllButton" Content="모든 활동"
                                   Appearance="Secondary" Margin="0,0,8,0"
                                   Click="ActivityFilterAllButton_Click"/>
                        <ui:Button x:Name="ActivityFilterMailButton" Content="메일"
                                   Icon="{ui:SymbolIcon Mail24}"
                                   Appearance="Transparent" Margin="0,0,8,0"
                                   Click="ActivityFilterMailButton_Click"/>
                        <ui:Button x:Name="ActivityFilterChatButton" Content="채팅"
                                   Icon="{ui:SymbolIcon Chat24}"
                                   Appearance="Transparent" Margin="0,0,8,0"
                                   Click="ActivityFilterChatButton_Click"/>
                        <ui:Button x:Name="ActivityFilterFileButton" Content="파일"
                                   Icon="{ui:SymbolIcon Document24}"
                                   Appearance="Transparent"
                                   Click="ActivityFilterFileButton_Click"/>
                    </StackPanel>
                </Border>

                <!-- 활동 피드 목록 -->
                <Grid Grid.Row="2">
                    <ListView x:Name="ActivityListView"
                              Background="Transparent" BorderThickness="0"
                              Padding="8"
                              SelectionChanged="ActivityListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,2"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        CornerRadius="6"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 타입 아이콘 -->
                                        <Border Grid.Column="0" Width="40" Height="40"
                                                CornerRadius="20" Margin="0,0,12,0"
                                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                                            <ui:SymbolIcon Symbol="Alert24" FontSize="20"
                                                           Foreground="{StaticResource ActivityAccentBrush}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- 내용 -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Description}" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <!-- 시간 -->
                                        <TextBlock Grid.Column="2" Text="{Binding TimestampDisplay}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   VerticalAlignment="Top" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- 빈 상태 표시 -->
                    <StackPanel x:Name="ActivityEmptyState"
                                VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Collapsed">
                        <ui:SymbolIcon Symbol="Alert24" FontSize="64"
                                       Foreground="{StaticResource ActivityAccentBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="활동 피드" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="최근 활동이 없습니다" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <ui:Button x:Name="ActivityLoadButton" Content="활동 로드" Margin="0,16,0,0"
                                   Appearance="Secondary" Click="ActivityLoadButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== 플래너 뷰 컨테이너 (Column 1-7 전체 사용, AI 패널 포함, 초기에는 숨김) ========== -->
        <Border x:Name="PlannerViewBorder"
                Grid.Column="1" Grid.ColumnSpan="7"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                Focusable="True"
                KeyDown="PlannerView_KeyDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
                    <!-- GridSplitter -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ========== 좌측 패널: Outlook 스타일 사이드바 ========== -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="TaskListSquareLtr24" FontSize="20" Margin="0,0,8,0" Foreground="{StaticResource PlannerAccentBrush}"/>
                                    <TextBlock Text="플래너" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ui:Button Grid.Column="1" x:Name="PlannerRefreshButton"
                                           Icon="{ui:SymbolIcon ArrowSync24}"
                                           Appearance="Transparent" Padding="6"
                                           ToolTip="새로고침"
                                           Click="PlannerRefreshButton_Click"/>
                            </Grid>
                        </Border>

                        <!-- 사이드바 컨텐츠 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="8">
                                <!-- 나의 하루 -->
                                <ui:Button x:Name="PlannerMyDayButton"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Appearance="Transparent" Padding="12,10"
                                           Margin="0,0,0,4"
                                           Click="PlannerMyDayButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="CalendarDay24" FontSize="20" Margin="0,0,12,0"
                                                       Foreground="{StaticResource PlannerAccentBrush}"/>
                                        <TextBlock Text="나의 하루" VerticalAlignment="Center" FontSize="14"/>
                                    </StackPanel>
                                </ui:Button>

                                <!-- 내 작업 -->
                                <ui:Button x:Name="PlannerMyTasksButton"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Appearance="Transparent" Padding="12,10"
                                           Margin="0,0,0,4"
                                           Click="PlannerMyTasksButton_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Person24" FontSize="20" Margin="0,0,12,0"
                                                       Foreground="#0078D4"/>
                                        <TextBlock Text="내 작업" VerticalAlignment="Center" FontSize="14"/>
                                    </StackPanel>
                                </ui:Button>

                                <!-- 구분선 -->
                                <Separator Margin="0,12,0,12"/>

                                <!-- 고정 섹션 -->
                                <Expander x:Name="PlannerPinnedExpander" IsExpanded="True" Margin="0,0,0,8"
                                          Visibility="Collapsed">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Pin24" FontSize="16" Margin="0,0,8,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="고정" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <ListBox x:Name="PlannerPinnedPlansItemsControl"
                                             Background="Transparent" BorderThickness="0"
                                             SelectionChanged="PlannerPinnedPlanItem_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                <Setter Property="Padding" Value="12,8"/>
                                                <Setter Property="Margin" Value="0,0,0,2"/>
                                                <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <ui:SymbolIcon Symbol="Board24" FontSize="16" Margin="0,0,10,0"
                                                                       Foreground="{StaticResource PlannerAccentBrush}"/>
                                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="13"/>
                                                    </StackPanel>
                                                    <!-- 핀 버튼: 고정 섹션에서는 항상 표시 (해제용) -->
                                                    <ui:Button Grid.Column="1"
                                                               Width="24" Height="24" Padding="0"
                                                               Appearance="Transparent"
                                                               VerticalAlignment="Center"
                                                               Tag="{Binding}"
                                                               Click="PlannerPinButton_Click">
                                                        <ui:SymbolIcon Symbol="PinOff24" FontSize="14"
                                                                       Foreground="{StaticResource PlannerAccentBrush}"/>
                                                    </ui:Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Expander>

                                <!-- 내 플랜 -->
                                <Expander IsExpanded="True">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Board24" FontSize="16" Margin="0,0,8,0"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            <TextBlock Text="내 플랜" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <Grid Margin="0,8,0,0">
                                        <ListBox x:Name="PlannerListBox"
                                                 Background="Transparent" BorderThickness="0"
                                                 SelectionChanged="PlannerListBox_SelectionChanged">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                                    <Setter Property="Padding" Value="12,8"/>
                                                    <Setter Property="Margin" Value="0,0,0,2"/>
                                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid x:Name="PlanItemGrid">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                            <ui:SymbolIcon Symbol="Board24" FontSize="16" Margin="0,0,10,0"
                                                                           Foreground="{StaticResource PlannerAccentBrush}"/>
                                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center" FontSize="13"/>
                                                        </StackPanel>
                                                        <!-- 핀 버튼: 마우스 오버 시 표시, 핀 고정된 경우 항상 표시 -->
                                                        <ui:Button x:Name="PinButton" Grid.Column="1"
                                                                   Width="24" Height="24" Padding="0"
                                                                   Appearance="Transparent"
                                                                   VerticalAlignment="Center"
                                                                   Tag="{Binding}"
                                                                   Click="PlannerPinButton_Click">
                                                            <ui:Button.Style>
                                                                <Style TargetType="ui:Button" BasedOn="{StaticResource {x:Type ui:Button}}">
                                                                    <Setter Property="Visibility" Value="Hidden"/>
                                                                    <Style.Triggers>
                                                                        <!-- 핀 고정된 경우 항상 표시 -->
                                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                        <!-- 마우스 오버 시 표시 -->
                                                                        <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </ui:Button.Style>
                                                            <ui:SymbolIcon FontSize="14">
                                                                <ui:SymbolIcon.Style>
                                                                    <Style TargetType="ui:SymbolIcon">
                                                                        <Setter Property="Symbol" Value="Pin24"/>
                                                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                                <Setter Property="Symbol" Value="PinOff24"/>
                                                                                <Setter Property="Foreground" Value="{StaticResource PlannerAccentBrush}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </ui:SymbolIcon.Style>
                                                            </ui:SymbolIcon>
                                                        </ui:Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- 플랜 없음 표시 -->
                                        <StackPanel x:Name="PlannerEmptyState"
                                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                                    Visibility="Collapsed">
                                            <ui:SymbolIcon Symbol="TaskListSquareLtr24" FontSize="32"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
                                            <TextBlock Text="플랜이 없습니다" FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       HorizontalAlignment="Center"/>
                                            <ui:Button x:Name="PlannerLoadPlansButton" Content="플랜 로드" Margin="0,12,0,0"
                                                       Appearance="Secondary" Click="PlannerLoadPlansButton_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- GridSplitter (플래너) -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- ========== 우측 패널: 칸반 보드 ========== -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 보드 헤더 -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock x:Name="PlannerBoardTitle" Text="플랜을 선택하세요"
                                           FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- 툴바 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button x:Name="PlannerAddBucketButton"
                                           Content="버킷 추가" Icon="{ui:SymbolIcon Add24}"
                                           Appearance="Transparent" Margin="0,0,8,0"
                                           IsEnabled="False"
                                           Click="PlannerAddBucketButton_Click"/>
                                <ui:Button x:Name="PlannerAddTaskButton"
                                           Content="작업 추가" Icon="{ui:SymbolIcon TaskListAdd24}"
                                           Appearance="Primary"
                                           IsEnabled="False"
                                           Click="PlannerAddTaskButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 칸반 보드 영역 -->
                    <ScrollViewer Grid.Row="1" x:Name="PlannerBoardScrollViewer"
                                  HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="PlannerBoardScrollViewer_PreviewMouseWheel">
                        <ItemsControl x:Name="PlannerBucketsItemsControl">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="16"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- 버킷 컬럼 -->
                                    <Border Width="300" Margin="0,0,16,0"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="8" Padding="12"
                                            AllowDrop="True"
                                            Tag="{Binding}"
                                            DragEnter="PlannerBucket_DragEnter"
                                            DragLeave="PlannerBucket_DragLeave"
                                            Drop="PlannerBucket_Drop">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- 버킷 헤더 -->
                                            <Border Grid.Row="0" Margin="0,0,0,12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                                        <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                                CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                                            <TextBlock Text="{Binding Tasks.Count}" FontSize="12"
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                    <ui:Button Grid.Column="1"
                                                               Icon="{ui:SymbolIcon MoreHorizontal24}"
                                                               Appearance="Transparent" Padding="4"
                                                               Tag="{Binding}"
                                                               Click="PlannerBucketMenu_Click"/>
                                                </Grid>
                                            </Border>

                                            <!-- 작업 목록 (스크롤 가능, 전체 높이 사용) -->
                                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                                                <ItemsControl ItemsSource="{Binding Tasks}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <!-- 작업 카드 -->
                                                            <Border x:Name="TaskCardBorder"
                                                                    CornerRadius="8" Margin="0,0,0,8"
                                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                    BorderThickness="1"
                                                                    Cursor="Hand"
                                                                    Tag="{Binding}"
                                                                    PreviewMouseLeftButtonDown="PlannerTaskCard_PreviewMouseLeftButtonDown"
                                                                    PreviewMouseMove="PlannerTaskCard_PreviewMouseMove"
                                                                    MouseLeftButtonUp="PlannerTaskCard_MouseLeftButtonUp">
                                                                <!-- 우클릭 컨텍스트 메뉴 -->
                                                                <Border.ContextMenu>
                                                                    <ContextMenu>
                                                                        <MenuItem Header="열기" Click="PlannerTaskContextMenu_Open_Click"/>
                                                                        <Separator/>
                                                                        <MenuItem Header="완료로 표시" Click="PlannerTaskContextMenu_Complete_Click"/>
                                                                        <Separator/>
                                                                        <MenuItem Header="삭제" Click="PlannerTaskContextMenu_Delete_Click"
                                                                                  InputGestureText="Delete"
                                                                                  Foreground="#D13438"/>
                                                                    </ContextMenu>
                                                                </Border.ContextMenu>
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
                                                                        <Style.Triggers>
                                                                            <!-- 마우스 오버 시 배경색 변화 -->
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                                            </Trigger>
                                                                            <!-- 선택 상태일 때 배경색 - 더 명확한 색상 -->
                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                <Setter Property="Background" Value="#2D5016"/>
                                                                                <Setter Property="BorderBrush" Value="{StaticResource PlannerAccentBrush}"/>
                                                                                <Setter Property="BorderThickness" Value="2"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <Grid Margin="12">
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                        <RowDefinition Height="Auto"/>
                                                                    </Grid.RowDefinitions>

                                                                    <!-- Row 0: 라벨 태그들 (Outlook 스타일 텍스트 배지) -->
                                                                    <ItemsControl Grid.Row="0" ItemsSource="{Binding AppliedCategories}"
                                                                                  Visibility="{Binding HasCategories, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                                  Margin="0,0,0,8">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel Orientation="Horizontal"/>
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border CornerRadius="4" Padding="8,3"
                                                                                        Background="{Binding ColorBrush}"
                                                                                        Margin="0,0,6,4">
                                                                                    <TextBlock Text="{Binding Name}"
                                                                                               FontSize="11" FontWeight="Medium"
                                                                                               Foreground="White"/>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>

                                                                    <!-- Row 1: 작업 제목 -->
                                                                    <TextBlock Grid.Row="1" Text="{Binding Title}"
                                                                               FontSize="13" TextWrapping="Wrap"
                                                                               TextDecorations="{Binding IsComplete, Converter={StaticResource BoolToStrikethroughConverter}}"/>

                                                                    <!-- Row 2: 진행률 바 -->
                                                                    <ProgressBar Grid.Row="2" Value="{Binding PercentComplete}"
                                                                                 Maximum="100" Height="4" Margin="0,8,0,0"
                                                                                 Visibility="{Binding PercentComplete, Converter={StaticResource IntToVisibilityConverter}}"/>

                                                                    <!-- Row 3: 메타 정보 (마감일 + 담당자) -->
                                                                    <Grid Grid.Row="3" Margin="0,8,0,0">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>

                                                                        <!-- 좌측: 기한, 체크리스트 -->
                                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <!-- 기한 (Outlook 스타일) -->
                                                                            <StackPanel Orientation="Horizontal" Margin="0,0,8,0"
                                                                                        Visibility="{Binding DueDateTime, Converter={StaticResource NullToVisibilityConverter}}">
                                                                                <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="14"
                                                                                               Foreground="{Binding DueStatus, Converter={StaticResource DueStatusToForegroundConverter}}"
                                                                                               Margin="0,0,4,0"/>
                                                                                <TextBlock Text="기한" FontSize="11"
                                                                                           Foreground="{Binding DueStatus, Converter={StaticResource DueStatusToForegroundConverter}}"/>
                                                                            </StackPanel>

                                                                            <!-- 체크리스트 -->
                                                                            <StackPanel Orientation="Horizontal"
                                                                                        Visibility="{Binding ChecklistItemCount, Converter={StaticResource IntToVisibilityConverter}}">
                                                                                <ui:SymbolIcon Symbol="CheckboxChecked24" FontSize="12" Margin="0,0,4,0"/>
                                                                                <TextBlock Text="{Binding ChecklistDisplay}" FontSize="11"/>
                                                                            </StackPanel>
                                                                        </StackPanel>

                                                                        <!-- 우측: 담당자 아바타들 (겹침 스타일) -->
                                                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding Assignees}"
                                                                                      Visibility="{Binding HasAssignees, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                            <ItemsControl.ItemsPanel>
                                                                                <ItemsPanelTemplate>
                                                                                    <StackPanel Orientation="Horizontal"/>
                                                                                </ItemsPanelTemplate>
                                                                            </ItemsControl.ItemsPanel>
                                                                            <ItemsControl.ItemTemplate>
                                                                                <DataTemplate>
                                                                                    <Grid Width="24" Height="24" Margin="-6,0,0,0" ToolTip="{Binding DisplayName}">
                                                                                        <!-- 프로필 사진이 있는 경우 -->
                                                                                        <Border CornerRadius="12"
                                                                                                BorderBrush="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                                                                BorderThickness="2"
                                                                                                Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                                            <Border.Background>
                                                                                                <ImageBrush ImageSource="{Binding PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}}" Stretch="UniformToFill"/>
                                                                                            </Border.Background>
                                                                                        </Border>
                                                                                        <!-- 프로필 사진이 없는 경우 (이니셜) -->
                                                                                        <Border CornerRadius="12"
                                                                                                Background="{Binding AvatarColor}"
                                                                                                BorderBrush="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                                                                                BorderThickness="2"
                                                                                                Visibility="{Binding HasPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                                                            <TextBlock Text="{Binding Initial}"
                                                                                                       FontSize="10" FontWeight="SemiBold"
                                                                                                       Foreground="White"
                                                                                                       HorizontalAlignment="Center"
                                                                                                       VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                    </Grid>
                                                                                </DataTemplate>
                                                                            </ItemsControl.ItemTemplate>
                                                                        </ItemsControl>
                                                                    </Grid>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>

                                            <!-- 작업 추가 버튼 -->
                                            <ui:Button Grid.Row="2"
                                                       HorizontalAlignment="Stretch"
                                                       HorizontalContentAlignment="Left"
                                                       Appearance="Transparent" Padding="8,6"
                                                       Margin="0,8,0,0"
                                                       Tag="{Binding}"
                                                       Click="PlannerBucketAddTask_Click">
                                                <StackPanel Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="Add24" FontSize="14" Margin="0,0,8,0"/>
                                                    <TextBlock Text="작업 추가" FontSize="13"/>
                                                </StackPanel>
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- 플랜 미선택 안내 -->
                    <StackPanel x:Name="PlannerNoPlanSelected" Grid.Row="1"
                                VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="TaskListSquareLtr24" FontSize="64"
                                       Foreground="{StaticResource PlannerAccentBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="플래너" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="좌측에서 플랜을 선택하세요" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"/>
                    </StackPanel>

                    <!-- 나의 하루 / 내 작업 뷰 (보드 대신 표시) -->
                    <Grid x:Name="PlannerMyTasksView" Grid.Row="1" Visibility="Collapsed">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 뷰 헤더 -->
                        <Border Grid.Row="0" Padding="16,12"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <TextBlock x:Name="PlannerMyTasksViewTitle" Text="내 작업"
                                       FontSize="18" FontWeight="SemiBold"/>
                        </Border>

                        <!-- 작업 목록 -->
                        <ListView Grid.Row="1" x:Name="PlannerMyTasksListView"
                                  SelectionMode="Single"
                                  SelectionChanged="PlannerMyTasksListView_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12,8" Margin="0,0,0,4"
                                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                            CornerRadius="6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 완료 체크박스 -->
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsComplete}"
                                                      Margin="0,0,12,0" VerticalAlignment="Center"
                                                      Click="PlannerMyTaskCheckBox_Click"/>

                                            <!-- 제목 및 정보 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Title}" FontSize="14"
                                                           TextDecorations="{Binding IsComplete, Converter={StaticResource BoolToStrikethroughConverter}}"/>
                                                <TextBlock Text="{Binding DueDateDisplay}" FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           Visibility="{Binding DueDateTime, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            </StackPanel>

                                            <!-- 우선순위 -->
                                            <Border Grid.Column="2" CornerRadius="3" Padding="8,4"
                                                    Background="{Binding PriorityColor}"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PriorityDisplay}" FontSize="11"
                                                           Foreground="White"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== OneDrive 뷰 컨테이너 (Column 1-5 전체 사용, 초기에는 숨김) ========== -->
        <!-- Teams 스타일 OneDrive UI - 좌측 사이드바 + 우측 콘텐츠 영역 -->
        <Border x:Name="OneDriveViewBorder"
                Grid.Column="1" Grid.ColumnSpan="5"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- 좌측 사이드바 -->
                    <ColumnDefinition Width="220" MinWidth="180" MaxWidth="350"/>
                    <!-- GridSplitter -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- 우측 콘텐츠 영역 -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ===== 좌측 사이드바 ===== -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,1,0"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Row 0: 네비게이션 메뉴 -->
                        <Border Grid.Row="0" Padding="8,12,8,0">
                            <StackPanel>
                                <!-- 홈 -->
                                <ui:Button x:Name="OneDriveNavHome"
                                           Content="홈"
                                           Icon="{ui:SymbolIcon Home20}"
                                           Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Padding="12,8"
                                           Click="OneDriveNav_Click"
                                           Tag="home"/>
                                <!-- 공유됨 -->
                                <ui:Button x:Name="OneDriveNavShared"
                                           Content="공유됨"
                                           Icon="{ui:SymbolIcon People20}"
                                           Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Padding="12,8"
                                           Click="OneDriveNav_Click"
                                           Tag="shared"/>
                                <!-- 즐겨찾기 -->
                                <ui:Button x:Name="OneDriveNavFavorites"
                                           Content="즐겨찾기"
                                           Icon="{ui:SymbolIcon Star20}"
                                           Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Padding="12,8"
                                           Click="OneDriveNav_Click"
                                           Tag="favorites"/>
                                <!-- 휴지통 -->
                                <ui:Button x:Name="OneDriveNavTrash"
                                           Content="휴지통"
                                           Icon="{ui:SymbolIcon Delete20}"
                                           Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Padding="12,8"
                                           Click="OneDriveNav_Click"
                                           Tag="trash"/>

                                <!-- 구분선 -->
                                <Separator Margin="4,12,4,8"/>

                                <!-- 내 파일 (루트 폴더 - 클릭 가능) -->
                                <ui:Button x:Name="OneDriveNavMyFiles"
                                           Content="내 파일"
                                           Icon="{ui:SymbolIcon Folder20}"
                                           Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Padding="12,6"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Click="OneDriveNav_Click"
                                           Tag="myfiles"/>
                            </StackPanel>
                        </Border>

                        <!-- Row 1: 폴더 트리 (ScrollViewer) -->
                        <Border Grid.Row="1" Padding="8,0,8,8">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <TreeView x:Name="OneDriveFolderTree"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Padding="0"
                                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                          SelectedItemChanged="OneDriveFolderTree_SelectedItemChanged">
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="Padding" Value="4,2"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                            <EventSetter Event="Expanded" Handler="OneDriveFolderTreeItem_Expanded"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.ItemTemplate>
                                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                            <StackPanel Orientation="Horizontal" Margin="2,4">
                                                <ui:SymbolIcon Symbol="Folder16" FontSize="16"
                                                               Foreground="#FFB900" Margin="0,0,8,0"/>
                                                <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            </StackPanel>
                                        </HierarchicalDataTemplate>
                                    </TreeView.ItemTemplate>
                                </TreeView>
                            </ScrollViewer>
                        </Border>

                        <!-- Row 2: 드라이브 용량 정보 -->
                        <Border Grid.Row="2" Padding="16,8,16,16">
                            <StackPanel x:Name="OneDriveDriveInfoPanel" Visibility="Collapsed">
                                <TextBlock Text="저장소" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,8"/>
                                <ProgressBar x:Name="OneDriveStorageBar"
                                             Height="4" Minimum="0" Maximum="100"
                                             Foreground="{StaticResource OneDriveAccentBrush}"/>
                                <TextBlock x:Name="OneDriveStorageText"
                                           FontSize="11" Margin="0,6,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- GridSplitter (OneDrive) -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- ===== 우측 콘텐츠 영역 ===== -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: 상단 헤더 (경로 + 액션 버튼) -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Breadcrumb 경로 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ui:Button x:Name="OneDriveGoUpButton" Icon="{ui:SymbolIcon ArrowUp20}"
                                           Appearance="Transparent" Padding="6" Margin="0,0,8,0"
                                           ToolTip="상위 폴더" Click="OneDriveGoUpButton_Click"/>
                                <ItemsControl x:Name="OneDriveBreadcrumb">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <ui:Button Content="{Binding Name}" Appearance="Transparent"
                                                           Foreground="{StaticResource OneDriveAccentBrush}"
                                                           Padding="4,2" FontSize="14"
                                                           Click="OneDriveBreadcrumbItem_Click"
                                                           Tag="{Binding}"/>
                                                <TextBlock Text="›" VerticalAlignment="Center" Margin="4,0"
                                                           FontSize="14"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            
                            <!-- 액션 버튼들 -->
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <ui:Button x:Name="OneDriveNewFolderButton" Icon="{ui:SymbolIcon FolderAdd20}"
                                           Content="새 폴더" Appearance="Transparent" Margin="0,0,4,0"
                                           Click="OneDriveNewFolderButton_Click"/>
                                <ui:Button x:Name="OneDriveUploadButton" Icon="{ui:SymbolIcon ArrowUpload20}"
                                           Content="업로드" Appearance="Transparent" Margin="0,0,4,0"
                                           Click="OneDriveUploadButton_Click"/>
                                <ui:Button x:Name="OneDriveRefreshButton" Icon="{ui:SymbolIcon ArrowSync20}"
                                           Appearance="Transparent" ToolTip="새로고침"
                                           Click="OneDriveRefreshButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 1: 필터 탭 바 -->
                    <Border Grid.Row="1" Padding="16,8"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- 파일 타입 필터 -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <ui:Button x:Name="OneDriveFilterAll"
                                           Content="모두" Appearance="Secondary"
                                           Padding="12,6" Margin="0,0,4,0"
                                           Click="OneDriveFilter_Click" Tag="all"/>
                                <ui:Button x:Name="OneDriveFilterWord"
                                           Icon="{ui:SymbolIcon DocumentText20}"
                                           Content="Word" Appearance="Transparent"
                                           Padding="12,6" Margin="0,0,4,0"
                                           Click="OneDriveFilter_Click" Tag="word"/>
                                <ui:Button x:Name="OneDriveFilterExcel"
                                           Icon="{ui:SymbolIcon TableSimple20}"
                                           Content="Excel" Appearance="Transparent"
                                           Padding="12,6" Margin="0,0,4,0"
                                           Click="OneDriveFilter_Click" Tag="excel"/>
                                <ui:Button x:Name="OneDriveFilterPowerPoint"
                                           Icon="{ui:SymbolIcon SlideText20}"
                                           Content="PowerPoint" Appearance="Transparent"
                                           Padding="12,6" Margin="0,0,4,0"
                                           Click="OneDriveFilter_Click" Tag="ppt"/>
                                <ui:Button x:Name="OneDriveFilterPdf"
                                           Icon="{ui:SymbolIcon Document20}"
                                           Content="PDF" Appearance="Transparent"
                                           Padding="12,6" Margin="0,0,4,0"
                                           Click="OneDriveFilter_Click" Tag="pdf"/>
                            </StackPanel>
                            
                            <!-- 뷰 모드 + 검색 -->
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button x:Name="OneDriveListViewButton" Icon="{ui:SymbolIcon List20}"
                                           ToolTip="목록 보기" Appearance="Secondary" Padding="8"
                                           Click="OneDriveListViewButton_Click"/>
                                <ui:Button x:Name="OneDriveGridViewButton" Icon="{ui:SymbolIcon Grid20}"
                                           ToolTip="그리드 보기" Appearance="Transparent" Padding="8" Margin="4,0,12,0"
                                           Click="OneDriveGridViewButton_Click"/>
                                <ui:TextBox x:Name="OneDriveSearchBox" PlaceholderText="파일 검색..."
                                            Icon="{ui:SymbolIcon Search20}" Width="220"
                                            KeyDown="OneDriveSearchBox_KeyDown"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Row 2: 컬럼 헤더 (정렬 가능) -->
                    <Border Grid.Row="2" Padding="16,8"
                            Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*" MinWidth="200"/>
                                <ColumnDefinition Width="140"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="이름" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="수정한 날짜" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="소유자" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="크기" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0"/>
                        </Grid>
                    </Border>

                    <!-- Row 3: 파일 목록 -->
                    <Grid Grid.Row="3">
                            <!-- 빈 상태 -->
                            <StackPanel x:Name="OneDriveEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:SymbolIcon Symbol="Cloud48" FontSize="64" Foreground="{StaticResource OneDriveAccentBrush}" Margin="0,0,0,20"/>
                                <TextBlock Text="OneDrive" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                <TextBlock Text="클라우드 파일을 관리하세요" FontSize="13"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                <ui:Button x:Name="OneDriveLoadFilesButton" Content="파일 로드"
                                           Icon="{ui:SymbolIcon ArrowSync20}" Appearance="Primary"
                                           Margin="0,20,0,0" Padding="20,10" Click="OneDriveLoadFilesButton_Click"/>
                            </StackPanel>

                            <!-- 파일 목록 (ListView) -->
                            <ListView x:Name="OneDriveFileListView" Visibility="Collapsed"
                                      SelectionMode="Single"
                                      SelectionChanged="OneDriveFileListView_SelectionChanged"
                                      MouseDoubleClick="OneDriveFileListView_MouseDoubleClick"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <!-- 컨텍스트 메뉴 (마우스 우클릭) - Teams 스타일 -->
                                <ListView.ContextMenu>
                                    <ContextMenu>
                                        <!-- 열기 (서브메뉴) -->
                                        <MenuItem Header="열기">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Open20"/>
                                            </MenuItem.Icon>
                                            <MenuItem Header="앱에서 열기" Click="OneDriveContext_OpenInApp_Click">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="AppGeneric20"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="브라우저에서 열기" Click="OneDriveContext_Open_Click">
                                                <MenuItem.Icon>
                                                    <ui:SymbolIcon Symbol="Globe20"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </MenuItem>
                                        <!-- 미리 보기 -->
                                        <MenuItem Header="미리 보기" Click="OneDriveContext_Preview_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Eye20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 공유 -->
                                        <MenuItem Header="공유" Click="OneDriveContext_Share_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Share20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 링크 복사 -->
                                        <MenuItem Header="링크 복사" Click="OneDriveContext_CopyLink_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Link20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 액세스 관리 -->
                                        <MenuItem Header="액세스 관리" Click="OneDriveContext_ManageAccess_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="PeopleSettings20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <!-- 삭제 -->
                                        <MenuItem Header="삭제" Click="OneDriveContext_Delete_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Delete20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 즐겨찾기 -->
                                        <MenuItem Header="즐겨찾기" Click="OneDriveContext_Favorite_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Star20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 바로 가기 추가 -->
                                        <MenuItem Header="바로 가기 추가" Click="OneDriveContext_AddShortcut_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Pin20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 다운로드 -->
                                        <MenuItem Header="다운로드" Click="OneDriveContext_Download_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="ArrowDownload20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 이름 바꾸기 -->
                                        <MenuItem Header="이름 바꾸기" Click="OneDriveContext_Rename_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Rename20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- OneDrive에서 열기 -->
                                        <MenuItem Header="OneDrive에서 열기" Click="OneDriveContext_OpenInOneDrive_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Cloud20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <!-- 다음으로 이동 -->
                                        <MenuItem Header="다음으로 이동" Click="OneDriveContext_MoveTo_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="FolderArrowRight20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 다음으로 복사 -->
                                        <MenuItem Header="다음으로 복사" Click="OneDriveContext_CopyTo_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Copy20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <Separator/>
                                        <!-- 버전 기록 -->
                                        <MenuItem Header="버전 기록" Click="OneDriveContext_VersionHistory_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="History20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                        <!-- 세부 정보 -->
                                        <MenuItem Header="세부 정보" Click="OneDriveContext_Properties_Click">
                                            <MenuItem.Icon>
                                                <ui:SymbolIcon Symbol="Info20"/>
                                            </MenuItem.Icon>
                                        </MenuItem>
                                    </ContextMenu>
                                </ListView.ContextMenu>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="Padding" Value="16,10"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                        <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListView.ItemContainerStyle>
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*" MinWidth="200"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="100"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 파일 타입 아이콘 -->
                                            <Grid Grid.Column="0" Width="32" Height="32">
                                                <ui:SymbolIcon Symbol="Folder24" FontSize="24"
                                                               Foreground="#FFB900"
                                                               Visibility="{Binding IsFolder, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <ui:SymbolIcon Symbol="Document24" FontSize="24"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               Visibility="{Binding IsFolder, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                            </Grid>

                                            <!-- 파일 이름 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Name}" FontSize="13"
                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>

                                            <!-- 수정 날짜 -->
                                            <TextBlock Grid.Column="2" Text="{Binding LastModifiedDisplay}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                            <!-- 소유자 -->
                                            <TextBlock Grid.Column="3" Text="{Binding OwnerDisplayName, FallbackValue=나}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>

                                            <!-- 크기 -->
                                            <TextBlock Grid.Column="4" Text="{Binding SizeDisplay}"
                                                       FontSize="12" VerticalAlignment="Center"
                                                       HorizontalAlignment="Right" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>

                            <!-- ========== 사람별 파일 뷰 (Teams 스타일) ========== -->
                            <ScrollViewer x:Name="OneDrivePeopleView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,16,16,16">
                                    <!-- 헤더 -->
                                    <Grid Margin="0,0,0,16">
                                        <TextBlock Text="사람" FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <ui:TextBox x:Name="OneDrivePeopleFilterBox"
                                                    PlaceholderText="사용자별 필터링"
                                                    Width="200" HorizontalAlignment="Right"
                                                    TextChanged="OneDrivePeopleFilter_TextChanged"/>
                                    </Grid>

                                    <!-- 사람별 파일 목록 -->
                                    <ItemsControl x:Name="OneDrivePeopleItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,16" Padding="0">
                                                    <StackPanel>
                                                        <!-- 사람 헤더 (프로필 + 이름) -->
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                            <Border Width="40" Height="40" CornerRadius="20"
                                                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                    Margin="0,0,12,0">
                                                                <TextBlock Text="{Binding PersonInitials}"
                                                                           FontSize="14" FontWeight="SemiBold"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Border>
                                                            <TextBlock Text="{Binding PersonName}" FontSize="15" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>

                                                        <!-- 파일 칩 목록 (가로 스크롤) -->
                                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                                            <ItemsControl ItemsSource="{Binding Files}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <StackPanel Orientation="Horizontal"/>
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                                CornerRadius="4" Padding="10,8" Margin="0,0,8,0"
                                                                                Cursor="Hand" MouseLeftButtonDown="OneDrivePeopleFile_Click">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <Border Width="24" Height="24" CornerRadius="2"
                                                                                        Background="{Binding IconBackground}" Margin="0,0,8,0">
                                                                                    <TextBlock Text="{Binding IconText}" FontSize="9" FontWeight="Bold"
                                                                                               Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                </Border>
                                                                                <TextBlock Text="{Binding Name}" FontSize="12"
                                                                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                                           VerticalAlignment="Center" MaxWidth="200" TextTrimming="CharacterEllipsis"/>
                                                                            </StackPanel>
                                                                        </Border>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </ScrollViewer>

                                                        <!-- +N개 더보기 버튼 -->
                                                        <ui:Button Content="{Binding MoreFilesText}"
                                                                   Visibility="{Binding HasMoreFiles, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                   Appearance="Transparent"
                                                                   Padding="8,4" Margin="0,8,0,0"
                                                                   Click="OneDrivePeopleMoreFiles_Click"
                                                                   Tag="{Binding PersonName}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ========== 모임별 파일 뷰 (Teams 스타일) ========== -->
                            <ScrollViewer x:Name="OneDriveMeetingsView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,16,16,16">
                                    <!-- 안내 배너 -->
                                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4" Padding="12" Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Info20" Foreground="{DynamicResource AccentFillColorDefaultBrush}" Margin="0,0,8,0"/>
                                            <TextBlock Text="모든 회의 모임이 여기에 있습니다! 이제 공유된 파일이 있는 모임을 찾을 수 있습니다."
                                                       FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- 필터 -->
                                    <Grid Margin="0,0,0,16">
                                        <TextBlock Text="지난 모임" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <ui:TextBox x:Name="OneDriveMeetingsFilterBox"
                                                    PlaceholderText="모임 이름별 필터링"
                                                    Width="200" HorizontalAlignment="Right"
                                                    TextChanged="OneDriveMeetingsFilter_TextChanged"/>
                                    </Grid>

                                    <!-- 모임별 파일 목록 -->
                                    <ItemsControl x:Name="OneDriveMeetingsItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                        CornerRadius="8" Margin="0,0,0,12" Padding="0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- 날짜/시간 영역 -->
                                                        <Border Grid.Column="0" Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                CornerRadius="8,0,0,8" Padding="12">
                                                            <StackPanel VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding MeetingTime}" FontSize="12"
                                                                           Foreground="White" Opacity="0.9"/>
                                                                <TextBlock Text="{Binding MeetingDate}" FontSize="14" FontWeight="SemiBold"
                                                                           Foreground="White"/>
                                                            </StackPanel>
                                                        </Border>

                                                        <!-- 모임 정보 + 파일 -->
                                                        <StackPanel Grid.Column="1" Margin="16,12">
                                                            <!-- 모임 제목 -->
                                                            <TextBlock Text="{Binding MeetingTitle}" FontSize="14" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                       Margin="0,0,0,4"/>

                                                            <!-- 참석자 아이콘들 -->
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                                <ItemsControl ItemsSource="{Binding Attendees}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Width="28" Height="28" CornerRadius="14"
                                                                                    Background="{DynamicResource AccentFillColorSecondaryBrush}"
                                                                                    Margin="-6,0,0,0" BorderThickness="2"
                                                                                    BorderBrush="{DynamicResource ControlFillColorDefaultBrush}">
                                                                                <TextBlock Text="{Binding Initials}" FontSize="10" FontWeight="SemiBold"
                                                                                           Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                                <TextBlock Text="{Binding MoreAttendeesText}"
                                                                           Visibility="{Binding HasMoreAttendees, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                           FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                                <TextBlock Text="{Binding OrganizerText}"
                                                                           FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                                                            </StackPanel>

                                                            <!-- 파일 칩들 -->
                                                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                                                <ItemsControl ItemsSource="{Binding Files}">
                                                                    <ItemsControl.ItemsPanel>
                                                                        <ItemsPanelTemplate>
                                                                            <StackPanel Orientation="Horizontal"/>
                                                                        </ItemsPanelTemplate>
                                                                    </ItemsControl.ItemsPanel>
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Border Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                                                                    CornerRadius="4" Padding="10,6" Margin="0,0,8,0"
                                                                                    Cursor="Hand" MouseLeftButtonDown="OneDriveMeetingFile_Click">
                                                                                <StackPanel Orientation="Horizontal">
                                                                                    <Border Width="20" Height="20" CornerRadius="2"
                                                                                            Background="{Binding IconBackground}" Margin="0,0,6,0">
                                                                                        <TextBlock Text="{Binding IconText}" FontSize="8" FontWeight="Bold"
                                                                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                                    </Border>
                                                                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                                               VerticalAlignment="Center" MaxWidth="180" TextTrimming="CharacterEllipsis"/>
                                                                                </StackPanel>
                                                                            </Border>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </ScrollViewer>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- ========== 미디어 갤러리 뷰 (Teams 스타일) ========== -->
                            <ScrollViewer x:Name="OneDriveMediaView" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="0,16,16,16">
                                    <!-- 헤더 + 툴바 -->
                                    <Grid Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="미디어" FontSize="18" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                            <ui:Button Icon="{ui:SymbolIcon GridDots20}" Appearance="Transparent" Padding="8" ToolTip="그리드 보기"/>
                                            <ui:Button Icon="{ui:SymbolIcon ArrowSort20}" Appearance="Transparent" Padding="8" ToolTip="정렬"/>
                                            <Slider x:Name="OneDriveMediaZoomSlider" Width="100" Minimum="80" Maximum="200" Value="120"
                                                    VerticalAlignment="Center" Margin="8,0,0,0" ToolTip="썸네일 크기"/>
                                        </StackPanel>
                                    </Grid>

                                    <!-- 모든 사진 섹션 -->
                                    <TextBlock Text="모든 사진" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Margin="0,0,0,12"/>

                                    <!-- 날짜별 그룹화된 미디어 -->
                                    <ItemsControl x:Name="OneDriveMediaItemsControl">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Margin="0,0,0,24">
                                                    <!-- 날짜 헤더 -->
                                                    <TextBlock Text="{Binding DateHeader}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                               Margin="0,0,0,12"/>

                                                    <!-- 썸네일 그리드 -->
                                                    <ItemsControl ItemsSource="{Binding Items}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel/>
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Width="120" Height="120" Margin="4"
                                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                        CornerRadius="4" Cursor="Hand"
                                                                        MouseLeftButtonDown="OneDriveMediaItem_Click"
                                                                        Tag="{Binding}">
                                                                    <Grid>
                                                                        <!-- 썸네일 이미지 또는 플레이스홀더 -->
                                                                        <Image Source="{Binding ThumbnailUrl, TargetNullValue={x:Null}}"
                                                                               Stretch="UniformToFill"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                        <!-- 이미지 없을 때 아이콘 표시 -->
                                                                        <ui:SymbolIcon Symbol="Image24" FontSize="32"
                                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                       Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                                        <!-- 파일명 오버레이 -->
                                                                        <Border VerticalAlignment="Bottom"
                                                                                Background="#80000000" Padding="6,4">
                                                                            <TextBlock Text="{Binding Name}" FontSize="10"
                                                                                       Foreground="White" TextTrimming="CharacterEllipsis"/>
                                                                        </Border>
                                                                        <!-- 비디오 아이콘 -->
                                                                        <ui:SymbolIcon Symbol="Play24" FontSize="24"
                                                                                       Foreground="White"
                                                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                                       Visibility="{Binding IsVideo, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                            <ui:SymbolIcon.Effect>
                                                                                <DropShadowEffect ShadowDepth="0" BlurRadius="4" Color="Black"/>
                                                                            </ui:SymbolIcon.Effect>
                                                                        </ui:SymbolIcon>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </ScrollViewer>

                        <!-- 로딩 인디케이터 -->
                        <Border x:Name="OneDriveLoadingOverlay" Visibility="Collapsed"
                                Background="{DynamicResource ApplicationBackgroundBrush}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                                <TextBlock Text="로딩 중..." FontSize="13"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- ========== 휴지통 뷰 (Teams 스타일) - Row 2~3 영역 덮음 ========== -->
                    <Border x:Name="OneDriveTrashView" Grid.Row="2" Grid.RowSpan="2"
                            Visibility="Collapsed"
                            Background="{DynamicResource ApplicationBackgroundBrush}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 헤더 -->
                            <Border Grid.Row="0" Padding="16,12"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,0,1">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Delete24" FontSize="20" Margin="0,0,10,0"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        <TextBlock Text="휴지통" FontSize="18" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <ui:Button x:Name="OneDriveTrashRestoreAllBtn" Content="모두 복원"
                                                   Appearance="Secondary" Margin="0,0,8,0"
                                                   Click="OneDriveTrashRestoreAll_Click"/>
                                        <ui:Button x:Name="OneDriveTrashEmptyBtn" Content="휴지통 비우기"
                                                   Appearance="Danger"
                                                   Click="OneDriveTrashEmpty_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 안내 메시지 -->
                            <Border Grid.Row="1" Padding="16,8"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <TextBlock Text="삭제된 항목은 93일 동안 휴지통에 보관됩니다. 이후 자동으로 영구 삭제됩니다."
                                           FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Border>

                            <!-- 휴지통 파일 목록 (Grid + GridSplitter 기반) -->
                            <Grid Grid.Row="2" x:Name="OneDriveTrashGrid">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 컬럼 헤더 -->
                                <Grid Grid.Row="0" Background="{DynamicResource ApplicationBackgroundBrush}"
                                      x:Name="OneDriveTrashHeaderGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*" MinWidth="150"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="2*" MinWidth="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="140" MinWidth="100"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="100" MinWidth="80"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="80" MinWidth="60"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="70"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="이름" Padding="8,8" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center"
                                                  Background="{DynamicResource ControlElevationBorderBrush}" Cursor="SizeWE"/>
                                    <TextBlock Grid.Column="2" Text="원래 위치" Padding="8,8" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <GridSplitter Grid.Column="3" Width="1" HorizontalAlignment="Center"
                                                  Background="{DynamicResource ControlElevationBorderBrush}" Cursor="SizeWE"/>
                                    <TextBlock Grid.Column="4" Text="삭제 날짜" Padding="8,8" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <GridSplitter Grid.Column="5" Width="1" HorizontalAlignment="Center"
                                                  Background="{DynamicResource ControlElevationBorderBrush}" Cursor="SizeWE"/>
                                    <TextBlock Grid.Column="6" Text="삭제한 사용자" Padding="8,8" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <GridSplitter Grid.Column="7" Width="1" HorizontalAlignment="Center"
                                                  Background="{DynamicResource ControlElevationBorderBrush}" Cursor="SizeWE"/>
                                    <TextBlock Grid.Column="8" Text="크기" Padding="8,8" VerticalAlignment="Center"
                                               FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <GridSplitter Grid.Column="9" Width="1" HorizontalAlignment="Center"
                                                  Background="{DynamicResource ControlElevationBorderBrush}" Cursor="SizeWE"/>
                                </Grid>

                                <!-- 데이터 행 목록 -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl x:Name="OneDriveTrashListView" ItemsSource="{Binding TrashItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border x:Name="RowBorder" Background="Transparent" MinHeight="32"
                                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                        BorderThickness="0,0,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="{Binding ColumnDefinitions[0].Width, ElementName=OneDriveTrashHeaderGrid}"/>
                                                            <ColumnDefinition Width="1"/>
                                                            <ColumnDefinition Width="{Binding ColumnDefinitions[2].Width, ElementName=OneDriveTrashHeaderGrid}"/>
                                                            <ColumnDefinition Width="1"/>
                                                            <ColumnDefinition Width="{Binding ColumnDefinitions[4].Width, ElementName=OneDriveTrashHeaderGrid}"/>
                                                            <ColumnDefinition Width="1"/>
                                                            <ColumnDefinition Width="{Binding ColumnDefinitions[6].Width, ElementName=OneDriveTrashHeaderGrid}"/>
                                                            <ColumnDefinition Width="1"/>
                                                            <ColumnDefinition Width="{Binding ColumnDefinitions[8].Width, ElementName=OneDriveTrashHeaderGrid}"/>
                                                            <ColumnDefinition Width="1"/>
                                                            <ColumnDefinition Width="70"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- 이름 -->
                                                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                                                            <Grid Width="20" Height="20" Margin="0,0,8,0">
                                                                <ui:SymbolIcon Symbol="Folder24" FontSize="16" Foreground="#FFB900"
                                                                               Visibility="{Binding IsFolder, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                <ui:SymbolIcon Symbol="Document24" FontSize="16"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                               Visibility="{Binding IsFolder, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                            </Grid>
                                                            <TextBlock Text="{Binding LeafName}" VerticalAlignment="Center"
                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <!-- 원래 위치 -->
                                                        <TextBlock Grid.Column="2" Text="{Binding DirName}" Margin="8,0"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <!-- 삭제 날짜 -->
                                                        <TextBlock Grid.Column="4" Text="{Binding DeletedDateDisplay}" Margin="8,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <!-- 삭제한 사용자 -->
                                                        <TextBlock Grid.Column="6" Text="{Binding DeletedByName}" Margin="8,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <!-- 크기 -->
                                                        <TextBlock Grid.Column="8" Text="{Binding SizeDisplay}" Margin="8,0"
                                                                   VerticalAlignment="Center" HorizontalAlignment="Right"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <!-- 액션 버튼 -->
                                                        <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Center" Margin="4,0">
                                                            <ui:Button ToolTip="복원" Appearance="Secondary"
                                                                       Padding="4" Margin="0,0,4,0"
                                                                       Tag="{Binding}"
                                                                       Click="OneDriveTrashRestore_Click">
                                                                <ui:SymbolIcon Symbol="ArrowUndo24" FontSize="14"/>
                                                            </ui:Button>
                                                            <ui:Button ToolTip="영구 삭제" Appearance="Danger"
                                                                       Padding="4"
                                                                       Tag="{Binding}"
                                                                       Click="OneDriveTrashDelete_Click">
                                                                <ui:SymbolIcon Symbol="Delete24" FontSize="14"/>
                                                            </ui:Button>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="RowBorder" Property="Background" Value="#19FFFFFF"/>
                                                    </Trigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>

                            <!-- 빈 상태 -->
                            <StackPanel x:Name="OneDriveTrashEmptyState" Grid.Row="2"
                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                        Visibility="{Binding TrashItems.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Invert}">
                                <ui:SymbolIcon Symbol="Delete24" FontSize="48"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center"/>
                                <TextBlock Text="휴지통이 비어 있습니다" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center" Margin="0,12,0,4"/>
                                <TextBlock Text="삭제된 파일이 여기에 표시됩니다"
                                           FontSize="13" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== OneNote 뷰 컨테이너 (Column 1-6 사용, AI 패널은 Column 7에서 표시) ========== -->
        <Border x:Name="OneNoteViewBorder"
                Grid.Column="1" Grid.ColumnSpan="6"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="280" MinWidth="200" MaxWidth="400"/>
                    <!-- GridSplitter -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측 패널: 노트북/섹션/페이지 탐색 (OneNote 스타일) -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더: OneNote 타이틀 및 액션 버튼 -->
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Notebook24" FontSize="24" Margin="0,0,10,0" Foreground="{StaticResource OneNoteAccentBrush}"/>
                                    <TextBlock Text="OneNote" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button x:Name="OneNoteRefreshButton" Icon="{ui:SymbolIcon ArrowSync24}"
                                               Appearance="Transparent" ToolTip="새로고침" Click="OneNoteRefreshButton_Click"
                                               Padding="6" Margin="0,0,4,0"/>
                                    <ui:Button x:Name="OneNoteAddSiteButton" Icon="{ui:SymbolIcon Globe24}"
                                               Appearance="Transparent" ToolTip="SharePoint 사이트 추가" Click="OneNoteAddSiteButton_Click"
                                               Padding="6" Margin="0,0,4,0"/>
                                    <ui:Button x:Name="OneNoteNewNotebookButton" Icon="{ui:SymbolIcon Add24}"
                                               Appearance="Transparent" ToolTip="새 노트북" Click="OneNoteNewNotebookButton_Click"
                                               Padding="6"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 검색 바 -->
                        <Border Grid.Row="1" Padding="12,8">
                            <ui:TextBox x:Name="OneNoteSearchBox" PlaceholderText="노트 검색..."
                                        Icon="{ui:SymbolIcon Search24}"
                                        KeyDown="OneNoteSearchBox_KeyDown"/>
                        </Border>

                        <!-- 노트북/섹션/페이지 트리뷰 -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel>
                                <!-- 검색 결과 패널 (즐겨찾기 위) -->
                                <Border x:Name="OneNoteSearchResultsPanel" Visibility="Collapsed" Margin="8,4"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="4">
                                    <StackPanel>
                                        <DockPanel Margin="8,6,8,2">
                                            <ui:SymbolIcon Symbol="Search24" FontSize="14" Margin="0,0,6,0"
                                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                            <ui:ProgressRing x:Name="OneNoteSearchProgressRing" IsIndeterminate="True"
                                                             Width="14" Height="14" Margin="0,0,6,0"
                                                             Visibility="Collapsed" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="OneNoteSearchResultsHeader" Text="검색 결과"
                                                       FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                            <Button x:Name="OneNoteSearchCloseButton" DockPanel.Dock="Right"
                                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                                    Click="OneNoteSearchClose_Click"
                                                    Background="Transparent" BorderThickness="0"
                                                    Padding="4" Cursor="Hand" ToolTip="검색 닫기">
                                                <ui:SymbolIcon Symbol="Dismiss16" FontSize="12"/>
                                            </Button>
                                        </DockPanel>
                                        <ListBox x:Name="OneNoteSearchResultsListBox"
                                                 Background="Transparent" BorderThickness="0"
                                                 MaxHeight="300"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                                 SelectionChanged="OneNoteSearchResults_SelectionChanged">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="4,2">
                                                        <StackPanel.ContextMenu>
                                                            <ContextMenu Opened="OneNoteContextMenu_Opened" Closed="OneNoteContextMenu_Closed">
                                                                <MenuItem Header="즐겨찾기 추가" Click="AddToFavorites_Click"
                                                                          Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                                    <MenuItem.Icon>
                                                                        <ui:SymbolIcon Symbol="Star24"/>
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                                <MenuItem Header="즐겨찾기 제거" Click="RemoveFromFavorites_Click"
                                                                          Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                    <MenuItem.Icon>
                                                                        <ui:SymbolIcon Symbol="StarOff24"/>
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                                <Separator/>
                                                                <MenuItem Header="노트 삭제" Click="PageDelete_Click" Foreground="#E74856">
                                                                    <MenuItem.Icon>
                                                                        <ui:SymbolIcon Symbol="Delete24" Foreground="#E74856"/>
                                                                    </MenuItem.Icon>
                                                                </MenuItem>
                                                            </ContextMenu>
                                                        </StackPanel.ContextMenu>
                                                        <DockPanel>
                                                            <ui:SymbolIcon FontSize="14" Margin="0,0,6,0"
                                                                           Symbol="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToIconConverter}}"/>
                                                            <TextBlock Text="{Binding Title}" FontSize="13"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                        </DockPanel>
                                                        <TextBlock FontSize="11" Margin="20,0,0,0"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                                            <TextBlock.Text>
                                                                <MultiBinding StringFormat="{}{0} / {1}">
                                                                    <Binding Path="NotebookName"/>
                                                                    <Binding Path="SectionName"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>
                                </Border>

                                <!-- 즐겨찾기 섹션 -->
                                <Expander x:Name="OneNoteFavoritesExpander" IsExpanded="True" Margin="8,4">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Star24" FontSize="14" Margin="0,0,6,0"
                                                           Foreground="#FFD700"/>
                                            <TextBlock Text="즐겨찾기" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <TreeView x:Name="OneNoteFavoritesTreeView" Background="Transparent" BorderThickness="0"
                                              SelectedItemChanged="OneNoteFavoritesTreeView_SelectedItemChanged" Margin="-14,4,0,0"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                              VirtualizingStackPanel.IsVirtualizing="False"
                                              AllowDrop="True"
                                              DragOver="OneNoteFavoritesTreeView_DragOver"
                                              Drop="OneNoteFavoritesTreeView_Drop">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <EventSetter Event="Expanded" Handler="FavoriteTreeViewItem_Expanded"/>
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="FavoriteTreeViewItem_PreviewMouseLeftButtonDown"/>
                                                <EventSetter Event="PreviewMouseLeftButtonUp" Handler="FavoriteTreeViewItem_PreviewMouseLeftButtonUp"/>
                                                <EventSetter Event="PreviewMouseMove" Handler="FavoriteTreeViewItem_PreviewMouseMove"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TreeViewItem">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" MinWidth="19"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition/>
                                                                </Grid.RowDefinitions>
                                                                <!-- 확장/축소 토글 버튼 -->
                                                                <ToggleButton x:Name="Expander" Grid.Column="0" ClickMode="Press"
                                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                              Focusable="False" Width="16" Height="16">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Width="19" Height="19" Padding="4,2,2,2">
                                                                                <Path x:Name="ExpandPath" Data="M 0 0 L 6 5 L 0 10 Z"
                                                                                      Fill="#CCCCCC"
                                                                                      Stroke="#CCCCCC" StrokeThickness="1"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="ExpandPath" Property="Data" Value="M 0 2 L 8 2 L 4 6 Z"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="ExpandPath" Property="Fill" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                                    <Setter TargetName="ExpandPath" Property="Stroke" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                                <!-- 콘텐츠 영역 (선택 배경 적용) -->
                                                                <Border x:Name="ContentBorder" Grid.Column="1" Background="Transparent"
                                                                        CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                                                    <ContentPresenter x:Name="PART_Header" ContentSource="Header"
                                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                                </Border>
                                                                <!-- 자식 항목 영역 -->
                                                                <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsExpanded" Value="False">
                                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                                <Trigger Property="HasItems" Value="False">
                                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                                </Trigger>
                                                                <!-- TreeViewItem 선택 스타일 제거 - 데이터 바인딩(IsSelected)으로 페이지만 하이라이트 -->
                                                                <!-- 마우스 오버 -->
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.ItemTemplate>
                                            <!-- 노트북/섹션/페이지 계층형 템플릿 - 페이지만 IsSelected로 하이라이트 -->
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                <Grid HorizontalAlignment="Stretch" Background="{Binding IsSelected, Converter={StaticResource IsSelectedToBackgroundConverter}}" Margin="2,4">
                                                    <Grid.ContextMenu>
                                                        <ContextMenu Opened="OneNoteContextMenu_Opened" Closed="OneNoteContextMenu_Closed">
                                                            <MenuItem Header="노트 추가" Click="FavoriteSectionAddPage_Click"
                                                                      Visibility="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToSectionVisibilityConverter}}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="Add24"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="즐겨찾기 제거" Click="FavoriteListItem_RemoveClick"
                                                                      Visibility="{Binding IsDirectFavorite, Converter={StaticResource DirectFavoriteToVisibilityConverter}}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="StarOff24"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <Separator Visibility="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToNotSectionVisibilityConverter}}"/>
                                                            <MenuItem Header="섹션 삭제" Click="FavoriteSectionDelete_Click" Foreground="#E74856"
                                                                      Visibility="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToSectionVisibilityConverter}}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="Delete24" Foreground="#E74856"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </Grid.ContextMenu>
                                                    <StackPanel Orientation="Horizontal">
                                                        <!-- 타입별 아이콘 (노트북/섹션/페이지) -->
                                                        <ui:SymbolIcon Symbol="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToIconConverter}}" FontSize="14"
                                                                       Foreground="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToColorConverter}}" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                       Visibility="{Binding IsLoadingChildren, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                        <!-- 로딩 스피너 -->
                                                        <ui:ProgressRing IsIndeterminate="True" Width="14" Height="14" Margin="0,0,6,0"
                                                                         Visibility="{Binding IsLoadingChildren, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                        <StackPanel VerticalAlignment="Center" Margin="0,-2,0,-2">
                                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            <TextBlock Text="{Binding LocationDisplay}" FontSize="11" Margin="0,-1,0,0"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Grid>
                                                <!-- 2단계 자식 항목 템플릿 - 페이지만 IsSelected로 하이라이트 -->
                                                <HierarchicalDataTemplate.ItemTemplate>
                                                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                        <Grid HorizontalAlignment="Stretch" Background="{Binding IsSelected, Converter={StaticResource IsSelectedToBackgroundConverter}}" Margin="2,3">
                                                            <Grid.ContextMenu>
                                                                <ContextMenu Opened="OneNoteContextMenu_Opened" Closed="OneNoteContextMenu_Closed">
                                                                    <MenuItem Header="노트 추가" Click="FavoriteSectionAddPage_Click"
                                                                              Visibility="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToSectionVisibilityConverter}}">
                                                                        <MenuItem.Icon>
                                                                            <ui:SymbolIcon Symbol="Add24"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="즐겨찾기 제거" Click="FavoriteListItem_RemoveClick"
                                                                              Visibility="{Binding IsDirectFavorite, Converter={StaticResource DirectFavoriteToVisibilityConverter}}">
                                                                        <MenuItem.Icon>
                                                                            <ui:SymbolIcon Symbol="StarOff24"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <Separator Visibility="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToNotSectionVisibilityConverter}}"/>
                                                                    <MenuItem Header="섹션 삭제" Click="FavoriteSectionDelete_Click" Foreground="#E74856"
                                                                              Visibility="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToSectionVisibilityConverter}}">
                                                                        <MenuItem.Icon>
                                                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#E74856"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="노트 삭제" Click="FavoritePageDelete_Click" Foreground="#E74856"
                                                                              Visibility="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToPageVisibilityConverter}}">
                                                                        <MenuItem.Icon>
                                                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#E74856"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                </ContextMenu>
                                                            </Grid.ContextMenu>
                                                            <StackPanel Orientation="Horizontal">
                                                                <!-- 타입별 아이콘 -->
                                                                <ui:SymbolIcon Symbol="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToIconConverter}}" FontSize="14"
                                                                               Foreground="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToColorConverter}}" Margin="0,0,6,0" VerticalAlignment="Center"
                                                                               Visibility="{Binding IsLoadingChildren, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                                <!-- 로딩 스피너 -->
                                                                <ui:ProgressRing IsIndeterminate="True" Width="14" Height="14" Margin="0,0,6,0"
                                                                                 Visibility="{Binding IsLoadingChildren, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                <TextBlock Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <!-- 3단계 자식 (노트북→섹션→페이지) - 페이지만 IsSelected로 하이라이트 -->
                                                        <HierarchicalDataTemplate.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid HorizontalAlignment="Stretch" Background="{Binding IsSelected, Converter={StaticResource IsSelectedToBackgroundConverter}}" Margin="2,2">
                                                                    <Grid.ContextMenu>
                                                                        <ContextMenu Opened="OneNoteContextMenu_Opened" Closed="OneNoteContextMenu_Closed">
                                                                            <MenuItem Header="즐겨찾기 제거" Click="FavoriteListItem_RemoveClick"
                                                                                      Visibility="{Binding IsDirectFavorite, Converter={StaticResource DirectFavoriteToVisibilityConverter}}">
                                                                                <MenuItem.Icon>
                                                                                    <ui:SymbolIcon Symbol="StarOff24"/>
                                                                                </MenuItem.Icon>
                                                                            </MenuItem>
                                                                            <Separator Visibility="{Binding IsDirectFavorite, Converter={StaticResource DirectFavoriteToVisibilityConverter}}"/>
                                                                            <MenuItem Header="노트 삭제" Click="FavoritePageDelete_Click" Foreground="#E74856">
                                                                                <MenuItem.Icon>
                                                                                    <ui:SymbolIcon Symbol="Delete24" Foreground="#E74856"/>
                                                                                </MenuItem.Icon>
                                                                            </MenuItem>
                                                                        </ContextMenu>
                                                                    </Grid.ContextMenu>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <ui:SymbolIcon Symbol="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToIconConverter}}" FontSize="12"
                                                                                       Foreground="{Binding ItemType, Converter={StaticResource FavoriteItemTypeToColorConverter}}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </HierarchicalDataTemplate.ItemTemplate>
                                                    </HierarchicalDataTemplate>
                                                </HierarchicalDataTemplate.ItemTemplate>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </Expander>

                                <!-- 노트북 목록 -->
                                <Expander x:Name="OneNoteNotebooksExpander" IsExpanded="True" Margin="8,4">
                                    <Expander.Header>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Notebook24" FontSize="16" Margin="0,0,8,0"
                                                           Foreground="{StaticResource OneNoteAccentBrush}"/>
                                            <TextBlock Text="노트북" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Expander.Header>
                                    <TreeView x:Name="OneNoteTreeView" Background="Transparent" BorderThickness="0" Margin="-14,4,0,0"
                                              SelectedItemChanged="OneNoteTreeView_SelectedItemChanged"
                                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                        <TreeView.ItemContainerStyle>
                                            <Style TargetType="TreeViewItem">
                                                <EventSetter Event="Expanded" Handler="OneNoteTreeViewItem_Expanded"/>
                                                <EventSetter Event="PreviewMouseLeftButtonDown" Handler="OneNoteTreeViewItem_PreviewMouseLeftButtonDown"/>
                                                <EventSetter Event="PreviewMouseLeftButtonUp" Handler="OneNoteTreeViewItem_PreviewMouseLeftButtonUp"/>
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                <Setter Property="Padding" Value="4,2"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="TreeViewItem">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" MinWidth="19"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition/>
                                                                </Grid.RowDefinitions>
                                                                <!-- 확장/축소 토글 버튼 -->
                                                                <ToggleButton x:Name="Expander" Grid.Column="0" ClickMode="Press"
                                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                              Focusable="False" Width="16" Height="16">
                                                                    <ToggleButton.Template>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Width="19" Height="19" Padding="4,2,2,2">
                                                                                <Path x:Name="ExpandPath" Data="M 0 0 L 6 5 L 0 10 Z"
                                                                                      Fill="#CCCCCC"
                                                                                      Stroke="#CCCCCC" StrokeThickness="1"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="ExpandPath" Property="Data" Value="M 0 2 L 8 2 L 4 6 Z"/>
                                                                                </Trigger>
                                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                                    <Setter TargetName="ExpandPath" Property="Fill" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                                    <Setter TargetName="ExpandPath" Property="Stroke" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </ToggleButton.Template>
                                                                </ToggleButton>
                                                                <!-- 콘텐츠 영역 (선택 배경 적용) -->
                                                                <Border x:Name="ContentBorder" Grid.Column="1" Background="Transparent"
                                                                        CornerRadius="4" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                                                                    <ContentPresenter x:Name="PART_Header" ContentSource="Header"
                                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                                                </Border>
                                                                <!-- 자식 항목 영역 -->
                                                                <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Grid.Column="1"/>
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsExpanded" Value="False">
                                                                    <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                                                </Trigger>
                                                                <Trigger Property="HasItems" Value="False">
                                                                    <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                                                </Trigger>
                                                                <!-- TreeViewItem 선택 스타일 제거 - 데이터 바인딩(IsSelected)으로 페이지만 하이라이트 -->
                                                                <!-- 마우스 오버 -->
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ContentBorder" Property="Background" Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </TreeView.ItemContainerStyle>
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Sections}">
                                                <StackPanel Orientation="Horizontal" Margin="2,4">
                                                    <StackPanel.ContextMenu>
                                                        <ContextMenu Opened="OneNoteContextMenu_Opened" Closed="OneNoteContextMenu_Closed">
                                                            <MenuItem Header="즐겨찾기 추가" Click="NotebookAddToFavorites_Click"
                                                                      Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="Star24"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                            <MenuItem Header="즐겨찾기 제거" Click="NotebookRemoveFromFavorites_Click"
                                                                      Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                <MenuItem.Icon>
                                                                    <ui:SymbolIcon Symbol="StarOff24"/>
                                                                </MenuItem.Icon>
                                                            </MenuItem>
                                                        </ContextMenu>
                                                    </StackPanel.ContextMenu>
                                                    <!-- 노트북 아이콘 (로딩 중이 아닐 때) -->
                                                    <ui:SymbolIcon Symbol="Notebook24" FontSize="16" Foreground="{StaticResource OneNoteAccentBrush}" Margin="0,0,4,0"
                                                                   Visibility="{Binding IsLoadingSections, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                                                    <!-- 로딩 스피너 (로딩 중일 때) -->
                                                    <ui:ProgressRing IsIndeterminate="True" Width="16" Height="16" Margin="0,0,4,0"
                                                                     Visibility="{Binding IsLoadingSections, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <!-- 공유 아이콘 (그룹 노트북인 경우) -->
                                                    <ui:SymbolIcon Symbol="People24" FontSize="12" Foreground="#0078D4" Margin="0,0,4,0"
                                                                   Visibility="{Binding IsShared, Converter={StaticResource BoolToVisibilityConverter}}"
                                                                   ToolTip="{Binding SourceName}"/>
                                                    <!-- 즐겨찾기 별 아이콘 (아이콘 뒤, 명칭 앞) -->
                                                    <ui:SymbolIcon Symbol="Star24" FontSize="10" Foreground="#FFD700" Margin="0,0,4,0"
                                                                   Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                    <!-- 출처 라벨 (그룹 노트북인 경우) -->
                                                    <TextBlock Text="{Binding SourceName, StringFormat=' [{0}]'}" FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"
                                                               Visibility="{Binding IsShared, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                                <HierarchicalDataTemplate.ItemTemplate>
                                                    <HierarchicalDataTemplate ItemsSource="{Binding Pages}">
                                                        <Grid HorizontalAlignment="Stretch" Background="Transparent" Margin="2,3">
                                                            <Grid.ContextMenu>
                                                                <ContextMenu Opened="OneNoteContextMenu_Opened" Closed="OneNoteContextMenu_Closed">
                                                                    <MenuItem Header="노트 추가" Click="SectionAddPage_Click">
                                                                        <MenuItem.Icon>
                                                                            <ui:SymbolIcon Symbol="Add24"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <Separator/>
                                                                    <MenuItem Header="즐겨찾기 추가" Click="SectionAddToFavorites_Click"
                                                                              Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                                        <MenuItem.Icon>
                                                                            <ui:SymbolIcon Symbol="Star24"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <MenuItem Header="즐겨찾기 제거" Click="SectionRemoveFromFavorites_Click"
                                                                              Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                        <MenuItem.Icon>
                                                                            <ui:SymbolIcon Symbol="StarOff24"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                    <Separator/>
                                                                    <MenuItem Header="섹션 삭제" Click="SectionDelete_Click" Foreground="#E74856">
                                                                        <MenuItem.Icon>
                                                                            <ui:SymbolIcon Symbol="Delete24" Foreground="#E74856"/>
                                                                        </MenuItem.Icon>
                                                                    </MenuItem>
                                                                </ContextMenu>
                                                            </Grid.ContextMenu>
                                                            <StackPanel Orientation="Horizontal">
                                                                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="14" Foreground="#107C10" Margin="0,0,4,0"/>
                                                                <!-- 즐겨찾기 별 아이콘 (아이콘 뒤, 명칭 앞) -->
                                                                <ui:SymbolIcon Symbol="Star24" FontSize="10" Foreground="#FFD700" Margin="0,0,4,0"
                                                                               Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                <TextBlock Text="{Binding DisplayName}" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                            </StackPanel>
                                                        </Grid>
                                                        <!-- 3단계 자식 (노트북→섹션→페이지) - 페이지만 IsSelected로 하이라이트 -->
                                                        <HierarchicalDataTemplate.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid HorizontalAlignment="Stretch" Background="{Binding IsSelected, Converter={StaticResource IsSelectedToBackgroundConverter}}" Margin="2,2">
                                                                    <Grid.ContextMenu>
                                                                        <ContextMenu Opened="OneNoteContextMenu_Opened" Closed="OneNoteContextMenu_Closed">
                                                                            <MenuItem Header="즐겨찾기 추가" Click="AddToFavorites_Click"
                                                                                      Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                                                                <MenuItem.Icon>
                                                                                    <ui:SymbolIcon Symbol="Star24"/>
                                                                                </MenuItem.Icon>
                                                                            </MenuItem>
                                                                            <MenuItem Header="즐겨찾기 제거" Click="RemoveFromFavorites_Click"
                                                                                      Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}">
                                                                                <MenuItem.Icon>
                                                                                    <ui:SymbolIcon Symbol="StarOff24"/>
                                                                                </MenuItem.Icon>
                                                                            </MenuItem>
                                                                            <Separator/>
                                                                            <MenuItem Header="노트 삭제" Click="PageDelete_Click" Foreground="#E74856">
                                                                                <MenuItem.Icon>
                                                                                    <ui:SymbolIcon Symbol="Delete24" Foreground="#E74856"/>
                                                                                </MenuItem.Icon>
                                                                            </MenuItem>
                                                                        </ContextMenu>
                                                                    </Grid.ContextMenu>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <ui:SymbolIcon Symbol="Document24" FontSize="12"
                                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,4,0"/>
                                                                        <!-- 즐겨찾기 별 아이콘 (아이콘 뒤, 명칭 앞) -->
                                                                        <ui:SymbolIcon Symbol="Star24" FontSize="10" Foreground="#FFD700" Margin="0,0,4,0"
                                                                                       Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </HierarchicalDataTemplate.ItemTemplate>
                                                    </HierarchicalDataTemplate>
                                                </HierarchicalDataTemplate.ItemTemplate>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>
                                </Expander>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- GridSplitter (OneNote) -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- 우측 패널: 페이지 콘텐츠 뷰어/에디터 -->
                <Border Grid.Column="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 페이지 헤더 (선택된 페이지가 있을 때만) -->
                        <Border x:Name="OneNotePageHeaderBorder" Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <StackPanel Orientation="Horizontal">
                                        <!-- 제목 표시 (클릭 시 편집 모드) -->
                                        <TextBlock x:Name="OneNotePageTitleText" Text="페이지 제목" FontSize="18" FontWeight="SemiBold"
                                                   Cursor="Hand" ToolTip="클릭하여 제목 수정"
                                                   MouseLeftButtonDown="OneNotePageTitle_Click"/>
                                        <!-- 제목 편집 (기본 숨김) -->
                                        <TextBox x:Name="OneNotePageTitleEdit" FontSize="18" FontWeight="SemiBold"
                                                 MinWidth="200" Visibility="Collapsed"
                                                 LostFocus="OneNotePageTitleEdit_LostFocus"
                                                 KeyDown="OneNotePageTitleEdit_KeyDown"
                                                 TextChanged="OneNotePageTitleEdit_TextChanged"/>
                                        <!-- 저장 대상 표시 (●) - 미저장 변경사항 있을 때 표시 -->
                                        <TextBlock x:Name="OneNoteUnsavedIndicator" Text=" ●" FontSize="18" FontWeight="Bold"
                                                   Foreground="#FF6B6B" Visibility="Collapsed" ToolTip="저장되지 않은 변경사항 있음"/>
                                    </StackPanel>
                                    <TextBlock x:Name="OneNotePageLocationText" Text="노트북 > 섹션" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <ui:Button x:Name="OneNoteSaveButton" Icon="{ui:SymbolIcon Save24}"
                                               Appearance="Transparent" ToolTip="저장 (Ctrl+S)" Padding="8"
                                               Click="OneNoteSaveButton_Click"/>
                                    <ui:Button x:Name="OneNoteEditButton" Icon="{ui:SymbolIcon Edit24}"
                                               Appearance="Transparent" ToolTip="편집" Padding="8"/>
                                    <ui:Button x:Name="OneNoteShareButton" Icon="{ui:SymbolIcon Share24}"
                                               Appearance="Transparent" ToolTip="공유" Padding="8"/>
                                    <ui:Button x:Name="OneNoteMoreButton" Icon="{ui:SymbolIcon MoreHorizontal24}"
                                               Appearance="Transparent" ToolTip="더보기" Padding="8"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 페이지 콘텐츠 (탭 포함) -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 콘텐츠 탭 바 (항상 표시) -->
                            <!-- 탭 바 (진짜 탭 스타일) -->
                            <Border x:Name="OneNoteContentTabBar" Grid.Row="0"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    Visibility="Visible">
                                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,-1">
                                    <!-- 노트내용 탭 -->
                                    <Border x:Name="OneNoteTabNoteContent"
                                            Padding="16,10" Margin="4,4,0,0"
                                            CornerRadius="6,6,0,0"
                                            Background="{DynamicResource ApplicationBackgroundBrush}"
                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                            BorderThickness="1,1,1,0"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OneNoteContentTab_MouseDown" Tag="note">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="Document24" FontSize="14" Margin="0,0,6,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                            <TextBlock Text="노트내용" FontSize="13" FontWeight="Medium" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- 녹음내용 탭 -->
                                    <Border x:Name="OneNoteTabRecordingContent"
                                            Padding="16,10" Margin="0,4,0,0"
                                            CornerRadius="6,6,0,0"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="1,1,1,0"
                                            Cursor="Hand"
                                            MouseLeftButtonDown="OneNoteContentTab_MouseDown" Tag="recording">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon x:Name="OneNoteTabRecordingIcon" Symbol="Mic24" FontSize="14" Margin="0,0,6,0"
                                                           Foreground="#999999"/>
                                            <TextBlock x:Name="OneNoteTabRecordingText" Text="녹음내용" FontSize="13"
                                                       Foreground="#999999"/>
                                        </StackPanel>
                                    </Border>
                                    <!-- 동적 분석 결과 탭 (코드에서 생성) -->
                                    <ItemsControl x:Name="OneNoteAnalysisTabHost">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                </StackPanel>
                                </ScrollViewer>
                            </Border>

                            <!-- 탭 콘텐츠 영역 -->
                            <Grid Grid.Row="1">
                                <!-- 빈 상태 (페이지 미선택) -->
                                <StackPanel x:Name="OneNoteEmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <ui:SymbolIcon Symbol="Notebook24" FontSize="72" Foreground="{StaticResource OneNoteAccentBrush}" Margin="0,0,0,24"/>
                                    <TextBlock Text="OneNote" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="노트를 선택하여 내용을 확인하세요" FontSize="14"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                    <ui:Button x:Name="OneNoteNewPageButton" Content="새 페이지 만들기"
                                               Icon="{ui:SymbolIcon Add24}" Appearance="Primary"
                                               Margin="0,24,0,0" Padding="16,10" Click="OneNoteNewPageButton_Click"/>
                                </StackPanel>

                                <!-- 노트내용 패널 (기존 WebView2 에디터) -->
                                <Border x:Name="OneNoteNoteContentPanel" Visibility="Collapsed">
                                    <Grid>
                                        <!-- 페이지 콘텐츠 (TinyMCE WebView2 에디터) -->
                                        <Border x:Name="OneNoteContentBorder" Visibility="Collapsed" CornerRadius="8" Margin="8"
                                                Background="{DynamicResource ApplicationBackgroundBrush}">
                                            <wv2:WebView2 x:Name="OneNoteEditorWebView"
                                                          DefaultBackgroundColor="Transparent"
                                                          GotFocus="OneNoteEditorWebView_GotFocus"
                                                          AllowDrop="True"
                                                          PreviewDragOver="OneNoteEditorWebView_DragOver"
                                                          PreviewDrop="OneNoteEditorWebView_Drop"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- 녹음내용 패널 (읽기 모드, 좌우 분할) -->
                                <Border x:Name="OneNoteRecordingContentPanel" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="300"/>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*" MinWidth="300"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 좌측: STT 결과 -->
                                        <Border Grid.Column="0" Padding="16"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                BorderThickness="0,0,1,0">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- STT 헤더 -->
                                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <ui:SymbolIcon Symbol="Mic24" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="음성 인식 (STT)" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <!-- 실시간 표시기 (녹음 중일 때) -->
                                                        <Ellipse x:Name="OneNoteSTTLiveIndicator" Width="8" Height="8" Fill="#10B981" Margin="8,0,4,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                        <TextBlock x:Name="OneNoteSTTLiveText" Text="실시간" FontSize="11" Foreground="#10B981" VerticalAlignment="Center" Visibility="Collapsed"/>
                                                    </StackPanel>
                                                    <!-- 버튼 그룹 (화자분리 토글 + STT 분석) -->
                                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                        <!-- 화자분리 전/후 토글 버튼 -->
                                                        <ui:Button x:Name="OneNoteDiarizationToggleButton"
                                                                   Content="화자분리 전"
                                                                   Icon="{ui:SymbolIcon People24}"
                                                                   Appearance="Secondary"
                                                                   FontSize="11"
                                                                   Padding="10,5"
                                                                   Margin="0,0,8,0"
                                                                   Visibility="Collapsed"
                                                                   ToolTip="화자분리 적용 전/후 비교"
                                                                   Click="OneNoteDiarizationToggle_Click"/>
                                                        <!-- STT 분석 버튼 (녹음탭의 모델 설정 사용) -->
                                                        <ui:Button x:Name="OneNoteTabRunSTTButton"
                                                                   Content="STT 분석"
                                                                   Icon="{ui:SymbolIcon Mic24}"
                                                                   Appearance="Secondary"
                                                                   FontSize="11"
                                                                   Padding="10,5"
                                                                   Click="OneNoteTabRunSTT_Click"/>
                                                    </StackPanel>

                                                    <!-- STT 진행률 표시 -->
                                                    <Border x:Name="OneNoteSTTProgressPanel" Grid.Row="1" Grid.ColumnSpan="2"
                                                            Visibility="Collapsed" Margin="0,8,0,0"
                                                            Padding="12" CornerRadius="8"
                                                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                                                        <StackPanel>
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock x:Name="OneNoteSTTProgressText" Text="분석 중..."
                                                                           FontSize="12" FontWeight="SemiBold"/>
                                                                <TextBlock x:Name="OneNoteSTTProgressPercent" Grid.Column="1"
                                                                           Text="0%" FontSize="12" FontWeight="SemiBold"
                                                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                            </Grid>
                                                            <Slider x:Name="OneNoteSTTProgressBar" Minimum="0" Maximum="100" Value="0"
                                                                    Height="20" Margin="0,8,0,0"
                                                                    IsHitTestVisible="False" Focusable="False"
                                                                    ToolTip="STT 진행률"/>
                                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                                <ui:SymbolIcon Symbol="Timer24" FontSize="12"
                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                <TextBlock x:Name="OneNoteSTTTimeRemaining" Text="예상 남은 시간: 계산 중..."
                                                                           FontSize="11" Margin="4,0,0,0"
                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </Grid>

                                                <!-- STT 세그먼트 목록 -->
                                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                    <Grid>
                                                        <!-- 빈 상태 -->
                                                        <TextBlock x:Name="OneNoteSTTEmptyText" Text="STT 분석 결과가 없습니다."
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                        <!-- 세그먼트 목록 -->
                                                        <ItemsControl x:Name="OneNoteSTTSegmentsList" Visibility="Collapsed">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border Margin="0,0,0,8" Padding="12" CornerRadius="8"
                                                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                            Cursor="Hand"
                                                                            MouseLeftButtonDown="STTSegment_Click">
                                                                        <Grid>
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="Auto"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>

                                                                            <!-- 화자 아바타 -->
                                                                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                                                                    Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                                                    Margin="0,0,10,0" VerticalAlignment="Top">
                                                                                <TextBlock Text="{Binding SpeakerInitial}"
                                                                                           FontSize="13" FontWeight="SemiBold"
                                                                                           Foreground="White"
                                                                                           HorizontalAlignment="Center"
                                                                                           VerticalAlignment="Center"/>
                                                                            </Border>

                                                                            <StackPanel Grid.Column="1">
                                                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                                    <TextBlock Text="{Binding Speaker}"
                                                                                               FontWeight="SemiBold" FontSize="12"
                                                                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                                                    <TextBlock Text="{Binding TimeRange}"
                                                                                               Margin="8,0,0,0" FontSize="10"
                                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                                </StackPanel>
                                                                                <TextBlock Text="{Binding Text}"
                                                                                           TextWrapping="Wrap" FontSize="13"/>
                                                                            </StackPanel>
                                                                        </Grid>
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>

                                        <!-- GridSplitter -->
                                        <GridSplitter Grid.Column="1" Width="4"
                                                      HorizontalAlignment="Stretch"
                                                      Background="Transparent" Cursor="SizeWE"/>

                                        <!-- 우측: AI 요약 -->
                                        <Border Grid.Column="2" Padding="16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="*"/>
                                                </Grid.RowDefinitions>

                                                <!-- 요약 헤더 -->
                                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <ui:SymbolIcon Symbol="Sparkle24" FontSize="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                        <TextBlock Text="AI 요약" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                        <!-- 진행 중 표시기 -->
                                                        <ui:ProgressRing x:Name="OneNoteSummaryProgress" Width="16" Height="16" Margin="8,0,0,0" IsIndeterminate="True" Visibility="Collapsed"/>
                                                        <TextBlock x:Name="OneNoteSummaryProgressText" Text="" FontSize="12" Margin="8,0,0,0"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <!-- AI 요약 버튼 -->
                                                    <ui:Button x:Name="OneNoteTabRunSummaryButton"
                                                               Grid.Column="1"
                                                               Content="AI 요약"
                                                               Icon="{ui:SymbolIcon Sparkle24}"
                                                               Appearance="Secondary"
                                                               FontSize="11"
                                                               Padding="10,5"
                                                               Click="OneNoteTabRunSummary_Click"/>
                                                </Grid>

                                                <!-- 요약 콘텐츠 -->
                                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                                    <Grid>
                                                        <!-- 빈 상태 -->
                                                        <TextBlock x:Name="OneNoteSummaryEmptyText" Text="AI 요약이 없습니다."
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                                        <!-- 요약 결과 -->
                                                        <StackPanel x:Name="OneNoteSummaryContent" Visibility="Collapsed">
                                                            <!-- 회의 제목 (맨 위에 표시) -->
                                                            <Border x:Name="OneNoteSummaryTitlePanel" Padding="16" CornerRadius="8" Margin="0,0,20,12"
                                                                    Background="{DynamicResource AccentFillColorDefaultBrush}" Visibility="Collapsed">
                                                                <TextBlock x:Name="OneNoteSummaryTitleTextBlock"
                                                                           TextWrapping="Wrap" FontSize="15" FontWeight="Bold"
                                                                           Foreground="White" TextAlignment="Center"/>
                                                            </Border>

                                                            <!-- 요약 텍스트 -->
                                                            <Border Padding="14" CornerRadius="8" Margin="0,0,0,12"
                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                                                <StackPanel>
                                                                    <TextBlock Text="요약" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                                                    <TextBlock x:Name="OneNoteSummaryText"
                                                                               TextWrapping="Wrap" FontSize="13" LineHeight="20"/>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- 핵심 포인트 -->
                                                            <Border x:Name="OneNoteKeyPointsPanel" Padding="14" CornerRadius="8" Margin="0,0,0,12"
                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}" Visibility="Collapsed">
                                                                <StackPanel>
                                                                    <TextBlock Text="핵심 포인트" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                                                    <ItemsControl x:Name="OneNoteKeyPointsList">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Padding="10" Margin="0,0,0,6" CornerRadius="6"
                                                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                                                    <TextBlock Text="{Binding}" TextWrapping="Wrap" FontSize="12"/>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>

                                                            <!-- 액션 아이템 -->
                                                            <Border x:Name="OneNoteActionItemsPanel" Padding="14" CornerRadius="8" Margin="0,0,20,0"
                                                                    Background="{DynamicResource ControlFillColorDefaultBrush}" Visibility="Collapsed">
                                                                <StackPanel>
                                                                    <TextBlock Text="액션 아이템" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,8"/>
                                                                    <ItemsControl x:Name="OneNoteActionItemsList">
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate>
                                                                                <Border Padding="8,6" Margin="0,0,0,6" CornerRadius="6"
                                                                                        Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="*"/>
                                                                                            <ColumnDefinition Width="Auto"/>
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0" Text="{Binding Description}"
                                                                                                   TextWrapping="Wrap" FontSize="12"
                                                                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                                                        <ui:Button Grid.Column="1" x:Name="AddToTodoButton"
                                                                                                   Appearance="{Binding IsAddedToTodo, Converter={StaticResource BoolToAppearanceConverter}}"
                                                                                                   ToolTip="{Binding IsAddedToTodo, Converter={StaticResource BoolToTodoTooltipConverter}}"
                                                                                                   Padding="6,4" Loaded="AddToTodoButton_Loaded"
                                                                                                   Click="AddToTodoButton_Click">
                                                                                            <StackPanel Orientation="Horizontal">
                                                                                                <ui:SymbolIcon Symbol="{Binding IsAddedToTodo, Converter={StaticResource BoolToTodoIconConverter}}" FontSize="14"/>
                                                                                            </StackPanel>
                                                                                        </ui:Button>
                                                                                    </Grid>
                                                                                </Border>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </StackPanel>
                                                            </Border>
                                                        </StackPanel>
                                                    </Grid>
                                                </ScrollViewer>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                </Border>

                                <!-- 동적 분석 결과 패널 (넓게 보기) -->
                                <Border x:Name="OneNoteAnalysisContentPanel" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <!-- 파일명 헤더 -->
                                        <Border Grid.Row="0" Padding="16,10"
                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,0,1">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="DocumentSearch24" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="OneNoteAnalysisContentFileName" Text="" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                        <!-- 분석 결과 본문 -->
                                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16">
                                            <TextBlock x:Name="OneNoteAnalysisContentText" TextWrapping="Wrap" FontSize="13"
                                                       PreviewMouseWheel="AnalysisContentText_PreviewMouseWheel"/>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>

                                <!-- 로딩 인디케이터 -->
                                <Border x:Name="OneNoteLoadingOverlay" Visibility="Collapsed"
                                        Background="{DynamicResource ApplicationBackgroundBrush}">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48"/>
                                        <TextBlock Text="로딩 중..." FontSize="14"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ========== 통화 뷰 컨테이너 (Column 1-5 전체 사용, 초기에는 숨김) ========== -->
        <Border x:Name="CallsViewBorder"
                Grid.Column="1" Grid.ColumnSpan="5"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="320" MinWidth="320" MaxWidth="400"/>
                    <!-- GridSplitter -->
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측 패널: 다이얼패드 + 연락처 -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 헤더 -->
                        <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Call24" FontSize="20" Margin="0,0,8,0" Foreground="{StaticResource CallsAccentBrush}"/>
                                    <TextBlock Text="통화" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <ui:Button x:Name="CallsRefreshButton" HorizontalAlignment="Right" Appearance="Transparent" ToolTip="새로고침" Click="CallsRefreshButton_Click">
                                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <!-- 내 상태 표시 -->
                        <Border Grid.Row="1" Padding="12,8" Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Ellipse Grid.Column="0" Width="12" Height="12" Margin="0,0,8,0">
                                    <Ellipse.Fill>
                                        <SolidColorBrush x:Name="CallsMyStatusBrush" Color="#107C10"/>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <TextBlock Grid.Column="1" x:Name="CallsMyStatusText" Text="대화 가능" VerticalAlignment="Center" FontSize="13"/>
                                <ui:Button Grid.Column="2" x:Name="CallsStatusMenuButton" Appearance="Transparent" Content="상태 변경" FontSize="12" Click="CallsStatusMenuButton_Click"/>
                            </Grid>
                        </Border>

                        <!-- 연락처 검색 -->
                        <Border Grid.Row="2" Padding="12,8">
                            <ui:TextBox x:Name="CallsSearchBox" PlaceholderText="이름 또는 이메일로 검색..." Icon="{ui:SymbolIcon Search24}" KeyDown="CallsSearchBox_KeyDown"/>
                        </Border>

                        <!-- 탭: 다이얼패드/자주 연락하는 사람 -->
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- 탭 바 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,4,12,8">
                                <ui:Button x:Name="CallsDialPadTab" Content="다이얼 패드" Appearance="Transparent" Margin="0,0,8,0" Click="CallsDialPadTab_Click"/>
                                <ui:Button x:Name="CallsContactsTab" Content="연락처" Appearance="Primary" Click="CallsContactsTab_Click"/>
                            </StackPanel>

                            <!-- 다이얼 패드 영역 -->
                            <Border Grid.Row="1" x:Name="CallsDialPadPanel" Visibility="Collapsed" Padding="20">
                                <StackPanel>
                                    <!-- 입력 번호 표시 -->
                                    <Border Background="{DynamicResource ControlFillColorDefaultBrush}" CornerRadius="8" Padding="16,12" Margin="0,0,0,16">
                                        <TextBlock x:Name="CallsDialNumber" Text="" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center" TextWrapping="NoWrap"/>
                                    </Border>

                                    <!-- 숫자 키패드 -->
                                    <UniformGrid Columns="3" Rows="4" Margin="0,0,0,16">
                                        <ui:Button Content="1" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="1"/>
                                        <ui:Button Content="2" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="2"/>
                                        <ui:Button Content="3" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="3"/>
                                        <ui:Button Content="4" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="4"/>
                                        <ui:Button Content="5" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="5"/>
                                        <ui:Button Content="6" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="6"/>
                                        <ui:Button Content="7" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="7"/>
                                        <ui:Button Content="8" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="8"/>
                                        <ui:Button Content="9" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="9"/>
                                        <ui:Button Content="*" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="*"/>
                                        <ui:Button Content="0" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="0"/>
                                        <ui:Button Content="#" FontSize="20" Margin="4" Height="50" Click="DialButton_Click" Tag="#"/>
                                    </UniformGrid>

                                    <!-- 통화 버튼 -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:Button Grid.Column="0" Content="지우기" Appearance="Secondary" HorizontalAlignment="Stretch" Margin="4" Click="DialClearButton_Click"/>
                                        <ui:Button Grid.Column="1" Width="60" Height="60" Appearance="Primary" CornerRadius="30" Margin="8" Click="DialCallButton_Click">
                                            <ui:SymbolIcon Symbol="Call24" FontSize="24"/>
                                        </ui:Button>
                                        <ui:Button Grid.Column="2" Appearance="Secondary" HorizontalAlignment="Stretch" Margin="4" Click="DialBackspaceButton_Click">
                                            <ui:SymbolIcon Symbol="Backspace24"/>
                                        </ui:Button>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- 연락처 목록 영역 -->
                            <Border Grid.Row="1" x:Name="CallsContactsPanel" Visibility="Visible">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 자주 연락하는 사람 헤더 -->
                                    <TextBlock Grid.Row="0" Text="자주 연락하는 사람" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="12,4,12,8"/>

                                    <!-- 연락처 리스트 -->
                                    <ListView x:Name="CallsContactsListView" Grid.Row="1"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              SelectionChanged="CallsContactsListView_SelectionChanged">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="4,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 아바타 + 상태 표시 -->
                                                    <Grid Grid.Column="0" Margin="0,0,12,0">
                                                        <Border Width="40" Height="40" CornerRadius="20" Background="{StaticResource CallsAccentBrush}">
                                                            <TextBlock Text="{Binding Initials}" FontSize="14" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <Ellipse Width="12" Height="12" HorizontalAlignment="Right" VerticalAlignment="Bottom" Stroke="White" StrokeThickness="2">
                                                            <Ellipse.Fill>
                                                                <SolidColorBrush Color="{Binding AvailabilityColor}"/>
                                                            </Ellipse.Fill>
                                                        </Ellipse>
                                                    </Grid>

                                                    <!-- 이름/이메일/상태 -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Email}" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <!-- 통화 버튼 -->
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                        <ui:Button Appearance="Transparent" ToolTip="음성 통화" Width="32" Height="32" Margin="2" Click="ContactCallButton_Click" Tag="{Binding}">
                                                            <ui:SymbolIcon Symbol="Call24" FontSize="16"/>
                                                        </ui:Button>
                                                        <ui:Button Appearance="Transparent" ToolTip="영상 통화" Width="32" Height="32" Margin="2" Click="ContactVideoCallButton_Click" Tag="{Binding}">
                                                            <ui:SymbolIcon Symbol="Video24" FontSize="16"/>
                                                        </ui:Button>
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <!-- 빈 상태 표시 -->
                                    <StackPanel x:Name="CallsContactsEmptyState" Grid.Row="1" Visibility="Collapsed" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <ui:SymbolIcon Symbol="People24" FontSize="32" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"/>
                                        <TextBlock Text="연락처가 없습니다" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <!-- GridSplitter (통화) -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- 우측 패널: 선택된 연락처 상세 / 검색 결과 -->
                <Grid Grid.Column="2">
                    <!-- 검색 결과 표시 -->
                    <Border x:Name="CallsSearchResultsPanel" Visibility="Collapsed" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="검색 결과" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

                            <ListView x:Name="CallsSearchResultsListView" Grid.Row="1"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      SelectionChanged="CallsSearchResultsListView_SelectionChanged">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 아바타 -->
                                            <Grid Grid.Column="0" Margin="0,0,16,0">
                                                <Border Width="48" Height="48" CornerRadius="24" Background="{StaticResource CallsAccentBrush}">
                                                    <TextBlock Text="{Binding Initials}" FontSize="16" FontWeight="SemiBold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <Ellipse Width="14" Height="14" HorizontalAlignment="Right" VerticalAlignment="Bottom" Stroke="White" StrokeThickness="2">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding AvailabilityColor}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                            </Grid>

                                            <!-- 정보 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" FontSize="14"/>
                                                <TextBlock Text="{Binding Email}" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock Text="{Binding JobTitle}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                    <TextBlock Text=" • " FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Visibility="{Binding Department, Converter={StaticResource NullToVisibilityConverter}}"/>
                                                    <TextBlock Text="{Binding Department}" FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- 통화 버튼 -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ui:Button Appearance="Primary" ToolTip="음성 통화" Width="40" Height="40" Margin="4" Click="SearchResultCallButton_Click" Tag="{Binding}">
                                                    <ui:SymbolIcon Symbol="Call24" FontSize="18"/>
                                                </ui:Button>
                                                <ui:Button Appearance="Secondary" ToolTip="영상 통화" Width="40" Height="40" Margin="4" Click="SearchResultVideoCallButton_Click" Tag="{Binding}">
                                                    <ui:SymbolIcon Symbol="Video24" FontSize="18"/>
                                                </ui:Button>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Border>

                    <!-- 기본 화면: 통화 안내 -->
                    <StackPanel x:Name="CallsDefaultPanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <ui:SymbolIcon Symbol="Call24" FontSize="64" Foreground="{StaticResource CallsAccentBrush}" Margin="0,0,0,16"/>
                        <TextBlock Text="통화" FontSize="24" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                        <TextBlock Text="연락처를 검색하거나 다이얼 패드를 사용하세요" FontSize="14" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="실제 통화 기능은 Azure Communication Services 연동이 필요합니다" FontSize="12" Foreground="{DynamicResource TextFillColorTertiaryBrush}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== 설정 뷰 컨테이너 (Column 1-5 전체 사용, 초기에는 숨김) ========== -->
        <Border x:Name="SettingsViewBorder"
                Grid.Column="1" Grid.ColumnSpan="7"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 헤더 -->
                <Border Grid.Row="0" Padding="24,16" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,0,1">
                    <TextBlock Text="설정" FontSize="24" FontWeight="SemiBold"/>
                </Border>

                <!-- 본문 3단 레이아웃 -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 대메뉴 패널 -->
                    <Border Grid.Column="0" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="SettingsMainMenuPanel" Margin="0,8,0,0"/>
                        </ScrollViewer>
                    </Border>

                    <!-- 소메뉴 패널 -->
                    <Border Grid.Column="1" Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,1,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock x:Name="SettingsSubMenuTitle" FontWeight="SemiBold"
                                           Margin="16,16,16,8" Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                                <StackPanel x:Name="SettingsSubMenuPanel"/>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <!-- 설정 내용 패널 -->
                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="SettingsContentPanel" Margin="24,16"/>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </Border>

        <!-- ========== AI 분석 패널 영역 (Column 7) ========== -->
        <Border x:Name="AIPanelBorder" Grid.Column="7"
                Background="{DynamicResource ControlOnImageFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ========== OneDrive 사이드 패널 (OneDrive 탭 활성 시 표시) ========== -->
                <Border x:Name="OneDriveSidePanel" Grid.Row="0" Grid.RowSpan="2"
                        Visibility="Collapsed">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12">
                        <StackPanel>
                            <!-- 다음으로 파일 찾아보기 -->
                            <Expander x:Name="OneDriveRightFindByExpander"
                                      IsExpanded="True"
                                      Padding="0"
                                      Margin="0,0,0,20">
                                <Expander.Header>
                                    <TextBlock Text="다음으로 파일 찾아보기" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Expander.Header>
                                <StackPanel Margin="0,8,0,0">
                                    <!-- 사람 -->
                                    <ui:Button x:Name="OneDriveRightFindByPeople"
                                               Content="사람"
                                               Icon="{ui:SymbolIcon Person20}"
                                               Appearance="Transparent"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Left"
                                               Padding="10,8"
                                               Click="OneDriveFindBy_Click"
                                               Tag="people"/>
                                    <!-- 모임 -->
                                    <ui:Button x:Name="OneDriveRightFindByMeetings"
                                               Content="모임"
                                               Icon="{ui:SymbolIcon CalendarLtr20}"
                                               Appearance="Transparent"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Left"
                                               Padding="10,8"
                                               Click="OneDriveFindBy_Click"
                                               Tag="meetings"/>
                                    <!-- 미디어 -->
                                    <ui:Button x:Name="OneDriveRightFindByMedia"
                                               Content="미디어"
                                               Icon="{ui:SymbolIcon Image20}"
                                               Appearance="Transparent"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Left"
                                               Padding="10,8"
                                               Click="OneDriveFindBy_Click"
                                               Tag="media"/>
                                </StackPanel>
                            </Expander>

                            <!-- 빠른 액세스 (최근 접근 파일) -->
                            <StackPanel>
                                <TextBlock Text="빠른 액세스" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,0,0,12"/>
                                <ItemsControl x:Name="OneDriveQuickAccessList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <ui:Button Appearance="Transparent"
                                                       HorizontalAlignment="Stretch"
                                                       HorizontalContentAlignment="Left"
                                                       Padding="8,10"
                                                       Margin="0,2"
                                                       Click="OneDriveQuickAccess_Click"
                                                       Tag="{Binding}">
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- 파일 타입에 따른 아이콘 -->
                                                    <Border Width="32" Height="32" Margin="0,0,12,0"
                                                            Background="{Binding IconBackground}"
                                                            CornerRadius="4">
                                                        <TextBlock Text="{Binding IconText}"
                                                                   FontSize="11" FontWeight="Bold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="13"
                                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="200"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxWidth="200"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </ui:Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ========== OneNote AI 패널 (OneNote 탭 활성 시 표시) ========== -->
                <Border x:Name="OneNoteMainAIPanel" Grid.Row="0" Grid.RowSpan="2"
                        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- AI 패널 헤더 -->
                        <Border Grid.Row="0" Padding="12,10"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Sparkle24" FontSize="20" Margin="0,0,8,0" Foreground="#7FB8D8"/>
                                <TextBlock Text="AI 분석" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- AI 탭 바 (진짜 탭 스타일) -->
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1"
                                Background="{DynamicResource ControlFillColorDefaultBrush}">
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,-1">
                                <!-- 녹음 탭 -->
                                <Border x:Name="OneNoteAITabRecord"
                                        Padding="14,8" Margin="4,4,0,0"
                                        CornerRadius="6,6,0,0"
                                        Background="{DynamicResource ApplicationBackgroundBrush}"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        BorderThickness="1,1,1,0"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="OneNoteAITab_MouseDown" Tag="record">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Mic24" FontSize="12" Margin="0,0,5,0"/>
                                        <TextBlock Text="녹음" FontSize="12" FontWeight="Medium"/>
                                    </StackPanel>
                                </Border>
                                <!-- 파일 탭 -->
                                <Border x:Name="OneNoteAITabFile"
                                        Padding="14,8" Margin="0,4,0,0"
                                        CornerRadius="6,6,0,0"
                                        Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="1,1,1,0"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="OneNoteAITab_MouseDown" Tag="file">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Attach24" FontSize="12" Margin="0,0,5,0"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        <TextBlock Text="파일" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- AI 탭 컨텐츠 -->
                        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                            <Grid>
                                <!-- 녹음 탭 -->
                                <Border x:Name="OneNoteAIRecordPanel" Visibility="Visible" Padding="12">
                                    <StackPanel>
                                        <!-- 녹음 컨트롤 -->
                                        <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                CornerRadius="8" Padding="16" Margin="0,0,0,16">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="160"/>
                                                </Grid.RowDefinitions>

                                                <!-- 탭 헤더 -->
                                                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                                                    <Border x:Name="OneNoteRecordTab"
                                                            Background="{DynamicResource ApplicationBackgroundBrush}"
                                                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                            BorderThickness="1" CornerRadius="4" Padding="12,6"
                                                            Cursor="Hand" MouseDown="OneNoteRecordTab_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon x:Name="OneNoteRecordTabIcon" Symbol="Mic24" FontSize="14"/>
                                                            <TextBlock x:Name="OneNoteRecordTabText" Text="녹음" FontSize="12" FontWeight="Medium" Margin="6,0,0,0"/>
                                                        </StackPanel>
                                                    </Border>
                                                    <Border x:Name="OneNoteOptionsTab"
                                                            Background="Transparent" BorderThickness="0"
                                                            CornerRadius="4" Padding="12,6" Margin="4,0,0,0"
                                                            Cursor="Hand" MouseDown="OneNoteOptionsTab_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <ui:SymbolIcon x:Name="OneNoteOptionsTabIcon" Symbol="Settings24" FontSize="14"
                                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                            <TextBlock x:Name="OneNoteOptionsTabText" Text="옵션" FontSize="12" Margin="6,0,0,0"
                                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>

                                                <!-- 녹음 탭 콘텐츠 (기본 표시) -->
                                                <StackPanel x:Name="OneNoteRecordTabContent" Grid.Row="1" MinHeight="130">
                                                    <!-- 녹음 상태 표시 -->
                                                    <TextBlock x:Name="OneNoteRecordingStatus"
                                                               Text="대기 중"
                                                               HorizontalAlignment="Center"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               Margin="0,0,0,8"/>

                                                    <!-- 녹음 시간 -->
                                                    <TextBlock x:Name="OneNoteRecordingTime"
                                                               Text="00:00"
                                                               HorizontalAlignment="Center"
                                                               FontSize="28" FontWeight="Bold"
                                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                                               Margin="0,0,0,8"/>

                                                    <!-- 볼륨 레벨 바 -->
                                                    <ProgressBar x:Name="OneNoteVolumeLevel"
                                                                 Height="6" Minimum="0" Maximum="1" Value="0"
                                                                 Margin="0,0,0,16"/>

                                                    <!-- 녹음 버튼들 -->
                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                        <!-- 녹음 시작/중지 버튼 -->
                                                        <ui:Button x:Name="OneNoteRecordStartButton"
                                                                   Icon="{ui:SymbolIcon Mic24}"
                                                                   Appearance="Primary"
                                                                   ToolTip="녹음 시작"
                                                                   Width="48" Height="48"
                                                                   Margin="4"
                                                                   Click="OneNoteRecordStart_Click"/>

                                                        <!-- 일시정지/재개 버튼 -->
                                                        <ui:Button x:Name="OneNoteRecordPauseButton"
                                                                   Icon="{ui:SymbolIcon Pause24}"
                                                                   Appearance="Secondary"
                                                                   ToolTip="일시정지"
                                                                   Width="48" Height="48"
                                                                   Margin="4"
                                                                   IsEnabled="False"
                                                                   Click="OneNoteRecordPause_Click"/>

                                                        <!-- 취소 버튼 -->
                                                        <ui:Button x:Name="OneNoteRecordCancelButton"
                                                                   Icon="{ui:SymbolIcon Delete24}"
                                                                   Appearance="Caution"
                                                                   ToolTip="녹음 취소"
                                                                   Width="48" Height="48"
                                                                   Margin="4"
                                                                   IsEnabled="False"
                                                                   Click="OneNoteRecordCancel_Click"/>
                                                    </StackPanel>
                                                </StackPanel>

                                                <!-- 옵션 탭 콘텐츠 (기본 숨김) -->
                                                <Border x:Name="OneNoteOptionsTabContent" Grid.Row="1" Visibility="Collapsed"
                                                        Padding="10,8"
                                                        VerticalAlignment="Stretch">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 첫 번째 줄: STT 주기 -->
                                                        <ToggleButton x:Name="OneNoteAutoSTTToggle" Grid.Row="0" Grid.Column="0"
                                                                      IsChecked="True"
                                                                      ToolTip="자동 STT 분석 (녹음 시 실시간 음성인식)"
                                                                      Width="24" Height="24"
                                                                      Padding="0" Margin="0,0,6,6"
                                                                      Click="OneNoteAutoSTTToggle_Click">
                                                            <ui:SymbolIcon Symbol="Mic16" FontSize="12" Foreground="#333333"/>
                                                        </ToggleButton>
                                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="STT" FontSize="12" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" Margin="0,0,8,6"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <ComboBox x:Name="OneNoteSTTIntervalSelector" Grid.Row="0" Grid.Column="2"
                                                                  Width="90" Height="28"
                                                                  FontSize="11"
                                                                  Padding="8,4"
                                                                  SelectedIndex="2"
                                                                  HorizontalAlignment="Left"
                                                                  Margin="0,0,0,6"
                                                                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                  BorderThickness="1"
                                                                  SelectionChanged="OneNoteSTTIntervalSelector_SelectionChanged"
                                                                  ToolTip="STT 분석 주기 (실시간 청크 간격)">
                                                            <ComboBoxItem Content="5초" Tag="5"/>
                                                            <ComboBoxItem Content="10초" Tag="10"/>
                                                            <ComboBoxItem Content="15초" Tag="15"/>
                                                            <ComboBoxItem Content="20초" Tag="20"/>
                                                            <ComboBoxItem Content="30초" Tag="30"/>
                                                            <ComboBoxItem Content="1분" Tag="60"/>
                                                        </ComboBox>

                                                        <!-- 두 번째 줄: STT 모델 선택 -->
                                                        <ComboBox x:Name="OneNoteSTTModelSelector" Grid.Row="1" Grid.Column="2"
                                                                  Width="140" Height="28"
                                                                  FontSize="11"
                                                                  Padding="8,4"
                                                                  SelectedIndex="2"
                                                                  HorizontalAlignment="Left"
                                                                  Margin="0,0,0,6"
                                                                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                  BorderThickness="1"
                                                                  SelectionChanged="OneNoteSTTModelSelector_SelectionChanged"
                                                                  ToolTip="STT 모델 선택">
                                                            <ComboBoxItem Content="SenseVoice" Tag="sensevoice"/>
                                                            <ComboBoxItem Content="Whisper" Tag="whisper"/>
                                                            <ComboBoxItem Content="Whisper (GPU)" Tag="whispergpu"/>
                                                        </ComboBox>

                                                        <!-- 세 번째 줄: 요약 주기 -->
                                                        <ToggleButton x:Name="OneNoteAutoSummaryToggle" Grid.Row="2" Grid.Column="0"
                                                                      IsChecked="True"
                                                                      ToolTip="자동 요약 (STT 결과를 AI로 요약)"
                                                                      Width="24" Height="24"
                                                                      Padding="0" Margin="0,0,6,0"
                                                                      Click="OneNoteAutoSummaryToggle_Click">
                                                            <ui:SymbolIcon Symbol="Sparkle16" FontSize="12" Foreground="#333333"/>
                                                        </ToggleButton>
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="요약" FontSize="12" FontWeight="SemiBold"
                                                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        <ComboBox x:Name="OneNoteSummaryIntervalSelector" Grid.Row="2" Grid.Column="2"
                                                                  Width="90" Height="28"
                                                                  FontSize="11"
                                                                  Padding="8,4"
                                                                  SelectedIndex="2"
                                                                  HorizontalAlignment="Left"
                                                                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                                  BorderThickness="1"
                                                                  SelectionChanged="OneNoteSummaryIntervalSelector_SelectionChanged"
                                                                  ToolTip="AI 요약 주기">
                                                            <ComboBoxItem Content="10초" Tag="10"/>
                                                            <ComboBoxItem Content="20초" Tag="20"/>
                                                            <ComboBoxItem Content="30초" Tag="30"/>
                                                            <ComboBoxItem Content="1분" Tag="60"/>
                                                            <ComboBoxItem Content="5분" Tag="300"/>
                                                            <ComboBoxItem Content="10분" Tag="600"/>
                                                        </ComboBox>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <!-- 녹음 파일 목록 헤더 -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="녹음 파일" FontWeight="SemiBold" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <ui:Button Grid.Column="1"
                                                       Icon="{ui:SymbolIcon ArrowSync24}"
                                                       Appearance="Transparent"
                                                       ToolTip="새로고침"
                                                       Padding="4"
                                                       Click="OneNoteRecordingsRefresh_Click"/>
                                        </Grid>

                                        <!-- 녹음 파일 목록 (선택 가능) -->
                                        <ListBox x:Name="OneNoteRecordingsList"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 SelectedItem="{Binding SelectedRecording, Mode=TwoWay}"
                                                 SelectionChanged="OneNoteRecordingsList_SelectionChanged">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="Padding" Value="0"/>
                                                    <Setter Property="Margin" Value="0,0,0,6"/>
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ListBoxItem">
                                                                <Border x:Name="Border"
                                                                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                        CornerRadius="6" Padding="10"
                                                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                        BorderThickness="1"
                                                                        Cursor="Hand">
                                                                    <ContentPresenter/>
                                                                </Border>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsSelected" Value="True">
                                                                        <Setter TargetName="Border" Property="BorderBrush"
                                                                                Value="{DynamicResource SystemAccentColorBrush}"/>
                                                                        <Setter TargetName="Border" Property="BorderThickness" Value="2"/>
                                                                        <Setter TargetName="Border" Property="Background"
                                                                                Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                                    </Trigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter TargetName="Border" Property="Background"
                                                                                Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                        <StackPanel>
                                                            <!-- 상단: 파일 정보 -->
                                                            <StackPanel ToolTip="{Binding FileName}">
                                                                <TextBlock Text="{Binding DisplayName}"
                                                                           FontSize="12" FontWeight="Medium"/>
                                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                                    <TextBlock Text="{Binding DurationDisplay}"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                                    <!-- STT/요약 상태 표시 -->
                                                                    <TextBlock Text=" · STT"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                                               Visibility="{Binding HasSTT, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                    <TextBlock Text=" · 요약"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                                               Visibility="{Binding HasSummary, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                                </StackPanel>
                                                            </StackPanel>

                                                            <!-- 중간: 플레이어 컨트롤 -->
                                                            <Grid Margin="0,8,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- 재생/일시정지 -->
                                                                <Button Grid.Column="0"
                                                                        Background="{DynamicResource SystemAccentColorBrush}"
                                                                        Foreground="White"
                                                                        ToolTip="재생/일시정지"
                                                                        Padding="4"
                                                                        Width="32" Height="32"
                                                                        Tag="{Binding}"
                                                                        Click="OneNoteRecordingPlay_Click">
                                                                    <ui:SymbolIcon Symbol="{Binding IsPlaying, Converter={StaticResource BoolToPlayPauseIconConverter}, FallbackValue=Play24}"/>
                                                                </Button>

                                                                <!-- 진행 바 및 시간 -->
                                                                <StackPanel Grid.Column="1" Margin="8,0" VerticalAlignment="Center">
                                                                    <Slider x:Name="RecordingProgressSlider"
                                                                            Minimum="0"
                                                                            Maximum="{Binding Duration.TotalSeconds}"
                                                                            Value="{Binding CurrentPosition.TotalSeconds, Mode=OneWay}"
                                                                            Height="16"
                                                                            Tag="{Binding}"
                                                                            IsMoveToPointEnabled="True"
                                                                            Thumb.DragCompleted="RecordingProgressSlider_DragCompleted"
                                                                            PreviewMouseLeftButtonUp="RecordingProgressSlider_PreviewMouseUp"/>
                                                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                                        <TextBlock Text="{Binding CurrentPositionDisplay}"
                                                                                   FontSize="10"
                                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                        <TextBlock Text=" / "
                                                                                   FontSize="10"
                                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                        <TextBlock Text="{Binding DurationDisplay}"
                                                                                   FontSize="10"
                                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- 하단: STT분석, 요약, 삭제 버튼 -->
                                                            <Grid Margin="0,8,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>

                                                                <!-- STT분석, 요약 버튼 -->
                                                                <StackPanel Orientation="Horizontal">
                                                                    <ui:Button Content="{Binding STTButtonContent}"
                                                                               Icon="{ui:SymbolIcon Mic24}"
                                                                               Appearance="{Binding IsSTTInProgress, Converter={StaticResource BoolToAppearanceConverter}}"
                                                                               FontSize="11"
                                                                               Padding="8,4"
                                                                               Margin="0,0,6,0"
                                                                               Tag="{Binding}"
                                                                               Click="OneNoteRecordingRunSTT_Click"/>
                                                                    <ui:Button Content="{Binding SummaryButtonContent}"
                                                                               Icon="{ui:SymbolIcon Sparkle24}"
                                                                               Appearance="{Binding IsSummaryInProgress, Converter={StaticResource BoolToAppearanceConverter}}"
                                                                               FontSize="11"
                                                                               Padding="8,4"
                                                                               Tag="{Binding}"
                                                                               Click="OneNoteRecordingRunSummary_Click"/>
                                                                </StackPanel>

                                                                <!-- 삭제 버튼 -->
                                                                <ui:Button Grid.Column="1"
                                                                           Icon="{ui:SymbolIcon Delete24}"
                                                                           Appearance="Transparent"
                                                                           ToolTip="삭제"
                                                                           Padding="4"
                                                                           Tag="{Binding}"
                                                                           Click="OneNoteRecordingDelete_Click"/>
                                                            </Grid>
                                                        </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- 녹음 파일 없을 때 -->
                                        <TextBlock x:Name="OneNoteNoRecordingsText"
                                                   Text="녹음 파일이 없습니다"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,20,0,0"
                                                   Visibility="Collapsed"/>

                                    </StackPanel>
                                </Border>

                                <!-- STT 탭 -->
                                <Border x:Name="OneNoteAISTTPanel" Visibility="Collapsed" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="음성 → 텍스트" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12"/>

                                        <!-- STT 진행 상태 -->
                                        <StackPanel x:Name="STTProgressPanel" Visibility="Collapsed" Margin="0,0,0,12">
                                            <ProgressBar IsIndeterminate="True" Height="4"/>
                                            <TextBlock Text="음성 인식 중..." FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <!-- STT 결과 없을 때 -->
                                        <StackPanel x:Name="STTEmptyPanel">
                                            <TextBlock Text="녹음 파일을 선택하고 STT를 실행하세요."
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                            <ui:Button x:Name="STTSelectRecordingButton"
                                                       Content="녹음 파일에서 STT 실행"
                                                       Appearance="Secondary"
                                                       Margin="0,12,0,0"
                                                       Click="STTSelectRecording_Click"/>
                                        </StackPanel>

                                        <!-- STT 결과 목록 -->
                                        <ScrollViewer x:Name="STTResultScrollViewer"
                                                      MaxHeight="400"
                                                      Visibility="Collapsed"
                                                      VerticalScrollBarVisibility="Auto">
                                            <ItemsControl x:Name="STTResultList">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Margin="0,4" Padding="8" CornerRadius="6"
                                                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                                BorderThickness="1">
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Speaker}"
                                                                               FontWeight="SemiBold"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                                                    <TextBlock Text="{Binding TimeRange}"
                                                                               Margin="8,0,0,0"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Text}"
                                                                           TextWrapping="Wrap"
                                                                           FontSize="12"
                                                                           Margin="0,4,0,0"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <!-- 요약 탭 -->
                                <Border x:Name="OneNoteAISummaryPanel" Visibility="Collapsed" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="AI 요약" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,12"/>

                                        <!-- 요약 진행 상태 -->
                                        <StackPanel x:Name="SummaryProgressPanel" Visibility="Collapsed" Margin="0,0,0,12">
                                            <ProgressBar IsIndeterminate="True" Height="4"/>
                                            <TextBlock Text="요약 생성 중..." FontSize="11"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <!-- 요약 결과 없을 때 -->
                                        <StackPanel x:Name="SummaryEmptyPanel">
                                            <TextBlock Text="STT 결과가 있으면 AI 요약을 생성할 수 있습니다."
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                            <ui:Button x:Name="SummaryGenerateButton"
                                                       Content="STT 결과에서 요약 생성"
                                                       Appearance="Secondary"
                                                       Margin="0,12,0,0"
                                                       Click="SummaryGenerate_Click"/>
                                        </StackPanel>

                                        <!-- 요약 결과 -->
                                        <ScrollViewer x:Name="SummaryResultScrollViewer"
                                                      MaxHeight="400"
                                                      Visibility="Collapsed"
                                                      VerticalScrollBarVisibility="Auto">
                                            <StackPanel>
                                                <!-- 제목 섹션 -->
                                                <Border x:Name="OneNoteSummaryTitleBorder" Margin="0,0,0,8" Padding="12" CornerRadius="6"
                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                        Visibility="Collapsed">
                                                    <TextBlock x:Name="OneNoteSummaryTitleText"
                                                               TextWrapping="Wrap"
                                                               FontWeight="Bold"
                                                               FontSize="14"
                                                               Foreground="White"
                                                               TextAlignment="Center"/>
                                                </Border>

                                                <!-- 요약 섹션 -->
                                                <Border Margin="0,0,0,8" Padding="10" CornerRadius="6"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="요약" FontWeight="SemiBold" FontSize="12"/>
                                                        <TextBlock x:Name="SummaryText"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="12"
                                                                   Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- 핵심 포인트 -->
                                                <Border Margin="0,0,0,8" Padding="10" CornerRadius="6"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="핵심 포인트" FontWeight="SemiBold" FontSize="12"/>
                                                        <ItemsControl x:Name="KeyPointsList" Margin="0,6,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                        <TextBlock Text="•" Margin="0,0,6,0"/>
                                                                        <TextBlock Text="{Binding}"
                                                                                   TextWrapping="Wrap"
                                                                                   FontSize="12"/>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>

                                                <!-- 액션 아이템 -->
                                                <Border Padding="10" CornerRadius="6"
                                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                                    <StackPanel>
                                                        <TextBlock Text="액션 아이템" FontWeight="SemiBold" FontSize="12"/>
                                                        <ItemsControl x:Name="ActionItemsList" Margin="0,6,0,0">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <StackPanel Orientation="Horizontal" Margin="0,2">
                                                                        <CheckBox IsChecked="{Binding IsAddedToTodo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  Margin="0,0,6,0"
                                                                                  Loaded="ActionItemCheckBox_Loaded"/>
                                                                        <TextBlock Text="{Binding DisplayText}"
                                                                                   TextWrapping="Wrap"
                                                                                   FontSize="12"
                                                                                   VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Border>

                                <!-- 파일 패널 -->
                                <Grid x:Name="OneNoteAIFilePanel" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>

                                    <!-- 파일 목록 헤더 -->
                                    <Grid Grid.Row="0" Margin="10,10,10,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="첨부파일" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <Button x:Name="OneNoteFileRefresh_Button" Grid.Column="1" Margin="0,0,5,0"
                                                Padding="8,4" Click="OneNoteFileRefresh_Click"
                                                ToolTip="새로고침">
                                            <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14"/>
                                        </Button>
                                        <Button x:Name="OneNoteFileAnalyzeAll_Button" Grid.Column="2"
                                                Padding="8,4" Click="OneNoteAttachmentAnalyzeAll_Click"
                                                ToolTip="전체 AI 분석">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="Sparkle24" FontSize="14" Margin="0,0,4,0"/>
                                                <TextBlock Text="AI 전체 분석" FontSize="12"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>

                                    <!-- 파일 목록 -->
                                    <ListBox x:Name="OneNoteFileListBox" Grid.Row="1" Margin="10,0,10,5"
                                             Background="Transparent" BorderThickness="0"
                                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                             SelectionChanged="OneNoteFileListBox_SelectionChanged"
                                             PreviewMouseLeftButtonDown="OneNoteFileListBox_PreviewMouseLeftButtonDown">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="Margin" Value="0,0,0,4"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="ItemBorder" Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                                    CornerRadius="6" Padding="10,8" BorderThickness="1"
                                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsSelected" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                                                </Trigger>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- 파일 아이콘 -->
                                                        <Image Grid.Column="0" Width="24" Height="24" Margin="0,0,8,0"
                                                               VerticalAlignment="Center"
                                                               Source="{Binding IconBase64, Converter={StaticResource Base64ToImageSourceConverter}}"
                                                               RenderOptions.BitmapScalingMode="HighQuality"
                                                               MouseLeftButtonDown="OneNoteFileItem_MouseDoubleClick" Cursor="Hand"/>
                                                        <!-- 파일명 + 상태 -->
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MouseLeftButtonDown="OneNoteFileItem_MouseDoubleClick" Cursor="Hand">
                                                            <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="Medium"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding AnalysisStatus}" FontSize="11"
                                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                        </StackPanel>
                                                        <!-- 넓게보기 버튼 (분석 결과 있을 때만, 빨강 강조) -->
                                                        <Button Grid.Column="2" Padding="4,3" Margin="2,0"
                                                                Click="OneNoteAttachmentExpandView_Click"
                                                                ToolTip="넓게 보기" VerticalAlignment="Center"
                                                                Visibility="{Binding HasAnalysis, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <ui:SymbolIcon Symbol="ArrowExpand24" FontSize="12" Foreground="#E74C3C"/>
                                                        </Button>
                                                        <!-- 분석 버튼 -->
                                                        <Button Grid.Column="3" Padding="4,3" Margin="2,0"
                                                                Click="OneNoteAttachmentAnalyze_Click"
                                                                ToolTip="AI 분석" VerticalAlignment="Center">
                                                            <ui:SymbolIcon Symbol="Sparkle24" FontSize="12"/>
                                                        </Button>
                                                        <!-- 열기 버튼 -->
                                                        <Button Grid.Column="4" Padding="4,3"
                                                                Click="OneNoteAttachmentOpen_Click"
                                                                ToolTip="파일 열기" VerticalAlignment="Center">
                                                            <ui:SymbolIcon Symbol="Open24" FontSize="12"/>
                                                        </Button>
                                                    </Grid>
                                                    <!-- 인라인 분석결과 (선택 시에만 표시, 정사각형 고정, 내부 스크롤) -->
                                                    <Border x:Name="InlineAnalysisBorder" Margin="0,6,0,0" CornerRadius="6" Padding="8"
                                                            Height="{Binding ActualWidth, RelativeSource={RelativeSource Self}}"
                                                            HorizontalAlignment="Stretch"
                                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}" BorderThickness="1"
                                                            >
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <MultiDataTrigger>
                                                                        <MultiDataTrigger.Conditions>
                                                                            <Condition Binding="{Binding HasAnalysis}" Value="True"/>
                                                                            <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True"/>
                                                                            <Condition Binding="{Binding IsSummaryExpanded}" Value="True"/>
                                                                        </MultiDataTrigger.Conditions>
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </MultiDataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                                            <TextBlock Text="{Binding AnalysisSummary}" TextWrapping="Wrap" FontSize="12"/>
                                                        </ScrollViewer>
                                                    </Border>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <!-- 빈 목록 메시지 -->
                                    <TextBlock x:Name="OneNoteFileEmptyMessage" Grid.Row="1"
                                               Text="첨부파일이 없습니다" FontSize="13"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="Collapsed"/>

                                    <!-- 분석 결과 섹션 (인라인으로 이동됨 — 이 섹션은 더 이상 사용하지 않음) -->
                                    <StackPanel x:Name="OneNoteFileAnalysisSection" Grid.Row="2" Grid.RowSpan="2" Visibility="Collapsed">
                                        <TextBlock x:Name="OneNoteFileAnalysisResult" Visibility="Collapsed"/>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- AI 패널 헤더 -->
                <Border x:Name="AIPanelHeader" Grid.Row="0"
                        Padding="16,12"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <!-- ✨ 이모지 스타일 애니메이션 -->
                        <TextBlock Text="✨" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Style.Triggers>
                                        <EventTrigger RoutedEvent="Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                     From="1" To="0.5" Duration="0:0:0.6"
                                                                     AutoReverse="True"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="AI 분석"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- AI 분석 내용 -->
                <ScrollViewer x:Name="AIPanelContent" Grid.Row="1"
                              Padding="16"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}">

                        <!-- 우선순위 -->
                        <Border Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="우선순위"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding SelectedEmail.PriorityLevel, FallbackValue='분석 대기중'}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 요약 -->
                        <Border Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="요약"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedEmail.Summary, FallbackValue='AI 분석이 완료되면 요약이 표시됩니다.'}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- 마감일 -->
                        <Border Margin="0,0,0,16"
                                Visibility="{Binding SelectedEmail.Deadline, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="마감일"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedEmail.Deadline, StringFormat='{}{0:yyyy-MM-dd}'}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 키워드 -->
                        <Border Margin="0,0,0,16"
                                Visibility="{Binding SelectedEmail.Keywords, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="키워드"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedEmail.Keywords}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ========== 캘린더 세부 일정 패널 (Column 7, 캘린더 모드에서만 표시) ========== -->
        <Border x:Name="CalendarDetailPanel" Grid.Column="7"
                Visibility="Collapsed"
                Background="{DynamicResource ControlOnImageFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1,0,0,0">
            <TabControl x:Name="CalendarTabControl">
                <!-- 일정 탭 -->
                <TabItem Header="일정">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 날짜 헤더 -->
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock x:Name="CalDetailDateText"
                                           Text="2026년 1월 17일"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="CalDetailDayText"
                                           Text="금요일"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 캘린더 세부 내용 -->
                        <ScrollViewer Grid.Row="1"
                                      Padding="16"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CalendarDetailContent">
                                <!-- 일정 목록 헤더 -->
                        <Border Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="CalDetailEventCountText"
                                           Grid.Column="0"
                                           Text="일정 (0건)"
                                           FontWeight="SemiBold"
                                           FontSize="14"/>
                                <ui:Button Grid.Column="1"
                                           x:Name="CalDetailAddEventButton"
                                           Appearance="Secondary"
                                           ToolTip="새 일정 추가"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Click="CalDetailAddEventButton_Click">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="14"/>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <!-- 일정 목록 -->
                        <StackPanel x:Name="CalDetailEventsList">
                            <!-- 일정 아이템들이 동적으로 추가됨 -->
                            <TextBlock x:Name="CalDetailNoEventsText"
                                       Text="선택한 날짜에 일정이 없습니다."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,32"/>
                        </StackPanel>

                        <!-- 월간 요약 섹션 -->
                        <Border Margin="0,24,0,0" Padding="12"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="이번 달 요약" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="총 일정"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="CalDetailMonthTotalText"
                                               Grid.Column="1" Text="0건" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="이번 주"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="CalDetailWeekTotalText"
                                               Grid.Column="1" Text="0건" FontWeight="SemiBold"/>
                                </Grid>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- TODO 탭 -->
                <TabItem Header="To Do">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- TODO 헤더 -->
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="TaskListLtr24" FontSize="20" Margin="0,0,8,0"/>
                                    <TextBlock Text="할 일 목록"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ui:Button Grid.Column="1"
                                           x:Name="RefreshTodoButton"
                                           Appearance="Secondary"
                                           ToolTip="새로고침"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Margin="0,0,4,0"
                                           Click="RefreshTodoButton_Click">
                                    <ui:SymbolIcon Symbol="ArrowSync24" FontSize="14"/>
                                </ui:Button>
                                <ui:Button Grid.Column="2"
                                           Appearance="Secondary"
                                           ToolTip="새 할 일 추가"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Click="AddTodoButton_Click">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="14"/>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <!-- TODO 목록 -->
                        <ScrollViewer Grid.Row="1"
                                      Padding="16"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <!-- 로딩 인디케이터 -->
                                <StackPanel x:Name="TodoLoadingPanel" Visibility="Collapsed"
                                            HorizontalAlignment="Center" Margin="0,32">
                                    <ui:ProgressRing IsIndeterminate="True" Width="24" Height="24"/>
                                    <TextBlock Text="불러오는 중..." FontSize="12" Margin="0,8,0,0"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                </StackPanel>

                                <!-- TODO 항목 없을 때 -->
                                <TextBlock x:Name="NoTodoText"
                                           Text="할 일이 없습니다."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,32"
                                           Visibility="Collapsed"/>

                                <!-- TODO 목록 -->
                                <ItemsControl x:Name="TodoItemsControl">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="8,10" Margin="0,0,0,6" CornerRadius="6"
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 체크박스 -->
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding IsCompleted, Mode=TwoWay}"
                                                              VerticalAlignment="Top"
                                                              Margin="0,2,8,0"
                                                              Loaded="TodoItemCheckBox_Loaded"/>

                                                    <!-- 제목 및 마감일 -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Title}"
                                                                   FontSize="13"
                                                                   TextWrapping="Wrap"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxHeight="40"/>
                                                        <TextBlock Text="{Binding DueDateDisplay}"
                                                                   FontSize="11"
                                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                                   Visibility="{Binding DueDate, Converter={StaticResource NullToVisibilityConverter}}"
                                                                   Margin="0,2,0,0"/>
                                                    </StackPanel>

                                                    <!-- 중요도 아이콘 -->
                                                    <ui:SymbolIcon Grid.Column="2"
                                                                   Symbol="Star24"
                                                                   FontSize="14"
                                                                   Foreground="#FFD700"
                                                                   VerticalAlignment="Top"
                                                                   Margin="4,4,0,0"
                                                                   Visibility="{Binding IsImportant, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
        </Grid>

        <!-- ========== 하단 상태바 (Row 2) - 좌측 정렬된 동기화 상태 표시 ========== -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Height="28"
                Padding="0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0: 좌측 - 동기화 상태 (탭별 표시) -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <!-- 동기화 진행 중일 때 -->
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsMailSyncProgressVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                        <!-- 진행 중 아이콘 -->
                        <ui:ProgressRing Width="14" Height="14"
                                         IsIndeterminate="True"
                                         Margin="0,0,6,0"/>
                        <!-- 진행률 텍스트: 완료/전체 (%) -->
                        <TextBlock Text="{Binding MailSyncProgressText}"
                                   Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <!-- 프로그레스바 -->
                        <ProgressBar Value="{Binding MailSyncProgress, Mode=OneWay}"
                                     Minimum="0" Maximum="100"
                                     Width="80" Height="6"
                                     Margin="8,0,0,0"
                                     Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                     Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <!-- 마지막 동기화 시간 (탭별 분기 - 진행 중이 아닐 때만 표시) -->
                    <TextBlock Text="{Binding CurrentSyncTimeText}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsMailSyncProgressVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                    <!-- 이메일/일정 개수 (모드에 따라 분기) -->
                    <TextBlock Text="{Binding StatusBarCountText}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11"
                               Margin="8,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Column 2: 우측 - AI 분석 상태 및 동기화 토글 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,12,0">
                    <!-- AI 아이콘 -->
                    <TextBlock Text="🤖" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <!-- AI 진행률 텍스트 -->
                    <TextBlock Text="{Binding AiAnalysisProgressText}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <!-- AI 프로그레스바 -->
                    <ProgressBar Value="{Binding AiAnalysisProgress, Mode=OneWay}"
                                 Minimum="0" Maximum="100"
                                 Width="60" Height="6"
                                 Margin="6,0,0,0"
                                 Foreground="#4CAF50"
                                 Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                    <!-- 동기화 토글 버튼 -->
                    <ui:Button Content="{Binding SyncButtonIcon}"
                               Command="{Binding ToggleSyncCommand}"
                               ToolTip="{Binding SyncButtonTooltip}"
                               Appearance="Secondary"
                               FontSize="10"
                               Width="28" Height="22"
                               Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
