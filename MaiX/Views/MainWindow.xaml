                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- 콘텐츠 영역 (선택 배경 적용) -->
                                            <Border x:Name="ContentBorder"
                                                    Grid.Row="0"
                                                    Background="Transparent"
                                                    CornerRadius="4"
                                                    Margin="4,2,4,0">
