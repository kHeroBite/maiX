<ui:FluentWindow x:Class="MaiX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:MaiX.Views"
        xmlns:vm="clr-namespace:MaiX.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        PreviewKeyDown="MainWindow_PreviewKeyDown">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            Height="40"
            ShowMaximize="False"
            ShowMinimize="False"
            ShowClose="False"
            CanMaximize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Width="18" Height="18"
                              Margin="0,-1,0,0"
                              RenderOptions.BitmapScalingMode="HighQuality"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                    <ui:ImageIcon.Source>
                        <BitmapImage UriSource="pack://application:,,,/Assets/icon.png"
                                     DecodePixelWidth="36"
                                     DecodePixelHeight="36"
                                     CacheOption="OnLoad"/>
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <Grid HorizontalAlignment="Stretch">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: 로고 (mAiX - Ai 하늘색, X 도트 디자인) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="m" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Text="Ai" FontSize="16" FontWeight="Bold" Foreground="#7FB8D8"/>
                        <!-- X: 도트 디자인 (연한 색상) -->
                        <Canvas Width="12" Height="12" Margin="1,2,0,0">
                            <!-- 그림자 도트 (오프셋) -->
                            <Rectangle Canvas.Left="1" Canvas.Top="1" Width="2" Height="2" Fill="#777777"/>
                            <Rectangle Canvas.Left="9" Canvas.Top="1" Width="2" Height="2" Fill="#777777"/>
                            <Rectangle Canvas.Left="3" Canvas.Top="3" Width="2" Height="2" Fill="#666666"/>
                            <Rectangle Canvas.Left="7" Canvas.Top="3" Width="2" Height="2" Fill="#666666"/>
                            <Rectangle Canvas.Left="5" Canvas.Top="5" Width="2" Height="2" Fill="#555555"/>
                            <Rectangle Canvas.Left="3" Canvas.Top="7" Width="2" Height="2" Fill="#666666"/>
                            <Rectangle Canvas.Left="7" Canvas.Top="7" Width="2" Height="2" Fill="#666666"/>
                            <Rectangle Canvas.Left="1" Canvas.Top="9" Width="2" Height="2" Fill="#777777"/>
                            <Rectangle Canvas.Left="9" Canvas.Top="9" Width="2" Height="2" Fill="#777777"/>
                            <!-- 메인 도트 -->
                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Rectangle Canvas.Left="8" Canvas.Top="0" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Rectangle Canvas.Left="2" Canvas.Top="2" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Rectangle Canvas.Left="6" Canvas.Top="2" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="4" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Rectangle Canvas.Left="2" Canvas.Top="6" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Rectangle Canvas.Left="6" Canvas.Top="6" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Rectangle Canvas.Left="0" Canvas.Top="8" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                            <Rectangle Canvas.Left="8" Canvas.Top="8" Width="2" Height="2" Fill="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </Canvas>
                    </StackPanel>

                    <!-- Column 1: 메뉴바 (타이틀바로 이동) -->
                    <Menu Grid.Column="1" VerticalAlignment="Center" Background="Transparent" Margin="0,0,16,0">
                        <MenuItem Padding="8,4">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="PlugConnected24" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="접속" VerticalAlignment="Center"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem x:Name="MenuAutoLogin" Click="MenuAutoLogin_Click">
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon x:Name="AutoLoginCheckIcon" Grid.Column="0" Symbol="Checkmark24" FontSize="12" Visibility="Collapsed" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="자동로그인" VerticalAlignment="Center"/>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="MenuLogout_Click">
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0" Symbol="SignOut24" FontSize="12" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="로그아웃" VerticalAlignment="Center"/>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Click="MenuExit_Click">
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0" Symbol="Dismiss24" FontSize="12" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="종료" VerticalAlignment="Center"/>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                        <!-- 동기화 메뉴 (신규 통합) -->
                        <MenuItem Padding="8,4">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowSync24" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="동기화" VerticalAlignment="Center"/>
                                </StackPanel>
                            </MenuItem.Header>

                            <!-- AI 서브메뉴 -->
                            <MenuItem>
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="✨" FontSize="10" HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="AI" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                    </Grid>
                                </MenuItem.Header>
                                <MenuItem x:Name="MenuAISyncPause2" Click="MenuAISyncPause_Click"
                                          Visibility="{Binding IsAISyncPaused, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                    <MenuItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon x:Name="MenuAISyncPauseIcon" Grid.Column="0" Symbol="Pause24" FontSize="12" Foreground="#FFD700" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="분석 중지" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem x:Name="MenuAISyncResume2" Click="MenuAISyncResume_Click"
                                          Visibility="{Binding IsAISyncPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <MenuItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon x:Name="MenuAISyncResumeIcon" Grid.Column="0" Symbol="Play24" FontSize="12" Foreground="#888888" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="분석 시작" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <!-- 즐겨찾기(메일) 분석 기간 - 신규 -->
                                <MenuItem x:Name="MenuFavoriteAiPeriod">
                                    <MenuItem.Header>
                                        <Grid MinWidth="130">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="Star24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="즐겨찾기(메일) 분석 기간" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="MenuFavoriteAiPeriodCurrent" Header="현재: 최근 5건" IsEnabled="False" FontStyle="Italic"/>
                                    <Separator/>
                                    <MenuItem x:Name="MenuFavoriteAiPeriod5" Header="최근 5건" Click="MenuFavoriteAiPeriod_Click" Tag="Count:5"/>
                                    <MenuItem x:Name="MenuFavoriteAiPeriodDay" Header="하루" Click="MenuFavoriteAiPeriod_Click" Tag="Days:1"/>
                                    <MenuItem x:Name="MenuFavoriteAiPeriodWeek" Header="1주일" Click="MenuFavoriteAiPeriod_Click" Tag="Weeks:1"/>
                                    <MenuItem x:Name="MenuFavoriteAiPeriodMonth" Header="1달" Click="MenuFavoriteAiPeriod_Click" Tag="Months:1"/>
                                    <MenuItem x:Name="MenuFavoriteAiPeriodYear" Header="1년" Click="MenuFavoriteAiPeriod_Click" Tag="Years:1"/>
                                    <MenuItem x:Name="MenuFavoriteAiPeriodAll" Header="전체" Click="MenuFavoriteAiPeriod_Click" Tag="All:0"/>
                                </MenuItem>
                                <!-- 즐겨찾기(메일) 분석 주기 -->
                                <MenuItem x:Name="MenuFavoriteAnalysisInterval">
                                    <MenuItem.Header>
                                        <Grid MinWidth="130">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="Clock24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="즐겨찾기(메일) 분석 주기" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="MenuFavoriteAnalysisIntervalCurrent" Header="현재: 30초" IsEnabled="False" FontStyle="Italic"/>
                                    <Separator/>
                                    <MenuItem x:Name="MenuFavoriteAnalysisInterval1s" Header="1초" Click="MenuFavoriteAnalysisInterval_Click" Tag="1"/>
                                    <MenuItem x:Name="MenuFavoriteAnalysisInterval5s" Header="5초" Click="MenuFavoriteAnalysisInterval_Click" Tag="5"/>
                                    <MenuItem x:Name="MenuFavoriteAnalysisInterval10s" Header="10초" Click="MenuFavoriteAnalysisInterval_Click" Tag="10"/>
                                    <MenuItem x:Name="MenuFavoriteAnalysisInterval30s" Header="30초" Click="MenuFavoriteAnalysisInterval_Click" Tag="30"/>
                                    <MenuItem x:Name="MenuFavoriteAnalysisInterval1m" Header="1분" Click="MenuFavoriteAnalysisInterval_Click" Tag="60"/>
                                    <MenuItem x:Name="MenuFavoriteAnalysisInterval5m" Header="5분" Click="MenuFavoriteAnalysisInterval_Click" Tag="300"/>
                                </MenuItem>
                                <Separator/>
                                <!-- 전체 분석 기간 -->
                                <MenuItem x:Name="MenuAIAnalysisPeriod">
                                    <MenuItem.Header>
                                        <Grid MinWidth="100">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="CalendarLtr24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="전체 분석 기간" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="MenuAIAnalysisPeriodCurrent" Header="현재: 최근 5건" IsEnabled="False" FontStyle="Italic"/>
                                    <Separator/>
                                    <MenuItem x:Name="MenuAIAnalysis5" Header="최근 5건" Click="MenuAIAnalysis5_Click"/>
                                    <MenuItem x:Name="MenuAIAnalysisDay" Header="하루" Click="MenuAIAnalysisDay_Click"/>
                                    <MenuItem x:Name="MenuAIAnalysisWeek" Header="1주일" Click="MenuAIAnalysisWeek_Click"/>
                                    <MenuItem x:Name="MenuAIAnalysisMonth" Header="1달" Click="MenuAIAnalysisMonth_Click"/>
                                    <MenuItem x:Name="MenuAIAnalysisYear" Header="1년" Click="MenuAIAnalysisYear_Click"/>
                                    <MenuItem x:Name="MenuAIAnalysisAll" Header="전체" Click="MenuAIAnalysisAll_Click"/>
                                </MenuItem>
                                <!-- 전체 분석 주기 -->
                                <MenuItem x:Name="MenuFullAnalysisInterval">
                                    <MenuItem.Header>
                                        <Grid MinWidth="130">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="Clock24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="전체 분석 주기" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="MenuFullAnalysisIntervalCurrent" Header="현재: 5분" IsEnabled="False" FontStyle="Italic"/>
                                    <Separator/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval1s" Header="1초" Click="MenuFullAnalysisInterval_Click" Tag="1"/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval5s" Header="5초" Click="MenuFullAnalysisInterval_Click" Tag="5"/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval10s" Header="10초" Click="MenuFullAnalysisInterval_Click" Tag="10"/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval30s" Header="30초" Click="MenuFullAnalysisInterval_Click" Tag="30"/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval1m" Header="1분" Click="MenuFullAnalysisInterval_Click" Tag="60"/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval5m" Header="5분" Click="MenuFullAnalysisInterval_Click" Tag="300"/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval10m" Header="10분" Click="MenuFullAnalysisInterval_Click" Tag="600"/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval30m" Header="30분" Click="MenuFullAnalysisInterval_Click" Tag="1800"/>
                                    <MenuItem x:Name="MenuFullAnalysisInterval1h" Header="1시간" Click="MenuFullAnalysisInterval_Click" Tag="3600"/>
                                </MenuItem>
                            </MenuItem>

                            <!-- MS365 서브메뉴 -->
                            <MenuItem>
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0" Symbol="Cloud24" FontSize="12" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="MS365" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                    </Grid>
                                </MenuItem.Header>
                                <MenuItem x:Name="MenuMailSyncPause" Click="MenuMailSyncPause_Click"
                                          Visibility="{Binding IsSyncPaused, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                    <MenuItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon x:Name="MenuMailSyncPauseIcon" Grid.Column="0" Symbol="Pause24" FontSize="12" Foreground="#0078D4" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="동기화 중지" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem x:Name="MenuMailSyncResume" Click="MenuMailSyncResume_Click"
                                          Visibility="{Binding IsSyncPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <MenuItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon x:Name="MenuMailSyncResumeIcon" Grid.Column="0" Symbol="Play24" FontSize="12" Foreground="#888888" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="동기화 시작" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                                <Separator/>
                                <!-- 즐겨찾기(메일) 동기화 기간 - 신규 -->
                                <MenuItem x:Name="MenuFavoriteSyncPeriod">
                                    <MenuItem.Header>
                                        <Grid MinWidth="130">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="Star24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="즐겨찾기(메일) 동기화 기간" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="MenuFavoriteSyncPeriodCurrent" Header="현재: 최근 5건" IsEnabled="False" FontStyle="Italic"/>
                                    <Separator/>
                                    <MenuItem x:Name="MenuFavoriteSyncPeriod5" Header="최근 5건" Click="MenuFavoriteSyncPeriod_Click" Tag="Count:5"/>
                                    <MenuItem x:Name="MenuFavoriteSyncPeriodDay" Header="하루" Click="MenuFavoriteSyncPeriod_Click" Tag="Days:1"/>
                                    <MenuItem x:Name="MenuFavoriteSyncPeriodWeek" Header="1주일" Click="MenuFavoriteSyncPeriod_Click" Tag="Weeks:1"/>
                                    <MenuItem x:Name="MenuFavoriteSyncPeriodMonth" Header="1달" Click="MenuFavoriteSyncPeriod_Click" Tag="Months:1"/>
                                    <MenuItem x:Name="MenuFavoriteSyncPeriodYear" Header="1년" Click="MenuFavoriteSyncPeriod_Click" Tag="Years:1"/>
                                    <MenuItem x:Name="MenuFavoriteSyncPeriodAll" Header="전체" Click="MenuFavoriteSyncPeriod_Click" Tag="All:0"/>
                                </MenuItem>
                                <!-- 즐겨찾기(메일) 동기화 주기 -->
                                <MenuItem x:Name="MenuFavoriteSyncInterval">
                                    <MenuItem.Header>
                                        <Grid MinWidth="130">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="Clock24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="즐겨찾기(메일) 동기화 주기" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="MenuFavoriteSyncIntervalCurrent" Header="현재: 30초" IsEnabled="False" FontStyle="Italic"/>
                                    <Separator/>
                                    <MenuItem x:Name="MenuFavoriteSyncInterval1s" Header="1초" Click="MenuFavoriteSyncInterval_Click" Tag="1"/>
                                    <MenuItem x:Name="MenuFavoriteSyncInterval5s" Header="5초" Click="MenuFavoriteSyncInterval_Click" Tag="5"/>
                                    <MenuItem x:Name="MenuFavoriteSyncInterval10s" Header="10초" Click="MenuFavoriteSyncInterval_Click" Tag="10"/>
                                    <MenuItem x:Name="MenuFavoriteSyncInterval30s" Header="30초" Click="MenuFavoriteSyncInterval_Click" Tag="30"/>
                                    <MenuItem x:Name="MenuFavoriteSyncInterval1m" Header="1분" Click="MenuFavoriteSyncInterval_Click" Tag="60"/>
                                    <MenuItem x:Name="MenuFavoriteSyncInterval5m" Header="5분" Click="MenuFavoriteSyncInterval_Click" Tag="300"/>
                                </MenuItem>
                                <Separator/>
                                <!-- 전체 동기화 기간 -->
                                <MenuItem x:Name="MenuSyncPeriod">
                                    <MenuItem.Header>
                                        <Grid MinWidth="100">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="CalendarLtr24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="전체 동기화 기간" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="MenuSyncPeriodCurrent" Header="현재: 최근 5건" IsEnabled="False" FontStyle="Italic"/>
                                    <Separator/>
                                    <MenuItem x:Name="MenuMailSync5" Header="최근 5건" Click="MenuMailSync5_Click"/>
                                    <MenuItem x:Name="MenuMailSyncDay" Header="하루" Click="MenuMailSyncDay_Click"/>
                                    <MenuItem x:Name="MenuMailSyncWeek" Header="1주일" Click="MenuMailSyncWeek_Click"/>
                                    <MenuItem x:Name="MenuMailSyncMonth" Header="1달" Click="MenuMailSyncMonth_Click"/>
                                    <MenuItem x:Name="MenuMailSyncYear" Header="1년" Click="MenuMailSyncYear_Click"/>
                                    <MenuItem x:Name="MenuMailSyncAll" Header="전체" Click="MenuMailSyncAll_Click"/>
                                </MenuItem>
                                <!-- 전체 동기화 주기 -->
                                <MenuItem x:Name="MenuFullSyncInterval">
                                    <MenuItem.Header>
                                        <Grid MinWidth="130">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="Clock24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="전체 동기화 주기" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                        </Grid>
                                    </MenuItem.Header>
                                    <MenuItem x:Name="MenuFullSyncIntervalCurrent" Header="현재: 5분" IsEnabled="False" FontStyle="Italic"/>
                                    <Separator/>
                                    <MenuItem x:Name="MenuFullSyncInterval1s" Header="1초" Click="MenuFullSyncInterval_Click" Tag="1"/>
                                    <MenuItem x:Name="MenuFullSyncInterval5s" Header="5초" Click="MenuFullSyncInterval_Click" Tag="5"/>
                                    <MenuItem x:Name="MenuFullSyncInterval10s" Header="10초" Click="MenuFullSyncInterval_Click" Tag="10"/>
                                    <MenuItem x:Name="MenuFullSyncInterval30s" Header="30초" Click="MenuFullSyncInterval_Click" Tag="30"/>
                                    <MenuItem x:Name="MenuFullSyncInterval1m" Header="1분" Click="MenuFullSyncInterval_Click" Tag="60"/>
                                    <MenuItem x:Name="MenuFullSyncInterval5m" Header="5분" Click="MenuFullSyncInterval_Click" Tag="300"/>
                                    <MenuItem x:Name="MenuFullSyncInterval10m" Header="10분" Click="MenuFullSyncInterval_Click" Tag="600"/>
                                    <MenuItem x:Name="MenuFullSyncInterval30m" Header="30분" Click="MenuFullSyncInterval_Click" Tag="1800"/>
                                    <MenuItem x:Name="MenuFullSyncInterval1h" Header="1시간" Click="MenuFullSyncInterval_Click" Tag="3600"/>
                                </MenuItem>
                                <Separator/>
                                <!-- 전체 재동기화 -->
                                <MenuItem Click="MenuForceResync_Click">
                                    <MenuItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="ArrowSync24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock Grid.Column="1" Text="전체 재동기화" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                            </MenuItem>
                        </MenuItem>
                        <MenuItem Padding="8,4">
                            <MenuItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Settings24" FontSize="12" Margin="0,0,4,0"/>
                                    <TextBlock Text="시스템" VerticalAlignment="Center"/>
                                </StackPanel>
                            </MenuItem.Header>
                            <MenuItem Click="MenuApiSettings_Click">
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0" Symbol="Key24" FontSize="12" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="API 관리" VerticalAlignment="Center"/>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                            <MenuItem Click="MenuSignatureSettings_Click">
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0" Symbol="Signature24" FontSize="12" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="서명 관리" VerticalAlignment="Center"/>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                            <Separator/>
                            <MenuItem>
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="30"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon Grid.Column="0" Symbol="ColorBackground24" FontSize="12" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="테마" VerticalAlignment="Center" Margin="0,0,20,0"/>
                                    </Grid>
                                </MenuItem.Header>
                                <MenuItem x:Name="MenuThemeDark2" Click="MenuThemeDark_Click">
                                    <MenuItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon x:Name="MenuThemeDarkIcon" Grid.Column="0" Symbol="WeatherMoon24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock x:Name="MenuThemeDarkText" Grid.Column="1" Text="다크 모드" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem x:Name="MenuThemeLight2" Click="MenuThemeLight_Click">
                                    <MenuItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon x:Name="MenuThemeLightIcon" Grid.Column="0" Symbol="WeatherSunny24" FontSize="12" HorizontalAlignment="Left"/>
                                            <TextBlock x:Name="MenuThemeLightText" Grid.Column="1" Text="라이트 모드" VerticalAlignment="Center"/>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                            </MenuItem>
                            <Separator/>
                            <MenuItem x:Name="MenuGpuMode2" Click="MenuGpuMode_Click">
                                <MenuItem.Header>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ui:SymbolIcon x:Name="GpuModeCheckMark" Grid.Column="0" Symbol="Checkmark24" FontSize="12" Visibility="Collapsed" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="GPU 모드" VerticalAlignment="Center"/>
                                    </Grid>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <!-- Column 2: 검색 영역 (폴더선택 + 검색창 + 고급검색) - 창 크기에 따라 축소 -->
                    <Grid Grid.Column="2" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*" MinWidth="100"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 폴더 선택 드롭다운 (모든 폴더, 기본 폴더들) -->
                        <ComboBox x:Name="SearchFolderComboBox"
                                  AutomationProperties.AutomationId="SearchFolderComboBox"
                                  Grid.Column="0"
                                  Width="140"
                                  Height="32"
                                  Padding="8,2"
                                  Margin="0,0,4,0"
                                  VerticalContentAlignment="Center"
                                  ItemsSource="{Binding SearchFolderOptions}"
                                  SelectedItem="{Binding SelectedSearchFolderOption}"
                                  ToolTip="검색 대상 폴더">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- 검색창 (창 크기에 따라 축소/확장, 최소 100px) -->
                        <ui:TextBox x:Name="TitleBarSearchBox"
                                    AutomationProperties.AutomationId="TitleBarSearchBox"
                                    Grid.Column="1"
                                    PlaceholderText="🔍 메일 검색 (Ctrl+K)"
                                    Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                    Height="32"
                                    MinWidth="100"
                                    FontSize="12"
                                    Margin="0,0,4,0"
                                    KeyDown="TitleBarSearchBox_KeyDown"
                                    TextChanged="TitleBarSearchBox_TextChanged"
                                    GotFocus="TitleBarSearchBox_GotFocus"
                                    LostFocus="TitleBarSearchBox_LostFocus"/>

                        <!-- 고급 검색 버튼 -->
                        <ui:Button x:Name="AdvancedSearchButton"
                                   Grid.Column="2"
                                   ToolTip="고급 검색"
                                   Appearance="Transparent"
                                   Height="30" Width="30"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="AdvancedSearchButton_Click">
                            <ui:SymbolIcon Symbol="ChevronDown24" FontSize="14"/>
                        </ui:Button>
                    </Grid>

                </Grid>
            </ui:TitleBar.Header>

            <!-- 우측 버튼들 (최소화 버튼 왼쪽) -->
            <ui:TitleBar.TrailingContent>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <!-- AI 분석 버튼 (진행중: 노란색 별 깜빡임, 중지중: 회색 고정) -->
                    <ui:Button x:Name="AISyncButton"
                               Command="{Binding ToggleAISyncCommand}"
                               ToolTip="{Binding AISyncButtonTooltip}"
                               Style="{StaticResource TitleBarTransparentButtonStyle}">
                        <Grid>
                            <!-- 진행중일 때: ✨ 스타일 (목표 이미지와 동일하게) -->
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{Binding IsAISyncPaused, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <!-- 큰 별: 중지상태와 동일한 크기/위치/비율 -->
                                <TextBlock x:Name="AISyncStar1" Text="✦" FontSize="22" Foreground="#FFD700" Margin="3,-5,0,0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="0.8" ScaleY="1.0" />
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="1" To="0.3" Duration="0:0:1.6"
                                                                             AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- 작은 별: 중지상태와 동일한 크기/위치/비율 -->
                                <TextBlock x:Name="AISyncStar2" Text="✦" FontSize="8" Foreground="#FFDF00" Margin="2,1,0,0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="0.8" ScaleY="1.0" />
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.8">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="1" To="0.3" Duration="0:0:0.6"
                                                                             AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <!-- 중간 별: 중지상태와 동일한 크기/위치/비율 -->
                                <TextBlock x:Name="AISyncStar3" Text="✦" FontSize="10" Foreground="#FFC125" Margin="1,9,0,0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="0.8" ScaleY="1.0" />
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                             From="1" To="0.3" Duration="0:0:1.0"
                                                                             AutoReverse="True"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <!-- 중지중일 때: 회색 별 3개 -->
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{Binding IsAISyncPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="✦" FontSize="22" Foreground="#888888" Margin="3,-5,0,0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="0.8" ScaleY="1.0" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <TextBlock Text="✦" FontSize="8" Foreground="#AAAAAA" Margin="2,1,0,0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="0.8" ScaleY="1.0" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <TextBlock Text="✦" FontSize="10" Foreground="#999999" Margin="1,9,0,0"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <ScaleTransform ScaleX="0.8" ScaleY="1.0" />
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Grid>
                        </Grid>
                    </ui:Button>
                    <!-- 메일 동기화 버튼 (동기화중: 편지 꺼내기 애니메이션, 중지중: 회색 고정) -->
                    <ui:Button x:Name="SyncButton"
                               Command="{Binding ToggleSyncCommand}"
                               ToolTip="{Binding SyncButtonTooltip}"
                               Style="{StaticResource TitleBarTransparentButtonStyle}">
                        <Grid>
                            <!-- 동기화 중일 때: 열린 편지 + 나가는 문서 애니메이션 -->
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{Binding IsSyncPaused, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                <ui:SymbolIcon Symbol="MailRead24" FontSize="14" Foreground="#2196F3"/>
                                <TextBlock Text="📄" FontSize="8" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform x:Name="DocTranslate"/>
                                    </TextBlock.RenderTransform>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0" Value="2"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="-10">
                                                                    <EasingDoubleKeyFrame.EasingFunction>
                                                                        <QuadraticEase EasingMode="EaseOut"/>
                                                                    </EasingDoubleKeyFrame.EasingFunction>
                                                                </EasingDoubleKeyFrame>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="2"/>
                                                            </DoubleAnimationUsingKeyFrames>
                                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                                <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="1"/>
                                                                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0"/>
                                                                <DiscreteDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
                                                            </DoubleAnimationUsingKeyFrames>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <!-- 중지 중일 때: 회색 닫힌 편지 아이콘 -->
                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                                  Visibility="{Binding IsSyncPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                <ui:SymbolIcon Symbol="Mail24" FontSize="14" Foreground="#888888"/>
                            </Grid>
                        </Grid>
                    </ui:Button>
                    <!-- 테마 토글 버튼 -->
                    <ui:Button x:Name="ThemeToggleButton"
                               ToolTip="테마 전환"
                               Style="{StaticResource TitleBarTransparentButtonStyle}"
                               Click="ThemeToggleButton_Click">
                        <ui:SymbolIcon x:Name="ThemeIcon" Symbol="WeatherSunny24" FontSize="16"/>
                    </ui:Button>
                    <!-- GPU 모드 토글 버튼 -->
                    <ui:Button x:Name="GpuToggleButton"
                               ToolTip="GPU/CPU 렌더링 전환"
                               Style="{StaticResource TitleBarTransparentButtonStyle}"
                               Click="GpuToggleButton_Click">
                        <ui:SymbolIcon x:Name="GpuIcon" Symbol="Desktop24" FontSize="16"/>
                    </ui:Button>
                    <!-- 알림 버튼 -->
                    <ui:Button x:Name="NotificationButton"
                               ToolTip="알림"
                               Style="{StaticResource TitleBarTransparentButtonStyle}"
                               Click="NotificationButton_Click">
                        <ui:SymbolIcon Symbol="Alert24" FontSize="16"/>
                    </ui:Button>
                    <!-- 설정 버튼 (동기화 설정으로 연결) -->
                    <ui:Button x:Name="TitleBarSettingsButton"
                               ToolTip="동기화 설정"
                               Style="{StaticResource TitleBarTransparentButtonStyle}"
                               Margin="0"
                               Click="SettingsButton_Click">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="16"/>
                    </ui:Button>
                    <!-- 구분선 -->
                    <Border Width="1" Height="16" Background="{DynamicResource ControlStrokeColorDefaultBrush}" Margin="4,0,0,0" VerticalAlignment="Center"/>
                    <!-- 커스텀 최소화 버튼 -->
                    <ui:Button x:Name="CustomMinimizeButton"
                               ToolTip="최소화"
                               Style="{StaticResource TitleBarTransparentButtonStyle}"
                               Width="32" Height="32"
                               Padding="0" Margin="0"
                               Click="CustomMinimizeButton_Click">
                        <ui:SymbolIcon Symbol="Subtract24" FontSize="13"/>
                    </ui:Button>
                    <!-- 커스텀 최대화/복원 버튼 -->
                    <ui:Button x:Name="CustomMaximizeButton"
                               ToolTip="최대화"
                               Style="{StaticResource TitleBarTransparentButtonStyle}"
                               Width="32" Height="32"
                               Padding="0" Margin="0"
                               Click="CustomMaximizeButton_Click">
                        <ui:SymbolIcon x:Name="MaximizeIcon" Symbol="Maximize24" FontSize="13"/>
                    </ui:Button>
                    <!-- 커스텀 종료 버튼 -->
                    <ui:Button x:Name="CustomCloseButton"
                               ToolTip="닫기"
                               Style="{StaticResource TitleBarCloseButtonStyle}"
                               Width="32" Height="32"
                               Padding="0" Margin="0"
                               Click="CustomCloseButton_Click">
                        <ui:SymbolIcon Symbol="Dismiss24" FontSize="13"/>
                    </ui:Button>
                </StackPanel>
            </ui:TitleBar.TrailingContent>

        </ui:TitleBar>

        <!-- 고급 검색 팝업 (Window 레벨) -->
        <Popup x:Name="AdvancedSearchPopup"
               PlacementTarget="{Binding ElementName=AdvancedSearchButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,4,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel Width="380">
                    <TextBlock Text="고급 검색" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                    <TextBlock Text="발신자" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="보낸 사람 이메일 또는 이름"
                                Text="{Binding AdvancedSearchFrom, UpdateSourceTrigger=PropertyChanged}"
                                Height="32" Margin="0,0,0,8"/>

                    <TextBlock Text="수신자" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="받는 사람 이메일 또는 이름"
                                Text="{Binding AdvancedSearchTo, UpdateSourceTrigger=PropertyChanged}"
                                Height="32" Margin="0,0,0,8"/>

                    <TextBlock Text="제목" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="제목에 포함된 텍스트"
                                Text="{Binding AdvancedSearchSubject, UpdateSourceTrigger=PropertyChanged}"
                                Height="32" Margin="0,0,0,8"/>

                    <TextBlock Text="본문" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="본문에 포함된 텍스트"
                                Text="{Binding AdvancedSearchBody, UpdateSourceTrigger=PropertyChanged}"
                                Height="32" Margin="0,0,0,8"/>

                    <TextBlock Text="날짜 범위" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <DatePicker x:Name="DateFromPicker" SelectedDate="{Binding AdvancedSearchDateFrom}" Width="175"
                                    Loaded="DatePicker_Loaded"/>
                        <TextBlock Text="~" VerticalAlignment="Center" Margin="8,0"/>
                        <DatePicker x:Name="DateToPicker" SelectedDate="{Binding AdvancedSearchDateTo}" Width="175"
                                    Loaded="DatePicker_Loaded"/>
                    </StackPanel>

                    <CheckBox Content="첨부파일 있는 메일만"
                              IsChecked="{Binding AdvancedSearchHasAttachment}"
                              Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="초기화"
                                   Appearance="Secondary"
                                   Margin="0,0,8,0"
                                   Click="AdvancedSearchClear_Click"/>
                        <ui:Button Content="검색"
                                   Appearance="Primary"
                                   Click="AdvancedSearch_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- 알림 패널 팝업 (Window 레벨) -->
        <Popup x:Name="NotificationPopup"
               PlacementTarget="{Binding ElementName=NotificationButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="360"
                    MaxHeight="500"
                    Margin="0,4,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 알림 패널 헤더 -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="알림"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Appearance="Transparent"
                                           ToolTip="필터"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Margin="0,0,4,0">
                                    <ui:SymbolIcon Symbol="Filter24" FontSize="14"/>
                                </ui:Button>
                                <ui:Button Appearance="Transparent"
                                           ToolTip="알림 설정"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Margin="0,0,4,0">
                                    <ui:SymbolIcon Symbol="Settings24" FontSize="14"/>
                                </ui:Button>
                                <ui:Button Appearance="Transparent"
                                           ToolTip="닫기"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Click="CloseNotificationPopup_Click">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 알림 목록 또는 빈 상태 -->
                    <ScrollViewer Grid.Row="1" Padding="16"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="400">
                        <StackPanel x:Name="NotificationListContent">
                            <!-- 알림 없을 때 기본 상태 -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,48">
                                <ui:SymbolIcon Symbol="Alert24" FontSize="48"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,16"/>
                                <TextBlock Text="모두 확인했습니다!"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="새 알림이 없습니다."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <!-- 알림이 있을 경우 동적으로 추가됨 -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>

        <!-- 검색 자동완성 팝업 (Window 레벨) -->
        <Popup x:Name="SearchAutocompletePopup"
               PlacementTarget="{Binding ElementName=TitleBarSearchBox}"
               Placement="Bottom"
               StaysOpen="True"
               AllowsTransparency="True">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="500"
                    MaxHeight="400"
                    Margin="0,4,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 검색 헤더 (뒤로가기 + 검색) -->
                    <Border Grid.Row="0" Padding="12,8"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Appearance="Transparent"
                                       Width="24" Height="24"
                                       Padding="0"
                                       Margin="0,0,8,0"
                                       Click="SearchAutocompleteBack_Click">
                                <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="14"/>
                            </ui:Button>
                            <TextBlock Text="검색"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 검색 탭 (모두 | 메일 | 사람) -->
                    <Border Grid.Row="1" Padding="12,8"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button x:Name="SearchTabAll"
                                       Content="모두"
                                       Appearance="Primary"
                                       Height="26"
                                       Padding="12,4"
                                       Margin="0,0,4,0"
                                       Click="SearchTab_Click"/>
                            <ui:Button x:Name="SearchTabMail"
                                       Content="메일"
                                       Appearance="Secondary"
                                       Height="26"
                                       Padding="12,4"
                                       Margin="0,0,4,0"
                                       Click="SearchTab_Click"/>
                            <ui:Button x:Name="SearchTabPerson"
                                       Content="사람"
                                       Appearance="Secondary"
                                       Height="26"
                                       Padding="12,4"
                                       Click="SearchTab_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- 검색 히스토리 및 제안 목록 -->
                    <ScrollViewer Grid.Row="2" Padding="8"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="280">
                        <StackPanel x:Name="SearchSuggestionsList">
                            <!-- 최근 검색 -->
                            <TextBlock Text="최근 검색"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,8,8,4"/>

                            <!-- 최근 검색 항목들 (동적 추가) -->
                            <ItemsControl x:Name="RecentSearchItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent"
                                                Padding="8,6"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="RecentSearchItem_Click"
                                                Tag="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="History24" FontSize="14"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="✕"
                                                        FontSize="10"
                                                        Padding="4,2"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                        Cursor="Hand"
                                                        Click="RemoveRecentSearch_Click"
                                                        Tag="{Binding}"
                                                        ToolTip="검색어 삭제"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 연락처 제안 -->
                            <TextBlock Text="연락처"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,12,8,4"
                                       x:Name="ContactSuggestionsHeader"
                                       Visibility="Collapsed"/>

                            <ItemsControl x:Name="ContactSuggestionItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent"
                                                Padding="8,6"
                                                Cursor="Hand"
                                                CornerRadius="4"
                                                MouseLeftButtonUp="ContactSuggestionItem_Click"
                                                Tag="{Binding}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- 프로필 사진 / 이니셜 컨테이너 -->
                                                <Grid Grid.Column="0" Width="32" Height="32" Margin="0,0,10,0">
                                                    <!-- 프로필 사진 (있을 때만 표시) -->
                                                    <Border CornerRadius="16"
                                                            Visibility="{Binding PhotoBase64, Converter={StaticResource NullToVisibilityConverter}}">
                                                        <Border.Background>
                                                            <ImageBrush ImageSource="{Binding PhotoBase64, Converter={StaticResource Base64ToImageSourceConverter}}"
                                                                        Stretch="UniformToFill"/>
                                                        </Border.Background>
                                                    </Border>

                                                    <!-- 이니셜 아바타 (사진 없을 때 표시) -->
                                                    <Border CornerRadius="16"
                                                            Background="{DynamicResource SystemAccentColorSecondaryBrush}"
                                                            Visibility="{Binding PhotoBase64, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                                                        <TextBlock Text="{Binding Initials}"
                                                                   FontSize="12"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="White"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Border>
                                                </Grid>

                                                <!-- 이름 및 이메일 -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontWeight="Medium"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding Email, Mode=OneWay}"/>
                                                        <Run Text="{Binding PositionString, Mode=OneWay, StringFormat=' • {0}'}"
                                                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                                    </TextBlock>
                                                </StackPanel>

                                                <!-- 소스 라벨 -->
                                                <Border Grid.Column="2"
                                                        Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        VerticalAlignment="Center"
                                                        Margin="8,0,0,0">
                                                    <TextBlock Text="{Binding SourceLabel}"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>

        <!-- 메인 콘텐츠 -->
        <Grid x:Name="MainContentGrid" Grid.Row="1">
        <Grid.ColumnDefinitions>
            <!-- 좌측 네비게이션 아이콘바 -->
            <ColumnDefinition x:Name="NavBarColumn" Width="52"/>
            <!-- 폴더 트리 (250px 고정) -->
            <ColumnDefinition x:Name="FolderColumn" Width="250" MinWidth="150" MaxWidth="400"/>
            <!-- Splitter 1 -->
            <ColumnDefinition Width="Auto"/>
            <!-- 메일 리스트 (350px 기본) -->
            <ColumnDefinition x:Name="MailListColumn" Width="350" MinWidth="250" MaxWidth="600"/>
            <!-- Splitter 2 -->
            <ColumnDefinition Width="Auto"/>
            <!-- 본문 (나머지) -->
            <ColumnDefinition x:Name="BodyColumn" Width="*" MinWidth="300"/>
            <!-- Splitter 3 -->
            <ColumnDefinition Width="Auto"/>
            <!-- AI 패널 (독립 영역) -->
            <ColumnDefinition x:Name="AIColumn" Width="300" MinWidth="200" MaxWidth="500"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 좌측 네비게이션 아이콘바 (Column 0) ========== -->
        <Border Grid.Column="0"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 상단 네비게이션 아이콘들 -->
                <StackPanel Grid.Row="0" Margin="0,8,0,0">
                    <!-- ===== 상단 그룹: 핵심 기능 ===== -->
                    <!-- 메일 아이콘 (#0078D4 Outlook Blue) -->
                    <RadioButton x:Name="NavMailButton"
                                 AutomationProperties.AutomationId="NavMailButton"
                                 IsChecked="True"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavMailButton_Checked"
                                 ToolTip="메일">
                        <ui:SymbolIcon Symbol="Mail24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- 캘린더 아이콘 (#0078D4 Calendar Blue) -->
                    <RadioButton x:Name="NavCalendarButton"
                                 AutomationProperties.AutomationId="NavCalendarButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavCalendarButton_Checked"
                                 ToolTip="일정">
                        <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- 채팅 아이콘 (#6264A7 Teams Purple) -->
                    <RadioButton x:Name="NavChatButton"
                                 AutomationProperties.AutomationId="NavChatButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavChatButton_Checked"
                                 ToolTip="채팅">
                        <ui:SymbolIcon Symbol="Chat24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- 팀 아이콘 (#6264A7 Teams Purple) -->
                    <RadioButton x:Name="NavTeamsButton"
                                 AutomationProperties.AutomationId="NavTeamsButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavTeamsButton_Checked"
                                 ToolTip="팀">
                        <ui:SymbolIcon Symbol="PeopleTeam24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- 활동 아이콘 (#F7630C Activity Orange) -->
                    <RadioButton x:Name="NavActivityButton"
                                 AutomationProperties.AutomationId="NavActivityButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavActivityButton_Checked"
                                 ToolTip="활동">
                        <ui:SymbolIcon Symbol="Alert24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- 구분선 -->
                    <Separator Margin="8,8,8,8" Background="{DynamicResource ControlElevationBorderBrush}"/>

                    <!-- ===== 중단 그룹: 생산성 도구 ===== -->
                    <!-- 플래너 아이콘 (#31752F Planner Green) -->
                    <RadioButton x:Name="NavPlannerButton"
                                 AutomationProperties.AutomationId="NavPlannerButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavPlannerButton_Checked"
                                 ToolTip="플래너">
                        <ui:SymbolIcon Symbol="TaskListSquareLtr24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- OneDrive 아이콘 (#0078D4 OneDrive Blue) -->
                    <RadioButton x:Name="NavOneDriveButton"
                                 AutomationProperties.AutomationId="NavOneDriveButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavOneDriveButton_Checked"
                                 ToolTip="OneDrive">
                        <ui:SymbolIcon Symbol="Cloud24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- OneNote 아이콘 (#7719AA OneNote Purple) -->
                    <RadioButton x:Name="NavOneNoteButton"
                                 AutomationProperties.AutomationId="NavOneNoteButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavOneNoteButton_Checked"
                                 ToolTip="OneNote">
                        <ui:SymbolIcon Symbol="Notebook24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- 통화 아이콘 (#0078D4 Calling Blue) -->
                    <RadioButton x:Name="NavCallsButton"
                                 AutomationProperties.AutomationId="NavCallsButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavCallsButton_Checked"
                                 ToolTip="통화">
                        <ui:SymbolIcon Symbol="Call24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                </StackPanel>

                <!-- 하단 설정 아이콘 -->
                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <RadioButton x:Name="NavSettingsButton"
                                 AutomationProperties.AutomationId="NavSettingsButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavSettingsButton_Checked"
                                 ToolTip="설정">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== 메일 뷰 컨테이너 (Column 1-7) - 캘린더 뷰와 교체 가능 ========== -->

        <!-- ========== 폴더 트리 영역 (Column 1) ========== -->
        <Border x:Name="FolderTreeBorder" Grid.Column="1"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 폴더 헤더 -->
                <Border Grid.Row="0" Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Folder24" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="폴더" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 즐겨찾기 섹션 (라벨 없이 폴더만 표시) -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Margin="0,0,0,4"
                        x:Name="FavoriteSection">
                    <StackPanel>
                        <!-- 즐겨찾기 폴더 목록 (드래그&드롭 순서 변경 지원) -->
                        <ListBox x:Name="FavoriteListBox"
                                 AutomationProperties.AutomationId="FavoriteListBox"
                                 ItemsSource="{Binding FavoriteFolders}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="4,0,4,4"
                                 AllowDrop="True"
                                 SelectionChanged="FavoriteListBox_SelectionChanged"
                                 PreviewMouseRightButtonDown="FavoriteListBox_PreviewMouseRightButtonDown"
                                 PreviewMouseLeftButtonDown="FavoriteListBox_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="FavoriteListBox_PreviewMouseMove"
                                 Drop="FavoriteListBox_Drop"
                                 DragOver="FavoriteListBox_DragOver">
                            <ListBox.Resources>
                                <Style TargetType="ContextMenu">
                                    <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                                    <Setter Property="Padding" Value="4"/>
                                </Style>
                                <Style x:Key="SimpleMenuItemStyle" TargetType="MenuItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter ContentSource="Header"
                                                                      RecognizesAccessKey="True"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SelectionBackgroundBrush}"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ContextMenu>
                                <ContextMenu Background="{DynamicResource ApplicationBackgroundBrush}"
                                             BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                             Padding="4"
                                             HasDropShadow="True">
                                    <ContextMenu.Template>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ContextMenu.Template>
                                    <MenuItem Click="RemoveFavorite_Click" Header="☆ 즐겨찾기 제거"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <MenuItem.Template>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Border"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="12,8">
                                                    <TextBlock Text="{TemplateBinding Header}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </MenuItem.Template>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Click="FolderResync_Click" Header="🔄 이 폴더 재동기화"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <MenuItem.Template>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Border"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="12,8">
                                                    <TextBlock Text="{TemplateBinding Header}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </MenuItem.Template>
                                    </MenuItem>
                                    <MenuItem Click="FolderAIReanalyze_Click" Header="🤖 AI 재분석"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <MenuItem.Template>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Border"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="12,8">
                                                    <TextBlock Text="{TemplateBinding Header}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </MenuItem.Template>
                                    </MenuItem>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:SymbolIcon Grid.Column="0"
                                                       Symbol="Star24"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource FavoriteStarBrush}"
                                                       Margin="0,0,4,0"
                                                       VerticalAlignment="Center"/>

                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="Folder24"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- 읽지 않은 메일 수 배지 -->
                                        <Border Grid.Column="3"
                                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                CornerRadius="8"
                                                Padding="5,1"
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding UnreadItemCount, Converter={StaticResource IntToVisibilityConverter}}">
                                            <TextBlock Text="{Binding UnreadItemCount}"
                                                       Foreground="White"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- 폴더 트리 -->
                <TreeView Grid.Row="2"
                          x:Name="FolderTreeView"
                          ItemsSource="{Binding FolderTree}"
                          BorderThickness="0"
                          Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          SelectedItemChanged="FolderTreeView_SelectedItemChanged"
                          AllowDrop="True"
                          DragEnter="FolderTreeView_DragEnter"
                          DragOver="FolderTreeView_DragOver"
                          Drop="FolderTreeView_Drop">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TreeViewItem">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <!-- 헤더 영역 - 전체 행 배경색 적용 -->
                                            <Border x:Name="Bd"
                                                    Grid.Row="0"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="4,2"
                                                    Margin="0,1,8,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 확장/축소 토글 -->
                                                    <ToggleButton x:Name="Expander"
                                                                  Grid.Column="0"
                                                                  ClickMode="Press"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  Width="16" Height="16"
                                                                  Margin="0,0,4,0"
                                                                  Background="Transparent"
                                                                  BorderThickness="0">
                                                        <ToggleButton.Style>
                                                            <Style TargetType="ToggleButton">
                                                                <Setter Property="Focusable" Value="False"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Padding="2">
                                                                                <Path x:Name="ExpandPath"
                                                                                      Data="M0,0 L4,4 L0,8 Z"
                                                                                      Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="ExpandPath" Property="Data" Value="M0,0 L8,0 L4,4 Z"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ToggleButton.Style>
                                                    </ToggleButton>
                                                    <!-- 콘텐츠 -->
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      Grid.Column="1"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="Stretch"/>
                                                </Grid>
                                            </Border>
                                            <!-- 자식 항목 영역 -->
                                            <ItemsPresenter x:Name="ItemsHost"
                                                            Grid.Row="1"
                                                            Margin="16,0,0,0"
                                                            Visibility="Collapsed"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsSelected" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <Style TargetType="ContextMenu">
                            <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                            <Setter Property="Padding" Value="4"/>
                        </Style>
                        <Style x:Key="SimpleMenuItemStyle" TargetType="MenuItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="Padding" Value="12,8"/>
