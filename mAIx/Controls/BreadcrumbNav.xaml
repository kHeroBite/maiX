<UserControl x:Class="mAIx.Controls.BreadcrumbNav"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="40" d:DesignWidth="600">

    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
        <!-- 홈(루트) 버튼 -->
        <ui:Button x:Name="HomeButton"
                   Icon="{ui:SymbolIcon Home20}"
                   Appearance="Transparent" Padding="6"
                   Margin="0,0,4,0"
                   ToolTip="홈"
                   Click="HomeButton_Click"/>

        <!-- 상위 폴더 버튼 -->
        <ui:Button x:Name="GoUpButton"
                   Icon="{ui:SymbolIcon ArrowUp20}"
                   Appearance="Transparent" Padding="6"
                   Margin="0,0,8,0"
                   ToolTip="상위 폴더"
                   Click="GoUpButton_Click"/>

        <!-- 경로 아이템 -->
        <ItemsControl x:Name="BreadcrumbItems">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="{Binding Name}"
                                   Appearance="Transparent"
                                   Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                   Padding="4,2" FontSize="14"
                                   Click="BreadcrumbItem_Click"
                                   Tag="{Binding}"/>
                        <TextBlock Text="›" VerticalAlignment="Center" Margin="4,0"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
