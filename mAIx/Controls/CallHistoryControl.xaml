<UserControl x:Class="mAIx.Controls.CallHistoryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Padding="16,12"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Call24" FontSize="20" Margin="0,0,8,0"
                                   Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                    <TextBlock Text="통화 이력" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="CallCountText" Text="" FontSize="12" Margin="8,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <ui:Button Grid.Column="1" x:Name="RefreshButton"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Appearance="Transparent" Padding="6"
                           ToolTip="새로고침"
                           Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <!-- 검색 + 필터 -->
        <Border Grid.Row="1" Padding="12,8"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 검색 -->
                <ui:TextBox x:Name="SearchBox" Grid.Row="0"
                           PlaceholderText="통화 이력 검색..."
                           Icon="{ui:SymbolIcon Search24}"
                           Margin="0,0,0,8"
                           TextChanged="SearchBox_TextChanged"/>

                <!-- 필터 버튼 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal">
                    <ui:Button x:Name="FilterAllButton" Content="전체" Appearance="Primary"
                               Margin="0,0,4,0" Padding="10,5" Click="FilterAllButton_Click"/>
                    <ui:Button x:Name="FilterMissedButton" Appearance="Transparent"
                               Margin="0,0,4,0" Padding="10,5" Click="FilterMissedButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="CallMissed24" FontSize="14" Margin="0,0,4,0" Foreground="#D13438"/>
                            <TextBlock Text="부재중"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="FilterIncomingButton" Appearance="Transparent"
                               Margin="0,0,4,0" Padding="10,5" Click="FilterIncomingButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="CallInbound24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="수신"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="FilterOutgoingButton" Appearance="Transparent"
                               Padding="10,5" Click="FilterOutgoingButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="CallOutbound24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="발신"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 통화 이력 목록 -->
        <Grid Grid.Row="2">
            <!-- 로딩 -->
            <ui:ProgressRing x:Name="LoadingRing" IsIndeterminate="True" Visibility="Collapsed"
                             Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- 통화 목록 -->
            <ListView x:Name="CallHistoryListView"
                      Background="Transparent" BorderThickness="0" Padding="4"
                      SelectionChanged="CallHistoryListView_SelectionChanged">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10,8" Margin="4,2"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                CornerRadius="6"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 통화 유형 아이콘 -->
                                <Border Grid.Column="0" Width="36" Height="36"
                                        CornerRadius="18" Margin="0,0,10,0"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                    <ui:SymbolIcon Symbol="Call24" FontSize="16"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- 발신자/수신자 정보 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding CallerName}" FontSize="13" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding CallerPhone}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- 시간/통화시간 -->
                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock Text="{Binding TimeText}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding DurationText}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               HorizontalAlignment="Right" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- 다시 전화 버튼 -->
                                <ui:Button Grid.Column="3" Appearance="Transparent"
                                           ToolTip="다시 전화" Width="32" Height="32"
                                           Click="CallBackButton_Click" Tag="{Binding}">
                                    <ui:SymbolIcon Symbol="Call24" FontSize="14"/>
                                </ui:Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 빈 상태 -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <ui:SymbolIcon Symbol="Call24" FontSize="48"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
                <TextBlock Text="통화 이력이 없습니다" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="통화 기록이 생기면 여기에 표시됩니다" FontSize="13"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>

        <!-- 하단: 다이얼패드 토글 -->
        <Border Grid.Row="3" Padding="12,8"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 부재중 통화 요약 -->
                <TextBlock x:Name="MissedCallsSummary" Grid.Column="0"
                           FontSize="12" VerticalAlignment="Center"
                           Foreground="#D13438"/>

                <!-- 다이얼패드 열기 -->
                <ui:Button Grid.Column="1" x:Name="DialpadToggle"
                           Content="다이얼패드" Appearance="Secondary"
                           Icon="{ui:SymbolIcon Call24}"
                           Click="DialpadToggle_Click"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
