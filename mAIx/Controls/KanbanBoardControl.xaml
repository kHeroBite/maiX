<UserControl x:Class="mAIx.Controls.KanbanBoardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:local="clr-namespace:mAIx.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1200">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 보드 헤더 (뷰 전환, 필터) -->
            <RowDefinition Height="Auto"/>
            <!-- 칸반 보드 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더: 뷰 전환 + 필터 -->
        <Border Grid.Row="0" Padding="16,8"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측: 보드 제목 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="BoardTitleText" Text="칸반 보드"
                               FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                            CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TotalTaskCountText" Text="0" FontSize="12"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>
                </StackPanel>

                <!-- 우측: 뷰 전환 + 필터 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <!-- 필터: 우선순위 -->
                    <ComboBox x:Name="PriorityFilterCombo" Width="120" Margin="0,0,8,0"
                              SelectionChanged="PriorityFilterCombo_SelectionChanged">
                        <ComboBoxItem Content="모든 우선순위" IsSelected="True"/>
                        <ComboBoxItem Content="긴급" Tag="1"/>
                        <ComboBoxItem Content="중요" Tag="3"/>
                        <ComboBoxItem Content="중간" Tag="5"/>
                        <ComboBoxItem Content="낮음" Tag="9"/>
                    </ComboBox>

                    <!-- 뷰 전환 -->
                    <ui:Button x:Name="KanbanViewButton"
                               Icon="{ui:SymbolIcon Board24}" ToolTip="칸반 보드"
                               Appearance="Primary" Padding="6" Margin="0,0,4,0"
                               Click="KanbanViewButton_Click"/>
                    <ui:Button x:Name="TimelineViewButton"
                               Icon="{ui:SymbolIcon Timeline24}" ToolTip="타임라인"
                               Appearance="Transparent" Padding="6"
                               Click="TimelineViewButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 칸반 보드 (수평 스크롤) -->
        <ScrollViewer Grid.Row="1" x:Name="BoardScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      PreviewMouseWheel="BoardScrollViewer_PreviewMouseWheel">
            <ItemsControl x:Name="BucketsItemsControl">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Margin="16"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 버킷 컬럼 -->
                        <Border Width="300" Margin="0,0,16,0"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                CornerRadius="8" Padding="12"
                                AllowDrop="True"
                                Tag="{Binding}"
                                DragEnter="Bucket_DragEnter"
                                DragLeave="Bucket_DragLeave"
                                Drop="Bucket_Drop">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 버킷 헤더 -->
                                <Border Grid.Row="0" Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"/>
                                            <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                                                    CornerRadius="10" Padding="8,2" Margin="8,0,0,0">
                                                <TextBlock Text="{Binding Tasks.Count}" FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <ui:Button Icon="{ui:SymbolIcon Add24}"
                                                       Appearance="Transparent" Padding="4"
                                                       Tag="{Binding}"
                                                       Click="BucketAddTask_Click" ToolTip="작업 추가"/>
                                            <ui:Button Icon="{ui:SymbolIcon MoreHorizontal24}"
                                                       Appearance="Transparent" Padding="4"
                                                       Tag="{Binding}"
                                                       Click="BucketMenu_Click"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- 카드 목록 -->
                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,4,0">
                                    <ItemsControl ItemsSource="{Binding Tasks}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <local:KanbanCardControl Margin="0,0,0,8"
                                                    DataContext="{Binding}"
                                                    PreviewMouseLeftButtonDown="Card_PreviewMouseLeftButtonDown"
                                                    PreviewMouseMove="Card_PreviewMouseMove"
                                                    MouseLeftButtonUp="Card_MouseLeftButtonUp"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- 하단 작업 추가 버튼 -->
                                <ui:Button Grid.Row="2"
                                           HorizontalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Appearance="Transparent" Padding="8,6"
                                           Margin="0,8,0,0"
                                           Tag="{Binding}"
                                           Click="BucketAddTask_Click">
                                    <StackPanel Orientation="Horizontal">
                                        <ui:SymbolIcon Symbol="Add24" FontSize="14" Margin="0,0,8,0"/>
                                        <TextBlock Text="작업 추가" FontSize="13"/>
                                    </StackPanel>
                                </ui:Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 타임라인 뷰 (칸반 보드와 전환) -->
        <Grid Grid.Row="1" x:Name="TimelineView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 타임라인 헤더 (날짜 범위) -->
            <Border Grid.Row="0" Padding="16,8"
                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                <StackPanel Orientation="Horizontal">
                    <ui:Button Icon="{ui:SymbolIcon ChevronLeft24}" Appearance="Transparent" Padding="4"
                               Click="TimelinePrev_Click"/>
                    <TextBlock x:Name="TimelineRangeText" Text="" FontSize="14" FontWeight="SemiBold"
                               VerticalAlignment="Center" Margin="12,0"/>
                    <ui:Button Icon="{ui:SymbolIcon ChevronRight24}" Appearance="Transparent" Padding="4"
                               Click="TimelineNext_Click"/>
                    <ui:Button Content="오늘" Appearance="Secondary" Padding="8,4" Margin="12,0,0,0"
                               Click="TimelineToday_Click"/>
                </StackPanel>
            </Border>

            <!-- 타임라인 본체 (간트 차트 형태) -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="TimelineCanvas" MinHeight="400" MinWidth="800"/>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
