<UserControl x:Class="mAIx.Controls.Teams.ChannelSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="500">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,20" MaxWidth="480">

            <!-- ── 채널 기본 정보 섹션 ──────────────────────────── -->
            <TextBlock Text="채널 정보" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,10"/>

            <Border Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,16">
                <StackPanel>
                    <!-- 채널 이름 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="채널 이름"
                                   FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ChannelName}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </Grid>

                    <!-- 채널 유형 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="채널 유형"
                                   FontSize="13" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="LockClosed24" FontSize="13" Margin="0,0,6,0"
                                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                            <TextBlock Text="{Binding ChannelType}" FontSize="13"/>
                        </StackPanel>
                    </Grid>

                    <!-- 채널 설명 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="설명"
                                   FontSize="13" VerticalAlignment="Top" Margin="0,2,0,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <TextBlock Grid.Column="1" Text="{Binding ChannelDescription}"
                                   FontSize="13" TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── 즐겨찾기 토글 ──────────────────────────────────── -->
            <Border Padding="14,12"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <ui:SymbolIcon Symbol="Star24" FontSize="18" Margin="0,0,10,0"
                                      Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        <StackPanel>
                            <TextBlock Text="즐겨찾기" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="즐겨찾기에 추가하면 사이드바에서 빠르게 접근할 수 있습니다"
                                       FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <ui:Button Grid.Column="1" Appearance="Secondary"
                               Command="{Binding ToggleFavoriteCommand}"
                               Padding="10,6">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="{Binding FavoriteIcon}" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="{Binding FavoriteLabel}" FontSize="12"/>
                        </StackPanel>
                    </ui:Button>
                </Grid>
            </Border>

            <!-- ── 알림 설정 섹션 ──────────────────────────────────── -->
            <TextBlock Text="알림 설정" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,10"/>

            <Border Padding="16"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Margin="0,0,0,16">
                <StackPanel>
                    <!-- 언급만 -->
                    <RadioButton GroupName="NotificationGroup" Margin="0,0,0,10"
                                 IsChecked="{Binding IsNotifyMentionOnly, Mode=TwoWay}">
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="언급만" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="@멘션 또는 답글이 있을 때만 알림을 받습니다"
                                       FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- 모든 활동 -->
                    <RadioButton GroupName="NotificationGroup" Margin="0,0,0,10"
                                 IsChecked="{Binding IsNotifyAllActivity, Mode=TwoWay}">
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="모든 활동" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="새 게시물, 답글, 멘션 등 모든 활동에 대해 알림을 받습니다"
                                       FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- 없음 -->
                    <RadioButton GroupName="NotificationGroup"
                                 IsChecked="{Binding IsNotifyOff, Mode=TwoWay}">
                        <StackPanel Margin="8,0,0,0">
                            <TextBlock Text="없음" FontSize="13" FontWeight="SemiBold"/>
                            <TextBlock Text="이 채널의 모든 알림을 끕니다"
                                       FontSize="11" Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </RadioButton>

                    <!-- 저장 버튼 -->
                    <Separator Margin="0,12,0,12" Background="{DynamicResource ControlElevationBorderBrush}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <!-- 저장 완료 메시지 -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                                    Visibility="{Binding IsSaved, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ui:SymbolIcon Symbol="Checkmark24" FontSize="14" Margin="0,0,6,0"
                                          Foreground="#10B981"/>
                            <TextBlock Text="저장되었습니다" FontSize="12" Foreground="#10B981"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <ui:Button Grid.Column="1" Appearance="Primary"
                                   Command="{Binding SaveNotificationSettingCommand}"
                                   Content="저장" Padding="16,6"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ── 멤버 목록 섹션 ──────────────────────────────────── -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="멤버" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" FontSize="12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center">
                    <Run Text="{Binding MemberCount, Mode=OneWay}"/>
                    <Run Text="명"/>
                </TextBlock>
            </Grid>

            <Border Padding="8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <ItemsControl ItemsSource="{Binding MemberList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6,8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="38"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 아바타 -->
                                <Border Grid.Column="0" Width="34" Height="34" CornerRadius="17"
                                        Background="{Binding DisplayName, Converter={StaticResource NameToAvatarColorConverter}}">
                                    <TextBlock Text="{Binding Initial}"
                                               Foreground="White" FontWeight="SemiBold" FontSize="13"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- 이름 -->
                                <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                           FontSize="13" VerticalAlignment="Center"
                                           Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>

                                <!-- 역할 뱃지 -->
                                <Border Grid.Column="2" CornerRadius="4" Padding="8,3"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <TextBlock Text="{Binding Role}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
