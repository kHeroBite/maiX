<UserControl x:Class="mAIx.Controls.Teams.ChannelFilesControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 업로드 툴바 -->
            <RowDefinition Height="Auto"/>
            <!-- 파일 목록 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 오프라인 플레이스홀더 -->
        <StackPanel Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}}">
            <ui:SymbolIcon Symbol="CloudDismiss24" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
            <TextBlock Text="연결 실패" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="네트워크 연결을 확인하세요" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- 파일 툴바 (업로드 + 새 폴더) -->
        <Border Grid.Row="0" Padding="16,8"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <StackPanel Orientation="Horizontal">
                <ui:Button x:Name="UploadFileButton"
                           Icon="{ui:SymbolIcon ArrowUpload24}"
                           Content="업로드" Padding="12,6" Margin="0,0,8,0"
                           Appearance="Primary"
                           Click="UploadFileButton_Click"
                           ToolTip="파일 업로드"/>
                <ui:Button x:Name="NewFolderButton"
                           Icon="{ui:SymbolIcon FolderAdd24}"
                           Content="새 폴더" Padding="12,6"
                           Appearance="Secondary"
                           Click="NewFolderButton_Click"
                           ToolTip="새 폴더 만들기"/>
            </StackPanel>
        </Border>

        <!-- 파일 목록 DataGrid (드래그앤드롭 지원) -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"
              AllowDrop="True"
              DragOver="FilesGrid_DragOver"
              Drop="FilesGrid_Drop">

            <!-- 파일 없을 때 빈 화면 -->
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="{Binding HasChannelFiles, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                <ui:SymbolIcon Symbol="FolderOpen24" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
                <TextBlock Text="파일이 없습니다" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                <TextBlock Text="파일을 업로드하거나 드래그하여 추가하세요" FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 파일 목록 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasChannelFiles, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding ChannelFiles}" Margin="16">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:Button Appearance="Transparent" HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Left" Padding="12,8" Margin="0,0,0,4"
                                       Click="ChannelFile_Click" Tag="{Binding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="100"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- 파일 아이콘 -->
                                    <ui:SymbolIcon Grid.Column="0" Symbol="{Binding FileIcon}" FontSize="20"/>
                                    <!-- 파일 이름 -->
                                    <TextBlock Grid.Column="1" Text="{Binding Name}"
                                               VerticalAlignment="Center" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                                    <!-- 파일 크기 -->
                                    <TextBlock Grid.Column="2" Text="{Binding SizeDisplay}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"/>
                                    <!-- 업로드한 사람 -->
                                    <TextBlock Grid.Column="3" Text="{Binding CreatedBy}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12"
                                               TextTrimming="CharacterEllipsis"/>
                                    <!-- 수정 날짜 -->
                                    <TextBlock Grid.Column="4"
                                               Text="{Binding LastModified, StringFormat='{}{0:MM/dd HH:mm}'}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" FontSize="12"/>
                                </Grid>
                            </ui:Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 드래그앤드롭 오버레이 -->
            <Border x:Name="DragDropOverlay"
                    Background="{DynamicResource SystemAccentColorBrush}"
                    Opacity="0.15"
                    CornerRadius="8"
                    Visibility="Collapsed"
                    Margin="8">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="ArrowUpload24" FontSize="48" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <TextBlock Text="파일을 놓아 업로드" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
