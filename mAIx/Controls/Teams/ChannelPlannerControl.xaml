<UserControl x:Class="mAIx.Controls.Teams.ChannelPlannerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="1000">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 툴바 -->
            <RowDefinition Height="Auto"/>
            <!-- 칸반 보드 본문 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== 로딩 오버레이 ===== -->
        <Grid Grid.RowSpan="2" Panel.ZIndex="10"
              Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}" Opacity="0.7"/>
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ui:ProgressRing IsIndeterminate="True" Width="40" Height="40"/>
                <TextBlock Text="로드 중..." Margin="0,12,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- ===== 상단 툴바 ===== -->
        <Border Grid.Row="0" Padding="16,8"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽: 새 작업 + 필터 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:Button x:Name="AddTaskButton"
                               Icon="{ui:SymbolIcon Add24}"
                               Content="새 작업"
                               Padding="12,6" Margin="0,0,12,0"
                               Appearance="Primary"
                               Click="AddTaskButton_Click"
                               ToolTip="새 작업 추가"/>

                    <!-- 담당자 필터 -->
                    <ComboBox x:Name="AssigneeFilterCombo"
                              Width="120" Margin="0,0,8,0"
                              SelectedIndex="0"
                              SelectionChanged="AssigneeFilterCombo_SelectionChanged"
                              ToolTip="담당자 필터">
                        <ComboBoxItem Content="모든 담당자" Tag="all"/>
                        <ComboBoxItem Content="나에게 할당됨" Tag="me"/>
                        <ComboBoxItem Content="미할당" Tag="unassigned"/>
                    </ComboBox>

                    <!-- 우선순위 필터 -->
                    <ComboBox x:Name="PriorityFilterCombo"
                              Width="110" Margin="0,0,8,0"
                              SelectedIndex="0"
                              SelectionChanged="PriorityFilterCombo_SelectionChanged"
                              ToolTip="우선순위 필터">
                        <ComboBoxItem Content="모든 우선순위" Tag="all"/>
                        <ComboBoxItem Content="긴급" Tag="urgent"/>
                        <ComboBoxItem Content="중요" Tag="important"/>
                        <ComboBoxItem Content="보통" Tag="medium"/>
                        <ComboBoxItem Content="낮음" Tag="low"/>
                    </ComboBox>
                </StackPanel>

                <!-- 오른쪽: 보드/목록 전환 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button x:Name="BoardViewButton"
                               Icon="{ui:SymbolIcon Board24}"
                               Padding="8,6" Margin="0,0,4,0"
                               Click="BoardViewButton_Click"
                               ToolTip="보드 보기"/>
                    <ui:Button x:Name="ListViewButton"
                               Icon="{ui:SymbolIcon List24}"
                               Padding="8,6"
                               Click="ListViewButton_Click"
                               ToolTip="목록 보기"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 본문: 보드 뷰 ===== -->
        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled"
                      Visibility="{Binding IsBoardView, Converter={StaticResource BoolToVisibilityConverter}}">
            <ItemsControl x:Name="BucketsPanel"
                          ItemsSource="{Binding Buckets}"
                          Margin="12,12,12,12">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 칸반 열 -->
                        <Border Width="280" Margin="0,0,12,0"
                                Background="{DynamicResource LayerFillColorDefaultBrush}"
                                CornerRadius="8"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <!-- 열 헤더 -->
                                    <RowDefinition Height="Auto"/>
                                    <!-- 작업 카드 목록 -->
                                    <RowDefinition Height="*"/>
                                    <!-- 작업 추가 버튼 -->
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 열 헤더 -->
                                <Border Grid.Row="0" Padding="12,10"
                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                        BorderThickness="0,0,0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold" FontSize="14"
                                                   VerticalAlignment="Center"/>
                                        <!-- 작업 수 배지 -->
                                        <Border Background="{DynamicResource SystemAccentColorBrush}"
                                                CornerRadius="10"
                                                Padding="6,2" Margin="8,0,0,0"
                                                VerticalAlignment="Center"
                                                MinWidth="22">
                                            <TextBlock Text="{Binding TaskCount}"
                                                       Foreground="White"
                                                       FontSize="11" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- 작업 카드 목록 (UI 가상화) -->
                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto"
                                              MaxHeight="420"
                                              Padding="8,4">
                                    <ItemsControl ItemsSource="{Binding Tasks}"
                                                  VirtualizingStackPanel.IsVirtualizing="True"
                                                  VirtualizingStackPanel.VirtualizationMode="Recycling">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel Orientation="Vertical"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- 작업 카드 -->
                                                <Border x:Name="TaskCard"
                                                        Margin="0,4,0,0"
                                                        Padding="10,10,10,8"
                                                        Background="{DynamicResource ApplicationBackgroundBrush}"
                                                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="6"
                                                        AllowDrop="True"
                                                        Cursor="Hand">
                                                    <!-- 우선순위 컬러 바 -->
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1"
                                                                          Opacity="0.08" Direction="270"/>
                                                    </Border.Effect>
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- 우선순위 색상 바 + 체크박스 + 제목 -->
                                                        <Grid Grid.Row="0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="4"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- 우선순위 색상 바 -->
                                                            <Border Grid.Column="0"
                                                                    Width="4" CornerRadius="2"
                                                                    Margin="0,0,8,0">
                                                                <Border.Background>
                                                                    <SolidColorBrush Color="{Binding PriorityColor}"/>
                                                                </Border.Background>
                                                            </Border>

                                                            <!-- 체크박스 (완료 토글) -->
                                                            <CheckBox Grid.Column="1"
                                                                      IsChecked="{Binding IsCompleted}"
                                                                      Margin="0,0,8,0"
                                                                      VerticalAlignment="Top"/>

                                                            <!-- 제목 -->
                                                            <TextBlock Grid.Column="2"
                                                                       Text="{Binding Title}"
                                                                       FontSize="13"
                                                                       FontWeight="Medium"
                                                                       TextWrapping="Wrap"
                                                                       VerticalAlignment="Top"
                                                                       MaxHeight="60"/>
                                                        </Grid>

                                                        <!-- 담당자 + 마감일 -->
                                                        <Grid Grid.Row="1" Margin="12,8,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>

                                                            <!-- 담당자 아바타 -->
                                                            <StackPanel Grid.Column="0"
                                                                        Orientation="Horizontal"
                                                                        Visibility="{Binding AssigneeName, Converter={StaticResource NullToCollapsedConverter}}">
                                                                <Border Width="22" Height="22"
                                                                        CornerRadius="11"
                                                                        Background="{DynamicResource SystemAccentColorBrush}"
                                                                        Margin="0,0,4,0">
                                                                    <TextBlock Text="{Binding AssigneeInitials}"
                                                                               FontSize="9"
                                                                               Foreground="White"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"/>
                                                                </Border>
                                                                <TextBlock Text="{Binding AssigneeName}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>

                                                            <!-- 마감일 -->
                                                            <StackPanel Grid.Column="1"
                                                                        Orientation="Horizontal"
                                                                        Visibility="{Binding DueDate, Converter={StaticResource NullToCollapsedConverter}}">
                                                                <ui:SymbolIcon Symbol="CalendarLtr16"
                                                                               FontSize="12"
                                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                               Margin="0,0,3,0"
                                                                               VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding DueDate, StringFormat={}{0:MM/dd}}"
                                                                           FontSize="11"
                                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                           VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <!-- 작업 추가 버튼 -->
                                <ui:Button Grid.Row="2"
                                           x:Name="AddCardButton"
                                           Icon="{ui:SymbolIcon Add24}"
                                           Content="작업 추가"
                                           Appearance="Transparent"
                                           HorizontalAlignment="Stretch"
                                           Margin="8,4,8,8"
                                           Padding="8,6"
                                           Tag="{Binding}"
                                           Click="AddCardButton_Click"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ===== 본문: 목록 뷰 ===== -->
        <Grid Grid.Row="1"
              Visibility="{Binding IsBoardView, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <ListView x:Name="TaskListView"
                      ItemsSource="{Binding AllTasks}"
                      Margin="12"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="제목" Width="300">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="8" Height="8" CornerRadius="4"
                                                Margin="0,0,8,0" VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="{Binding PriorityColor}"/>
                                            </Border.Background>
                                        </Border>
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="버킷" Width="120"
                                        DisplayMemberBinding="{Binding BucketName}"/>
                        <GridViewColumn Header="담당자" Width="120"
                                        DisplayMemberBinding="{Binding AssigneeName}"/>
                        <GridViewColumn Header="우선순위" Width="80"
                                        DisplayMemberBinding="{Binding PriorityLabel}"/>
                        <GridViewColumn Header="마감일" Width="90">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DueDate, StringFormat={}{0:yyyy-MM-dd}}"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="진행률" Width="80"
                                        DisplayMemberBinding="{Binding PercentComplete, StringFormat={}{0}%}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>

        <!-- ===== 빈 상태 (버킷 없을 때) ===== -->
        <StackPanel Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}">
            <ui:SymbolIcon Symbol="TaskListLtr24" FontSize="48"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           Margin="0,0,0,12"/>
            <TextBlock Text="작업이 없습니다" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="'새 작업' 버튼으로 첫 작업을 추가하세요" FontSize="13"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
