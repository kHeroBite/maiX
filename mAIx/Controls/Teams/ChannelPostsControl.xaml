<UserControl x:Class="mAIx.Controls.Teams.ChannelPostsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 메시지 목록 영역 -->
            <RowDefinition Height="*"/>
            <!-- 메시지 입력 영역 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 오프라인 플레이스홀더 -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}}">
            <ui:SymbolIcon Symbol="CloudDismiss24" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
            <TextBlock Text="연결 실패" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="네트워크 연결을 확인하세요" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- 메시지 목록 -->
        <ScrollViewer Grid.Row="0" x:Name="MessagesScrollViewer"
                      VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <ItemsControl ItemsSource="{Binding Messages}" Margin="16,16,16,8"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Padding="14"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <!-- 우클릭 컨텍스트 메뉴 -->
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="편집"
                                              Click="ContextMenu_Edit_Click"
                                              Tag="{Binding}">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="Edit24"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="삭제"
                                              Click="ContextMenu_Delete_Click"
                                              Tag="{Binding}">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="Delete24"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Header="고정"
                                              Click="ContextMenu_Pin_Click"
                                              Tag="{Binding}">
                                        <MenuItem.Icon>
                                            <ui:SymbolIcon Symbol="Pin24"/>
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 아바타 -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                        Background="{Binding FromUser, Converter={StaticResource NameToAvatarColorConverter}}"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding FromUser, Converter={StaticResource StringToInitialConverter}}"
                                               Foreground="White" FontWeight="SemiBold" FontSize="15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- 메시지 내용 -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <!-- 헤더 행: 이름 + 시간 + 고정 아이콘 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <TextBlock Text="{Binding FromUser}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding ChannelTimeDisplay}"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                                        <!-- 고정 표시 -->
                                        <ui:SymbolIcon Symbol="Pin24" FontSize="12" Margin="8,0,0,0"
                                                       VerticalAlignment="Center"
                                                       Foreground="{StaticResource TeamsAccentBrush}"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                    </StackPanel>
                                    <!-- 본문 -->
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"/>
                                    <!-- 리액션 표시 -->
                                    <TextBlock Text="{Binding Reactions}"
                                               FontSize="16" Margin="0,0,0,6"
                                               Visibility="{Binding Reactions, Converter={StaticResource NullToVisibilityConverter}}"/>
                                    <!-- 리액션 버튼 행 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                        <Button Content="👍" Padding="6,2" Margin="0,0,4,0" FontSize="14"
                                                Background="Transparent" BorderBrush="Transparent"
                                                Click="Reaction_Click" Tag="like" ToolTip="좋아요"/>
                                        <Button Content="❤️" Padding="6,2" Margin="0,0,4,0" FontSize="14"
                                                Background="Transparent" BorderBrush="Transparent"
                                                Click="Reaction_Click" Tag="heart" ToolTip="하트"/>
                                        <Button Content="😄" Padding="6,2" Margin="0,0,4,0" FontSize="14"
                                                Background="Transparent" BorderBrush="Transparent"
                                                Click="Reaction_Click" Tag="laugh" ToolTip="웃음"/>
                                        <Button Content="😮" Padding="6,2" Margin="0,0,4,0" FontSize="14"
                                                Background="Transparent" BorderBrush="Transparent"
                                                Click="Reaction_Click" Tag="wow" ToolTip="놀람"/>
                                        <Button Content="😢" Padding="6,2" Margin="0,0,4,0" FontSize="14"
                                                Background="Transparent" BorderBrush="Transparent"
                                                Click="Reaction_Click" Tag="sad" ToolTip="슬픔"/>
                                        <Button Content="😡" Padding="6,2" Margin="0,0,4,0" FontSize="14"
                                                Background="Transparent" BorderBrush="Transparent"
                                                Click="Reaction_Click" Tag="angry" ToolTip="화남"/>
                                        <!-- 스레드 회신 -->
                                        <ui:Button Appearance="Transparent" Padding="6,2" Margin="8,0,0,0"
                                                   Click="ReplyToThread_Click" Tag="{Binding}">
                                            <StackPanel Orientation="Horizontal">
                                                <ui:SymbolIcon Symbol="ChatMultiple24" FontSize="13" Margin="0,0,4,0"
                                                               Foreground="{StaticResource TeamsAccentBrush}"/>
                                                <TextBlock Text="회신" FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                            </StackPanel>
                                        </ui:Button>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 메시지 입력 영역 -->
        <Border Grid.Row="1" Padding="16,10"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- 편집 모드 알림 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 포맷 툴바 -->
                    <RowDefinition Height="Auto"/>
                    <!-- 입력 + 전송 -->
                    <RowDefinition Height="Auto"/>
                    <!-- @멘션 팝업 -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 편집 모드 배너 -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                        CornerRadius="4" Padding="8,4" Margin="0,0,0,6"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Edit24" FontSize="13" Margin="0,0,6,0"/>
                        <TextBlock Text="메시지 편집 중" FontSize="12" VerticalAlignment="Center"/>
                        <ui:Button Appearance="Transparent" Padding="4,2" Margin="8,0,0,0"
                                   Content="취소" FontSize="11"
                                   Command="{Binding CancelEditCommand}"/>
                    </StackPanel>
                </Border>

                <!-- 리치텍스트 포맷 툴바 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                    <ui:Button Appearance="Transparent" Padding="6,4"
                               ToolTip="굵게 (Bold)"
                               Command="{Binding FormatBoldCommand}">
                        <TextBlock Text="B" FontWeight="Bold" FontSize="14"/>
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Padding="6,4" Margin="2,0,0,0"
                               ToolTip="기울임 (Italic)"
                               Command="{Binding FormatItalicCommand}">
                        <TextBlock Text="I" FontStyle="Italic" FontSize="14"/>
                    </ui:Button>
                    <ui:Button Appearance="Transparent" Padding="6,4" Margin="2,0,0,0"
                               ToolTip="코드 (Code)"
                               Command="{Binding FormatCodeCommand}">
                        <TextBlock Text="&lt;/&gt;" FontFamily="Consolas" FontSize="12"/>
                    </ui:Button>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                               Margin="6,2" Height="16" VerticalAlignment="Center"/>
                    <ui:Button Appearance="Transparent" Padding="6,4"
                               ToolTip="@멘션"
                               Click="MentionButton_Click">
                        <TextBlock Text="@" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource TeamsAccentBrush}"/>
                    </ui:Button>
                </StackPanel>

                <!-- 입력 + 전송 버튼 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="TeamsChannelMessageInput" Grid.Column="0"
                                PlaceholderText="메시지를 입력하세요..."
                                Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                                Margin="0,0,8,0"
                                KeyDown="TeamsChannelMessageInput_KeyDown"
                                TextChanged="TeamsChannelMessageInput_TextChanged"/>
                    <ui:Button Grid.Column="1" x:Name="TeamsChannelSendButton"
                               Icon="{ui:SymbolIcon Send24}"
                               Appearance="Primary"
                               Command="{Binding SendMessageCommand}"
                               ToolTip="전송 (Enter)"/>
                </Grid>

                <!-- @멘션 팝업 -->
                <Popup Grid.Row="3" x:Name="MentionPopup"
                       IsOpen="{Binding IsMentionPopupOpen}"
                       PlacementTarget="{Binding ElementName=TeamsChannelMessageInput}"
                       Placement="Top"
                       StaysOpen="False">
                    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1" CornerRadius="6" Padding="4">
                        <ListBox ItemsSource="{Binding MentionCandidates}"
                                 MaxHeight="180"
                                 SelectionChanged="MentionList_SelectionChanged"
                                 Background="Transparent"
                                 BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Padding="8,4" FontSize="13"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>
            </Grid>
        </Border>
    </Grid>
</UserControl>
