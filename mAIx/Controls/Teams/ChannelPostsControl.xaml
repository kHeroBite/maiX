<UserControl x:Class="mAIx.Controls.Teams.ChannelPostsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 메시지 목록 영역 -->
            <RowDefinition Height="*"/>
            <!-- 메시지 입력 영역 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 오프라인 플레이스홀더 -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}}">
            <ui:SymbolIcon Symbol="CloudDismiss24" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
            <TextBlock Text="연결 실패" FontSize="16" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            <TextBlock Text="네트워크 연결을 확인하세요" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- 메시지 목록 (가상화 적용) -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto"
                      Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <ItemsControl ItemsSource="{Binding ChannelMessages}" Margin="16">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel IsVirtualizing="True" VirtualizationMode="Recycling"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Padding="14"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="44"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <!-- 아바타 (사용자별 색상) -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20"
                                        Background="{Binding FromUser, Converter={StaticResource NameToAvatarColorConverter}}"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding FromUser, Converter={StaticResource StringToInitialConverter}}"
                                               Foreground="White" FontWeight="SemiBold" FontSize="15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- 메시지 내용 -->
                                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <!-- 온라인 상태 표시 -->
                                        <Ellipse Width="8" Height="8" Fill="#10B981" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding FromUser}" FontWeight="SemiBold" FontSize="14"/>
                                        <TextBlock Text="{Binding ChannelTimeDisplay}"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Margin="10,0,0,0" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- 메시지 본문 -->
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="14" Margin="0,0,0,8"/>
                                    <!-- 스레드에서 회신 버튼 -->
                                    <ui:Button Appearance="Transparent" Padding="6,4" Margin="0,4,0,0"
                                               Click="ReplyToThread_Click" Tag="{Binding}"
                                               HorizontalAlignment="Left">
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="ChatMultiple24" FontSize="14" Margin="0,0,6,0"
                                                           Foreground="{StaticResource TeamsAccentBrush}"/>
                                            <TextBlock Text="스레드에서 회신" FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>
                                    </ui:Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 메시지 입력 영역 -->
        <Border Grid.Row="1" Padding="16,12"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Visibility="{Binding IsOffline, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="TeamsChannelMessageInput" Grid.Column="0"
                            PlaceholderText="메시지를 입력하세요..."
                            Margin="0,0,8,0"
                            KeyDown="TeamsChannelMessageInput_KeyDown"/>
                <ui:Button Grid.Column="1" x:Name="TeamsChannelSendButton"
                           Icon="{ui:SymbolIcon Send24}"
                           Appearance="Primary"
                           Click="TeamsChannelSendButton_Click"
                           ToolTip="전송"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
