<UserControl x:Class="mAIx.Controls.ThreadPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:mAIx.Converters"
             mc:Ignorable="d" d:DesignWidth="360" d:DesignHeight="600"
             Background="{DynamicResource ApplicationBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더: 스레드 + 닫기 버튼 -->
        <Border Grid.Row="0" Padding="16,12" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="스레드" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <ui:Button Grid.Column="1" x:Name="CloseThreadButton" Appearance="Transparent" Padding="6"
                           ToolTip="닫기" Click="CloseThreadButton_Click">
                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="16"/>
                </ui:Button>
            </Grid>
        </Border>

        <!-- 원본 메시지 -->
        <Border Grid.Row="1" Padding="16,12" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource SubtleFillColorSecondaryBrush}">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <!-- 원본 발신자 아바타 -->
                    <Border Width="28" Height="28" CornerRadius="4" Margin="0,0,8,0"
                            Background="{Binding ParentMessage.FromUser, Converter={StaticResource NameToAvatarColorConverter}}">
                        <TextBlock Text="{Binding ParentMessage.FromUserInitial}" FontSize="11" Foreground="White" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="{Binding ParentMessage.FromUser}" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding ParentMessage.TimeDisplay}" FontSize="11" Margin="8,0,0,0"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="{Binding ParentMessage.Content}" TextWrapping="Wrap" FontSize="14" Margin="36,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- 답글 목록 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Padding="0,4">
            <ItemsControl x:Name="ThreadRepliesItemsControl" ItemsSource="{Binding Replies}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="16,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="36"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 아바타 -->
                                <Grid Grid.Column="0" Width="28" Height="28" VerticalAlignment="Top">
                                    <Border CornerRadius="4" ClipToBounds="True"
                                            Visibility="{Binding HasFromUserPhoto, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding FromUserPhoto, Converter={StaticResource Base64ToImageSourceConverter}}" Stretch="UniformToFill"/>
                                        </Border.Background>
                                    </Border>
                                    <Border CornerRadius="4" Background="{Binding FromUser, Converter={StaticResource NameToAvatarColorConverter}}"
                                            Visibility="{Binding HasFromUserPhoto, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                        <TextBlock Text="{Binding FromUserInitial}" FontSize="11" Foreground="White" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- 답글 내용 -->
                                <StackPanel Grid.Column="1" Margin="4,0,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,2">
                                        <TextBlock Text="{Binding FromUser}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding TimeDisplay}" FontSize="11" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap" FontSize="13"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 답글 입력 -->
        <Border Grid.Row="3" Padding="12,8" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:TextBox x:Name="ThreadReplyInput" PlaceholderText="답글 입력..."
                            MinHeight="32"
                            KeyDown="ThreadReplyInput_KeyDown"/>
                <ui:Button Grid.Column="1" x:Name="ThreadSendButton" Appearance="Primary" Padding="8,6" Margin="8,0,0,0"
                           Click="ThreadSendButton_Click" ToolTip="답글 전송">
                    <ui:SymbolIcon Symbol="Send24" FontSize="14"/>
                </ui:Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
