<UserControl x:Class="mAIx.Controls.BacklinkPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="300">
    <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
            CornerRadius="8" Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <!-- 헤더 -->
                <RowDefinition Height="Auto"/>
                <!-- 로딩 -->
                <RowDefinition Height="Auto"/>
                <!-- 백링크 목록 -->
                <RowDefinition Height="*"/>
                <!-- 빈 상태 -->
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 헤더: 백링크 제목 + 새로고침 -->
            <Grid Grid.Row="0" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Link24" FontSize="18" Margin="0,0,8,0"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                    <TextBlock Text="백링크" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <Border Background="{DynamicResource ControlFillColorTertiaryBrush}"
                            CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="BacklinkCountText" Text="0" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </Border>
                </StackPanel>

                <ui:Button Grid.Column="1"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Appearance="Transparent" Padding="4"
                           ToolTip="새로고침"
                           Click="RefreshButton_Click"/>
            </Grid>

            <!-- 로딩 인디케이터 -->
            <ui:ProgressRing Grid.Row="1" x:Name="LoadingRing"
                             IsIndeterminate="True" Width="24" Height="24"
                             Visibility="Collapsed" Margin="0,8"/>

            <!-- 백링크 목록 -->
            <ListView Grid.Row="2" x:Name="BacklinksListView"
                      Background="Transparent" BorderThickness="0"
                      SelectionChanged="BacklinksListView_SelectionChanged"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                        <Setter Property="Padding" Value="8,6"/>
                        <Setter Property="Margin" Value="0,0,0,4"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- 페이지명 -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Document24" FontSize="14" Margin="0,0,6,0"
                                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Medium"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- 경로: 노트북 / 섹션 -->
                            <TextBlock Grid.Row="1" FontSize="11" Margin="20,2,0,0"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} / {1}">
                                        <Binding Path="NotebookName"/>
                                        <Binding Path="SectionName"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>

                            <!-- 미리보기 텍스트 -->
                            <TextBlock Grid.Row="2" Text="{Binding PreviewText}" FontSize="11"
                                       Margin="20,2,0,0" MaxHeight="32"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       TextTrimming="CharacterEllipsis" TextWrapping="Wrap"
                                       Visibility="{Binding PreviewText, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- 빈 상태 -->
            <StackPanel Grid.Row="3" x:Name="EmptyState"
                        VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed" Margin="0,20">
                <ui:SymbolIcon Symbol="Link24" FontSize="32"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,8"
                               HorizontalAlignment="Center"/>
                <TextBlock Text="이 페이지를 참조하는 페이지가 없습니다" FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
