<UserControl x:Class="mAIx.Controls.NotebookTreeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             mc:Ignorable="d"
             d:DesignHeight="500" d:DesignWidth="280">
    <Grid>
        <Grid.RowDefinitions>
            <!-- 검색/필터 -->
            <RowDefinition Height="Auto"/>
            <!-- 트리뷰 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 검색 바 -->
        <Border Grid.Row="0" Padding="8,6">
            <ui:TextBox x:Name="SearchBox" PlaceholderText="노트북 검색..."
                        Icon="{ui:SymbolIcon Search24}"
                        KeyDown="SearchBox_KeyDown"
                        TextChanged="SearchBox_TextChanged"/>
        </Border>

        <!-- 트리뷰: 노트북 > 섹션 > 페이지 -->
        <TreeView Grid.Row="1" x:Name="NotebookTreeView"
                  Background="Transparent" BorderThickness="0"
                  SelectedItemChanged="NotebookTreeView_SelectedItemChanged"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                  VirtualizingStackPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <TreeView.Resources>
                <!-- 노트북 레벨 -->
                <HierarchicalDataTemplate x:Key="NotebookTemplate"
                                          ItemsSource="{Binding Sections}"
                                          ItemTemplate="{DynamicResource SectionTemplate}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 아이콘: 📓 노트북 -->
                        <TextBlock Grid.Column="0" Text="📓" FontSize="16" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>

                        <!-- 노트북명 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding DisplayName}" FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding LastModifiedDisplay}" FontSize="10"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Visibility="{Binding LastModifiedDateTime, Converter={StaticResource NullToVisibilityConverter}}"/>
                        </StackPanel>

                        <!-- 공유 표시 -->
                        <ui:SymbolIcon Grid.Column="2" Symbol="People24" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Visibility="{Binding IsShared, Converter={StaticResource BoolToVisibilityConverter}}"
                                       ToolTip="{Binding SourceName}" Margin="4,0"/>
                    </Grid>
                </HierarchicalDataTemplate>

                <!-- 섹션 레벨 -->
                <HierarchicalDataTemplate x:Key="SectionTemplate"
                                          ItemsSource="{Binding Pages}"
                                          ItemTemplate="{DynamicResource PageTemplate}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 아이콘: 📑 섹션 -->
                        <TextBlock Grid.Column="0" Text="📑" FontSize="14" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" FontSize="13"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </HierarchicalDataTemplate>

                <!-- 페이지 레벨 -->
                <DataTemplate x:Key="PageTemplate">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 아이콘: 📄 페이지 -->
                        <TextBlock Grid.Column="0" Text="📄" FontSize="12" Margin="0,0,8,0"
                                   VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="1" Text="{Binding Title}" FontSize="12"
                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                        <!-- 즐겨찾기 표시 -->
                        <ui:SymbolIcon Grid.Column="2" Symbol="Star24" FontSize="10"
                                       Foreground="#FFD700"
                                       Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVisibilityConverter}}"
                                       Margin="4,0"/>
                    </Grid>
                </DataTemplate>
            </TreeView.Resources>

            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay, FallbackValue=False}"/>
                    <Setter Property="Padding" Value="4,2"/>
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                </Style>
            </TreeView.ItemContainerStyle>

            <!-- 컨텍스트 메뉴 -->
            <TreeView.ContextMenu>
                <ContextMenu x:Name="TreeContextMenu">
                    <MenuItem x:Name="RenameMenuItem" Header="이름 변경" Click="Rename_Click">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Rename24"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem x:Name="MoveMenuItem" Header="이동" Click="Move_Click">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowMove24"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem x:Name="DeleteMenuItem" Header="삭제" Click="Delete_Click" Foreground="#E74856">
                        <MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Delete24" Foreground="#E74856"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TreeView.ContextMenu>
        </TreeView>
    </Grid>
</UserControl>
