<UserControl x:Class="mAIx.Controls.ActivityFeedControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Padding="16,12"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Alert24" FontSize="20" Margin="0,0,8,0"
                                   Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"/>
                    <TextBlock Text="활동 피드" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ActivityCountText" Text="" FontSize="12" Margin="8,0,0,0"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" VerticalAlignment="Center"/>
                </StackPanel>
                <ui:Button Grid.Column="1" x:Name="RefreshButton"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Appearance="Transparent" Padding="6"
                           ToolTip="새로고침"
                           Click="RefreshButton_Click"/>
            </Grid>
        </Border>

        <!-- 필터 바 -->
        <Border Grid.Row="1" Padding="12,8"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    <ui:Button x:Name="FilterAllButton" Content="전체" Appearance="Primary"
                               Margin="0,0,4,0" Padding="12,6" Click="FilterAllButton_Click"/>
                    <ui:Button x:Name="FilterMailButton" Appearance="Transparent"
                               Margin="0,0,4,0" Padding="12,6" Click="FilterMailButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Mail24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="메일"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="FilterChatButton" Appearance="Transparent"
                               Margin="0,0,4,0" Padding="12,6" Click="FilterChatButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Chat24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="채팅"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="FilterFileButton" Appearance="Transparent"
                               Margin="0,0,4,0" Padding="12,6" Click="FilterFileButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Document24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="파일"/>
                        </StackPanel>
                    </ui:Button>
                    <ui:Button x:Name="FilterCalendarButton" Appearance="Transparent"
                               Padding="12,6" Click="FilterCalendarButton_Click">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="14" Margin="0,0,4,0"/>
                            <TextBlock Text="캘린더"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 활동 피드 목록 -->
        <Grid Grid.Row="2">
            <!-- 로딩 표시 -->
            <ui:ProgressRing x:Name="LoadingRing" IsIndeterminate="True" Visibility="Collapsed"
                             Width="40" Height="40" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <!-- 타임라인 형태 활동 목록 -->
            <ScrollViewer x:Name="ActivityScrollViewer" VerticalScrollBarVisibility="Auto" Padding="0">
                <ItemsControl x:Name="ActivityItemsControl">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,8" Margin="8,2"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    CornerRadius="6"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                    BorderThickness="1"
                                    Cursor="Hand"
                                    MouseLeftButtonUp="ActivityItem_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 타입 아이콘 (원형 배경) -->
                                    <Border Grid.Column="0" Width="36" Height="36"
                                            CornerRadius="18" Margin="0,0,12,0"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}">
                                        <ui:SymbolIcon Symbol="Alert24" FontSize="18"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 내용 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <!-- 시간 + 읽음 표시 -->
                                    <StackPanel Grid.Column="2" VerticalAlignment="Top" Margin="8,0,0,0">
                                        <TextBlock Text="{Binding TimestampDisplay}" FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   HorizontalAlignment="Right"/>
                                        <!-- 미읽음 표시는 IsRead=false일 때 코드비하인드에서 처리 -->
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 빈 상태 -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Visibility="Collapsed">
                <ui:SymbolIcon Symbol="Alert24" FontSize="48"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,12"/>
                <TextBlock Text="활동이 없습니다" FontSize="16" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="새 활동이 생기면 여기에 표시됩니다" FontSize="13"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
