<ui:FluentWindow x:Class="mAIx.Dialogs.MeetingScheduleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Teams 미팅 예약"
        Width="480" Height="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True">

    <Grid Margin="24,48,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 제목 -->
        <TextBlock Grid.Row="0" Text="Teams 미팅 예약" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <!-- 미팅 제목 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="미팅 제목" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="MeetingSubjectBox" PlaceholderText="미팅 제목을 입력하세요"/>
        </StackPanel>

        <!-- 시작 시간 -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="시작 시간" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <DatePicker x:Name="StartDatePicker" Grid.Column="0" Margin="0,0,4,0"/>
                <ui:TextBox x:Name="StartTimeBox" Grid.Column="1" PlaceholderText="HH:mm" Text="09:00" Margin="4,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- 종료 시간 -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="종료 시간" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <DatePicker x:Name="EndDatePicker" Grid.Column="0" Margin="0,0,4,0"/>
                <ui:TextBox x:Name="EndTimeBox" Grid.Column="1" PlaceholderText="HH:mm" Text="10:00" Margin="4,0,0,0"/>
            </Grid>
        </StackPanel>

        <!-- 참석자 -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12">
            <TextBlock Text="참석자 (이메일, 쉼표로 구분)" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="AttendeesBox" PlaceholderText="user1@company.com, user2@company.com"
                         AcceptsReturn="False" TextWrapping="Wrap" MinHeight="60"/>
        </StackPanel>

        <!-- 상태 메시지 -->
        <TextBlock Grid.Row="5" x:Name="StatusMessage" FontSize="12"
                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                   VerticalAlignment="Bottom" Margin="0,0,0,8"/>

        <!-- 버튼들 -->
        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <ui:Button x:Name="CancelButton" Content="취소" Appearance="Secondary" Padding="16,8" Margin="0,0,8,0"
                       Click="CancelButton_Click"/>
            <ui:Button x:Name="CreateButton" Content="미팅 생성" Appearance="Primary" Padding="16,8"
                       Click="CreateButton_Click">
                <ui:Button.Icon>
                    <ui:SymbolIcon Symbol="Video24"/>
                </ui:Button.Icon>
            </ui:Button>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
