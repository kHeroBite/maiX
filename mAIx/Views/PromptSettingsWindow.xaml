<ui:FluentWindow x:Class="mAIx.Views.PromptSettingsWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 Title="AI 프롬프트 설정"
                 Width="1000" Height="700"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar Grid.Row="0"
                     Title="AI 프롬프트 설정"
                     ShowMaximize="False"
                     ShowMinimize="False"/>

        <!-- 메인 콘텐츠 -->
        <Grid Grid.Row="1" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측 패널: 카테고리 + 프롬프트 목록 -->
            <Grid Grid.Column="0" Margin="0,0,12,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="카테고리" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ListBox x:Name="CategoryListBox" Grid.Row="1"
                         AutomationProperties.AutomationId="CategoryListBox"
                         SelectionChanged="CategoryListBox_SelectionChanged"
                         MinHeight="100"/>

                <TextBlock Grid.Row="2" Text="프롬프트" FontWeight="SemiBold" Margin="0,8,0,4"/>
                <ListBox x:Name="PromptListBox" Grid.Row="3"
                         AutomationProperties.AutomationId="PromptListBox"
                         DisplayMemberPath="Name"
                         SelectionChanged="PromptListBox_SelectionChanged"/>
            </Grid>

            <!-- 우측 패널: 프롬프트 상세 -->
            <Border Grid.Column="1" Padding="16"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 프롬프트 이름 -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="이름" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock x:Name="PromptNameText" Grid.Column="1"
                                   VerticalAlignment="Center" FontSize="14"/>
                    </Grid>

                    <!-- 프롬프트 키 -->
                    <Grid Grid.Row="1" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="키" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock x:Name="PromptKeyText" Grid.Column="1"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontFamily="Consolas"/>
                    </Grid>

                    <!-- 템플릿 라벨 -->
                    <TextBlock Grid.Row="2" Text="템플릿" FontWeight="SemiBold" Margin="0,0,0,4"/>

                    <!-- 템플릿 편집 -->
                    <ui:TextBox x:Name="TemplateTextBox" Grid.Row="3"
                                AutomationProperties.AutomationId="TemplateTextBox"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                VerticalScrollBarVisibility="Auto"
                                VerticalContentAlignment="Top"
                                MinHeight="300"
                                FontFamily="Consolas"
                                FontSize="13"
                                Margin="0,0,0,12"/>

                    <!-- 변수 목록 -->
                    <Grid Grid.Row="4" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="사용 변수" VerticalAlignment="Top" FontWeight="SemiBold"/>
                        <TextBlock x:Name="VariablesText" Grid.Column="1"
                                   TextWrapping="Wrap"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontFamily="Consolas" FontSize="12"/>
                    </Grid>

                    <!-- 활성화 토글 -->
                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="활성화" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <ToggleButton x:Name="EnabledToggle" Grid.Column="1"
                                      AutomationProperties.AutomationId="EnabledToggle"
                                      HorizontalAlignment="Left"
                                      Content="사용"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 하단 버튼 -->
        <Border Grid.Row="2" Padding="24,12"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <ui:Button AutomationProperties.AutomationId="RestoreDefaultButton"
                               Content="기본값 복원"
                               Appearance="Secondary"
                               Click="RestoreDefaultButton_Click"/>
                    <ui:Button AutomationProperties.AutomationId="ReloadAllButton"
                               Content="프롬프트 리로드"
                               Appearance="Secondary"
                               Margin="8,0,0,0"
                               Click="ReloadAllButton_Click"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button AutomationProperties.AutomationId="SaveButton"
                               Content="저장"
                               Appearance="Primary"
                               Width="100"
                               Margin="0,0,8,0"
                               Click="SaveButton_Click"/>
                    <ui:Button AutomationProperties.AutomationId="CloseButton"
                               Content="닫기"
                               Appearance="Secondary"
                               Width="100"
                               Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
