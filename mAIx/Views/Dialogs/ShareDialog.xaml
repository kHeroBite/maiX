<ui:FluentWindow x:Class="mAIx.Views.Dialogs.ShareDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="공유"
        Height="600" Width="500"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        Loaded="Window_Loaded">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <!-- 타이틀바 여백 -->
            <RowDefinition Height="32"/>
            <!-- 파일 이름 -->
            <RowDefinition Height="Auto"/>
            <!-- 공유 링크 생성 -->
            <RowDefinition Height="Auto"/>
            <!-- 사용자 초대 -->
            <RowDefinition Height="Auto"/>
            <!-- 기존 권한 목록 -->
            <RowDefinition Height="*"/>
            <!-- 닫기 버튼 -->
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 1: 파일 이름 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16">
            <TextBlock x:Name="FileNameText" FontSize="18" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </StackPanel>

        <!-- Row 2: 공유 링크 생성 -->
        <Border Grid.Row="2" Padding="16" Margin="0,0,0,12"
                CornerRadius="8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel>
                <TextBlock Text="공유 링크 생성" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,12"/>

                <!-- 권한 타입 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="권한:" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,12,0" Width="60"/>
                    <ComboBox x:Name="LinkTypeComboBox" Width="200" SelectedIndex="0">
                        <ComboBoxItem Content="보기만 가능"/>
                        <ComboBoxItem Content="편집 가능"/>
                    </ComboBox>
                </StackPanel>

                <!-- 만료일 -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="만료일:" FontSize="13" VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Margin="0,0,12,0" Width="60"/>
                    <DatePicker x:Name="ExpiryDatePicker" Width="200"/>
                </StackPanel>

                <!-- 링크 생성 버튼 + 결과 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="ShareLinkTextBox" Grid.Column="0"
                                PlaceholderText="링크가 여기에 표시됩니다" IsReadOnly="True"
                                Margin="0,0,8,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ui:Button x:Name="CreateLinkButton"
                                   Content="생성" Appearance="Primary"
                                   Padding="16,8" Margin="0,0,4,0"
                                   Click="CreateLinkButton_Click"/>
                        <ui:Button x:Name="CopyLinkButton"
                                   Icon="{ui:SymbolIcon Copy20}"
                                   Appearance="Secondary" Padding="8"
                                   ToolTip="클립보드 복사"
                                   Click="CopyLinkButton_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Row 3: 사용자 초대 -->
        <Border Grid.Row="3" Padding="16" Margin="0,0,0,12"
                CornerRadius="8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <StackPanel>
                <TextBlock Text="사용자 초대" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,12"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <ui:TextBox x:Name="InviteEmailTextBox" Grid.Column="0"
                                PlaceholderText="이메일 주소 입력"
                                Margin="0,0,8,0"/>
                    <ui:Button x:Name="InviteButton" Grid.Column="1"
                               Content="초대" Appearance="Primary"
                               Padding="16,8"
                               Click="InviteButton_Click"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Row 4: 기존 권한 목록 -->
        <Border Grid.Row="4" Padding="16"
                CornerRadius="8"
                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                BorderThickness="1"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="현재 공유 권한" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,12"/>
                <ListView x:Name="PermissionsListView" Grid.Row="1"
                          BorderThickness="0" Background="Transparent">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="8,6"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding DisplayName}" FontSize="13"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{Binding RoleDescription}" FontSize="11"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding PermissionType}" FontSize="12"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <!-- Row 5: 닫기 -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <ui:Button Content="닫기" Appearance="Secondary"
                       Padding="24,8" Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
