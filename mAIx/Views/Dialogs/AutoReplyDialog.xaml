<ui:FluentWindow x:Class="mAIx.Views.Dialogs.AutoReplyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="부재중 자동응답 설정"
        Height="580" Width="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        KeyDown="Window_KeyDown">

    <Grid Margin="20,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <TextBlock Grid.Row="0"
                   Text="부재중 자동응답"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <!-- ON/OFF 토글 + 모드 선택 -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="자동응답" VerticalAlignment="Center" Margin="0,0,12,0" FontSize="14"/>
                <CheckBox x:Name="AutoReplyToggle"
                          IsChecked="False"
                          Checked="AutoReplyToggle_Changed"
                          Unchecked="AutoReplyToggle_Changed"
                          Content="사용"/>
            </StackPanel>

            <StackPanel x:Name="ModePanel" Visibility="Collapsed">
                <RadioButton x:Name="AlwaysEnabledRadio"
                             Content="항상 사용"
                             GroupName="AutoReplyMode"
                             IsChecked="True"
                             Margin="0,4"
                             Checked="ModeRadio_Changed"/>
                <RadioButton x:Name="ScheduledRadio"
                             Content="기간 지정"
                             GroupName="AutoReplyMode"
                             Margin="0,4"
                             Checked="ModeRadio_Changed"/>
            </StackPanel>
        </StackPanel>

        <!-- 기간 설정 -->
        <StackPanel x:Name="SchedulePanel" Grid.Row="2" Visibility="Collapsed" Margin="0,0,0,12">
            <TextBlock Text="기간 설정" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="시작:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="StartDatePicker" Grid.Column="1" Margin="0,0,12,0"
                            SelectedDate="{x:Static System:DateTime.Now}"
                            xmlns:System="clr-namespace:System;assembly=mscorlib"/>
                <TextBlock Text="종료:" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <DatePicker x:Name="EndDatePicker" Grid.Column="3"/>
            </Grid>
        </StackPanel>

        <!-- 외부 수신자 범위 -->
        <StackPanel x:Name="AudiencePanel" Grid.Row="3" Visibility="Collapsed" Margin="0,0,0,12">
            <TextBlock Text="외부 수신자 범위" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <ComboBox x:Name="ExternalAudienceCombo" SelectedIndex="0" Width="200" HorizontalAlignment="Left">
                <ComboBoxItem Content="모든 외부 발신자" Tag="all"/>
                <ComboBoxItem Content="연락처만" Tag="contactsOnly"/>
                <ComboBoxItem Content="외부 응답 없음" Tag="none"/>
            </ComboBox>
        </StackPanel>

        <!-- 메시지 입력 영역 -->
        <Grid x:Name="MessagePanel" Grid.Row="4" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="내부 수신자 응답 메시지" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="InternalMessageBox" Grid.Row="1"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,12"/>

            <TextBlock Grid.Row="2" Text="외부 수신자 응답 메시지" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox x:Name="ExternalMessageBox" Grid.Row="3"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto"/>
        </Grid>

        <!-- 버튼 영역 -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,16,0,0">
            <ui:Button x:Name="SaveButton"
                       Content="저장"
                       Appearance="Primary"
                       Margin="0,0,8,0"
                       Padding="24,8"
                       Click="SaveButton_Click"/>
            <ui:Button Content="취소"
                       Appearance="Secondary"
                       Padding="24,8"
                       Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</ui:FluentWindow>
