<ui:FluentWindow x:Class="mAIx.Views.Dialogs.DailyBriefingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="AI 일일 브리핑"
        Width="520"
        Height="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ui:TitleBar Grid.Row="0" Title="AI 일일 브리핑" ShowMaximize="False" ShowMinimize="False"/>
        <Border Grid.Row="1" Margin="16,8,16,8">
            <Grid>
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Visible">
                    <ui:ProgressRing IsIndeterminate="True" Width="48" Height="48" Margin="0,0,0,12"/>
                    <TextBlock Text="AI가 브리핑을 생성 중입니다..." FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                <ScrollViewer x:Name="ResultScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <TextBlock x:Name="BriefingTextBlock" TextWrapping="Wrap" FontSize="13" LineHeight="22" Margin="4,4,4,4" Text=""/>
                </ScrollViewer>
                <StackPanel x:Name="ErrorPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                    <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="40" Foreground="{DynamicResource SystemFillColorCriticalBrush}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                    <TextBlock x:Name="ErrorTextBlock" Text="브리핑 생성에 실패했습니다." FontSize="13" Foreground="{DynamicResource SystemFillColorCriticalBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="2" Background="{DynamicResource ControlFillColorDefaultBrush}" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0" Padding="16,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button x:Name="CloseButton" Content="닫기" Appearance="Primary" Width="80" Click="CloseButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
