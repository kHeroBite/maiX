<ui:FluentWindow x:Class="mAIx.Views.Dialogs.EventEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="새 이벤트 - 일정"
        Height="700" Width="1050"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        KeyDown="Window_KeyDown">

    <Window.Resources>
        <!-- 아이콘 스타일 -->
        <Style x:Key="FieldIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- 필드 행 스타일 -->
        <Style x:Key="FieldRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 (아웃룩 스타일) -->
        <Border Grid.Row="0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 버튼들 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- 저장 버튼 -->
                    <ui:Button x:Name="SaveButton"
                              AutomationProperties.AutomationId="SaveButton"
                              Appearance="Primary"
                              Click="SaveButton_Click"
                              Margin="4,0"
                              Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="저장" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>

                    <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>

                    <!-- 이벤트 타입 버튼 (선택됨 표시) -->
                    <ui:Button Appearance="Secondary" Margin="4,0" Padding="12,6" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Calendar24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="이벤트" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>

                    <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>

                    <!-- 되풀이 항목 -->
                    <ui:Button x:Name="RecurrenceButton"
                              AutomationProperties.AutomationId="RecurrenceButton"
                              Appearance="Secondary"
                              Click="RecurrenceButton_Click"
                              Margin="4,0"
                              Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="ArrowRepeatAll24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="되풀이 항목" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>

                    <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>

                    <!-- 다른 용무 중 (상태) -->
                    <ui:Button x:Name="ShowAsButton"
                              Appearance="Secondary"
                              Click="ShowAsButton_Click"
                              Margin="4,0"
                              Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <Rectangle x:Name="ShowAsIndicator" Width="4" Height="14" Fill="#0078D4" Margin="0,0,6,0" RadiusX="2" RadiusY="2"/>
                            <TextBlock x:Name="ShowAsText" Text="다른 용무 중" VerticalAlignment="Center"/>
                            <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10" Margin="4,0,0,0"/>
                        </StackPanel>
                    </ui:Button>

                    <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>

                    <!-- 분류 -->
                    <ui:Button x:Name="CategoryButton"
                              Appearance="Secondary"
                              Click="CategoryButton_Click"
                              Margin="4,0"
                              Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Tag24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="분류" VerticalAlignment="Center"/>
                            <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10" Margin="4,0,0,0"/>
                        </StackPanel>
                    </ui:Button>

                    <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>

                    <!-- 삭제 버튼 (수정 모드에서만 표시) -->
                    <ui:Button x:Name="DeleteButton"
                              AutomationProperties.AutomationId="DeleteButton"
                              Appearance="Danger"
                              Click="DeleteButton_Click"
                              Margin="4,0"
                              Padding="12,6"
                              Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="삭제" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 메인 콘텐츠 영역 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="450"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 입력 폼 -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          Padding="0">
                <StackPanel>
                    <!-- 제목 입력 -->
                    <Border Style="{StaticResource FieldRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Edit20" Style="{StaticResource FieldIconStyle}"/>
                            <ui:TextBox x:Name="SubjectTextBox"
                                       AutomationProperties.AutomationId="SubjectTextBox"
                                       Grid.Column="1"
                                       PlaceholderText="제목 추가"
                                       FontSize="16"
                                       BorderThickness="0"
                                       Background="Transparent"/>
                        </Grid>
                    </Border>

                    <!-- 필수 참석자 초대 -->
                    <Border Style="{StaticResource FieldRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="People24" Style="{StaticResource FieldIconStyle}"/>
                            <ui:TextBox x:Name="AttendeesTextBox"
                                       AutomationProperties.AutomationId="AttendeesTextBox"
                                       Grid.Column="1"
                                       PlaceholderText="필수 참석자 초대"
                                       BorderThickness="0"
                                       Background="Transparent"
                                       TextChanged="AttendeesTextBox_TextChanged"
                                       PreviewKeyDown="AttendeesTextBox_PreviewKeyDown"/>
                            <ui:Button Grid.Column="2"
                                      Appearance="Transparent"
                                      Padding="8,4"
                                      Click="OptionalAttendeesButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="PeopleAdd24" FontSize="14" Margin="0,0,4,0"/>
                                    <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10"/>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </Border>


                    <!-- 선택적 참석자 (기본 숨김) -->
                    <Border x:Name="OptionalAttendeesRow"
                            Style="{StaticResource FieldRowStyle}"
                            Visibility="Collapsed">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="PersonAdd24" Style="{StaticResource FieldIconStyle}"/>
                            <ui:TextBox x:Name="OptionalAttendeesTextBox"
                                       AutomationProperties.AutomationId="OptionalAttendeesTextBox"
                                       Grid.Column="1"
                                       PlaceholderText="선택적 참석자"
                                       BorderThickness="0"
                                       Background="Transparent"/>
                        </Grid>
                    </Border>

                    <!-- 날짜/시간 -->
                    <Border Style="{StaticResource FieldRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <ui:SymbolIcon Grid.Column="0" Grid.RowSpan="2" Symbol="Clock24" Style="{StaticResource FieldIconStyle}"/>

                            <!-- 시작 날짜/시간 -->
                            <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                                <DatePicker x:Name="StartDatePicker"
                                           AutomationProperties.AutomationId="StartDatePicker"
                                           Width="160"
                                           Margin="0,0,8,0"/>
                                <ui:TextBox x:Name="StartTimeTextBox"
                                           AutomationProperties.AutomationId="StartTimeTextBox"
                                           Width="100"
                                           PlaceholderText="오후 9:00"
                                           HorizontalContentAlignment="Center"
                                           PreviewMouseWheel="TimeTextBox_PreviewMouseWheel"
                                           LostFocus="TimeTextBox_LostFocus"/>
                                <TextBlock Text=" - " VerticalAlignment="Center" Margin="8,0"/>
                                <ui:TextBox x:Name="EndTimeTextBox"
                                           AutomationProperties.AutomationId="EndTimeTextBox"
                                           Width="100"
                                           PlaceholderText="오후 9:30"
                                           HorizontalContentAlignment="Center"
                                           PreviewMouseWheel="TimeTextBox_PreviewMouseWheel"
                                           LostFocus="TimeTextBox_LostFocus"/>
                            </StackPanel>

                            <!-- 종료 날짜 (다른 날일 경우) -->
                            <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Visibility="Collapsed" x:Name="EndDateRow">
                                <TextBlock Text="종료:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <DatePicker x:Name="EndDatePicker" Width="160"/>
                            </StackPanel>

                            <!-- 종일/스케줄러 버튼 -->
                            <StackPanel Grid.Column="2" Grid.Row="0" Grid.RowSpan="2" Orientation="Horizontal" VerticalAlignment="Top">
                                <CheckBox x:Name="IsAllDayCheckBox"
                                         AutomationProperties.AutomationId="IsAllDayCheckBox"
                                         Content="종일"
                                         Margin="16,0,8,0"
                                         Checked="IsAllDayCheckBox_Changed"
                                         Unchecked="IsAllDayCheckBox_Changed"/>
                            </StackPanel>

                            <ui:Button Grid.Column="3" Grid.Row="0"
                                      Appearance="Transparent"
                                      Click="SchedulerButton_Click"
                                      VerticalAlignment="Top"
                                      Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="14" Margin="0,0,4,0"/>
                                    <TextBlock Text="스케줄러" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </Border>

                    <!-- 장소 -->
                    <Border Style="{StaticResource FieldRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Location24" Style="{StaticResource FieldIconStyle}"/>
                            <ui:TextBox x:Name="LocationTextBox"
                                       AutomationProperties.AutomationId="LocationTextBox"
                                       Grid.Column="1"
                                       PlaceholderText="회의실 또는 위치 추가"
                                       BorderThickness="0"
                                       Background="Transparent"/>
                            <ui:Button Grid.Column="2"
                                      Appearance="Transparent"
                                      Click="LocationSearchButton_Click"
                                      Padding="8,4">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Search24" FontSize="14" Margin="0,0,4,0"/>
                                    <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10"/>
                                </StackPanel>
                            </ui:Button>
                        </Grid>
                    </Border>

                    <!-- Teams 모임 토글 -->
                    <Border Style="{StaticResource FieldRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Video24" Style="{StaticResource FieldIconStyle}"/>
                            <ui:ToggleSwitch x:Name="IsOnlineMeetingToggle"
                                            AutomationProperties.AutomationId="IsOnlineMeetingToggle"
                                            Grid.Column="1"
                                            Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="2"
                                      Text="Teams 모임"
                                      VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- 알림 -->
                    <Border Style="{StaticResource FieldRowStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Alert24" Style="{StaticResource FieldIconStyle}"/>
                            <ComboBox x:Name="ReminderComboBox"
                                     AutomationProperties.AutomationId="ReminderComboBox"
                                     Grid.Column="1"
                                     Width="150"
                                     SelectedIndex="2">
                                <ComboBoxItem Content="없음" Tag="0"/>
                                <ComboBoxItem Content="5분 전" Tag="5"/>
                                <ComboBoxItem Content="15분 전" Tag="15"/>
                                <ComboBoxItem Content="30분 전" Tag="30"/>
                                <ComboBoxItem Content="1시간 전" Tag="60"/>
                                <ComboBoxItem Content="2시간 전" Tag="120"/>
                                <ComboBoxItem Content="1일 전" Tag="1440"/>
                                <ComboBoxItem Content="1주 전" Tag="10080"/>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- 메모/본문 영역 -->
                    <Border Padding="16,12" MinHeight="250">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <ui:SymbolIcon Grid.Column="0" Symbol="Document24" Style="{StaticResource FieldIconStyle}" VerticalAlignment="Top"/>
                            <ui:TextBox x:Name="BodyTextBox"
                                       AutomationProperties.AutomationId="BodyTextBox"
                                       Grid.Column="1"
                                       PlaceholderText="메모 또는 회의 안건을 입력하세요..."
                                       AcceptsReturn="True"
                                       TextWrapping="Wrap"
                                       MinHeight="200"
                                       VerticalContentAlignment="Top"
                                       BorderThickness="0"
                                       Background="Transparent"/>
                        </Grid>
                    </Border>

                    <!-- 본문 하단 툴바 (서식 도구) -->
                    <Border BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,1,0,0"
                            Padding="56,8,16,8">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Appearance="Transparent" Padding="6" ToolTip="첨부 파일">
                                <ui:SymbolIcon Symbol="Attach20" FontSize="14"/>
                            </ui:Button>
                            <ui:Button Appearance="Transparent" Padding="6" ToolTip="이미지 삽입">
                                <ui:SymbolIcon Symbol="Image20" FontSize="14"/>
                            </ui:Button>
                            <ui:Button Appearance="Transparent" Padding="6" ToolTip="이모지">
                                <TextBlock Text="😊" FontSize="14"/>
                            </ui:Button>
                            <ui:Button Appearance="Transparent" Padding="6" ToolTip="GIF">
                                <ui:SymbolIcon Symbol="Play20" FontSize="14"/>
                            </ui:Button>
                            <ui:Button Appearance="Transparent" Padding="6" ToolTip="서식">
                                <ui:SymbolIcon Symbol="TextBold20" FontSize="14"/>
                            </ui:Button>
                            <ui:Button Appearance="Transparent" Padding="6" ToolTip="중요도">
                                <ui:SymbolIcon Symbol="Star20" FontSize="14"/>
                            </ui:Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 오른쪽: 미니 캘린더 미리보기 -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1,0,0,0"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 미니 캘린더 헤더 -->
                    <Border Grid.Row="0" Padding="12,8"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0"
                                      Appearance="Transparent"
                                      Padding="4"
                                      Click="PrevDay_Click">
                                <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="12"/>
                            </ui:Button>
                            <TextBlock x:Name="PreviewDateText"
                                      Grid.Column="1"
                                      Text="화, 2026, 1월 20"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal">
                                <ui:Button Appearance="Transparent"
                                          Padding="4"
                                          Click="NextDay_Click">
                                    <ui:SymbolIcon Symbol="ChevronRight24" FontSize="12"/>
                                </ui:Button>
                                <ui:Button Appearance="Transparent"
                                          Padding="4"
                                          Click="ExpandPreview_Click">
                                    <ui:SymbolIcon Symbol="Maximize20" FontSize="12"/>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 일정 미리보기 (시간대별) -->
                    <ScrollViewer x:Name="TimeSlotScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="TimeSlotPanel" Margin="0,8">
                            <!-- 동적으로 시간대별 슬롯 생성 -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 참석자 자동완성 팝업 (Window 레벨에 배치하여 다른 요소와 겹침 방지) -->
        <Popup x:Name="AttendeesSuggestionPopup"
               PlacementTarget="{Binding ElementName=AttendeesTextBox}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               HorizontalOffset="40">
            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="4" MinWidth="350" MaxWidth="500"
                    Effect="{DynamicResource DefaultDropShadow}">
                <ListBox x:Name="AttendeesSuggestionList"
                         MaxHeight="200"
                         Background="Transparent"
                         BorderThickness="0"
                         SelectionChanged="AttendeesSuggestionList_SelectionChanged"
                         MouseDoubleClick="AttendeesSuggestionList_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                                    <TextBlock Text="{Binding Initials}"
                                              Foreground="White"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              FontSize="11"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Email}"
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                              FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Popup>
    </Grid>
</ui:FluentWindow>
