<ui:FluentWindow x:Class="MaiX.Views.Dialogs.SignatureSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="서명 관리"
        Width="900"
        Height="700"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar Grid.Row="0"
                     Title="서명 관리"
                     ShowMaximize="True"
                     ShowMinimize="False"/>

        <!-- 메인 콘텐츠 -->
        <Grid Grid.Row="1" Margin="16,8,16,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 서명 목록 -->
            <ui:Card Grid.Column="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="서명 목록" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <ListBox Grid.Row="1" x:Name="SignatureListBox"
                             BorderThickness="0"
                             Background="Transparent"
                             SelectionChanged="SignatureListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                    <ui:SymbolIcon Symbol="Signature24" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,0">
                        <ui:Button Icon="{ui:SymbolIcon Add24}"
                                   ToolTip="새 서명 추가"
                                   Appearance="Secondary"
                                   Margin="0,0,4,0"
                                   Click="AddSignature_Click"/>
                        <ui:Button Icon="{ui:SymbolIcon Delete24}"
                                   ToolTip="서명 삭제"
                                   Appearance="Secondary"
                                   Click="DeleteSignature_Click"/>
                    </StackPanel>
                </Grid>
            </ui:Card>

            <!-- 우측: 서명 편집 -->
            <ui:Card Grid.Column="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="서명 편집" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"/>

                    <!-- 서명 이름 -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,8">
                        <TextBlock Text="서명 이름" FontSize="12" Margin="0,0,0,4"/>
                        <ui:TextBox x:Name="SignatureNameTextBox"
                                    PlaceholderText="예: 업무용, 개인용"
                                    TextChanged="SignatureNameTextBox_TextChanged"/>
                    </StackPanel>

                    <!-- 서명 내용 (RichTextBox 에디터) -->
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="서명 내용" FontSize="12" Margin="0,0,0,4"/>

                        <!-- 서식 도구 모음 -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:Button x:Name="BoldBtn" Icon="{ui:SymbolIcon TextBold24}" ToolTip="굵게 (Ctrl+B)" Padding="6" Margin="0,0,2,0" Click="FormatBold_Click"/>
                            <ui:Button x:Name="ItalicBtn" Icon="{ui:SymbolIcon TextItalic24}" ToolTip="기울임 (Ctrl+I)" Padding="6" Margin="0,0,2,0" Click="FormatItalic_Click"/>
                            <ui:Button x:Name="UnderlineBtn" Icon="{ui:SymbolIcon TextUnderline24}" ToolTip="밑줄 (Ctrl+U)" Padding="6" Margin="0,0,8,0" Click="FormatUnderline_Click"/>
                            <Separator Width="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,4,8,4"/>
                            <ui:Button Icon="{ui:SymbolIcon TextAlignLeft24}" ToolTip="왼쪽 정렬" Padding="6" Margin="0,0,2,0" Click="AlignLeft_Click"/>
                            <ui:Button Icon="{ui:SymbolIcon TextAlignCenter24}" ToolTip="가운데 정렬" Padding="6" Margin="0,0,2,0" Click="AlignCenter_Click"/>
                            <ui:Button Icon="{ui:SymbolIcon TextAlignRight24}" ToolTip="오른쪽 정렬" Padding="6" Margin="0,0,8,0" Click="AlignRight_Click"/>
                            <Separator Width="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,4,8,4"/>
                            <ui:Button Icon="{ui:SymbolIcon Link24}" ToolTip="링크 삽입" Padding="6" Margin="0,0,2,0" Click="InsertLink_Click"/>
                            <ui:Button Icon="{ui:SymbolIcon Image24}" ToolTip="이미지 삽입" Padding="6" Margin="0,0,8,0" Click="InsertImage_Click"/>
                            <Separator Width="1" Background="{DynamicResource ControlElevationBorderBrush}" Margin="0,4,8,4"/>
                            <ComboBox x:Name="FontSizeCombo" Width="70" Height="28" ToolTip="글꼴 크기" SelectionChanged="FontSize_Changed">
                                <ComboBoxItem Content="8pt"/>
                                <ComboBoxItem Content="10pt"/>
                                <ComboBoxItem Content="12pt" IsSelected="True"/>
                                <ComboBoxItem Content="14pt"/>
                                <ComboBoxItem Content="16pt"/>
                                <ComboBoxItem Content="18pt"/>
                                <ComboBoxItem Content="24pt"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- RichTextBox 에디터 -->
                        <Border Grid.Row="2" BorderBrush="{DynamicResource ControlElevationBorderBrush}" BorderThickness="1" CornerRadius="4" Background="White">
                            <RichTextBox x:Name="SignatureEditor"
                                         AcceptsReturn="True"
                                         AcceptsTab="True"
                                         BorderThickness="0"
                                         Padding="8"
                                         FontFamily="Malgun Gothic"
                                         FontSize="12"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="White"
                                         Foreground="Black"/>
                        </Border>
                    </Grid>
                </Grid>
            </ui:Card>
        </Grid>

        <!-- 옵션 및 버튼 영역 -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 옵션 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <StackPanel Margin="0,0,24,0">
                        <TextBlock Text="새 메일 기본 서명" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="DefaultSignatureCombo" Width="150" Height="28"
                                  SelectionChanged="DefaultSignatureCombo_SelectionChanged"/>
                    </StackPanel>
                    <StackPanel>
                        <TextBlock Text="답장/전달 기본 서명" FontSize="11" Margin="0,0,0,2"/>
                        <ComboBox x:Name="ReplyForwardSignatureCombo" Width="150" Height="28"
                                  SelectionChanged="ReplyForwardSignatureCombo_SelectionChanged"/>
                    </StackPanel>
                </StackPanel>

                <!-- 버튼 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ui:Button Content="취소" Appearance="Secondary" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
                    <ui:Button Content="저장" Appearance="Primary" Width="80" Click="Save_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
