<ui:FluentWindow x:Class="mAIx.Views.Dialogs.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="작업 편집"
        Height="800" Width="700"
        MinHeight="600" MinWidth="550"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        KeyDown="Window_KeyDown"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- 아이콘 스타일 -->
        <Style x:Key="FieldIconStyle" TargetType="ui:SymbolIcon">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- 필드 행 스타일 -->
        <Style x:Key="FieldRowStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- 섹션 헤더 스타일 -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="Margin" Value="16,16,16,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 상단 툴바 -->
        <Border Grid.Row="0"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="8,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 왼쪽 버튼들 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <!-- 저장 버튼 -->
                    <ui:Button x:Name="SaveButton"
                              AutomationProperties.AutomationId="SaveButton"
                              Appearance="Primary"
                              Click="SaveButton_Click"
                              Margin="4,0"
                              Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Save24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="저장" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>

                    <Rectangle Width="1" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>

                    <!-- 완료 토글 -->
                    <ui:Button x:Name="CompleteButton"
                              AutomationProperties.AutomationId="CompleteButton"
                              Appearance="Secondary"
                              Click="CompleteButton_Click"
                              Margin="4,0"
                              Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <ui:SymbolIcon x:Name="CompleteIcon" Symbol="CheckmarkCircle24" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock x:Name="CompleteText" Text="완료로 표시" VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:Button>
                </StackPanel>

                <!-- 오른쪽: 삭제 버튼 -->
                <ui:Button Grid.Column="2"
                          x:Name="DeleteButton"
                          AutomationProperties.AutomationId="DeleteButton"
                          Appearance="Secondary"
                          Click="DeleteButton_Click"
                          Margin="4,0"
                          Padding="12,6">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Delete24" FontSize="14" Margin="0,0,6,0" Foreground="#D13438"/>
                        <TextBlock Text="삭제" Foreground="#D13438" VerticalAlignment="Center"/>
                    </StackPanel>
                </ui:Button>
            </Grid>
        </Border>

        <!-- 메인 콘텐츠 (스크롤) -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 작업 제목 -->
                <Border Style="{StaticResource FieldRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="TaskListSquareLtr24" Style="{StaticResource FieldIconStyle}"/>
                        <ui:TextBox x:Name="TitleTextBox"
                                   AutomationProperties.AutomationId="TitleTextBox"
                                   Grid.Column="1"
                                   PlaceholderText="작업 제목"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   BorderThickness="0"
                                   Background="Transparent"
                                   TextChanged="TitleTextBox_TextChanged"/>
                    </Grid>
                </Border>

                <!-- 버킷 선택 -->
                <Border Style="{StaticResource FieldRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="Column24" Style="{StaticResource FieldIconStyle}"/>
                        <TextBlock Grid.Column="1" Text="버킷" VerticalAlignment="Center"/>
                        <ComboBox x:Name="BucketComboBox"
                                 AutomationProperties.AutomationId="BucketComboBox"
                                 Grid.Column="2"
                                 HorizontalAlignment="Stretch"
                                 DisplayMemberPath="Name"
                                 SelectionChanged="BucketComboBox_SelectionChanged"/>
                    </Grid>
                </Border>

                <!-- 진행률 -->
                <Border Style="{StaticResource FieldRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="TaskListSquareLtr24" Style="{StaticResource FieldIconStyle}"/>
                        <TextBlock Grid.Column="1" Text="진행률" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ProgressComboBox"
                                 AutomationProperties.AutomationId="ProgressComboBox"
                                 Grid.Column="2"
                                 HorizontalAlignment="Stretch"
                                 SelectionChanged="ProgressComboBox_SelectionChanged">
                            <ComboBoxItem Content="시작 안 함" Tag="0"/>
                            <ComboBoxItem Content="진행 중" Tag="50"/>
                            <ComboBoxItem Content="완료" Tag="100"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- 우선 순위 -->
                <Border Style="{StaticResource FieldRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="Flag24" Style="{StaticResource FieldIconStyle}"/>
                        <TextBlock Grid.Column="1" Text="우선 순위" VerticalAlignment="Center"/>
                        <ComboBox x:Name="PriorityComboBox"
                                 AutomationProperties.AutomationId="PriorityComboBox"
                                 Grid.Column="2"
                                 HorizontalAlignment="Stretch"
                                 SelectionChanged="PriorityComboBox_SelectionChanged">
                            <ComboBoxItem Tag="1">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#D13438" Margin="0,0,8,0"/>
                                    <TextBlock Text="긴급"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="3">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#C239B3" Margin="0,0,8,0"/>
                                    <TextBlock Text="중요"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="5">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#0078D4" Margin="0,0,8,0"/>
                                    <TextBlock Text="중간"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem Tag="9">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#808080" Margin="0,0,8,0"/>
                                    <TextBlock Text="낮음"/>
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- 시작 날짜 -->
                <Border Style="{StaticResource FieldRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="CalendarLtr24" Style="{StaticResource FieldIconStyle}"/>
                        <TextBlock Grid.Column="1" Text="시작 날짜" VerticalAlignment="Center"/>
                        <DatePicker x:Name="StartDatePicker"
                                   AutomationProperties.AutomationId="StartDatePicker"
                                   Grid.Column="2"
                                   HorizontalAlignment="Stretch"
                                   SelectedDateChanged="StartDatePicker_SelectedDateChanged"/>
                    </Grid>
                </Border>

                <!-- 기한 -->
                <Border Style="{StaticResource FieldRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="CalendarCheckmark24" Style="{StaticResource FieldIconStyle}"/>
                        <TextBlock Grid.Column="1" Text="기한" VerticalAlignment="Center"/>
                        <DatePicker x:Name="DueDatePicker"
                                   AutomationProperties.AutomationId="DueDatePicker"
                                   Grid.Column="2"
                                   HorizontalAlignment="Stretch"
                                   SelectedDateChanged="DueDatePicker_SelectedDateChanged"/>
                    </Grid>
                </Border>

                <!-- 반복 (기본 - 추후 확장) -->
                <Border Style="{StaticResource FieldRowStyle}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0" Symbol="ArrowRepeatAll24" Style="{StaticResource FieldIconStyle}"/>
                        <TextBlock Grid.Column="1" Text="반복" VerticalAlignment="Center"/>
                        <ComboBox x:Name="RecurrenceComboBox"
                                 Grid.Column="2"
                                 HorizontalAlignment="Stretch"
                                 IsEnabled="False"
                                 ToolTip="반복 기능은 추후 지원 예정입니다">
                            <ComboBoxItem Content="반복 안 함" IsSelected="True"/>
                        </ComboBox>
                    </Grid>
                </Border>

                <!-- 메모 섹션 헤더 -->
                <TextBlock Text="메모" Style="{StaticResource SectionHeaderStyle}"/>

                <!-- 카드에 표시 체크박스 -->
                <Border Padding="16,8">
                    <CheckBox x:Name="ShowNotesOnCardCheckBox"
                             AutomationProperties.AutomationId="ShowNotesOnCardCheckBox"
                             Content="카드에 표시"
                             Checked="ShowNotesOnCardCheckBox_Changed"
                             Unchecked="ShowNotesOnCardCheckBox_Changed"/>
                </Border>

                <!-- 메모 에디터 (WebView2 TinyMCE) -->
                <Border Margin="16,0,16,16"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Height="200">
                    <wv2:WebView2 x:Name="NotesWebView"
                                 DefaultBackgroundColor="Transparent"
                                 AllowDrop="True"
                                 PreviewDragOver="NotesWebView_DragOver"
                                 PreviewDrop="NotesWebView_Drop"/>
                </Border>

                <!-- 검사 목록 섹션 -->
                <TextBlock Text="검사 목록" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Margin="16,0,16,8">
                    <StackPanel>
                        <!-- 검사 목록 아이템들 -->
                        <ItemsControl x:Name="ChecklistItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,0,0,4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <CheckBox Grid.Column="0"
                                                     IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                     Checked="ChecklistItem_CheckChanged"
                                                     Unchecked="ChecklistItem_CheckChanged"
                                                     Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                      Text="{Binding Title}"
                                                      VerticalAlignment="Center"
                                                      TextDecorations="{Binding IsChecked, Converter={StaticResource BoolToStrikethroughConverter}}"/>
                                            <ui:Button Grid.Column="2"
                                                      Appearance="Transparent"
                                                      Padding="4"
                                                      Tag="{Binding}"
                                                      Click="DeleteChecklistItem_Click">
                                                <ui:SymbolIcon Symbol="Delete16" FontSize="12"/>
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 항목 추가 입력 -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="NewChecklistItemTextBox"
                                       AutomationProperties.AutomationId="NewChecklistItemTextBox"
                                       Grid.Column="0"
                                       PlaceholderText="항목 추가"
                                       KeyDown="NewChecklistItemTextBox_KeyDown"/>
                            <ui:Button Grid.Column="1"
                                      Appearance="Secondary"
                                      Click="AddChecklistItem_Click"
                                      Margin="8,0,0,0"
                                      Padding="12,6">
                                <ui:SymbolIcon Symbol="Add24" FontSize="14"/>
                            </ui:Button>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 첨부 파일 섹션 -->
                <TextBlock Text="첨부 파일" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Margin="16,0,16,8">
                    <StackPanel>
                        <!-- 첨부 파일 목록 -->
                        <ItemsControl x:Name="AttachmentsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8,6" Margin="0,0,0,4"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="4"
                                            Cursor="Hand"
                                            MouseLeftButtonUp="Attachment_Click">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ui:SymbolIcon Grid.Column="0" Symbol="Attach24" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                      Text="{Binding Name}"
                                                      VerticalAlignment="Center"
                                                      TextDecorations="Underline"
                                                      Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                                            <ui:Button Grid.Column="2"
                                                      Appearance="Transparent"
                                                      Padding="4"
                                                      Tag="{Binding}"
                                                      Click="DeleteAttachment_Click"
                                                      ToolTip="삭제">
                                                <ui:SymbolIcon Symbol="Delete16" FontSize="12"/>
                                            </ui:Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 첨부 파일 추가 버튼 -->
                        <ui:Button Appearance="Secondary"
                                  Click="AddAttachment_Click"
                                  Margin="0,8,0,0"
                                  Padding="12,6"
                                  HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Attach24" FontSize="14" Margin="0,0,6,0"/>
                                <TextBlock Text="첨부 파일 추가"/>
                            </StackPanel>
                        </ui:Button>
                    </StackPanel>
                </Border>

                <!-- 댓글 섹션 -->
                <TextBlock Text="댓글" Style="{StaticResource SectionHeaderStyle}"/>

                <Border Margin="16,0,16,16">
                    <StackPanel>
                        <!-- 댓글 목록 -->
                        <ItemsControl x:Name="CommentsItemsControl">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="12" Margin="0,0,0,8"
                                            Background="{DynamicResource ControlFillColorDefaultBrush}"
                                            CornerRadius="8">
                                        <StackPanel>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- 아바타 -->
                                                <Border Grid.Column="0" Width="28" Height="28" CornerRadius="14"
                                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                        Margin="0,0,10,0">
                                                    <TextBlock Text="{Binding UserInitial}"
                                                              HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"
                                                              Foreground="White"
                                                              FontSize="12"
                                                              FontWeight="SemiBold"/>
                                                </Border>
                                                <!-- 사용자 이름과 시간 -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding UserName}" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                              FontSize="11"
                                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </Grid>
                                            <!-- 댓글 내용 -->
                                            <TextBlock Text="{Binding Content}"
                                                      Margin="38,8,0,0"
                                                      TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- 댓글 입력 -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ui:TextBox x:Name="NewCommentTextBox"
                                       AutomationProperties.AutomationId="NewCommentTextBox"
                                       Grid.Column="0"
                                       PlaceholderText="댓글 추가..."
                                       KeyDown="NewCommentTextBox_KeyDown"/>
                            <ui:Button Grid.Column="1"
                                      Appearance="Primary"
                                      Click="AddComment_Click"
                                      Margin="8,0,0,0"
                                      Padding="12,6">
                                <ui:SymbolIcon Symbol="Send24" FontSize="14"/>
                            </ui:Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- 하단 상태바 -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusText"
                          Grid.Column="0"
                          Text=""
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                          FontSize="12"/>
                <TextBlock Grid.Column="1"
                          Text="Esc: 닫기 | Ctrl+S: 저장"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                          FontSize="11"/>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
