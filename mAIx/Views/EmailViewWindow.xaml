<ui:FluentWindow x:Class="mAIx.Views.EmailViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:mAIx.Views"
        xmlns:converters="clr-namespace:mAIx.Converters"
        mc:Ignorable="d"
        Title="메일 보기"
        Height="700" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Window.Resources>
        <converters:JsonArrayToStringConverter x:Key="JsonArrayToStringConverter"/>
        <converters:EmptySubjectConverter x:Key="EmptySubjectConverter"/>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            ShowMaximize="True"
            ShowMinimize="True"
            ShowClose="True"
            CanMaximize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Width="24" Height="24"
                              RenderOptions.BitmapScalingMode="Fant"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                    <ui:ImageIcon.Source>
                        <BitmapImage UriSource="pack://application:,,,/Assets/icon.png"
                                     DecodePixelWidth="256"
                                     DecodePixelHeight="256"
                                     CacheOption="OnLoad"/>
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <TextBlock x:Name="TitleText" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
            </ui:TitleBar.Header>
        </ui:TitleBar>

        <!-- 메일 헤더 정보 -->
        <Border Grid.Row="1"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 제목 -->
                <TextBlock x:Name="SubjectText" Grid.Row="0"
                           FontSize="20" FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,12"/>

                <!-- 발신자 -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="보낸 사람:"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Width="70"/>
                    <TextBlock x:Name="FromText"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                </StackPanel>

                <!-- 수신자 -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="받는 사람:"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Width="70"/>
                    <TextBlock x:Name="ToText"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="700"/>
                </StackPanel>

                <!-- 참조 (CC) -->
                <StackPanel x:Name="CcRow" Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="Collapsed">
                    <TextBlock Text="참조:"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Width="70"/>
                    <TextBlock x:Name="CcText"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="700"/>
                </StackPanel>

                <!-- 숨은 참조 (BCC) -->
                <StackPanel x:Name="BccRow" Grid.Row="4" Orientation="Horizontal" Margin="0,0,0,8"
                            Visibility="Collapsed">
                    <TextBlock Text="숨은 참조:"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Width="70"/>
                    <TextBlock x:Name="BccText"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                               TextWrapping="Wrap"
                               MaxWidth="700"/>
                </StackPanel>

                <!-- 날짜 -->
                <StackPanel Grid.Row="5" Orientation="Horizontal">
                    <TextBlock Text="날짜:"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               Width="70"/>
                    <TextBlock x:Name="DateText"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- AI 도구바 -->
        <Border Grid.Row="2"
                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- AI 답장 버튼 + 톤 드롭다운 -->
                <ui:Button x:Name="AiReplyButton"
                           Content="AI 답장"
                           Icon="{ui:SymbolIcon Symbol=Mail24}"
                           Appearance="Primary"
                           Click="AiReplyButton_Click"
                           Margin="0,0,4,0"/>
                <ComboBox x:Name="ToneComboBox"
                          Width="90"
                          SelectedIndex="0"
                          VerticalAlignment="Center"
                          Margin="0,0,12,0"
                          ToolTip="답장 톤 선택">
                    <ComboBoxItem Content="정중"/>
                    <ComboBoxItem Content="캐주얼"/>
                    <ComboBoxItem Content="비즈니스"/>
                </ComboBox>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="0,0,12,0"/>

                <!-- TTS 읽어주기 / 중지 버튼 -->
                <ui:Button x:Name="TtsButton"
                           Content="읽어주기"
                           Icon="{ui:SymbolIcon Symbol=Speaker224}"
                           Click="TtsButton_Click"
                           Margin="0,0,12,0"/>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="0,0,12,0"/>

                <!-- 스누즈 버튼 -->
                <ui:Button x:Name="SnoozeButton"
                           Content="스누즈"
                           Icon="{ui:SymbolIcon Symbol=Clock24}"
                           Click="SnoozeButton_Click"
                           Margin="0,0,0,0"/>

                <!-- 스누즈 드롭다운 팝업 -->
                <Popup x:Name="SnoozePopup"
                       StaysOpen="False"
                       PlacementTarget="{Binding ElementName=SnoozeButton}"
                       Placement="Bottom">
                    <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="4">
                        <StackPanel>
                            <MenuItem Header="1시간 후" Tag="1h" Click="SnoozeMenuItem_Click" Padding="12,6"/>
                            <MenuItem Header="3시간 후" Tag="3h" Click="SnoozeMenuItem_Click" Padding="12,6"/>
                            <MenuItem Header="내일 아침 (9시)" Tag="tomorrow" Click="SnoozeMenuItem_Click" Padding="12,6"/>
                            <MenuItem Header="다음 주 월요일" Tag="nextmonday" Click="SnoozeMenuItem_Click" Padding="12,6"/>
                        </StackPanel>
                    </Border>
                </Popup>

                <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"
                           Margin="12,0,12,0"/>

                <!-- 스레드 요약 토글 버튼 -->
                <ui:Button x:Name="ThreadSummaryButton"
                           Content="스레드 요약"
                           Icon="{ui:SymbolIcon Symbol=TextBulletListSquare24}"
                           Click="ThreadSummaryButton_Click"/>

            </StackPanel>
        </Border>

        <!-- 스레드 요약 패널 (접이식) -->
        <Border x:Name="ThreadSummaryPanel"
                Grid.Row="3"
                Visibility="Collapsed"
                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <ui:SymbolIcon Symbol="TextBulletListSquare24" Margin="0,0,8,0"/>
                    <TextBlock Text="스레드 요약"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                    <ui:ProgressRing x:Name="ThreadSummaryLoading"
                                     Width="16" Height="16"
                                     IsIndeterminate="True"
                                     Visibility="Collapsed"
                                     Margin="8,0,0,0"/>
                </StackPanel>

                <TextBlock x:Name="ThreadSummaryText"
                           Grid.Row="1"
                           Text="요약을 불러오는 중..."
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           FontSize="13"
                           LineHeight="20"/>
            </Grid>
        </Border>

        <!-- 메일 본문 -->
        <wv2:WebView2 x:Name="BodyWebView"
                      Grid.Row="4"
                      DefaultBackgroundColor="Transparent"/>
    </Grid>
</ui:FluentWindow>
