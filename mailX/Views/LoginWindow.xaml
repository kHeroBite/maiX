<Window x:Class="mailX.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:vm="clr-namespace:mailX.ViewModels"
        mc:Ignorable="d"
        Title="mailX - 로그인"
        Height="420" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        d:DataContext="{d:DesignInstance Type=vm:LoginViewModel, IsDesignTimeCreatable=False}">

    <Border Background="White" CornerRadius="0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <!-- 좌측: 브랜드 패널 -->
            <Border Grid.Column="0" Background="#285032">
                <Grid>
                    <!-- 장식용 원형 도형들 -->
                    <Canvas>
                        <Ellipse Canvas.Left="50" Canvas.Top="20" Width="150" Height="150"
                                 Fill="#3C7850" Opacity="0.5"/>
                        <Ellipse Canvas.Left="200" Canvas.Top="80" Width="120" Height="120"
                                 Fill="#326844" Opacity="0.5"/>
                        <Ellipse Canvas.Left="150" Canvas.Top="100" Width="100" Height="100"
                                 Fill="#468C5C" Opacity="0.5"/>
                    </Canvas>

                    <!-- 로고 및 환영 메시지 -->
                    <StackPanel VerticalAlignment="Bottom" Margin="30,0,30,50">
                        <TextBlock Text="mailX"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="AI 기반 이메일 관리 시스템"
                                   FontSize="12"
                                   Foreground="#B4D4BC"
                                   Margin="0,8,0,0"/>
                        <TextBlock Text="Secure access to your workspace"
                                   FontSize="11"
                                   Foreground="#8CB898"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 우측: 로그인 폼 -->
            <Border Grid.Column="1" Background="White">
                <Grid>
                    <!-- 닫기 버튼 -->
                    <Button x:Name="buttonClose"
                            Content="X"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="0,10,10,0"
                            Width="25" Height="25"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="DarkGray"
                            FontWeight="Bold"
                            FontSize="10"
                            Click="ButtonClose_Click"
                            MouseEnter="ButtonClose_MouseEnter"
                            MouseLeave="ButtonClose_MouseLeave"
                            Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="3">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- 로그인 폼 내용 -->
                    <StackPanel VerticalAlignment="Center" Margin="30,0,30,0">
                        <!-- Sign in 타이틀 -->
                        <TextBlock Text="Sign in"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#285032"
                                   Margin="0,0,0,30"/>

                        <!-- 에러 메시지 -->
                        <Border Background="#FFEBE9"
                                CornerRadius="6"
                                Padding="12,10"
                                Margin="0,0,0,20"
                                Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="!"
                                           Foreground="#D13438"
                                           FontWeight="Bold"
                                           FontSize="14"
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding ErrorMessage}"
                                           Foreground="#D13438"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           FontSize="12"/>
                            </StackPanel>
                        </Border>

                        <!-- 저장된 계정 목록 -->
                        <StackPanel Visibility="{Binding HasSavedAccounts, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Margin="0,0,0,20">
                            <TextBlock Text="저장된 계정"
                                       FontWeight="SemiBold"
                                       Foreground="#404040"
                                       FontSize="12"
                                       Margin="0,0,0,10"/>

                            <ListBox ItemsSource="{Binding SavedAccounts}"
                                     SelectedItem="{Binding SelectedAccount}"
                                     MaxHeight="120"
                                     BorderThickness="1"
                                     BorderBrush="#E0E0E0"
                                     Background="#F8F8F8">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="8,6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 아바타 -->
                                            <Border Grid.Column="0"
                                                    Width="32" Height="32"
                                                    CornerRadius="16"
                                                    Background="#285032"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="{Binding DisplayName, Converter={StaticResource StringToInitialConverter}}"
                                                           Foreground="White"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- 계정 정보 -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding DisplayName}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12"
                                                           Foreground="#303030"/>
                                                <TextBlock Text="{Binding Email}"
                                                           FontSize="10"
                                                           Foreground="#808080"/>
                                            </StackPanel>

                                            <!-- 기본 계정 표시 -->
                                            <TextBlock Grid.Column="2"
                                                       Text="v"
                                                       FontSize="14"
                                                       FontWeight="Bold"
                                                       Foreground="#285032"
                                                       VerticalAlignment="Center"
                                                       Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- 저장된 계정으로 로그인 버튼 -->
                            <Button Content="선택한 계정으로 로그인"
                                    HorizontalAlignment="Stretch"
                                    Margin="0,10,0,0"
                                    Padding="0,12"
                                    Background="#285032"
                                    Foreground="White"
                                    FontWeight="SemiBold"
                                    BorderThickness="0"
                                    Command="{Binding LoginWithSavedAccountCommand}"
                                    IsEnabled="{Binding CanLoginWithSaved}"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                            CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>

                        <!-- 구분선 -->
                        <Grid Visibility="{Binding HasSavedAccounts, Converter={StaticResource BoolToVisibilityConverter}}"
                              Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Height="1" Background="#E0E0E0" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="또는" Foreground="#A0A0A0" FontSize="11" Margin="12,0"/>
                            <Border Grid.Column="2" Height="1" Background="#E0E0E0" VerticalAlignment="Center"/>
                        </Grid>

                        <!-- Microsoft 365 로그인 버튼 -->
                        <Button HorizontalAlignment="Stretch"
                                Padding="0,14"
                                Background="White"
                                BorderBrush="#285032"
                                BorderThickness="1"
                                Command="{Binding LoginCommand}"
                                IsEnabled="{Binding IsNotLoading}"
                                Cursor="Hand">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                            <StackPanel Orientation="Horizontal">
                                <!-- Microsoft 로고 -->
                                <Grid Width="20" Height="20" Margin="0,0,12,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition/>
                                        <RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Grid.Row="0" Grid.Column="0" Fill="#F25022" Margin="0,0,1,1"/>
                                    <Rectangle Grid.Row="0" Grid.Column="1" Fill="#7FBA00" Margin="1,0,0,1"/>
                                    <Rectangle Grid.Row="1" Grid.Column="0" Fill="#00A4EF" Margin="0,1,1,0"/>
                                    <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="1,1,0,0"/>
                                </Grid>
                                <TextBlock Text="Microsoft 365로 로그인"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           FontSize="12"
                                           Foreground="#285032"/>
                            </StackPanel>
                        </Button>

                        <!-- 로딩 표시 -->
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,20,0,0"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="로그인 중..."
                                       VerticalAlignment="Center"
                                       Foreground="#808080"
                                       FontSize="12"/>
                        </StackPanel>

                        <!-- 도움말 링크 -->
                        <TextBlock HorizontalAlignment="Center"
                                   Margin="0,30,0,0"
                                   FontSize="11">
                            <Hyperlink Foreground="#285032"
                                       NavigateUri="https://support.microsoft.com/office"
                                       RequestNavigate="Hyperlink_RequestNavigate">
                                Need help? Contact admin
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <!-- 버전 정보 -->
                    <TextBlock Text="v1.0.0"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Margin="0,0,12,8"
                               Foreground="#C0C0C0"
                               FontSize="10"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
