<ui:FluentWindow x:Class="mailX.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:mailX.Views"
        xmlns:vm="clr-namespace:mailX.ViewModels"
        mc:Ignorable="d"
        Title="mailX - 로그인"
        Height="550" Width="420"
        MinHeight="500" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        d:DataContext="{d:DesignInstance Type=vm:LoginViewModel, IsDesignTimeCreatable=False}">

    <Grid>
        <!-- 배경 그라데이션 -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1a1a2e" Offset="0"/>
                <GradientStop Color="#16213e" Offset="0.5"/>
                <GradientStop Color="#0f3460" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- 중앙 로그인 카드 -->
        <Border VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                CornerRadius="16"
                Padding="40,48"
                MinWidth="340">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel>
                <!-- 로고 영역 -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,40">
                    <Border Width="80" Height="80"
                            CornerRadius="16"
                            Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                            Margin="0,0,0,16">
                        <ui:SymbolIcon Symbol="Mail24"
                                       FontSize="40"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="mailX"
                               FontSize="32"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="AI 기반 이메일 관리"
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 에러 메시지 -->
                <Border Background="#FFEBE9"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,0,0,20"
                        Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="ErrorCircle24"
                                       Foreground="#D13438"
                                       FontSize="16"
                                       Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding ErrorMessage}"
                                   Foreground="#D13438"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 저장된 계정 목록 -->
                <StackPanel Visibility="{Binding HasSavedAccounts, Converter={StaticResource BoolToVisibilityConverter}}"
                            Margin="0,0,0,20">
                    <TextBlock Text="저장된 계정"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <ListBox ItemsSource="{Binding SavedAccounts}"
                             SelectedItem="{Binding SelectedAccount}"
                             MaxHeight="150"
                             BorderThickness="1"
                             BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="8,6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 아바타 -->
                                    <Border Grid.Column="0"
                                            Width="36" Height="36"
                                            CornerRadius="18"
                                            Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="{Binding DisplayName, Converter={StaticResource StringToInitialConverter}}"
                                                   Foreground="White"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 계정 정보 -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding Email}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>

                                    <!-- 기본 계정 표시 -->
                                    <ui:SymbolIcon Grid.Column="2"
                                                   Symbol="Checkmark24"
                                                   FontSize="16"
                                                   Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 저장된 계정으로 로그인 버튼 -->
                    <ui:Button Content="선택한 계정으로 로그인"
                               HorizontalAlignment="Stretch"
                               Margin="0,12,0,0"
                               Padding="0,12"
                               Appearance="Primary"
                               Command="{Binding LoginWithSavedAccountCommand}"
                               IsEnabled="{Binding CanLoginWithSaved}"/>
                </StackPanel>

                <!-- 구분선 (저장된 계정이 있을 경우) -->
                <Grid Visibility="{Binding HasSavedAccounts, Converter={StaticResource BoolToVisibilityConverter}}"
                      Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Height="1"
                            Background="{DynamicResource ControlElevationBorderBrush}"
                            VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               Text="또는"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="12"
                               Margin="16,0"/>
                    <Border Grid.Column="2"
                            Height="1"
                            Background="{DynamicResource ControlElevationBorderBrush}"
                            VerticalAlignment="Center"/>
                </Grid>

                <!-- Microsoft 365 로그인 버튼 -->
                <ui:Button HorizontalAlignment="Stretch"
                           Padding="0,14"
                           Command="{Binding LoginCommand}"
                           IsEnabled="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                    <StackPanel Orientation="Horizontal">
                        <!-- Microsoft 로고 -->
                        <Grid Width="20" Height="20" Margin="0,0,12,0">
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Rectangle Grid.Row="0" Grid.Column="0" Fill="#F25022" Margin="0,0,1,1"/>
                            <Rectangle Grid.Row="0" Grid.Column="1" Fill="#7FBA00" Margin="1,0,0,1"/>
                            <Rectangle Grid.Row="1" Grid.Column="0" Fill="#00A4EF" Margin="0,1,1,0"/>
                            <Rectangle Grid.Row="1" Grid.Column="1" Fill="#FFB900" Margin="1,1,0,0"/>
                        </Grid>
                        <TextBlock Text="Microsoft 365로 로그인"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"/>
                    </StackPanel>
                </ui:Button>

                <!-- 로딩 표시 -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,0"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="20" Height="20"
                                     Margin="0,0,12,0"/>
                    <TextBlock Text="로그인 중..."
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- 도움말 링크 -->
                <TextBlock HorizontalAlignment="Center"
                           Margin="0,30,0,0">
                    <Hyperlink NavigateUri="https://support.microsoft.com/office"
                               RequestNavigate="Hyperlink_RequestNavigate">
                        도움이 필요하신가요?
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- 버전 정보 -->
        <TextBlock Text="v1.0.0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Bottom"
                   Margin="0,0,16,12"
                   Foreground="#80FFFFFF"
                   FontSize="11"/>
    </Grid>
</ui:FluentWindow>
