<ui:FluentWindow x:Class="mailX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:mailX.Views"
        xmlns:vm="clr-namespace:mailX.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            ShowMaximize="True"
            ShowMinimize="True"
            ShowClose="True"
            CanMaximize="True">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Width="18" Height="18"
                              Margin="0,-1,0,0"
                              RenderOptions.BitmapScalingMode="HighQuality"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                    <ui:ImageIcon.Source>
                        <BitmapImage UriSource="pack://application:,,,/Assets/icon.png"
                                     DecodePixelWidth="36"
                                     DecodePixelHeight="36"
                                     CacheOption="OnLoad"/>
                    </ui:ImageIcon.Source>
                </ui:ImageIcon>
            </ui:TitleBar.Icon>
            <ui:TitleBar.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Column 0: 로고 (Ai 하늘색, X 도트 디자인) -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="m" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Ai" FontSize="16" FontWeight="Bold" Foreground="#5DADE2"/>
                        <TextBlock Text="l" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <!-- X: 도트 디자인 (3D 입체감) -->
                        <Canvas Width="14" Height="16" Margin="1,0,0,0">
                            <!-- 그림자 도트 (오프셋) -->
                            <Rectangle Canvas.Left="1" Canvas.Top="1" Width="3" Height="3" Fill="#666666"/>
                            <Rectangle Canvas.Left="11" Canvas.Top="1" Width="3" Height="3" Fill="#666666"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="4" Width="3" Height="3" Fill="#555555"/>
                            <Rectangle Canvas.Left="8" Canvas.Top="4" Width="3" Height="3" Fill="#555555"/>
                            <Rectangle Canvas.Left="6" Canvas.Top="7" Width="3" Height="3" Fill="#444444"/>
                            <Rectangle Canvas.Left="4" Canvas.Top="10" Width="3" Height="3" Fill="#555555"/>
                            <Rectangle Canvas.Left="8" Canvas.Top="10" Width="3" Height="3" Fill="#555555"/>
                            <Rectangle Canvas.Left="1" Canvas.Top="13" Width="3" Height="3" Fill="#666666"/>
                            <Rectangle Canvas.Left="11" Canvas.Top="13" Width="3" Height="3" Fill="#666666"/>
                            <!-- 메인 도트 -->
                            <Rectangle Canvas.Left="0" Canvas.Top="0" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Rectangle Canvas.Left="10" Canvas.Top="0" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Rectangle Canvas.Left="3" Canvas.Top="3" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Rectangle Canvas.Left="7" Canvas.Top="3" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Rectangle Canvas.Left="5" Canvas.Top="6" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Rectangle Canvas.Left="3" Canvas.Top="9" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Rectangle Canvas.Left="7" Canvas.Top="9" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Rectangle Canvas.Left="0" Canvas.Top="12" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Rectangle Canvas.Left="10" Canvas.Top="12" Width="3" Height="3" Fill="{DynamicResource TextFillColorPrimaryBrush}"/>
                        </Canvas>
                    </StackPanel>

                    <!-- Column 1: 메뉴바 (타이틀바로 이동) -->
                    <Menu Grid.Column="1" VerticalAlignment="Center" Background="Transparent" Margin="0,0,16,0">
                        <MenuItem Header="🔌 접속">
                            <MenuItem Header="🔄 재로그인" Padding="12,6" Click="MenuRelogin_Click"/>
                            <MenuItem Header="🚪 로그아웃" Padding="12,6" Click="MenuLogout_Click"/>
                            <Separator/>
                            <MenuItem Header="❌ 종료" Padding="12,6" Click="MenuExit_Click"/>
                        </MenuItem>
                        <MenuItem Header="📧 메일">
                            <MenuItem x:Name="MenuSyncPeriod" Padding="12,6">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📧 동기화 기간" VerticalAlignment="Center"/>
                                        <TextBlock Text=" ▶" FontSize="10" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </MenuItem.Header>
                                <!-- 현재 설정 표시 -->
                                <MenuItem x:Name="MenuSyncPeriodCurrent" Header="현재: 1주일" Padding="12,6" IsEnabled="False" FontStyle="Italic"/>
                                <Separator/>
                                <MenuItem x:Name="MenuMailSync100" Header="📋 100건" Padding="12,6" Click="MenuMailSync100_Click"/>
                                <MenuItem x:Name="MenuMailSyncDay" Header="📅 하루" Padding="12,6" Click="MenuMailSyncDay_Click"/>
                                <MenuItem x:Name="MenuMailSyncWeek" Header="📆 1주일" Padding="12,6" Click="MenuMailSyncWeek_Click"/>
                                <MenuItem x:Name="MenuMailSyncMonth" Header="🗓️ 1달" Padding="12,6" Click="MenuMailSyncMonth_Click"/>
                                <MenuItem x:Name="MenuMailSyncYear" Header="📅 1년" Padding="12,6" Click="MenuMailSyncYear_Click"/>
                                <MenuItem x:Name="MenuMailSyncAll" Header="♾️ 전체" Padding="12,6" Click="MenuMailSyncAll_Click"/>
                            </MenuItem>
                        </MenuItem>
                        <MenuItem Header="✨ Ai">
                            <MenuItem x:Name="MenuAISyncPause2" Header="⏸️ 분석 일시정지" Padding="12,6" Click="MenuAISyncPause_Click" Visibility="Collapsed"/>
                            <MenuItem x:Name="MenuAISyncResume2" Header="▶️ 분석 시작" Padding="12,6" Click="MenuAISyncResume_Click"/>
                        </MenuItem>
                        <MenuItem Header="⚙️ 시스템">
                            <MenuItem Header="🔑 API 관리" Padding="12,6" Click="MenuApiSettings_Click"/>
                            <MenuItem Header="✍️ 서명 관리" Padding="12,6" Click="MenuSignatureSettings_Click"/>
                            <Separator/>
                            <MenuItem Padding="12,6">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎨 테마" VerticalAlignment="Center"/>
                                        <TextBlock Text=" ▶" FontSize="10" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </MenuItem.Header>
                                <MenuItem x:Name="MenuThemeDark2" Header="🌙 다크 모드" Padding="12,6" Click="MenuThemeDark_Click"/>
                                <MenuItem x:Name="MenuThemeLight2" Header="☀️ 라이트 모드" Padding="12,6" Click="MenuThemeLight_Click"/>
                            </MenuItem>
                            <Separator/>
                            <MenuItem x:Name="MenuGpuMode2" Padding="12,6" Click="MenuGpuMode_Click">
                                <MenuItem.Header>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="GpuModeCheckMark" Text="✓" FontWeight="Bold" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Text="GPU 모드" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </MenuItem.Header>
                            </MenuItem>
                        </MenuItem>
                    </Menu>

                    <!-- Column 2: 검색 영역 (폴더선택 + 검색창 + 고급검색) -->
                    <Grid Grid.Column="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 폴더 선택 드롭다운 (모든 폴더, 기본 폴더들) -->
                        <ComboBox x:Name="SearchFolderComboBox"
                                  Grid.Column="0"
                                  Width="140"
                                  Height="32"
                                  Padding="8,2"
                                  Margin="0,0,4,0"
                                  VerticalContentAlignment="Center"
                                  ItemsSource="{Binding SearchFolderOptions}"
                                  SelectedItem="{Binding SelectedSearchFolderOption}"
                                  ToolTip="검색 대상 폴더">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Icon}" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding DisplayName}" FontSize="12" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>

                        <!-- 검색창 (너비 2배 확장: 600px) -->
                        <ui:TextBox x:Name="TitleBarSearchBox"
                                    Grid.Column="1"
                                    PlaceholderText="🔍 메일 검색 (Ctrl+K)"
                                    Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                    Height="32"
                                    Width="500"
                                    FontSize="12"
                                    Margin="0,0,4,0"
                                    KeyDown="TitleBarSearchBox_KeyDown"
                                    GotFocus="TitleBarSearchBox_GotFocus"
                                    LostFocus="TitleBarSearchBox_LostFocus"/>

                        <!-- 고급 검색 버튼 -->
                        <ui:Button x:Name="AdvancedSearchButton"
                                   Grid.Column="2"
                                   ToolTip="고급 검색"
                                   Appearance="Transparent"
                                   Height="30" Width="30"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="AdvancedSearchButton_Click">
                            <ui:SymbolIcon Symbol="ChevronDown24" FontSize="14"/>
                        </ui:Button>
                    </Grid>

                    <!-- Column 3: 우측 버튼들 (테마토글 + 알림 + 설정) -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                        <!-- 테마 토글 버튼 -->
                        <ui:Button x:Name="ThemeToggleButton"
                                   ToolTip="테마 전환"
                                   Appearance="Transparent"
                                   Height="30" Width="30"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="ThemeToggleButton_Click">
                            <ui:SymbolIcon x:Name="ThemeIcon" Symbol="WeatherSunny24" FontSize="16"/>
                        </ui:Button>
                        <!-- 알림 버튼 -->
                        <ui:Button x:Name="NotificationButton"
                                   ToolTip="알림"
                                   Appearance="Transparent"
                                   Height="30" Width="30"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="NotificationButton_Click">
                            <ui:SymbolIcon Symbol="Alert24" FontSize="16"/>
                        </ui:Button>
                        <!-- 설정 버튼 (동기화 설정으로 연결) -->
                        <ui:Button ToolTip="동기화 설정"
                                   Appearance="Transparent"
                                   Height="30" Width="30"
                                   Padding="0"
                                   Click="SettingsButton_Click">
                            <ui:SymbolIcon Symbol="Settings24" FontSize="16"/>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </ui:TitleBar.Header>

        </ui:TitleBar>

        <!-- 고급 검색 팝업 (Window 레벨) -->
        <Popup x:Name="AdvancedSearchPopup"
               PlacementTarget="{Binding ElementName=AdvancedSearchButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,4,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <StackPanel Width="380">
                    <TextBlock Text="고급 검색" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,12"/>

                    <TextBlock Text="발신자" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="보낸 사람 이메일 또는 이름"
                                Text="{Binding AdvancedSearchFrom, UpdateSourceTrigger=PropertyChanged}"
                                Height="32" Margin="0,0,0,8"/>

                    <TextBlock Text="수신자" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="받는 사람 이메일 또는 이름"
                                Text="{Binding AdvancedSearchTo, UpdateSourceTrigger=PropertyChanged}"
                                Height="32" Margin="0,0,0,8"/>

                    <TextBlock Text="제목" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="제목에 포함된 텍스트"
                                Text="{Binding AdvancedSearchSubject, UpdateSourceTrigger=PropertyChanged}"
                                Height="32" Margin="0,0,0,8"/>

                    <TextBlock Text="본문" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <ui:TextBox PlaceholderText="본문에 포함된 텍스트"
                                Text="{Binding AdvancedSearchBody, UpdateSourceTrigger=PropertyChanged}"
                                Height="32" Margin="0,0,0,8"/>

                    <TextBlock Text="날짜 범위" FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <DatePicker x:Name="DateFromPicker" SelectedDate="{Binding AdvancedSearchDateFrom}" Width="175"
                                    Loaded="DatePicker_Loaded"/>
                        <TextBlock Text="~" VerticalAlignment="Center" Margin="8,0"/>
                        <DatePicker x:Name="DateToPicker" SelectedDate="{Binding AdvancedSearchDateTo}" Width="175"
                                    Loaded="DatePicker_Loaded"/>
                    </StackPanel>

                    <CheckBox Content="첨부파일 있는 메일만"
                              IsChecked="{Binding AdvancedSearchHasAttachment}"
                              Margin="0,0,0,12"/>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <ui:Button Content="초기화"
                                   Appearance="Secondary"
                                   Margin="0,0,8,0"
                                   Click="AdvancedSearchClear_Click"/>
                        <ui:Button Content="검색"
                                   Appearance="Primary"
                                   Click="AdvancedSearch_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>

        <!-- 알림 패널 팝업 (Window 레벨) -->
        <Popup x:Name="NotificationPopup"
               PlacementTarget="{Binding ElementName=NotificationButton}"
               Placement="Bottom"
               StaysOpen="False"
               AllowsTransparency="True">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="360"
                    MaxHeight="500"
                    Margin="0,4,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 알림 패널 헤더 -->
                    <Border Grid.Row="0" Padding="16,12"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="알림"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <ui:Button Appearance="Transparent"
                                           ToolTip="필터"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Margin="0,0,4,0">
                                    <ui:SymbolIcon Symbol="Filter24" FontSize="14"/>
                                </ui:Button>
                                <ui:Button Appearance="Transparent"
                                           ToolTip="알림 설정"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Margin="0,0,4,0">
                                    <ui:SymbolIcon Symbol="Settings24" FontSize="14"/>
                                </ui:Button>
                                <ui:Button Appearance="Transparent"
                                           ToolTip="닫기"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Click="CloseNotificationPopup_Click">
                                    <ui:SymbolIcon Symbol="Dismiss24" FontSize="14"/>
                                </ui:Button>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- 알림 목록 또는 빈 상태 -->
                    <ScrollViewer Grid.Row="1" Padding="16"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="400">
                        <StackPanel x:Name="NotificationListContent">
                            <!-- 알림 없을 때 기본 상태 -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,48">
                                <ui:SymbolIcon Symbol="Alert24" FontSize="48"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               HorizontalAlignment="Center"
                                               Margin="0,0,0,16"/>
                                <TextBlock Text="모두 확인했습니다!"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="새 알림이 없습니다."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                            <!-- 알림이 있을 경우 동적으로 추가됨 -->
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>

        <!-- 검색 자동완성 팝업 (Window 레벨) -->
        <Popup x:Name="SearchAutocompletePopup"
               PlacementTarget="{Binding ElementName=TitleBarSearchBox}"
               Placement="Bottom"
               StaysOpen="True"
               AllowsTransparency="True">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Width="500"
                    MaxHeight="400"
                    Margin="0,4,0,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 검색 헤더 (뒤로가기 + 검색) -->
                    <Border Grid.Row="0" Padding="12,8"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Appearance="Transparent"
                                       Width="24" Height="24"
                                       Padding="0"
                                       Margin="0,0,8,0"
                                       Click="SearchAutocompleteBack_Click">
                                <ui:SymbolIcon Symbol="ArrowLeft24" FontSize="14"/>
                            </ui:Button>
                            <TextBlock Text="검색"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- 검색 탭 (모두 | 메일 | 사람) -->
                    <Border Grid.Row="1" Padding="12,8"
                            BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <ui:Button x:Name="SearchTabAll"
                                       Content="모두"
                                       Appearance="Primary"
                                       Height="26"
                                       Padding="12,4"
                                       Margin="0,0,4,0"
                                       Click="SearchTab_Click"/>
                            <ui:Button x:Name="SearchTabMail"
                                       Content="메일"
                                       Appearance="Secondary"
                                       Height="26"
                                       Padding="12,4"
                                       Margin="0,0,4,0"
                                       Click="SearchTab_Click"/>
                            <ui:Button x:Name="SearchTabPerson"
                                       Content="사람"
                                       Appearance="Secondary"
                                       Height="26"
                                       Padding="12,4"
                                       Click="SearchTab_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- 검색 히스토리 및 제안 목록 -->
                    <ScrollViewer Grid.Row="2" Padding="8"
                                  VerticalScrollBarVisibility="Auto"
                                  MaxHeight="280">
                        <StackPanel x:Name="SearchSuggestionsList">
                            <!-- 최근 검색 -->
                            <TextBlock Text="최근 검색"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,8,8,4"/>

                            <!-- 최근 검색 항목들 (동적 추가) -->
                            <ItemsControl x:Name="RecentSearchItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent"
                                                Padding="8,6"
                                                Cursor="Hand"
                                                MouseLeftButtonUp="RecentSearchItem_Click"
                                                Tag="{Binding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                    <ui:SymbolIcon Symbol="History24" FontSize="14"
                                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                                   Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="✕"
                                                        FontSize="10"
                                                        Padding="4,2"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                        Cursor="Hand"
                                                        Click="RemoveRecentSearch_Click"
                                                        Tag="{Binding}"
                                                        ToolTip="검색어 삭제"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- 연락처 제안 -->
                            <TextBlock Text="연락처"
                                       FontSize="11"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="8,12,8,4"
                                       x:Name="ContactSuggestionsHeader"
                                       Visibility="Collapsed"/>

                            <ItemsControl x:Name="ContactSuggestionItems">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="Transparent"
                                                Padding="8,6"
                                                Cursor="Hand">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="28" Height="28"
                                                         Fill="{DynamicResource SystemAccentColorSecondaryBrush}"
                                                         Margin="0,0,8,0"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontWeight="Medium"/>
                                                    <TextBlock Text="{Binding Email}"
                                                               FontSize="11"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Popup>

        <!-- 메인 콘텐츠 -->
        <Grid x:Name="MainContentGrid" Grid.Row="1">
        <Grid.ColumnDefinitions>
            <!-- 좌측 네비게이션 아이콘바 -->
            <ColumnDefinition x:Name="NavBarColumn" Width="52"/>
            <!-- 폴더 트리 (250px 고정) -->
            <ColumnDefinition x:Name="FolderColumn" Width="250" MinWidth="150" MaxWidth="400"/>
            <!-- Splitter 1 -->
            <ColumnDefinition Width="Auto"/>
            <!-- 메일 리스트 (350px 기본) -->
            <ColumnDefinition x:Name="MailListColumn" Width="350" MinWidth="250" MaxWidth="600"/>
            <!-- Splitter 2 -->
            <ColumnDefinition Width="Auto"/>
            <!-- 본문 (나머지) -->
            <ColumnDefinition x:Name="BodyColumn" Width="*" MinWidth="300"/>
            <!-- Splitter 3 -->
            <ColumnDefinition Width="Auto"/>
            <!-- AI 패널 (독립 영역) -->
            <ColumnDefinition x:Name="AIColumn" Width="300" MinWidth="200" MaxWidth="500"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 좌측 네비게이션 아이콘바 (Column 0) ========== -->
        <Border Grid.Column="0"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- 상단 네비게이션 아이콘들 -->
                <StackPanel Grid.Row="0" Margin="0,8,0,0">
                    <!-- 메일 아이콘 -->
                    <RadioButton x:Name="NavMailButton"
                                 IsChecked="True"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavMailButton_Checked"
                                 ToolTip="메일">
                        <ui:SymbolIcon Symbol="Mail24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>

                    <!-- 캘린더 아이콘 -->
                    <RadioButton x:Name="NavCalendarButton"
                                 GroupName="NavGroup"
                                 Style="{StaticResource NavIconRadioButtonStyle}"
                                 Checked="NavCalendarButton_Checked"
                                 ToolTip="일정">
                        <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </RadioButton>
                </StackPanel>

                <!-- 하단 설정 아이콘 -->
                <StackPanel Grid.Row="1" Margin="0,0,0,8">
                    <Button x:Name="NavSettingsButton"
                            Style="{StaticResource NavIconButtonStyle}"
                            Click="NavSettingsButton_Click"
                            ToolTip="설정">
                        <ui:SymbolIcon Symbol="Settings24" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ========== 메일 뷰 컨테이너 (Column 1-7) - 캘린더 뷰와 교체 가능 ========== -->

        <!-- ========== 폴더 트리 영역 (Column 1) ========== -->
        <Border x:Name="FolderTreeBorder" Grid.Column="1"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 폴더 헤더 -->
                <Border Grid.Row="0" Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Folder24" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="폴더" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 즐겨찾기 섹션 (라벨 없이 폴더만 표시) -->
                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Margin="0,0,0,4"
                        x:Name="FavoriteSection">
                    <StackPanel>
                        <!-- 즐겨찾기 폴더 목록 (드래그&드롭 순서 변경 지원) -->
                        <ListBox x:Name="FavoriteListBox"
                                 ItemsSource="{Binding FavoriteFolders}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Margin="4,0,4,4"
                                 AllowDrop="True"
                                 SelectionChanged="FavoriteListBox_SelectionChanged"
                                 PreviewMouseRightButtonDown="FavoriteListBox_PreviewMouseRightButtonDown"
                                 PreviewMouseLeftButtonDown="FavoriteListBox_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="FavoriteListBox_PreviewMouseMove"
                                 Drop="FavoriteListBox_Drop"
                                 DragOver="FavoriteListBox_DragOver">
                            <ListBox.Resources>
                                <Style TargetType="ContextMenu">
                                    <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                                    <Setter Property="Padding" Value="4"/>
                                </Style>
                                <Style x:Key="SimpleMenuItemStyle" TargetType="MenuItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                                    <Setter Property="Padding" Value="12,8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter ContentSource="Header"
                                                                      RecognizesAccessKey="True"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.Resources>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,4"/>
                                    <Setter Property="Margin" Value="0,1"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Border"
                                                        Background="{TemplateBinding Background}"
                                                        CornerRadius="4"
                                                        Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SelectionBackgroundBrush}"/>
                                                    </Trigger>
                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsMouseOver" Value="True"/>
                                                            <Condition Property="IsSelected" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ContextMenu>
                                <ContextMenu Background="{DynamicResource ApplicationBackgroundBrush}"
                                             BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                             Padding="4"
                                             HasDropShadow="True">
                                    <ContextMenu.Template>
                                        <ControlTemplate TargetType="ContextMenu">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="1"
                                                    CornerRadius="8"
                                                    Padding="{TemplateBinding Padding}">
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                            </Border>
                                        </ControlTemplate>
                                    </ContextMenu.Template>
                                    <MenuItem Click="RemoveFavorite_Click" Header="☆ 즐겨찾기 제거"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <MenuItem.Template>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Border"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="12,8">
                                                    <TextBlock Text="{TemplateBinding Header}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </MenuItem.Template>
                                    </MenuItem>
                                    <Separator/>
                                    <MenuItem Click="FolderResync_Click" Header="🔄 이 폴더 재동기화"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <MenuItem.Template>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Border"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="12,8">
                                                    <TextBlock Text="{TemplateBinding Header}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </MenuItem.Template>
                                    </MenuItem>
                                    <MenuItem Click="FolderAIReanalyze_Click" Header="🤖 AI 재분석"
                                              Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                        <MenuItem.Template>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border x:Name="Border"
                                                        Background="Transparent"
                                                        CornerRadius="4"
                                                        Padding="12,8">
                                                    <TextBlock Text="{TemplateBinding Header}"
                                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="Border" Property="Background"
                                                                Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </MenuItem.Template>
                                    </MenuItem>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="2,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <ui:SymbolIcon Grid.Column="0"
                                                       Symbol="Star24"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource FavoriteStarBrush}"
                                                       Margin="0,0,4,0"
                                                       VerticalAlignment="Center"/>

                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="Folder24"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       Margin="0,0,6,0"
                                                       VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayName}"
                                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- 읽지 않은 메일 수 배지 -->
                                        <Border Grid.Column="3"
                                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                CornerRadius="8"
                                                Padding="5,1"
                                                Margin="6,0,0,0"
                                                VerticalAlignment="Center"
                                                Visibility="{Binding UnreadItemCount, Converter={StaticResource IntToVisibilityConverter}}">
                                            <TextBlock Text="{Binding UnreadItemCount}"
                                                       Foreground="White"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </Border>

                <!-- 폴더 트리 -->
                <TreeView Grid.Row="2"
                          x:Name="FolderTreeView"
                          ItemsSource="{Binding FolderTree}"
                          BorderThickness="0"
                          Background="Transparent"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          SelectedItemChanged="FolderTreeView_SelectedItemChanged"
                          AllowDrop="True"
                          DragEnter="FolderTreeView_DragEnter"
                          DragOver="FolderTreeView_DragOver"
                          Drop="FolderTreeView_Drop">
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <EventSetter Event="PreviewMouseRightButtonDown" Handler="TreeViewItem_PreviewMouseRightButtonDown"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="TreeViewItem">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <!-- 헤더 영역 - 전체 행 배경색 적용 -->
                                            <Border x:Name="Bd"
                                                    Grid.Row="0"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="4"
                                                    Padding="4,2"
                                                    Margin="0,1,8,1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 확장/축소 토글 -->
                                                    <ToggleButton x:Name="Expander"
                                                                  Grid.Column="0"
                                                                  ClickMode="Press"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  Width="16" Height="16"
                                                                  Margin="0,0,4,0"
                                                                  Background="Transparent"
                                                                  BorderThickness="0">
                                                        <ToggleButton.Style>
                                                            <Style TargetType="ToggleButton">
                                                                <Setter Property="Focusable" Value="False"/>
                                                                <Setter Property="Template">
                                                                    <Setter.Value>
                                                                        <ControlTemplate TargetType="ToggleButton">
                                                                            <Border Background="Transparent" Padding="2">
                                                                                <Path x:Name="ExpandPath"
                                                                                      Data="M0,0 L4,4 L0,8 Z"
                                                                                      Fill="{DynamicResource TextFillColorSecondaryBrush}"
                                                                                      HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                            </Border>
                                                                            <ControlTemplate.Triggers>
                                                                                <Trigger Property="IsChecked" Value="True">
                                                                                    <Setter TargetName="ExpandPath" Property="Data" Value="M0,0 L8,0 L4,4 Z"/>
                                                                                </Trigger>
                                                                            </ControlTemplate.Triggers>
                                                                        </ControlTemplate>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </Style>
                                                        </ToggleButton.Style>
                                                    </ToggleButton>
                                                    <!-- 콘텐츠 -->
                                                    <ContentPresenter x:Name="PART_Header"
                                                                      Grid.Column="1"
                                                                      ContentSource="Header"
                                                                      HorizontalAlignment="Stretch"/>
                                                </Grid>
                                            </Border>
                                            <!-- 자식 항목 영역 -->
                                            <ItemsPresenter x:Name="ItemsHost"
                                                            Grid.Row="1"
                                                            Margin="16,0,0,0"
                                                            Visibility="Collapsed"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsExpanded" Value="True">
                                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible"/>
                                            </Trigger>
                                            <Trigger Property="HasItems" Value="False">
                                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsSelected" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SubtleFillColorTertiaryBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.ItemContainerStyle>
                    <TreeView.Resources>
                        <Style TargetType="ContextMenu">
                            <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ControlElevationBorderBrush}"/>
                            <Setter Property="Padding" Value="4"/>
                        </Style>
                        <Style x:Key="SimpleMenuItemStyle" TargetType="MenuItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="{TemplateBinding Background}"
                                                CornerRadius="4"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter ContentSource="Header"
                                                              RecognizesAccessKey="True"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </TreeView.Resources>
                    <TreeView.ContextMenu>
                        <ContextMenu Background="{DynamicResource ApplicationBackgroundBrush}"
                                     BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                     Padding="4">
                            <MenuItem Click="AddFavorite_Click" Header="⭐ 즐겨찾기 추가"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Click="FolderResync_Click" Header="🔄 이 폴더 재동기화"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <MenuItem Click="FolderAIReanalyze_Click" Header="🤖 AI 재분석"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <Grid Margin="4,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ui:SymbolIcon Grid.Column="0"
                                               Symbol="Folder24"
                                               FontSize="16"
                                               Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- 읽지 않은 메일 수 배지 -->
                                <Border Grid.Column="2"
                                        Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                        CornerRadius="10"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding UnreadItemCount, Converter={StaticResource IntToVisibilityConverter}}">
                                    <TextBlock Text="{Binding UnreadItemCount}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </Grid>
        </Border>

        <!-- GridSplitter 1 -->
        <GridSplitter x:Name="Splitter1" Grid.Column="2"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE"/>

        <!-- ========== 메일 리스트 영역 (Column 3) ========== -->
        <Border x:Name="MailListBorder" Grid.Column="3"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 메일 리스트 헤더 (Row 0) -->
                <Border Grid.Row="0" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <!-- 검색 모드 아이콘 -->
                            <ui:SymbolIcon Symbol="Search24" FontSize="20" Margin="0,0,8,0"
                                           Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <!-- 기본 메일 아이콘 -->
                            <ui:SymbolIcon Symbol="Mail24" FontSize="20" Margin="0,0,8,0"
                                           Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                            <!-- 검색 모드: 검색 결과 -->
                            <TextBlock Text="검색 결과"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <!-- 일반 모드: 폴더 이름 -->
                            <TextBlock Text="{Binding SelectedFolder.DisplayName, FallbackValue='메일'}"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsSearchMode, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}"/>
                        </StackPanel>

                        <!-- 새 메일 / 새로고침 / AI분석 / 메일동기화 버튼 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button x:Name="NewMailButton"
                                       Icon="{ui:SymbolIcon MailAdd24}"
                                       ToolTip="새 메일"
                                       Appearance="Primary"
                                       Width="34" Height="34"
                                       Padding="0"
                                       Margin="0,0,8,0"
                                       Click="NewMailButton_Click"/>
                            <ui:Button Icon="{ui:SymbolIcon ArrowClockwise24}"
                                       Command="{Binding LoadEmailsCommand}"
                                       ToolTip="새로고침"
                                       Appearance="Secondary"
                                       Width="34" Height="34"
                                       Padding="0"
                                       Margin="0,0,4,0"/>
                            <!-- AI 분석 버튼 (진행중: 노란색 별 깜빡임, 중지중: 회색 고정) -->
                            <ui:Button x:Name="AISyncButton"
                                       Command="{Binding ToggleAISyncCommand}"
                                       ToolTip="{Binding AISyncButtonTooltip}"
                                       Appearance="Secondary"
                                       Width="34" Height="34"
                                       Padding="0"
                                       Margin="0,0,4,0">
                                <Grid>
                                    <!-- 진행중일 때: 노란색 별 3개 (Grid 레이아웃, 패널 헤더와 동일) -->
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0"
                                          Visibility="{Binding IsAISyncPaused, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                        <TextBlock Text="✦" FontSize="12" Foreground="#FFD700" Margin="0,0,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="1" To="0.3" Duration="0:0:0.8"
                                                                                     AutoReverse="True"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="✦" FontSize="8" Foreground="#FFC125" Margin="6,-5,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="1" To="0.3" Duration="0:0:0.5"
                                                                                     AutoReverse="True"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="✦" FontSize="6" Foreground="#FFDF00" Margin="10,3,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                     From="1" To="0.3" Duration="0:0:0.3"
                                                                                     AutoReverse="True"/>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <!-- 중지중일 때: 회색 별 3개 (애니메이션 없음, Grid 레이아웃) -->
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,2,0,0"
                                          Visibility="{Binding IsAISyncPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <TextBlock Text="✦" FontSize="12" Foreground="#888888" Margin="0,0,0,0"/>
                                        <TextBlock Text="✦" FontSize="8" Foreground="#999999" Margin="6,-5,0,0"/>
                                        <TextBlock Text="✦" FontSize="6" Foreground="#AAAAAA" Margin="10,3,0,0"/>
                                    </Grid>
                                </Grid>
                            </ui:Button>
                            <!-- 메일 동기화 버튼 (동기화중: 편지 꺼내기 애니메이션, 중지중: 회색 고정) -->
                            <ui:Button x:Name="SyncButton"
                                       Command="{Binding ToggleSyncCommand}"
                                       ToolTip="{Binding SyncButtonTooltip}"
                                       Appearance="Secondary"
                                       Width="34" Height="34"
                                       Padding="0">
                                <Grid>
                                    <!-- 동기화 중일 때: 열린 편지 + 나가는 문서 애니메이션 -->
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Visibility="{Binding IsSyncPaused, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                                        <!-- 열린 편지봉투 (MailRead) -->
                                        <ui:SymbolIcon Symbol="MailRead24" FontSize="14" Foreground="#2196F3"/>
                                        <!-- 위로 날아가는 문서 -->
                                        <TextBlock Text="📄" FontSize="8" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                            <TextBlock.RenderTransform>
                                                <TranslateTransform x:Name="DocTranslate"/>
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <EventTrigger RoutedEvent="Loaded">
                                                            <BeginStoryboard>
                                                                <Storyboard RepeatBehavior="Forever">
                                                                    <!-- 위로 이동 (1.5초 주기) -->
                                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)">
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:0" Value="2"/>
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="-10">
                                                                            <EasingDoubleKeyFrame.EasingFunction>
                                                                                <QuadraticEase EasingMode="EaseOut"/>
                                                                            </EasingDoubleKeyFrame.EasingFunction>
                                                                        </EasingDoubleKeyFrame>
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="2"/>
                                                                    </DoubleAnimationUsingKeyFrames>
                                                                    <!-- 투명도 -->
                                                                    <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="Opacity">
                                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="1"/>
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="1"/>
                                                                        <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="0"/>
                                                                        <DiscreteDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
                                                                    </DoubleAnimationUsingKeyFrames>
                                                                </Storyboard>
                                                            </BeginStoryboard>
                                                        </EventTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                    <!-- 중지 중일 때: 회색 닫힌 편지 아이콘 -->
                                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"
                                          Visibility="{Binding IsSyncPaused, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <ui:SymbolIcon Symbol="Mail24" FontSize="14" Foreground="#888888"/>
                                    </Grid>
                                </Grid>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 정렬/뷰 토글 바 (Row 1) - 아웃룩 스타일 -->
                <Border Grid.Row="1" VerticalAlignment="Top" Padding="12,4,12,4"
                        Background="{DynamicResource SubtleFillColorTertiaryBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 왼쪽: 전체 선택 체크박스 -->
                        <CheckBox Grid.Column="0"
                                  x:Name="SelectAllCheckBox"
                                  ToolTip="전체 선택"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  Checked="SelectAllCheckBox_Checked"
                                  Unchecked="SelectAllCheckBox_Unchecked"/>

                        <!-- 가운데: 정렬 드롭다운 + 필터 버튼 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <!-- 정렬 드롭다운 버튼 -->
                            <ui:Button x:Name="SortDropdownButton"
                                       ToolTip="정렬 기준 선택"
                                       Appearance="Secondary"
                                       Height="28"
                                       Padding="8,0"
                                       Margin="0,0,4,0"
                                       Click="SortDropdownButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="ArrowSort24" FontSize="14" Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding SortByDisplayText, FallbackValue='날짜'}"
                                               FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <ui:SymbolIcon Symbol="ChevronDown24" FontSize="10" Margin="6,0,0,0"/>
                                </StackPanel>
                            </ui:Button>
                            <!-- 정렬 순서 토글 (오름차순/내림차순) -->
                            <ui:Button ToolTip="{Binding SortOrderTooltip, FallbackValue='정렬 순서 변경'}"
                                       Appearance="Secondary"
                                       Height="28" Width="28"
                                       Padding="0"
                                       Margin="0,0,4,0"
                                       Command="{Binding ToggleSortOrderCommand}">
                                <ui:SymbolIcon Symbol="{Binding SortOrderIcon, FallbackValue=ArrowSortDown24}" FontSize="14"/>
                            </ui:Button>
                            <!-- 필터 토글 버튼 -->
                            <ui:Button ToolTip="필터"
                                       Height="28" Width="28"
                                       Padding="0"
                                       Margin="0,0,4,0"
                                       Appearance="{Binding IsFilterPanelVisible, Converter={StaticResource BoolToAppearanceConverter}}"
                                       Command="{Binding ToggleFilterPanelCommand}">
                                <ui:SymbolIcon Symbol="Filter24" FontSize="14"/>
                            </ui:Button>
                        </StackPanel>

                        <!-- 오른쪽: 뷰 모드 버튼들 -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                            <ui:Button ToolTip="날짜별 그룹화"
                                       Height="28" Width="28"
                                       Padding="0"
                                       Margin="0,0,4,0"
                                       Appearance="{Binding IsDateGroupingEnabled, Converter={StaticResource BoolToAppearanceConverter}}"
                                       Command="{Binding ToggleDateGroupingCommand}">
                                <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="14"/>
                            </ui:Button>
                            <ui:Button ToolTip="스레드 뷰 (대화별 그룹)"
                                       Height="28" Width="28"
                                       Padding="0"
                                       Appearance="{Binding IsThreadViewMode, Converter={StaticResource BoolToAppearanceConverter}}"
                                       Command="{Binding ToggleThreadViewCommand}">
                                <ui:SymbolIcon Symbol="TextBulletListTree24" FontSize="14"/>
                            </ui:Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 메일 리스트 -->
                <ListBox Grid.Row="1"
                         x:Name="EmailListBox"
                         Margin="0,36,0,0"
                         ItemsSource="{Binding Emails}"
                         SelectedItem="{Binding SelectedEmail}"
                         SelectionMode="Extended"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         PreviewMouseRightButtonDown="EmailListBox_PreviewMouseRightButtonDown"
                         PreviewMouseLeftButtonDown="EmailListBox_PreviewMouseLeftButtonDown"
                         PreviewMouseMove="EmailListBox_PreviewMouseMove">
                    <ListBox.ContextMenu>
                        <ContextMenu Background="{DynamicResource ApplicationBackgroundBrush}"
                                     BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                     Padding="4">
                            <MenuItem Click="EmailAIReanalyze_Click" Header="🤖 AI 재분석"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <Separator Background="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>
                            <MenuItem Click="EmailReply_Click" Header="↩️ 답장"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <MenuItem Click="EmailReplyAll_Click" Header="↩️↩️ 전체 답장"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <MenuItem Click="EmailForward_Click" Header="➡️ 전달"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <Separator Background="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>
                            <!-- 핀고정 메뉴 -->
                            <MenuItem Click="EmailTogglePin_Click" Header="📌 고정/해제"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <Separator Background="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>
                            <!-- 플래그 메뉴 -->
                            <MenuItem Click="EmailSetFlag_Click" Header="🚩 플래그 설정"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <MenuItem Click="EmailCompleteFlag_Click" Header="✓ 플래그 완료"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <MenuItem Click="EmailClearFlag_Click" Header="⚪ 플래그 해제"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <Separator Background="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>
                            <!-- 읽음 표시 메뉴 -->
                            <MenuItem Click="EmailMarkAsRead_Click" Header="✉️ 읽음으로 표시"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <MenuItem Click="EmailMarkAsUnread_Click" Header="📩 읽지 않음으로 표시"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <Separator Background="{DynamicResource ControlElevationBorderBrush}" Margin="8,4"/>
                            <MenuItem Click="EmailDelete_Click" Header="🗑️ 삭제"
                                      Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border x:Name="Border"
                                                Background="Transparent"
                                                CornerRadius="4"
                                                Padding="12,8">
                                            <TextBlock Text="{TemplateBinding Header}"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsHighlighted" Value="True">
                                                <Setter TargetName="Border" Property="Background"
                                                        Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                        </ContextMenu>
                    </ListBox.ContextMenu>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- 콘텐츠 영역 (선택 배경 적용) -->
                                            <Border x:Name="ContentBorder"
                                                    Grid.Row="0"
                                                    Background="Transparent"
                                                    CornerRadius="4"
                                                    Margin="4,2,4,0">
                                                <ContentPresenter/>
                                            </Border>
                                            <!-- 구분선 (선택 영역 밖) -->
                                            <Border Grid.Row="1"
                                                    Height="1"
                                                    Background="{DynamicResource ControlElevationBorderBrush}"
                                                    Margin="12,2,12,0"/>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="ContentBorder" Property="Background"
                                                        Value="{DynamicResource SelectionBackgroundBrush}"/>
                                            </Trigger>
                                            <MultiTrigger>
                                                <MultiTrigger.Conditions>
                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                    <Condition Property="IsSelected" Value="False"/>
                                                </MultiTrigger.Conditions>
                                                <Setter TargetName="ContentBorder" Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </MultiTrigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <!-- 카테고리 색상 바 -->
                                        <ColumnDefinition Width="4"/>
                                        <!-- 아이콘 영역 (중요도, 플래그) -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- 메인 콘텐츠 -->
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 카테고리 색상 바 (왼쪽) -->
                                    <Rectangle Grid.Column="0"
                                               Width="3"
                                               Fill="{Binding Categories, Converter={StaticResource CategoryToColorConverter}}"
                                               Visibility="{Binding Categories, Converter={StaticResource CategoryToVisibilityConverter}}"
                                               RadiusX="1.5" RadiusY="1.5"
                                               Margin="0,2,4,2"/>

                                    <!-- 아이콘 영역 -->
                                    <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,6,0">
                                        <!-- 고정(Pin) 아이콘 -->
                                        <ui:SymbolIcon Symbol="Pin24"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                                       ToolTip="고정됨"
                                                       Visibility="{Binding IsPinned, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                        <!-- 중요도 높음 아이콘 -->
                                        <ui:SymbolIcon Symbol="Important24"
                                                       FontSize="14"
                                                       Foreground="#E74856"
                                                       ToolTip="중요"
                                                       Visibility="{Binding Importance, Converter={StaticResource ImportanceToVisibilityConverter}}"/>
                                        <!-- 플래그 아이콘 (flagged) -->
                                        <ui:SymbolIcon Symbol="Flag24"
                                                       FontSize="14"
                                                       Foreground="#FF6B00"
                                                       ToolTip="플래그 설정됨"
                                                       Visibility="{Binding FlagStatus, Converter={StaticResource FlagStatusToVisibilityConverter}, ConverterParameter=flagged}"/>
                                        <!-- 플래그 완료 아이콘 -->
                                        <ui:SymbolIcon Symbol="CheckmarkCircle24"
                                                       FontSize="14"
                                                       Foreground="#0B8A00"
                                                       ToolTip="플래그 완료"
                                                       Visibility="{Binding FlagStatus, Converter={StaticResource FlagStatusToVisibilityConverter}, ConverterParameter=complete}"/>
                                    </StackPanel>

                                    <!-- 메인 콘텐츠 -->
                                    <Grid Grid.Column="2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- 1행: 발신자, 아이콘들, 날짜 -->
                                        <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 발신자 -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding From}"
                                                       FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeightConverter}, FallbackValue=Normal}"
                                                       Foreground="{Binding IsRead, Converter={StaticResource BoolToForegroundConverter}}"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="13"/>

                                            <!-- 우측 아이콘 + 날짜 -->
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- 첨부파일 아이콘 -->
                                                <ui:SymbolIcon Symbol="Attach24"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                               ToolTip="첨부파일 있음"
                                                               Margin="0,0,4,0"
                                                               Visibility="{Binding HasAttachments, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                <!-- 날짜 -->
                                                <TextBlock Text="{Binding ReceivedDateTime, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                           FontSize="11"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Grid>

                                        <!-- 2행: 제목 -->
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Subject}"
                                                   FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeightConverter}, FallbackValue=Normal}"
                                                   Foreground="{Binding IsRead, Converter={StaticResource BoolToForegroundConverter}}"
                                                   TextTrimming="CharacterEllipsis"
                                                   FontSize="12"
                                                   Margin="0,3,0,0"/>

                                        <!-- 3행: AI 요약 + AI 아이콘 -->
                                        <Grid Grid.Row="2" Margin="0,3,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- AI 요약 (있을 경우) -->
                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding SummaryOneline}"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       FontSize="11"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding SummaryOneline, Converter={StaticResource NullToVisibilityConverter}}"/>

                                            <!-- AI 분석 완료 아이콘 (✨ 이모지 모티프) -->
                                            <TextBlock Grid.Column="1"
                                                       Text="✨"
                                                       FontSize="12"
                                                       ToolTip="AI 분석 완료"
                                                       Margin="4,0,0,0"
                                                       Visibility="{Binding AnalysisStatus, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=completed}"/>
                                        </Grid>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- GridSplitter 2 -->
        <GridSplitter x:Name="Splitter2" Grid.Column="4"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE"/>

        <!-- ========== 본문 영역 (Column 5) ========== -->
        <Grid x:Name="BodyAreaGrid" Grid.Column="5">
            <Grid.RowDefinitions>
                <!-- 액션 버튼 바 -->
                <RowDefinition Height="Auto"/>
                <!-- 메일 헤더 -->
                <RowDefinition Height="Auto"/>
                <!-- 본문 -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 액션 버튼 바 (Row 0) -->
            <Border Grid.Row="0"
                    Padding="12,8"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Background="{DynamicResource SubtleFillColorTertiaryBrush}"
                    Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 왼쪽: 액션 버튼들 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <!-- 회신 버튼 -->
                        <ui:Button x:Name="ReplyButton"
                                   ToolTip="회신"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="ReplyButton_Click">
                            <ui:SymbolIcon Symbol="ArrowReply24" FontSize="16"/>
                        </ui:Button>
                        <!-- 전체 회신 버튼 -->
                        <ui:Button x:Name="ReplyAllButton"
                                   ToolTip="전체 회신"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="ReplyAllButton_Click">
                            <ui:SymbolIcon Symbol="ArrowReplyAll24" FontSize="16"/>
                        </ui:Button>
                        <!-- 전달 버튼 -->
                        <ui:Button x:Name="ForwardButton"
                                   ToolTip="전달"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,12,0"
                                   Click="ForwardButton_Click">
                            <ui:SymbolIcon Symbol="ArrowForward24" FontSize="16"/>
                        </ui:Button>
                        <!-- 구분선 -->
                        <Border Width="1" Height="24"
                                Background="{DynamicResource ControlElevationBorderBrush}"
                                Margin="0,0,12,0"/>
                        <!-- 삭제 버튼 -->
                        <ui:Button x:Name="DeleteButton"
                                   ToolTip="삭제"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="DeleteButton_Click">
                            <ui:SymbolIcon Symbol="Delete24" FontSize="16"/>
                        </ui:Button>
                        <!-- 플래그 버튼 (상태 기반 하이라이팅) -->
                        <ui:Button x:Name="FlagButton"
                                   ToolTip="플래그 설정/해제"
                                   Appearance="{Binding SelectedEmail.FlagStatus, Converter={StaticResource FlagStatusToAppearanceConverter}}"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="FlagButton_Click">
                            <ui:SymbolIcon Symbol="Flag24" FontSize="16"
                                           Foreground="{Binding SelectedEmail.FlagStatus, Converter={StaticResource BoolToForegroundConverter}}"/>
                        </ui:Button>
                        <!-- 읽음/안읽음 토글 버튼 -->
                        <ui:Button x:Name="ReadUnreadButton"
                                   ToolTip="읽음/안읽음 표시"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Margin="0,0,4,0"
                                   Click="ReadUnreadButton_Click">
                            <ui:SymbolIcon Symbol="MailRead24" FontSize="16"/>
                        </ui:Button>
                        <!-- 고정(Pin) 버튼 (상태 기반 하이라이팅) -->
                        <ui:Button x:Name="PinButton"
                                   ToolTip="고정/해제"
                                   Appearance="{Binding SelectedEmail.IsPinned, Converter={StaticResource BoolToAppearanceConverter}}"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Command="{Binding TogglePinnedCommand}">
                            <ui:SymbolIcon Symbol="Pin24" FontSize="16"
                                           Foreground="{Binding SelectedEmail.IsPinned, Converter={StaticResource BoolToForegroundConverter}}"/>
                        </ui:Button>
                    </StackPanel>

                    <!-- 오른쪽: 날짜 및 더보기 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="{Binding SelectedEmail.ReceivedDateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <!-- 더보기 버튼 -->
                        <ui:Button x:Name="MoreActionsButton"
                                   ToolTip="더 많은 작업"
                                   Appearance="Secondary"
                                   Width="36" Height="36"
                                   Padding="0"
                                   Click="MoreActionsButton_Click">
                            <ui:SymbolIcon Symbol="MoreHorizontal24" FontSize="16"/>
                        </ui:Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 메일 헤더 정보 (Row 1) -->
            <Border Grid.Row="1"
                    Padding="20,16"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <!-- 제목 -->
                    <TextBlock Text="{Binding SelectedEmail.Subject}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <!-- 발신자 정보 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 아바타 -->
                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="20"
                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                Margin="0,0,12,0">
                            <TextBlock Text="{Binding SelectedEmail.From, Converter={StaticResource StringToInitialConverter}}"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- 발신자 및 수신자 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedEmail.From}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedEmail.To}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>

                    <!-- 첨부파일 표시 -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,12,0,0"
                                Visibility="{Binding SelectedEmail.HasAttachments, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ui:SymbolIcon Symbol="Attach24" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="첨부파일 있음"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 메일 본문 (WebView2) -->
            <Border Grid.Row="2">
                <wv2:WebView2 x:Name="MailBodyWebView"
                              DefaultBackgroundColor="Transparent"
                              Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}"/>
            </Border>

            <!-- 메일 미선택 시 안내 -->
            <Border Grid.Row="0" Grid.RowSpan="3"
                    Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <!-- 메일 아이콘 (열린 봉투 스타일) -->
                    <ui:SymbolIcon Symbol="MailInbox24" FontSize="72"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   Margin="0,0,0,20"/>
                    <TextBlock Text="읽을 항목 선택"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="선택된 항목이 없습니다."
                               FontSize="14"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- GridSplitter 3 (본문-AI 패널 사이) -->
        <GridSplitter x:Name="Splitter3" Grid.Column="6"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE"/>

        <!-- ========== 캘린더 뷰 컨테이너 (Column 1-5 전체 사용, 초기에는 숨김) ========== -->
        <Border x:Name="CalendarViewBorder"
                Grid.Column="1" Grid.ColumnSpan="5"
                Visibility="Collapsed"
                Background="{DynamicResource ApplicationBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- 좌측 미니캘린더 + 캘린더 목록 -->
                    <ColumnDefinition Width="250"/>
                    <!-- 메인 캘린더 뷰 -->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 좌측 패널: 미니캘린더 + 캘린더 목록 -->
                <Border Grid.Column="0"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- 월 네비게이션 -->
                        <Border Grid.Row="0" Padding="12,12,12,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        x:Name="CalPrevMonthBtn"
                                        Style="{StaticResource NavIconButtonStyle}"
                                        Width="28" Height="28"
                                        Click="CalPrevMonthBtn_Click">
                                    <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="14"/>
                                </Button>
                                <TextBlock Grid.Column="1"
                                           x:Name="CalMonthYearText"
                                           Text="2026년 1월"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="2"
                                        x:Name="CalNextMonthBtn"
                                        Style="{StaticResource NavIconButtonStyle}"
                                        Width="28" Height="28"
                                        Click="CalNextMonthBtn_Click">
                                    <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14"/>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- 미니 캘린더 그리드 -->
                        <Border Grid.Row="1" Padding="8,0,8,12">
                            <Grid x:Name="MiniCalendarGrid">
                                <!-- 요일 헤더 -->
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 요일 헤더 (일~토) -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="일" HorizontalAlignment="Center" FontSize="11" Foreground="#FF6B6B"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="월" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="화" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="수" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="목" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="5" Text="금" HorizontalAlignment="Center" FontSize="11"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="토" HorizontalAlignment="Center" FontSize="11" Foreground="#6B9DFF"/>

                                <!-- 날짜들은 코드비하인드에서 동적 생성 -->
                            </Grid>
                        </Border>

                        <!-- 내 캘린더 목록 + 선택된 날짜 일정 -->
                        <Border Grid.Row="2" Padding="12,8">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- 내 캘린더 섹션 -->
                                <StackPanel Grid.Row="0">
                                    <TextBlock Text="내 캘린더" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               Margin="0,0,0,8"/>
                                    <CheckBox x:Name="CalCheckDefault" IsChecked="True" Content="일정" Margin="0,4"/>
                                </StackPanel>

                                <!-- 선택된 날짜의 일정 목록 -->
                                <Border Grid.Row="1" Margin="0,16,0,0">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock x:Name="SelectedDateText"
                                                   Grid.Row="0"
                                                   Text="오늘의 일정"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Margin="0,0,0,8"/>

                                        <ScrollViewer Grid.Row="1"
                                                      VerticalScrollBarVisibility="Auto"
                                                      MaxHeight="200">
                                            <StackPanel x:Name="SelectedDateEventsPanel">
                                                <!-- 일정 아이템들이 동적으로 추가됨 -->
                                                <TextBlock x:Name="NoEventsText"
                                                           Text="일정이 없습니다"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,16"/>
                                            </StackPanel>
                                        </ScrollViewer>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- 새 일정 버튼 -->
                        <Border Grid.Row="3" Padding="12,8,12,12">
                            <ui:Button x:Name="NewEventButton"
                                       Appearance="Primary"
                                       HorizontalAlignment="Stretch"
                                       Click="NewEventButton_Click">
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="새 일정"/>
                                </StackPanel>
                            </ui:Button>
                        </Border>
                    </Grid>
                </Border>

                <!-- 메인 캘린더: 월간 뷰 -->
                <Border Grid.Column="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <!-- 툴바 -->
                            <RowDefinition Height="Auto"/>
                            <!-- 캘린더 그리드 -->
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 캘린더 툴바 -->
                        <Border Grid.Row="0"
                                Padding="16,8"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 네비게이션 -->
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:Button x:Name="CalTodayBtn" Content="오늘" Margin="0,0,8,0" Click="CalTodayBtn_Click"/>
                                    <Button Style="{StaticResource NavIconButtonStyle}" Width="32" Height="32" Click="CalPrevMonthBtn_Click">
                                        <ui:SymbolIcon Symbol="ChevronLeft24" FontSize="14"/>
                                    </Button>
                                    <Button Style="{StaticResource NavIconButtonStyle}" Width="32" Height="32" Click="CalNextMonthBtn_Click">
                                        <ui:SymbolIcon Symbol="ChevronRight24" FontSize="14"/>
                                    </Button>
                                    <TextBlock x:Name="CalMainMonthYearText"
                                               Text="2026년 1월"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </StackPanel>

                                <!-- 뷰 모드 토글 -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                    <ui:Button x:Name="CalDayViewBtn" Content="일" Width="40" Margin="0,0,4,0" Click="CalDayViewBtn_Click"/>
                                    <ui:Button x:Name="CalWeekViewBtn" Content="주" Width="40" Margin="0,0,4,0" Click="CalWeekViewBtn_Click"/>
                                    <ui:Button x:Name="CalMonthViewBtn" Content="월" Width="40" Appearance="Primary" Click="CalMonthViewBtn_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- 월간 캘린더 그리드 -->
                        <Border Grid.Row="1" Padding="8">
                            <Grid x:Name="MonthCalendarGrid">
                                <Grid.RowDefinitions>
                                    <!-- 요일 헤더 -->
                                    <RowDefinition Height="32"/>
                                    <!-- 6주 (최대) -->
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 요일 헤더 -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="일요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="월요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="화요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="3" Text="수요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="4" Text="목요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="5" Text="금요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                <TextBlock Grid.Row="0" Grid.Column="6" Text="토요일" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#6B9DFF"/>

                                <!-- 날짜 셀들은 코드비하인드에서 동적 생성 -->
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ========== AI 분석 패널 영역 (Column 7) ========== -->
        <Border x:Name="AIPanelBorder" Grid.Column="7"
                Background="{DynamicResource ControlOnImageFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- AI 패널 헤더 -->
                <Border Grid.Row="0"
                        Padding="16,12"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel Orientation="Horizontal">
                        <!-- 반짝이는 ✨ 아이콘 (3개 별, 각기 다른 노란색, 크기에 반비례하는 속도) -->
                        <Grid Margin="0,3,8,0" VerticalAlignment="Center">
                            <!-- 큰 별 (골드, 느린 속도 0.8초) -->
                            <TextBlock Text="✦" FontSize="14" Foreground="#FFD700" Margin="0,0,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.3" Duration="0:0:0.8"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- 중간 별 (황금색, 중간 속도 0.5초) -->
                            <TextBlock Text="✦" FontSize="10" Foreground="#FFC125" Margin="8,-6,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.2">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.3" Duration="0:0:0.5"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <!-- 작은 별 (카나리아, 빠른 속도 0.3초) -->
                            <TextBlock Text="✦" FontSize="7" Foreground="#FFDF00" Margin="12,4,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever" BeginTime="0:0:0.4">
                                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                         From="1" To="0.3" Duration="0:0:0.3"
                                                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <TextBlock Text="AI 분석"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- AI 분석 내용 -->
                <ScrollViewer Grid.Row="1"
                              Padding="16"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}">

                        <!-- 우선순위 -->
                        <Border Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="우선순위"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <Border Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                        CornerRadius="4"
                                        Padding="12,8"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding SelectedEmail.PriorityLevel, FallbackValue='분석 대기중'}"
                                               Foreground="White"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 요약 -->
                        <Border Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="요약"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedEmail.Summary, FallbackValue='AI 분석이 완료되면 요약이 표시됩니다.'}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- 마감일 -->
                        <Border Margin="0,0,0,16"
                                Visibility="{Binding SelectedEmail.Deadline, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="마감일"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedEmail.Deadline, StringFormat='{}{0:yyyy-MM-dd}'}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 키워드 -->
                        <Border Margin="0,0,0,16"
                                Visibility="{Binding SelectedEmail.Keywords, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="키워드"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8"/>
                                <TextBlock Text="{Binding SelectedEmail.Keywords}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ========== 캘린더 세부 일정 패널 (Column 7, 캘린더 모드에서만 표시) ========== -->
        <Border x:Name="CalendarDetailPanel" Grid.Column="7"
                Visibility="Collapsed"
                Background="{DynamicResource ControlOnImageFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="1,0,0,0">
            <TabControl x:Name="CalendarTabControl">
                <!-- 일정 탭 -->
                <TabItem Header="일정">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 날짜 헤더 -->
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel>
                                <TextBlock x:Name="CalDetailDateText"
                                           Text="2026년 1월 17일"
                                           FontSize="24"
                                           FontWeight="Bold"/>
                                <TextBlock x:Name="CalDetailDayText"
                                           Text="금요일"
                                           FontSize="14"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- 캘린더 세부 내용 -->
                        <ScrollViewer Grid.Row="1"
                                      Padding="16"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="CalendarDetailContent">
                                <!-- 일정 목록 헤더 -->
                        <Border Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="CalDetailEventCountText"
                                           Grid.Column="0"
                                           Text="일정 (0건)"
                                           FontWeight="SemiBold"
                                           FontSize="14"/>
                                <ui:Button Grid.Column="1"
                                           x:Name="CalDetailAddEventButton"
                                           Appearance="Secondary"
                                           ToolTip="새 일정 추가"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Click="CalDetailAddEventButton_Click">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="14"/>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <!-- 일정 목록 -->
                        <StackPanel x:Name="CalDetailEventsList">
                            <!-- 일정 아이템들이 동적으로 추가됨 -->
                            <TextBlock x:Name="CalDetailNoEventsText"
                                       Text="선택한 날짜에 일정이 없습니다."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       HorizontalAlignment="Center"
                                       Margin="0,32"/>
                        </StackPanel>

                        <!-- 월간 요약 섹션 -->
                        <Border Margin="0,24,0,0" Padding="12"
                                Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Text="이번 달 요약" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="총 일정"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="CalDetailMonthTotalText"
                                               Grid.Column="1" Text="0건" FontWeight="SemiBold"/>
                                </Grid>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="이번 주"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    <TextBlock x:Name="CalDetailWeekTotalText"
                                               Grid.Column="1" Text="0건" FontWeight="SemiBold"/>
                                </Grid>
                                </StackPanel>
                            </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- TODO 탭 -->
                <TabItem Header="To Do">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- TODO 헤더 -->
                        <Border Grid.Row="0" Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Orientation="Horizontal">
                                    <ui:SymbolIcon Symbol="TaskListLtr24" FontSize="20" Margin="0,0,8,0"/>
                                    <TextBlock Text="할 일 목록"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <ui:Button Grid.Column="1"
                                           Appearance="Secondary"
                                           ToolTip="새 할 일 추가"
                                           Width="28" Height="28"
                                           Padding="0"
                                           Click="AddTodoButton_Click">
                                    <ui:SymbolIcon Symbol="Add24" FontSize="14"/>
                                </ui:Button>
                            </Grid>
                        </Border>

                        <!-- TODO 목록 -->
                        <ScrollViewer Grid.Row="1"
                                      Padding="16"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="TodoListContent">
                                <!-- TODO 항목 없을 때 -->
                                <TextBlock x:Name="NoTodoText"
                                           Text="할 일이 없습니다."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           HorizontalAlignment="Center"
                                           Margin="0,32"/>
                                <!-- TODO 항목들이 동적으로 추가됨 -->
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
        </Grid>

        <!-- ========== 하단 상태바 (Row 2) - 7컬럼 구조로 메인 콘텐츠와 동기화 ========== -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- 폴더 영역 - 메인 콘텐츠 FolderColumn과 동기화 -->
                    <ColumnDefinition Width="{Binding ElementName=FolderColumn, Path=ActualWidth}"/>
                    <!-- Splitter 1 공간 -->
                    <ColumnDefinition Width="4"/>
                    <!-- 메일 리스트 영역 - 메인 콘텐츠 MailListColumn과 동기화 -->
                    <ColumnDefinition Width="{Binding ElementName=MailListColumn, Path=ActualWidth}"/>
                    <!-- Splitter 2 공간 -->
                    <ColumnDefinition Width="4"/>
                    <!-- 본문 영역 - 유동 너비 -->
                    <ColumnDefinition Width="*"/>
                    <!-- Splitter 3 공간 -->
                    <ColumnDefinition Width="4"/>
                    <!-- AI 패널 영역 - 메인 콘텐츠 AIColumn과 동기화 -->
                    <ColumnDefinition Width="{Binding ElementName=AIColumn, Path=ActualWidth}"/>
                </Grid.ColumnDefinitions>

                <!-- Column 0: 폴더 트리 아래 - 메일 동기화 상태 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <!-- 동기화 중일 때 ProgressRing -->
                    <ui:ProgressRing Width="14" Height="14"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsSyncing, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Margin="0,0,6,0"/>
                    <!-- 메일 아이콘 -->
                    <ui:SymbolIcon Symbol="Mail24" FontSize="14" Margin="0,0,6,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <!-- 메일 진행률 텍스트 -->
                    <TextBlock Text="{Binding MailSyncProgressText}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <!-- 메일 프로그레스바 -->
                    <ProgressBar Value="{Binding MailSyncProgress, Mode=OneWay}"
                                 Minimum="0" Maximum="100"
                                 Width="60" Height="6"
                                 Margin="6,0,0,0"
                                 Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                 Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                </StackPanel>

                <!-- Column 1: Splitter 1 공간 -->
                <Rectangle Grid.Column="1" Width="4"/>

                <!-- Column 2: 메일 리스트 아래 - 이메일 개수 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                    <TextBlock Text="{Binding EmailCount, StringFormat='{}{0}개의 이메일이 로드되었습니다'}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Column 3: Splitter 2 공간 -->
                <Rectangle Grid.Column="3" Width="4"/>

                <!-- Column 4: 본문 영역 아래 - 캘린더 동기화 상태 + 마지막 동기화 시간 -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- 캘린더 동기화 중일 때 ProgressRing -->
                    <ui:ProgressRing Width="14" Height="14"
                                     IsIndeterminate="True"
                                     Visibility="{Binding IsCalendarSyncing, Converter={StaticResource BoolToVisibilityConverter}}"
                                     Margin="0,0,6,0"/>
                    <!-- 캘린더 아이콘 -->
                    <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="14" Margin="0,0,6,0"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <!-- 캘린더 진행률 텍스트 -->
                    <TextBlock Text="{Binding CalendarSyncProgressText}"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                    <!-- 캘린더 프로그레스바 -->
                    <ProgressBar Value="{Binding CalendarSyncProgress, Mode=OneWay}"
                                 Minimum="0" Maximum="100"
                                 Width="60" Height="6"
                                 Margin="6,0,12,0"
                                 Foreground="#2196F3"
                                 Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                    <!-- 구분선 -->
                    <Rectangle Width="1" Height="12" Fill="{DynamicResource ControlElevationBorderBrush}" Margin="0,0,12,0"/>
                    <!-- 마지막 동기화 시간 -->
                    <TextBlock Text="{Binding LastSyncTimeText}"
                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Column 5: Splitter 3 공간 -->
                <Rectangle Grid.Column="5" Width="4"/>

                <!-- Column 6: AI 패널 아래 - AI 분석 상태 -->
                <Grid Grid.Column="6" Margin="8,0,12,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- AI 분석 진행상황 -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <!-- AI 아이콘 -->
                        <TextBlock Text="🤖" FontSize="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <!-- AI 진행률 텍스트 -->
                        <TextBlock Text="{Binding AiAnalysisProgressText}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                        <!-- AI 프로그레스바 -->
                        <ProgressBar Value="{Binding AiAnalysisProgress, Mode=OneWay}"
                                     Minimum="0" Maximum="100"
                                     Width="60" Height="6"
                                     Margin="6,0,0,0"
                                     Foreground="#4CAF50"
                                     Background="{DynamicResource ControlFillColorSecondaryBrush}"/>
                    </StackPanel>

                    <!-- 동기화 토글 버튼 -->
                    <ui:Button Grid.Column="1"
                               Content="{Binding SyncButtonIcon}"
                               Command="{Binding ToggleSyncCommand}"
                               ToolTip="{Binding SyncButtonTooltip}"
                               Appearance="Secondary"
                               FontSize="10"
                               Width="28" Height="22"
                               Margin="8,0,0,0"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>
