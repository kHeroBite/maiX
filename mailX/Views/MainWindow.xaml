<ui:FluentWindow x:Class="mailX.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:local="clr-namespace:mailX.Views"
        xmlns:vm="clr-namespace:mailX.ViewModels"
        mc:Ignorable="d"
        Title="{Binding Title}"
        Height="800" Width="1400"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar
            x:Name="TitleBar"
            Grid.Row="0"
            Title="mailX"
            Icon="pack://application:,,,/Assets/icon.png"
            ShowMaximize="True"
            ShowMinimize="True"
            ShowClose="True"
            CanMaximize="True"/>

        <!-- 메인 콘텐츠 -->
        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <!-- 폴더 트리 (250px 고정) -->
            <ColumnDefinition Width="250" MinWidth="150" MaxWidth="400"/>
            <!-- Splitter -->
            <ColumnDefinition Width="Auto"/>
            <!-- 메일 리스트 (350px 기본) -->
            <ColumnDefinition Width="350" MinWidth="250" MaxWidth="600"/>
            <!-- Splitter -->
            <ColumnDefinition Width="Auto"/>
            <!-- 본문 + AI 패널 (나머지) -->
            <ColumnDefinition Width="*" MinWidth="400"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 폴더 트리 영역 (Column 0) ========== -->
        <Border Grid.Column="0"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 폴더 헤더 -->
                <Border Grid.Row="0" Padding="16,12">
                    <StackPanel Orientation="Horizontal">
                        <ui:SymbolIcon Symbol="Folder24" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="폴더" FontSize="16" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- 폴더 리스트 -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Folders}"
                         SelectedItem="{Binding SelectedFolder}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="8,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <ui:SymbolIcon Grid.Column="0"
                                               Symbol="Folder24"
                                               FontSize="16"
                                               Margin="0,0,10,0"
                                               VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding DisplayName}"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>

                                <!-- 읽지 않은 메일 수 배지 -->
                                <Border Grid.Column="2"
                                        Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                        CornerRadius="10"
                                        Padding="6,2"
                                        Margin="8,0,0,0"
                                        VerticalAlignment="Center"
                                        Visibility="{Binding UnreadItemCount, Converter={StaticResource IntToVisibilityConverter}}">
                                    <TextBlock Text="{Binding UnreadItemCount}"
                                               Foreground="White"
                                               FontSize="11"
                                               FontWeight="SemiBold"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- GridSplitter 1 -->
        <GridSplitter Grid.Column="1"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE"/>

        <!-- ========== 메일 리스트 영역 (Column 2) ========== -->
        <Border Grid.Column="2"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 메일 리스트 헤더 -->
                <Border Grid.Row="0" Padding="16,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ui:SymbolIcon Symbol="Mail24" FontSize="20" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding SelectedFolder.DisplayName, FallbackValue='메일'}"
                                       FontSize="16" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- 새로고침 / 동기화 토글 버튼 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <ui:Button Icon="{ui:SymbolIcon ArrowClockwise24}"
                                       Command="{Binding LoadEmailsCommand}"
                                       ToolTip="새로고침"
                                       Appearance="Secondary"
                                       Margin="0,0,4,0"/>
                            <ui:Button Content="{Binding SyncButtonIcon}"
                                       Command="{Binding ToggleSyncCommand}"
                                       ToolTip="{Binding SyncButtonTooltip}"
                                       Appearance="Secondary"
                                       FontSize="12"
                                       Width="36"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 메일 리스트 -->
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Emails}"
                         SelectedItem="{Binding SelectedEmail}"
                         BorderThickness="0"
                         Background="Transparent"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="12,10" BorderThickness="0,0,0,1"
                                    BorderBrush="{DynamicResource ControlElevationBorderBrush}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- 발신자 및 날짜 -->
                                    <Grid Grid.Row="0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding From}"
                                                   FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeightConverter}, FallbackValue=Normal}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <!-- AI 분석 완료 아이콘 -->
                                        <ui:SymbolIcon Grid.Column="1"
                                                       Symbol="Brain24"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                       Margin="6,0,0,0"
                                                       ToolTip="AI 분석 완료"
                                                       Visibility="{Binding AnalysisStatus, Converter={StaticResource StringEqualsToVisibilityConverter}, ConverterParameter=completed}"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding ReceivedDateTime, StringFormat='{}{0:MM/dd HH:mm}'}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   FontSize="11"
                                                   Margin="8,0,0,0"/>
                                    </Grid>

                                    <!-- 제목 -->
                                    <TextBlock Grid.Row="1"
                                               Text="{Binding Subject}"
                                               FontWeight="{Binding IsRead, Converter={StaticResource BoolToFontWeightConverter}, FallbackValue=Normal}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,4,0,0"/>

                                    <!-- AI 요약 (있을 경우) -->
                                    <TextBlock Grid.Row="2"
                                               Text="{Binding SummaryOneline}"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,4,0,0"
                                               Visibility="{Binding SummaryOneline, Converter={StaticResource NullToVisibilityConverter}}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <!-- GridSplitter 2 -->
        <GridSplitter Grid.Column="3"
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="Transparent"
                      Cursor="SizeWE"/>

        <!-- ========== 본문 + AI 패널 영역 (Column 4) ========== -->
        <Grid Grid.Column="4">
            <Grid.RowDefinitions>
                <!-- 메일 헤더 -->
                <RowDefinition Height="Auto"/>
                <!-- 본문 + AI 패널 -->
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 메일 헤더 정보 -->
            <Border Grid.Row="0"
                    Padding="20,16"
                    BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}">
                <StackPanel>
                    <!-- 제목 -->
                    <TextBlock Text="{Binding SelectedEmail.Subject}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12"/>

                    <!-- 발신자 정보 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 아바타 -->
                        <Border Grid.Column="0"
                                Width="40" Height="40"
                                CornerRadius="20"
                                Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                Margin="0,0,12,0">
                            <TextBlock Text="{Binding SelectedEmail.From, Converter={StaticResource StringToInitialConverter}}"
                                       Foreground="White"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- 발신자 및 수신자 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedEmail.From}"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedEmail.To}"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       FontSize="12"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <!-- 날짜 -->
                        <TextBlock Grid.Column="2"
                                   Text="{Binding SelectedEmail.ReceivedDateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- 첨부파일 표시 -->
                    <StackPanel Orientation="Horizontal"
                                Margin="0,12,0,0"
                                Visibility="{Binding SelectedEmail.HasAttachments, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ui:SymbolIcon Symbol="Attach24" FontSize="14" Margin="0,0,6,0"/>
                        <TextBlock Text="첨부파일 있음"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 본문 영역 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="300" MinWidth="200" MaxWidth="500"/>
                </Grid.ColumnDefinitions>

                <!-- 메일 본문 (WebView2 또는 TextBlock) -->
                <Border Grid.Column="0" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <TextBlock Text="{Binding SelectedEmail.Body}"
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   LineHeight="24"/>
                    </ScrollViewer>
                </Border>

                <!-- Splitter for AI Panel -->
                <GridSplitter Grid.Column="1"
                              Width="4"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Stretch"
                              Background="Transparent"
                              Cursor="SizeWE"/>

                <!-- AI 분석 패널 -->
                <Border Grid.Column="2"
                        Background="{DynamicResource ControlOnImageFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                        BorderThickness="1,0,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- AI 패널 헤더 -->
                        <Border Grid.Row="0"
                                Padding="16,12"
                                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                                BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <ui:SymbolIcon Symbol="Brain24" FontSize="20" Margin="0,0,8,0"/>
                                <TextBlock Text="AI 분석"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                        <!-- AI 분석 내용 -->
                        <ScrollViewer Grid.Row="1"
                                      Padding="16"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}}">

                                <!-- 우선순위 -->
                                <Border Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="우선순위"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <Border Background="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                CornerRadius="4"
                                                Padding="12,8"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding SelectedEmail.PriorityLevel, FallbackValue='분석 대기중'}"
                                                       Foreground="White"
                                                       FontWeight="SemiBold"/>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- 요약 -->
                                <Border Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="요약"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding SelectedEmail.Summary, FallbackValue='AI 분석이 완료되면 요약이 표시됩니다.'}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- 마감일 -->
                                <Border Margin="0,0,0,16"
                                        Visibility="{Binding SelectedEmail.Deadline, Converter={StaticResource NullToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="마감일"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <StackPanel Orientation="Horizontal">
                                            <ui:SymbolIcon Symbol="CalendarLtr24" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding SelectedEmail.Deadline, StringFormat='{}{0:yyyy-MM-dd}'}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- 키워드 -->
                                <Border Margin="0,0,0,16"
                                        Visibility="{Binding SelectedEmail.Keywords, Converter={StaticResource NullToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="키워드"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding SelectedEmail.Keywords}"
                                                   TextWrapping="Wrap"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- 메일 미선택 시 안내 -->
            <Border Grid.Row="0" Grid.RowSpan="2"
                    Visibility="{Binding SelectedEmail, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="MailInbox24" FontSize="64"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,0,0,16"/>
                    <TextBlock Text="메일을 선택하세요"
                               FontSize="18"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
