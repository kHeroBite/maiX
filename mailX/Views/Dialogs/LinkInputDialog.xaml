<ui:FluentWindow x:Class="mailX.Views.Dialogs.LinkInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="링크 삽입"
        Width="400"
        Height="220"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 타이틀바 -->
        <ui:TitleBar Grid.Row="0"
                     Title="링크 삽입"
                     ShowMaximize="False"
                     ShowMinimize="False"/>

        <!-- 입력 영역 -->
        <StackPanel Grid.Row="1" Margin="16,8,16,8">
            <TextBlock Text="URL" FontSize="12" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="UrlTextBox"
                        PlaceholderText="https://example.com"
                        Margin="0,0,0,12"/>

            <TextBlock Text="표시 텍스트 (선택사항)" FontSize="12" Margin="0,0,0,4"/>
            <ui:TextBox x:Name="DisplayTextBox"
                        PlaceholderText="링크 텍스트"/>
        </StackPanel>

        <!-- 버튼 영역 -->
        <Border Grid.Row="2"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlElevationBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="취소" Appearance="Secondary" Width="80" Margin="0,0,8,0" Click="Cancel_Click"/>
                <ui:Button Content="삽입" Appearance="Primary" Width="80" Click="Insert_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
