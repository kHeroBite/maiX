<ui:FluentWindow x:Class="mailX.Views.Dialogs.EventEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        mc:Ignorable="d"
        Title="일정"
        Height="550" Width="500"
        MinHeight="450" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="Mica">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <TextBlock Grid.Row="0"
                   Text="일정 편집"
                   FontSize="20"
                   FontWeight="SemiBold"
                   Margin="0,8,0,16"/>

        <!-- 폼 영역 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 제목 -->
                <TextBlock Text="제목" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ui:TextBox x:Name="SubjectTextBox"
                           PlaceholderText="일정 제목을 입력하세요"
                           Margin="0,0,0,16"/>

                <!-- 장소 -->
                <TextBlock Text="장소" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ui:TextBox x:Name="LocationTextBox"
                           PlaceholderText="장소 (선택)"
                           Margin="0,0,0,16"/>

                <!-- 종일 일정 -->
                <CheckBox x:Name="IsAllDayCheckBox"
                          Content="종일 일정"
                          Margin="0,0,0,16"
                          Checked="IsAllDayCheckBox_Changed"
                          Unchecked="IsAllDayCheckBox_Changed"/>

                <!-- 시작 날짜/시간 -->
                <TextBlock Text="시작" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="StartDatePicker"
                               Grid.Column="0"
                               Margin="0,0,8,0"/>
                    <ui:TextBox x:Name="StartTimeTextBox"
                               Grid.Column="1"
                               Width="100"
                               PlaceholderText="09:00"/>
                </Grid>

                <!-- 종료 날짜/시간 -->
                <TextBlock Text="종료" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <DatePicker x:Name="EndDatePicker"
                               Grid.Column="0"
                               Margin="0,0,8,0"/>
                    <ui:TextBox x:Name="EndTimeTextBox"
                               Grid.Column="1"
                               Width="100"
                               PlaceholderText="10:00"/>
                </Grid>

                <!-- 알림 -->
                <TextBlock Text="알림" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ComboBox x:Name="ReminderComboBox"
                         Margin="0,0,0,16"
                         SelectedIndex="1">
                    <ComboBoxItem Content="없음" Tag="0"/>
                    <ComboBoxItem Content="15분 전" Tag="15"/>
                    <ComboBoxItem Content="30분 전" Tag="30"/>
                    <ComboBoxItem Content="1시간 전" Tag="60"/>
                    <ComboBoxItem Content="1일 전" Tag="1440"/>
                </ComboBox>

                <!-- 온라인 회의 -->
                <CheckBox x:Name="IsOnlineMeetingCheckBox"
                          Content="Teams 온라인 회의 추가"
                          Margin="0,0,0,16"/>

                <!-- 참석자 (이메일, 쉼표로 구분) -->
                <TextBlock Text="참석자" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ui:TextBox x:Name="AttendeesTextBox"
                           PlaceholderText="이메일 주소 (쉼표로 구분)"
                           Margin="0,0,0,16"/>

                <!-- 메모 -->
                <TextBlock Text="메모" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <ui:TextBox x:Name="BodyTextBox"
                           PlaceholderText="메모 (선택)"
                           AcceptsReturn="True"
                           MinHeight="80"
                           MaxHeight="120"
                           TextWrapping="Wrap"
                           VerticalScrollBarVisibility="Auto"
                           Margin="0,0,0,16"/>
            </StackPanel>
        </ScrollViewer>

        <!-- 버튼 영역 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 삭제 버튼 (수정 모드에서만 표시) -->
            <ui:Button x:Name="DeleteButton"
                      Grid.Column="0"
                      Appearance="Danger"
                      Content="삭제"
                      Click="DeleteButton_Click"
                      Visibility="Collapsed"/>

            <!-- 취소 -->
            <ui:Button Grid.Column="2"
                      Content="취소"
                      Margin="0,0,8,0"
                      Click="CancelButton_Click"/>

            <!-- 저장 -->
            <ui:Button Grid.Column="3"
                      x:Name="SaveButton"
                      Appearance="Primary"
                      Content="저장"
                      Click="SaveButton_Click"/>
        </Grid>
    </Grid>
</ui:FluentWindow>
