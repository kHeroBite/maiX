#!/bin/sh
# Codex CLI 환경에서만 커밋 메시지에 [코덱스] 접두사를 강제한다.

if [ -z "$CODEX_MANAGED_BY_NPM" ]; then
  exit 0
fi

msg_file="$1"
if [ ! -f "$msg_file" ]; then
  exit 0
fi

first_line="$(sed -n '1p' "$msg_file")"
case "$first_line" in
  "[코덱스]"*)
    exit 0
    ;;
  *)
    tmp_file="${msg_file}.codex-prefix"
    {
      printf "[코덱스] %s\n" "$first_line"
      tail -n +2 "$msg_file"
    } > "$tmp_file"
    mv "$tmp_file" "$msg_file"
    ;;
esac

exit 0
